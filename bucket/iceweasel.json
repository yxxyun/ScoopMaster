{
    "version": "152.0.2",
    "description": "Portable Runtime For Iceweasel (Firefox), an independent browser derived from Firefox/Mozilla community code.",
    "homepage": "https://sourceforge.net/projects/libportable",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://sourceforge.net/projects/libportable/files/Iceweasel/Stable/152.x/x86_64/Iceweasel-v152.0.2.l10n_win64_pgo.7z",
            "hash": "sha1:f79b4a0f7ddbe77a17fdc7877c32b6237c808380",
            "extract_dir": "Iceweasel_x64"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\App\\portable.ini\")) {",
        "    if (Test-Path \"$dir\\App\\portable(example).ini\") { Copy-Item \"$dir\\App\\portable(example).ini\" \"$dir\\App\\portable.ini\" }",
        "    else { New-Item \"$dir\\App\\portable.ini\" -Force | Out-Null; Set-Content \"$dir\\App\\portable.ini\" -Value $null -Encoding UTF8 }",
        "}",
        "if (!(Test-Path \"$persist_dir\\App\\config.js\")) { New-Item \"$dir\\App\\config.js\" -Force | Out-Null; Set-Content \"$dir\\App\\config.js\" -Value $null -Encoding UTF8 }",
        "if (!(Test-Path \"$persist_dir\\App\\defaults\\pref\\config-prefs.js\")) { New-Item \"$dir\\App\\defaults\\pref\\config-prefs.js\" -Force | Out-Null; Set-Content \"$dir\\App\\defaults\\pref\\config-prefs.js\" -Value $null -Encoding UTF8 }"
    ],
    "persist": [
        "App\\config.js",
        "App\\defaults\\pref\\config-prefs.js",
        "App\\portable.ini",
        "Profiles",
        "Plugins"
    ],
    "bin": "App\\Iceweasel.exe",
    "shortcuts": [
        [
            "App\\Iceweasel.exe",
            "Iceweasel"
        ]
    ],
    "checkver": {
        "url": "https://sourceforge.net/projects/libportable/rss",
        "regex": "/Iceweasel/Stable/(?<main>[\\d\\w.]+)/x86_64/Iceweasel-v([\\d.]+).l10n_win64_pgo.7z"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://sourceforge.net/projects/libportable/files/Iceweasel/Stable/$matchMain/x86_64/Iceweasel-v$version.l10n_win64_pgo.7z"
            }
        }
    }
}
