            "hash": "fa5ed2d8405f391213deb09d7059ad841b0f302f1d7e8700d64dd4c05284af9c"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.40/Netcatty-1.1.40-win-arm64.exe#/dl.7z",
            "hash": "f2abede2f40168df13211a3f822fc0dc8f830947e1cf457d61216f324e619d61"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude \"app*.7z\"",
        "Get-Item \"$dir\\app*.7z\" | Expand-7zipArchive -Destination \"$dir\" -Removal"
    ],
    "persist": "User Data",
    "shortcuts": [
        [
            "Netcatty.exe",
            "Netcatty",
            "--user-data-dir=\"$persist_dir\\User Data\""
