            "hash": "66b91fb6c012d02a67bc4f50ca8661f6baeb444f025b162aa696e585258656fe"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.45/Netcatty-1.1.45-win-arm64.exe#/dl.7z",
            "hash": "dad037d38e482f495554c18d596ea02885f19170f8558b252021e2e43145cd4c"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude \"app*.7z\"",
        "Get-Item \"$dir\\app*.7z\" | Expand-7zipArchive -Destination \"$dir\" -Removal"
