{
    "version": "1.1.7",
    "description": "A modern SSH client, SFTP browser, and terminal manager with a built-in AI agent. Native on macOS, Windows, and Linux. Open source.",
    "homepage": "https://netcatty.app",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.7/Netcatty-1.1.7-win-x64.exe",
            "hash": "0457ab7c9e3764b7dbf6fd3c986d81ac0e18eb73f82a00d99525f0187b512cd8"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.1/Netcatty-1.1.1-win-arm64.exe#/dl.7z",
            "hash": ""
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude \"app*.7z\"",
        "Get-Item \"$dir\\app*.7z\" | Expand-7zipArchive -Destination \"$dir\" -Removal"
    ],
    "persist": "User Data",
    "shortcuts": [
        [
            "Netcatty.exe",
            "Netcatty",
            "--user-data-dir=\"$persist_dir\\User Data\""
        ]
    ],
    "checkver": {
        "github": "https://github.com/binaricat/Netcatty"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-x64.exe"
            },
            "32bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win.exe"
            }
        }
    }
}
