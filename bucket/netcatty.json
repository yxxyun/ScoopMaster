            "hash": "3220a9d7c8f4a5419b339e3a253b10d07f4c90c765f0cf29a22e37cd0e04827a"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.60/Netcatty-1.1.60-win-arm64.exe#/dl.7z",
            "hash": "1169f616eddf2967056bf3433760cdfd8ec364e8f65e43c6723ff11035369dbc"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude \"app*.7z\"",
        "Get-Item \"$dir\\app*.7z\" | Expand-7zipArchive -Destination \"$dir\" -Removal"
