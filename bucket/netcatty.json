            "hash": "a01d66b099bb6e5fa0be611299e5ac70352dacbeac2fdabc4dd0c987714157ea"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.57/Netcatty-1.1.57-win-arm64.exe#/dl.7z",
