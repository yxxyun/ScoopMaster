            "hash": "3eff7b2a3ca489f4843bb3627d1200ed767410b3c2d5c025ebee763d12c8137f"
        },
        "arm64": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.1.23/Netcatty-1.1.23-win-arm64.exe#/dl.7z",
            "hash": "ddeb0100553ff9a2004d883c3d2bfd367999fe2863d5d695cccbcc4f142d9ac8"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude \"app*.7z\"",
        "Get-Item \"$dir\\app*.7z\" | Expand-7zipArchive -Destination \"$dir\" -Removal"
    ],
