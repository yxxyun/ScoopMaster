{
    "version": "1.0.88",
    "description": "Modern SSH manager and terminal app with host grouping, SFTP, keychain and port forwarding",
    "homepage": "https://github.com/binaricat/Netcatty",
    "license": "GPL-3.0-or-later",
    "notes": [
        "Netcatty 是一个现代 SSH 管理与终端应用，支持主机分组、SFTP、密钥链与端口转发",
        "用户数据目录 1：%APPDATA%\\Netcatty\\",
        "用户数据目录 2：%USERPROFILE%\\.netcatty\\（SSH 私钥缓存目录）",
        "本包会将这两个目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist",
        "若你在应用内将会话日志输出到自定义外部目录，那个外部目录不会被本 manifest 自动接管"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/binaricat/Netcatty/releases/download/v1.0.88/Netcatty-1.0.88-win-x64.exe#/dl.7z",
            "hash": "c1018700081ad4c9f7f3ed0f7fd0dc1c8262bbbcb9fe33a7f40a5fb0b6560bcd"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "Netcatty.exe",
    "shortcuts": [
        [
            "Netcatty.exe",
            "Netcatty"
        ]
    ],
    "post_install": [
        "$createJunction = {",
        "    param($source, $name)",
        "    $target = Join-Path $persist_dir $name",
        "    ensure $target",
        "",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$source\"",
        "        }",
        "",
        "        & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $source -ItemType Junction -Value $target | Out-Null",
        "}",
        "",
        "& $createJunction (Join-Path $env:APPDATA 'Netcatty') 'data'",
        "& $createJunction (Join-Path $env:USERPROFILE '.netcatty') 'dotnetcatty'"
    ],
    "persist": [
        "data",
        "dotnetcatty"
    ],
    "checkver": {
        "github": "https://github.com/binaricat/Netcatty"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/binaricat/Netcatty/releases/download/v$version/Netcatty-$version-win-x64.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
