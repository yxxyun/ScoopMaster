{
    "version": "2.2",
    "description": "A framework for creating UI systems in Grand Theft Auto V that is compatible with FiveM, RageMP, RagePluginHook ScriptHookVDotNet 2, and ScriptHookVDotNet 3",
    "homepage": "https://www.gta5-mods.com/scripts/lemonui",
    "license": "MIT",
    "url": "https://github.com/LemonUIbyLemon/LemonUI/releases/download/v2.2/LemonUI.zip",
    "hash": "ef95724eaa3389f02d44a4c87bd9b21e4626ebf34201167b0abeba84ef810ed6",
    "extract_dir": "SHVDN3",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "New-Item \"$env:GTAV_PATH\\scripts\" -ItemType Directory -Force | Out-Null",
        "Move-Item \"$dir\\LemonUI.SHVDN3.dll\" \"$env:GTAV_PATH\\scripts\" -Force",
        "Remove-Item \"$dir\\*\""
    ],
    "checkver": {
        "github": "https://github.com/LemonUIbyLemon/LemonUI",
        "regex": "v(\\d+\\.\\d+(?:\\.\\d+)*)"
    },
    "autoupdate": {
        "url": "https://github.com/LemonUIbyLemon/LemonUI/releases/download/v$version/LemonUI.zip"
    }
}
