{"version":"1.3.1","description":"Aseprite Windows Explorer Thumbnailer","homepage":"https://www.aseprite.org","license":"Proprietary","url":"https://aseprite.org/downloads/aseprite-thumbnailer-v1.3.1.zip","hash":"77496bcb8da11c20d6a2926770522f45cee489ab4b5551dadc76da42cc186233","extract_dir":"aseprite-thumbnailer","depends":["aseprite"],"post_install":["$aseprite_dir = scoop prefix aseprite","if (!$aseprite_dir -or !(Test-Path $aseprite_dir)) {","    Write-Warning 'Aseprite is not installed via Scoop. Install it first.'","    return","}","$arch = if ($architecture -eq '64bit') { 'x64' } else { 'x86' }","$src = \"$dir\\aseprite-thumbnailer-${arch}.dll\"","$dest = \"$aseprite_dir\\aseprite-thumbnailer.dll\"","$item = Get-Item $dest -ErrorAction SilentlyContinue","if ($item -and $item.LinkType -eq 'SymbolicLink') {","    $target = $item.Target","    $dest = if ($target -is [array]) { $target[0] } else { $target }","}","Copy-Item $src $dest -Force","Write-Host 'Successfully placed aseprite-thumbnailer.dll inside Aseprite directory.' -f Green"],"pre_uninstall":["$aseprite_dir = scoop prefix aseprite","if ($aseprite_dir -and (Test-Path $aseprite_dir)) {","    $dest = \"$aseprite_dir\\aseprite-thumbnailer.dll\"","    $item = Get-Item $dest -ErrorAction SilentlyContinue","    if ($item -and $item.LinkType -eq 'SymbolicLink') {","        $target = $item.Target","        $targetPath = if ($target -is [array]) { $target[0] } else { $target }","        Remove-Item $targetPath -Force -ErrorAction SilentlyContinue","    }","    Remove-Item $dest -Force -ErrorAction SilentlyContinue","}"],"checkver":{"url":"https://www.aseprite.org/download/","regex":"aseprite-thumbnailer-v([\\d.]+)\\.zip"},"autoupdate":{"url":"https://aseprite.org/downloads/aseprite-thumbnailer-v$version.zip"},"from":"https://github.com/USLTD/scoop-bucket"}
