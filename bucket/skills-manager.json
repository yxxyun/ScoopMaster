{
    "version": "1.28.3",
    "description": "Manage AI agent skills across coding tools from one central library",
    "homepage": "https://github.com/xingkongliang/skills-manager",
    "license": "MIT",
    "notes": [
        "Central library: %USERPROFILE%\\.skills-manager\\",
        "Repository path config: %APPDATA%\\skills-manager\\repo-config.json",
        "This package persists both directories through Scoop-managed Junction links",
        "Credentials stored in Windows Credential Manager are intentionally not copied into Scoop persist",
        "A custom central library remains at the user-selected path; its path configuration is persisted"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/xingkongliang/skills-manager/releases/download/v1.28.3/skills-manager_1.28.3_x64-setup.exe#/dl.7z",
            "hash": "0516f5b3ac3f158cab29f9283d609f21944a1cc21b9ee71b4e9f20179b954624"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\uninstall.exe\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": [
        "skills-manager.exe",
        "skills-manager-cli.exe"
    ],
    "shortcuts": [
        [
            "skills-manager.exe",
            "Skills Manager"
        ]
    ],
    "post_install": [
        "$mountPersistedDirectory = {",
        "    param($source, $persistName)",
        "    $target = Join-Path $persist_dir $persistName",
        "    ensure $target",
        "",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            $expected = [IO.Path]::GetFullPath($target).TrimEnd('\\')",
        "            $actual = @($item.Target) | Select-Object -First 1",
        "            if ($actual -and [IO.Path]::GetFullPath($actual).TrimEnd('\\') -ieq $expected) {",
        "                Write-Host \"Junction already managed by Scoop: $source\"",
        "                return",
        "            }",
        "            throw \"Path is an existing reparse point not managed by this package: $source\"",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"Path exists and is not a directory: $source\"",
        "        }",
        "",
        "        & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        $copyExitCode = $LASTEXITCODE",
        "        if ($copyExitCode -gt 7) {",
        "            throw \"Migration failed with robocopy exit code ${copyExitCode}: $source\"",
        "        }",
        "",
        "        $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"Backed up original directory: $backup\"",
        "    }",
        "",
        "    try {",
        "        New-Item -Path $source -ItemType Junction -Value $target -Force | Out-Null",
        "    } catch {",
        "        if ($backup -and (Test-Path $backup) -and -not (Test-Path $source)) {",
        "            Move-Item -LiteralPath $backup -Destination $source -Force",
        "        }",
        "        throw",
        "    }",
        "}",
        "",
        "& $mountPersistedDirectory (Join-Path $env:USERPROFILE '.skills-manager') 'library'",
        "& $mountPersistedDirectory (Join-Path $env:APPDATA 'skills-manager') 'config'"
    ],
    "post_uninstall": [
        "$removePersistedJunction = {",
        "    param($source, $persistName)",
        "    if (-not (Test-Path $source)) { return }",
        "",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if (-not ($item.Attributes -band [IO.FileAttributes]::ReparsePoint)) { return }",
        "",
        "    $target = Join-Path $persist_dir $persistName",
        "    $expected = [IO.Path]::GetFullPath($target).TrimEnd('\\')",
        "    $actual = @($item.Target) | Select-Object -First 1",
        "    if ($actual -and [IO.Path]::GetFullPath($actual).TrimEnd('\\') -ieq $expected) {",
        "        Remove-Item -LiteralPath $source -Force",
        "    }",
        "}",
        "",
        "& $removePersistedJunction (Join-Path $env:USERPROFILE '.skills-manager') 'library'",
        "& $removePersistedJunction (Join-Path $env:APPDATA 'skills-manager') 'config'"
    ],
    "persist": [
        "library",
        "config"
    ],
    "checkver": {
        "github": "https://github.com/xingkongliang/skills-manager"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xingkongliang/skills-manager/releases/download/v$version/skills-manager_$version_x64-setup.exe#/dl.7z"
            }
        }
    }
}
