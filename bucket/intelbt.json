{
    "version": "24.30.1",
    "description": "intel bluetooth driver",
    "homepage": "https://www.intel.com/content/www/us/en/download/18649/intel-wireless-bluetooth-drivers-for-windows-10-and-windows-11.html",
    "license": "Proprietary",
    "url": "https://downloadmirror.intel.com/915506/BT-24.30.1-64UWD-Win10-Win11.exe#/setup.exe",
    "hash": "39b13d8853e004d3a3251244c72b008329516c3e0ac9b813e9563117f61de7f1",
    "depends": "curl",
    "installer": {
        "script": "start-process \"$dir\\setup.exe\" -wait -NoNewWindow -a '/qn'"
    },
    "uninstaller": {
        "file": "setup.exe",
        "args": [
            "/x",
            "/qn"
        ]
    },
    "checkver": {
        "script": [
            "$src = 'https://www.intel.com/content/www/us/en/download/18649/intel-wireless-bluetooth-drivers-for-windows-10-and-windows-11.html'",
            "$html = curl -s $src",
            "$ver = [regex]::Matches($html, 'name=\"DownloadVersion\" content=\"(?<version>[\\d.]+)\"')",
            "$url = [regex]::Matches($html, 'download-button(.*)\"https://downloadmirror.intel.com/(?<url>.*exe)\"')",
            "[string]::Format('{0}|{1}', $ver[0].groups['version'].value, $url[0].groups['url'].value)"
        ],
        "regex": "(?<version>.+)\\|(?<url>.+)"
    },
    "autoupdate": {
        "url": "https://downloadmirror.intel.com/$matchUrl#/setup.exe"
    }
}
