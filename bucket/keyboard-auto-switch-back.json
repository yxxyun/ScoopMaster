{
    "version": "0.0.1",
    "description": "Automatically switch to the target keyboard layout when a new window is activated.",
    "homepage": "https://github.com/scillidan/AHK-KeyboardAutoSwitchBack",
    "license": "MIT",
    "notes": [
        "You can start \"Keyboard Auto Switch Back\" with Windows by running:",
        "reg import \"$dir\\add-startup.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/scillidan/AHK-KeyboardAutoSwitchBack/releases/download/v0.0.1/KeyboardAutoSwitchBack.zip",
            "hash": "1f0e735a4171667f4889ff5481e0f95bcfa19d7d3d99380d39eb0e2eda192b36"
        }
    },
    "post_install": [
        "$dirpath = $dir.Replace('\\', '\\\\')",
        "'add-startup.reg', 'remove-startup.reg' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\pile\\scripts\\$app\\$_\") {",
        "        $content = Get-Content \"$bucketsdir\\pile\\scripts\\$app\\$_\"",
        "        $content = $content.Replace('$dir', $dirpath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content -Path \"$dir\\$_\"",
        "    }",
        "}"
    ],
    "post_uninstall": "if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }",
    "shortcuts": [
        [
            "KeyboardAutoSwitchBack.exe",
            "Keyboard Auto Switch Back"
        ]
    ],
    "persist": "KeyboardAutoSwitchBack.ini",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/scillidan/AHK-KeyboardAutoSwitchBack/releases/download/v$version/KeyboardAutoSwitchBack.zip"
            }
        }
    }
}
