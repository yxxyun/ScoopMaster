{"version":"0.0.8","description":"Automatically switch to the target keyboard layout when a new window is activated.","homepage":"https://github.com/scillidan/AHK-KeyboardAutoSwitchBack","license":"MIT","notes":["You can start \"Keyboard Auto Switch Back\" with Windows by running:","reg import \"$dir\\add-startup.reg\"","Or enable it from the tray menu.","PS: If app crashes, please check the configuration file (.ini)."],"architecture":{"64bit":{"url":"https://github.com/scillidan/AHK-KeyboardAutoSwitchBack/releases/download/v0.0.8/KeyboardAutoSwitchBack.zip","hash":"fbe3b05c831acb0ac311edc8b50cecf06e02ae709c3561c0010647478db7b8bf"}},"post_install":["$dirpath = $dir.Replace('\\', '\\\\')","'add-startup.reg', 'remove-startup.reg' | ForEach-Object {","    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_\") {","        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_\"","        $content = $content.Replace('$dir', $dirpath)","        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }","        $content | Set-Content -Path \"$dir\\$_\"","    }","}"],"post_uninstall":"if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }","shortcuts":[["KeyboardAutoSwitchBack.exe","Keyboard Auto Switch Back"]],"persist":"KeyboardAutoSwitchBack.ini","checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/scillidan/AHK-KeyboardAutoSwitchBack/releases/download/v$version/KeyboardAutoSwitchBack.zip"}}},"from":"https://github.com/scillidan/scoop-pile"}
