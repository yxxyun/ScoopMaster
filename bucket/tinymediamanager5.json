    },
    "architecture": {
        "64bit": {
            "url": "https://archive.tinymediamanager.org/v5.3.0/tinyMediaManager-5.3.0-windows-amd64.zip",
            "hash": "de516c831628433c6f6cf85b5e8d8d19583ef27ac4a7e58f41bae06886fe9bdb"
        }
    },
    "extract_dir": "tinyMediaManager",
