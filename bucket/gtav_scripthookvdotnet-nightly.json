{
    "version": "3.7.0-173",
    "description": "An ASI plugin for Grand Theft Auto V, which allows running scripts written in any .NET language on the .NET Framework runtime in-game",
    "homepage": "https://scripthookvdotnet.github.io/",
    "license": "https://github.com/scripthookvdotnet/scripthookvdotnet/blob/main/LICENSE.txt",
    "url": "https://github.com/scripthookvdotnet/scripthookvdotnet-nightly/releases/download/v3.7.0-nightly.173/ScriptHookVDotNet-v3.7.0-nightly.173.zip",
    "hash": "cd9e90c05c3cf3afb388578247926b3c2f9f798f5a3e62795bc7830e37b132d8",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "Copy-Item \"$dir\\*\" \"$env:GTAV_PATH\" -Exclude 'Docs', 'Licenses', 'README.txt' -Force -Recurse",
        "Remove-Item \"$dir\\*\" -Force -Recurse"
    ],
    "checkver": {
        "github": "https://github.com/scripthookvdotnet/scripthookvdotnet-nightly",
        "regex": "v(?<version>\\d+\\.\\d+\\.\\d+)-nightly\\.(?<build>\\d+)",
        "replace": "${version}-${build}"
    },
    "autoupdate": {
        "url": "https://github.com/scripthookvdotnet/scripthookvdotnet-nightly/releases/download/v$matchVersion-nightly.$matchBuild/ScriptHookVDotNet-v$matchVersion-nightly.$matchBuild.zip"
    }
}
