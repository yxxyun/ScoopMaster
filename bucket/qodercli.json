    "architecture": {
        "64bit": {
            "url": "https://qoder-ide.oss-accelerate.aliyuncs.com/qodercli/releases/1.1.2/qodercli-windows-x64.zip",
            "hash": "8874897f5687432cf824cb883d41f9c446d1ed4742c30310eaef2ed75f216f17"
        }
    },
    "pre_install": [
        "$exe = Get-ChildItem \"$dir\\qodercli.exe\" -ErrorAction SilentlyContinue",
        "if (-not $exe) { $exe = Get-ChildItem \"$dir\\*.exe\" | Select-Object -First 1 }",
        "if ($exe) { Rename-Item $exe.FullName 'qodercli.exe' -Force }"
    ],
    "bin": "qodercli.exe",
    "shortcuts": [
        [
            "qodercli.exe",
            "Qoder CLI"
        ]
    ],
    "checkver": {
        "url": "https://download.qoder.com/qodercli/channels/manifest.json",
        "jsonpath": "$.latest"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://qoder-ide.oss-accelerate.aliyuncs.com/qodercli/releases/$version/qodercli-windows-x64.zip",
                "hash": {
                    "url": "https://download.qoder.com/qodercli/channels/manifest.json",
                    "jsonpath": "$.files[] | select(.os == \"windows\" and .arch == \"amd64\" and .variant == \"standard\") | .sha256"
                }
            }
        }
    }
}
