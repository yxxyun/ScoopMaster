{
    "version": "2026.03.31.1",
    "description": "Phoenix is a suite of configurations & advanced modifications for Mozilla Firefox, designed to put the user first - with a focus on privacy, security, freedom, & usability.",
    "homepage": "https://phoenix.celenity.dev/",
    "license": "GPL-3.0-or-later",
    "notes": "After Phoenix is installed, you MUST restart Firefox after its first run with Phoenix installed. This ensures all of Phoenix's changes are applied.",
    "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip",
    "hash": "9afe8d82e32d387fd95e3fe2690ff9f15775277f47e6e82c07c7f900e531ab8c",
    "pre_install": [
        "#--- Skip when Target already selected ---",
        "$configFile = Join-Path $persist_dir 'phoenix-target.txt'",
        "if (Test-Path $configFile) {",
        "   $target = Get-Content $configFile",
        "   info \"Using persisted choice: $(if ($target.Contains('\\')) { fname $target } else { $target })\"",
        "   return",
        "}",
        "# --- Collect Firefox installations ---",
        "# 1. Locate Scoop-installed Firefox packages (with 'Addition' folder support)",
        "$scoopFirefox = @(installed_apps) | Where-Object { $_ -notmatch 'bird' -and (Get-Manifest $_).post_install -match 'additional' } |",
        "   Select-Object @{Name = 'Name'; Expression = { $_ } }, @{Name = 'Location'; Expression = { (Get-Manifest $_)[2] } }",
        "# 2. Locate system-installed Firefox installations via registry",
        "$regPaths = @(",
        "    'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',",
        "    'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',",
        "    'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'",
        ")",
        "$systemFirefox = $regPaths | Get-ItemProperty -ErrorAction SilentlyContinue |",
        "   Where-Object { $_.InstallLocation -match 'Firefox' } |",
        "   Select-Object @{Name = 'Name'; Expression = { $_.DisplayName } }, @{Name = 'Location'; Expression = { $_.InstallLocation } }",
        "# 3. Combine both installation types",
        "$installedFirefox = $scoopFirefox + $systemFirefox",
        "if ($installedFirefox -eq 0) {",
        "    abort 'No supported Firefox installation found.'",
        "}",
        "# --- List packages and prompt for user selection ---",
        "Write-Host \"`nApply Phoenix to:\"",
        "for ($i = 0; $i -lt $installedFirefox.Count; $i++) {",
        "   $item = $installedFirefox[$i]",
	    "   Write-Host \" [$($i+1)]`t$($item.Name.PadRight(20))-`t$(if($item.Location) { \"$($item.Location)\"})\"",
        "} do {",
        "   $choice = Read-Host \"`n(Type '0' to exit)`nEnter package number\"",
        "   if ($choice -eq 0) { exit 0 }",
        "} while ($choice -notmatch '^\\d+$' -or $choice -lt 1 -or $choice -gt $installedFirefox.Count)",
        "$chosen = $installedFirefox[$choice - 1]",
        "success \"Saving choice: $($chosen.Name) - $($chosen.Location)\"",
        "ensure $persist_dir | Out-Null",
        "& { if (($chosen.Location).Contains('\\')) { $chosen.Location } else { $chosen.Name } } | Out-UTF8File -FilePath $configFile"
    ],
    "post_install": [
        "# --- Get and check target info ---",
        "$configFile = Join-Path $dir 'phoenix-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort \"Phoenix config file missing. Cannot retrieve target.`nPlease reinstall.\"",
        "}",
        "$target = Get-Content $configFile",
        "if (-not $target.Contains('\\')) {",
        "   $target = Join-Path (persistdir $target) 'addition'",
        "   ensure $target | Out-Null",
        "} elseif (-not (Test-Path $target)) {",
        "   abort \"Cannot $cmd $app `nNo target found at \"$target\"\"",
        "}",
        "# --- Copy files to target ---",
        "info \"Applying Phoenix to $(if ($target.Contains('\\')) { fname $target } else { $target })\"",
        "try {",
        "   Copy-Item -Path \"$dir\\*\" -Destination $target -Exclude '*.txt', 'README.md' -Force -Recurse -ErrorAction Stop",
        "} catch [System.UnauthorizedAccessException] {",
        "   error \"$app requires admin rights to operate in the target path\"; break",
        "} catch { <# -ErrorAction SilentlyContinue #> }",
        "# --- Trigger post_install script of target app ---",
        "if (-not $target.Contains('\\')) {",
        "   $persist_dir = persistdir $target",
        "   $dir = appdir $target",
        "   Invoke-HookScript post_install (Get-Manifest $target) $architecture 6>$null",
        "}"
    ],
    "pre_uninstall": [
        "# --- Get and check target info ---",
        "$configFile = Join-Path $dir 'phoenix-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort \"Phoenix config file missing. Cannot retrieve target.`nPlease reinstall.\"",
        "}",
        "$target = Get-Content $configFile",
        "if (-not $target.Contains('\\')) {",
        "   $target = Join-Path (persistdir $target) 'addition'",
        "   ensure $target | Out-Null",
        "} elseif (-not (Test-Path $target)) {",
        "   abort \"Cannot $cmd $app `nNo target found at \"$target\"\"",
        "}",
        "# --- Fetch items, sort by type and depth and try to delete files and only empty folders ---",
        "info \"Unapplying Phoenix from $(if ($target.Contains('\\')) { fname $target } else { $target })\"",
        "Get-ChildItem -Path $dir -Recurse | Sort-Object PSIsContainer, @{ Expression = { ($_.FullName -split '\\\\').Count }; Descending = $true } |",
        "ForEach-Object {",
        "   $item = Join-Path $target $_.FullName.Substring($dir.Length)",
        "   if (-not $_.PSIsContainer -or -not (Get-ChildItem $item -Force)) {",
        "       try {",
        "           Remove-Item $item -ErrorAction Stop",
        "       } catch [System.UnauthorizedAccessException] { ",
        "           error \"$app requires admin rights to operate in the target path\"; break",
        "       } catch { <# -ErrorAction SilentlyContinue #> }",
        "   }",
        "}",
        "# --- Delete Addition dir only if empty --- ",
        "if (-not $target.Contains('\\') -and -not (Get-ChildItem $target -Force)) {",
        "Remove-Item $target -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "persist": "phoenix-target.txt",
    "checkver": {
        "url": "https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest",
        "jsonpath": "$.tag_name"
    },
    "autoupdate": {
        "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip"
    }
}
