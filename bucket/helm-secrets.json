{
    "version": "4.7.6",
    "homepage": "https://github.com/jkroepke/helm-secrets",
    "description": "A helm plugin that help manage secrets with Git workflow and store them anywhere",
    "license": "Apache-2.0",
    "depends": "helm",
    "suggest": {
        "SOPS": "sops",
        "vals": "vals"
    },
