{
    "version": "6.9.1",
    "description": "一款速度快、不打扰、够安全、易于分享的网盘",
    "homepage": "https://alipan.com/",
    "license": {
        "identifier": "EULA",
        "url": "https://alipan.com/protocol/service"
    },
    "url": "https://dorado-api.deno.dev/alipan?version=6.9.1&dl#/aDrive-6.9.1.7z",
    "hash": "cc40289de6c35821214c816b8a1101c3ada822f05c7da3b770ae432067eea76a",
    "post_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Remove-Item \"$dir\\`$TEMP\" -Force -Recurse",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
        "Write-Host (\"`nPersisting $env:APPDATA\\aDrive ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\aDrive\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Require-Admin",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        ". \"$bucketsdir\\$bucket\\scripts\\adrive\\uninstall.ps1\""
    ],
    "shortcuts": [
        [
            "aDrive.exe",
            "阿里云盘"
        ]
    ],
    "checkver": {
        "url": "https://dorado-api.deno.dev/alipan",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://dorado-api.deno.dev/alipan?version=$version&dl#/aDrive-$version.7z"
    },
    "notes": "User data is persisted in \"$persist_dir\"."
}
