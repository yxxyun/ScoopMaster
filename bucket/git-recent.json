{
    "version": "20260714",
    "description": "See your latest local git branches, formatted real fancy.",
    "homepage": "https://github.com/scillidan/git-recent",
    "license": "MIT",
    "suggest": {
        "Git": "main/git"
    },
    "notes": [
        "It must be used inside a Bash/Zsh session,",
        "The easiest Windows option is Git Bash.",
        "(Experimental) To keep the right tools first, add these to the TOP of your System PATH",
        "  $env:SCOOP\\apps\\git\\current\\bin",
        "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "url": "https://github.com/scillidan/git-recent/archive/master.zip",
    "hash": "893bada66a2f08ccd550241ea266f7e23b5f7117edbf073ffbc952399d9edbb2",
    "extract_dir": "git-recent-master",
    "pre_install": [
        "New-Item -Path \"$dir\\git-recent.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\git-recent.cmd\" -Value \"bash $env:SCOOP\\apps\\git-recent\\current\\git-recent %*\"",
        "New-Item -Path \"$dir\\git-recent-og.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\git-recent-og.cmd\" -Value \"bash $env:SCOOP\\apps\\git-recent\\current\\git-recent-og %*\""
    ],
    "bin": [
        "git-recent.cmd",
        "git-recent-og.cmd"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/scillidan/git-recent/commits?per_page=1",
        "jsonpath": "$[0].commit.author.date",
        "regex": "(\\d{4})-(\\d{2})-(\\d{2}).*",
        "replace": "$1$2$3"
    },
    "autoupdate": {
        "url": "https://github.com/scillidan/git-recent/archive/master.zip"
    }
}
