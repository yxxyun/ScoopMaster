{"version":"0.0.9","description":"Auto search selected word in GoldenDict by double-click.","homepage":"https://github.com/scillidan/AHK-GoldenDictAutoSearch","license":"MIT","notes":["You can start \"GoldenDict Auto Search\" with Windows by running:","reg import \"$dir\\add-startup.reg\"","Or enable it from the tray menu.","PS: If app crashes, please check the configuration file (.ini)."],"architecture":{"64bit":{"url":"https://github.com/scillidan/AHK-GoldenDictAutoSearch/releases/download/v0.0.9/GoldenDictAutoSearch.zip","hash":"4559f4796329a25944a60b65c861f848031254c5811efe1576be731783cff49e"}},"post_install":["$dirpath = $dir.Replace('\\', '\\\\')","'add-startup.reg', 'remove-startup.reg' | ForEach-Object {","    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_\") {","        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_\"","        $content = $content.Replace('$dir', $dirpath)","        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }","        $content | Set-Content -Path \"$dir\\$_\"","    }","}"],"post_uninstall":"if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }","shortcuts":[["GoldenDictAutoSearch.exe","GoldenDict Auto Search"]],"persist":"GoldenDictAutoSearch.ini","checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/scillidan/AHK-GoldenDictAutoSearch/releases/download/v$version/GoldenDictAutoSearch.zip"}}},"from":"https://github.com/scillidan/scoop-pile"}
