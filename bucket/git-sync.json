{
    "version": "20250906",
    "description": "Safe and simple one-script git synchronization.",
    "homepage": "https://github.com/simonthum/git-sync",
    "license": "MIT",
    "suggest": {
        "Git": "main/git"
    },
    "notes": [
      "It must be used inside a Bash/Zsh session,",
      "The easiest Windows option is Git Bash.",
      "To keep the right tools first, add these to the TOP of your System PATH",
      "  $env:SCOOP\\apps\\git\\current\\bin",
      "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "url": "https://github.com/simonthum/git-sync/archive/master.zip",
    "hash": "499e60d336ab03a6bb504d7d9628ad6257d58bdeb4338a50303131e4ccb01d9b",
    "extract_dir": "git-sync-master",
    "pre_install": [
        "New-Item -Path \"$dir\\git-sync.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\git-sync.cmd\" -Value \"bash $env:SCOOP\\apps\\git-sync\\current\\git-sync %*\""
    ],
    "bin": "git-sync.cmd",
    "checkver": {
        "url": "https://api.github.com/repos/simonthum/git-sync/commits?per_page=1",
        "jsonpath": "$[0].commit.author.date",
        "regex": "(\\d{4})-(\\d{2})-(\\d{2}).*",
        "replace": "$1$2$3"
    },
    "autoupdate": {
        "url": "https://github.com/simonthum/git-sync/archive/master.zip"
    }
}
