{
    "version": "20250906",
    "description": "Safe and simple one-script git synchronization.",
    "homepage": "https://github.com/simonthum/git-sync",
    "license": "MIT",
    "notes": "Run with bash.exe. Recommend installing main/git then adding $env:SCOOP\\apps\\git\\current\\bin, $env:SCOOP\\apps\\git\\current\\usr\\bin to the top of the system environment's PATH.",
    "url": "https://github.com/simonthum/git-sync/archive/master.zip",
    "hash": "499e60d336ab03a6bb504d7d9628ad6257d58bdeb4338a50303131e4ccb01d9b",
    "extract_dir": "git-sync-master",
    "pre_install": [
        "New-Item -Path \"$dir\\git-sync.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\git-sync.cmd\" -Value \"bash $env:SCOOP\\apps\\git-sync\\current\\git-sync %*\""
    ],
    "bin": "git-sync.cmd",
    "checkver": {
        "url": "https://api.github.com/repos/simonthum/git-sync/commits",
        "regex": "(\\d+)-(\\d+)-(\\d+)+T",
        "replace": "$1$2$3"
    },
    "autoupdate": {
        "url": "https://github.com/simonthum/git-sync/archive/master.zip"
    }
}
