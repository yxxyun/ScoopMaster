{
    "version": "2.96.0",
    "description": "gh completion as a PowerShell module",
    "homepage": "https://github.com/cli/cli",
    "url": "https://github.com/Arama0517/completions/releases/download/gh_v2.96.0/gh-completion.psm1",
    "hash": "c877029dd7d00352bb1225c89f211660fd293067766295d996e40dd9fb7aad36",
    "license": "MIT",
    "depends": "gh",
    "notes": [
        "Run following command to import gh-completion automatically in Powershell:",
        "$dir\\add-profile-content.ps1"
    ],
    "pre_install": "if (!(Test-Path \"$bucketsdir\\extras\")) { throw 'Please install extras bucket first: scoop bucket add extras' }",
    "post_install": [
        "Import-Module gh-completion",
        "$BucketDir = Find-BucketDirectory -Root -Name $bucket",
        "$UtilsPath = $BucketDir | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (Test-Path $UtilsPath) {",
        "    Unblock-File $UtilsPath",
        "    Import-Module $UtilsPath",
        "    New-ProfileModifier -Type ImportModule -Name gh-completion -BucketDir $BucketDir",
        "    New-ProfileModifier -Type RemoveModule -Name gh-completion -BucketDir $BucketDir",
        "    Remove-Module ModifyPSProfile -ErrorAction SilentlyContinue",
        "} else {",
        "    throw 'Missing files, please update scoop buckets and reinstall this app.'",
        "}"
    ],
    "pre_uninstall": [
        "Remove-Module gh-completion -ErrorAction SilentlyContinue",
        "$UtilsPath = Find-BucketDirectory -Root -Name $install.bucket | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (($cmd -eq 'uninstall') -and (Test-Path \"$dir\\remove-profile-content.ps1\") -and (Test-Path $UtilsPath)) {",
        "    Unblock-File $UtilsPath",
        "    & \"$dir\\remove-profile-content.ps1\"",
        "}"
    ],
    "psmodule": {
        "name": "gh-completion"
    },
    "checkver": {
        "url": "https://api.github.com/repos/Arama0517/completions/releases",
        "regex": "\"tag_name\":\\s*\"gh_v([\\d.]+)\""
    },
    "autoupdate": {
        "url": "https://github.com/Arama0517/completions/releases/download/gh_v$version/gh-completion.psm1"
    }
}
