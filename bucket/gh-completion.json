{
    "version": "2.96.0",
    "description": "gh completion as a PowerShell module",
    "homepage": "https://github.com/cli/cli",
    "url": "http://www.msftconnecttest.com/connecttest.txt",
    "hash": "5e9a7996fe94d7be10595d7133748760bf8348198b71b7a50fd8affaa980ac61",
    "license": "MIT",
    "depends": "gh",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\connecttest.txt\" -ErrorAction SilentlyContinue",
            "gh completion -s powershell | Out-File -FilePath \"$dir\\gh-completion.psm1\" -Encoding utf8",
            "New-ModuleManifest -Path \"$dir\\gh-completion.psd1\" -RootModule 'gh-completion.psm1' -ModuleVersion $version -Author 'ScoopInstaller' -Description 'gh completion module' -PowerShellVersion '5.1'"
        ]
    },
    "psmodule": {
        "name": "gh-completion"
    },
    "checkver": {
        "github": "https://github.com/cli/cli"
    },
    "autoupdate": {
        "url": "http://www.msftconnecttest.com/connecttest.txt"
    }
}
