{
    "version": "2.92.0",
    "description": "a gh-completion generator",
    "homepage": "https://github.com/woyxiang/slug",
    "url": "http://www.msftconnecttest.com/connecttest.txt",
    "hash": "5e9a7996fe94d7be10595d7133748760bf8348198b71b7a50fd8affaa980ac61",
    "license": "MIT",
    "installer": {
        "script": [
            "ensure ~/.config/pwsh/completions",
            "Remove-Item $dir\\connecttest.txt",
            "gh completion -s powershell > ~/.config/pwsh/completions/gh-completion.ps1"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item ~\\.config\\pwsh\\completions\\gh-completion.ps1 -ErrorAction SilentlyContinue"
    },
    "checkver": {
        "github": "https://github.com/cli/cli"
    },
    "autoupdate": {
        "url": "http://www.msftconnecttest.com/connecttest.txt"
    }
}
