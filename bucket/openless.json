        "$dll86 = \"$dir\\windows-ime\\x86\\OpenLessIme.dll\"",
        "$cmd = \"regsvr32.exe /s /u `\\`\"$dll64`\\`\"; & `\\`\"$env:SystemRoot\\SysWOW64\\regsvr32.exe`\\`\" /s /u `\\`\"$dll86`\\`\"\"",
        "Start-Process powershell -ArgumentList \"-NoProfile -Command `\"$cmd`\"\" -Verb RunAs -Wait"
    ],
    "checkver": {
        "github": "https://github.com/Open-Less/openless",
