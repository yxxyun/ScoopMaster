            "hash": "f06dc5f99ebbffeb56ce1d78a306ff5f5488ba0546e0d4c6320bfc1fa23d1ca5",
            "installer": {
                "script": [
                    "$vendorRoot = Join-Path $dir 'package\\vendor\\x86_64-pc-windows-msvc'",
                    "$copyMap = @{",
                    "    'codex\\codex.exe' = 'codex.exe'",
                    "    'codex\\codex-command-runner.exe' = 'codex-command-runner.exe'",
                    "    'codex\\codex-windows-sandbox-setup.exe' = 'codex-windows-sandbox-setup.exe'",
                    "    'path\\rg.exe' = 'rg.exe'",
                    "}",
                    "foreach ($relativeSource in $copyMap.Keys) {",
                    "    $sourcePath = Join-Path $vendorRoot $relativeSource",
                    "    $destinationPath = Join-Path $dir $copyMap[$relativeSource]",
                    "    Move-Item -Force $sourcePath $destinationPath",
                    "}",
                    "Remove-Item (Join-Path $dir 'package') -Recurse -Force"
                ]
            }
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.115.0/codex-npm-win32-arm64-0.115.0.tgz",
