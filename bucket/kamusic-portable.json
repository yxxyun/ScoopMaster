    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name apps) scripts/AppsUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:LOCALAPPDATA\\kugou\"",
            "Dismount-ExternalRuntimeData -Target \"$env:APPDATA\\kugou\"",
            "Remove-Module -Name AppsUtils"
        ]
    },
