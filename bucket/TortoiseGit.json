{
    "version": "2.19.1.0",
    "description": "Windows Shell Interface to Git based on TortoiseSVN.",
    "homepage": "https://tortoisegit.org/",
    "license": {
        "identifier": "GPL-2.0-only"
    },
    "notes": [
        "To add TortoiseGit as a context menu option, run '$dir\\tortoisegit-install.reg'",
        "For file associations, run '$dir\\tortoisegit-install-tools.reg'",
        "Before uninstalling TortoiseGit, run '$dir\\tortoisegit-uninstall.reg' "
    ],
    "architecture": {
        "32bit": {
            "url": "https://download.tortoisegit.org/tgit/2.19.0.0/TortoiseGit-2.19.1.0-32bit.msi",
            "hash": "12db1efefec43832886911ee8d52f7eac6d6fa53d1321b0bec3ed726eb6f21d3"
        },
        "64bit": {
            "url": "https://download.tortoisegit.org/tgit/2.19.0.0/TortoiseGit-2.19.1.0-64bit.msi",
            "hash": "e07ebf37063023d96dc8509a5d69ffa52d316cda8feea08beddad4b9818e7be5"
        },
        "arm64": {
            "url": "https://download.tortoisegit.org/tgit/2.19.0.0/TortoiseGit-2.19.1.0-arm64.msi",
            "hash": "1706cb8093486e40080e0a156499e653fc916b0258a7d5121b4e8d84736b0c13"
        }
    },
    "extract_dir": "Program Files\\TortoiseGit",
    "post_install": [
        "$path = 'HKCU:\\Software\\TortoiseGit'",
        "if (!(Test-path \"$path\")) {",
        "    New-Item $path | Out-Null",
        "    New-ItemProperty -Path $path -Name 'VersionCheck' -PropertyType DWord -Value 0 -Force | Out-Null",
        "    New-ItemProperty -Path $path -Name 'MsysGit' -PropertyType String -Value \"$env:GIT_INSTALL_ROOT\\bin\" -Force | Out-Null",
        "}",
        "$bucketdir = Find-BucketDirectory -Name $bucket",
        "$escdir = $dir -replace \"\\\\\",\"\\\\\"",
        "(gc \"$bucketdir\\..\\scripts\\tortoisegit\\tortoisegit-install.reg.templ\") | % {$_ -replace \"%TGITHOME%\",\"$escdir\"} | out-file -enc oem \"$dir\\tortoisegit-install.reg\"",
        "(gc \"$bucketdir\\..\\scripts\\tortoisegit\\tortoisegit-install-tools.reg.templ\") | % {$_ -replace \"%TGITHOME%\",\"$escdir\"} | out-file -enc oem \"$dir\\tortoisegit-install-tools.reg\"",
        "cp \"$bucketdir\\..\\scripts\\tortoisegit\\tortoisegit-uninstall.reg\" \"$dir\""
    ],
    "bin": [
        "bin\\TortoiseGitUDiff.exe",
        "bin\\TortoiseGitPlink.exe"
    ],
    "shortcuts": [
        [
            "bin\\TortoiseGitMerge.exe",
            "TortoiseGit Merge"
        ],
        [
            "bin\\TortoiseGitBlame.exe",
            "TortoiseGit Blame"
        ],
        [
            "bin\\TortoiseGitIDiff.exe",
            "TortoiseGit Diff"
        ],
        [
            "bin\\TortoiseGitProc.exe",
            "TortoiseGit Settings",
            "/command:settings"
        ]
    ],
    "checkver": {
        "url": "https://tortoisegit.org/download/",
        "regex": "<a href=//download.tortoisegit.org/tgit/(?<version>[\\d\\.]+)/TortoiseGit-(?<patch>[\\d\\.]+)-32bit.msi",
        "replace": "${patch}"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://download.tortoisegit.org/tgit/$matchVersion/TortoiseGit-$matchPatch-32bit.msi"
            },
            "64bit": {
                "url": "https://download.tortoisegit.org/tgit/$matchVersion/TortoiseGit-$matchPatch-64bit.msi"
            },
            "arm64": {
                "url": "https://download.tortoisegit.org/tgit/$matchVersion/TortoiseGit-$matchPatch-arm64.msi"
            }
        }
    }
}
