{
    "version": "1.0.7.2",
    "description": "A paint.net filetype plugin for loading SVG and its compressed variant SVGZ",
    "homepage": "https://github.com/otuncelli/Scalable-Vector-Graphics-Plugin-for-Paint.NET",
    "license": "GPL-2.0-only",
    "depends": "extras/paint.net",
    "url": "https://github.com/otuncelli/Scalable-Vector-Graphics-Plugin-for-Paint.NET/releases/download/v1.0.7.2/SvgFileTypePlugin.zip",
    "hash": "7cb25c2b0710a16296a569abd3f6cdde36a6db7195bd3d075648a4b4508241ab",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\"",
        "Move-Item -Path \"$dir\\SvgFileTypePlugin\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\"",
            "Remove-Item \"$paintdotnet\\SvgFileTypePlugin\" -Force -Recurse"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/otuncelli/Scalable-Vector-Graphics-Plugin-for-Paint.NET/releases/download/v$version/SvgFileTypePlugin.zip"
    }
}
