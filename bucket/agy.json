{
    "version": "1.0.8",
    "description": "Antigravity CLI - AI agent runtime manager",
    "homepage": "https://github.com/google-antigravity/antigravity-cli",
    "license": "MIT",
    "notes": [
        "agy 具有内置自更新能力，安装后会自行管理版本更新。",
        "scoop update agy 仅更新 manifest 中的指向，实际二进制由 agy 自身管理。"
    ],
    "architecture": {
        "64bit": {
            "url": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_amd64.json",
            "hash": "sha512:c3ab3f0bec151cff6d79d1ad11f3adbdf5945a2ad5726a882bb6efb6cc51515a8098e4f12ef50ec8e72bf046d4dc865f4190ee033d7b8f59050596330edf7a12"
        },
        "arm64": {
            "url": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_arm64.json",
            "hash": "sha512:5facb6b1797bfc9a30912e54fd69751947a92716a41242e530c6b10882a90e211dc59b755aab33f8c0597e274d1209c1ab485a845f12585989b8d814809938c2"
        }
    },
    "pre_install": [
        "# 读取 manifest（Scoop 刚刚下载的 JSON 文件）",
        "$manifest = Get-Content \"$dir\\$fname\" -Encoding UTF8 | ConvertFrom-Json",
        "",
        "# 从 manifest 中的 url 下载实际二进制",
        "Write-Host \"Downloading agy $($manifest.version)...\"",
        "Invoke-WebRequest -Uri $manifest.url -OutFile \"$dir\\agy.exe\"",
        "",
        "# 校验 SHA512",
        "$hash = (Get-FileHash \"$dir\\agy.exe\" -Algorithm SHA512).Hash.ToLower()",
        "if ($hash -ne $manifest.sha512.ToLower()) {",
        "    error 'Antigravity CLI: checksum mismatch, the downloaded binary may be corrupted or compromised!'",
        "    break",
        "}",
        "",
        "Unblock-File -Path \"$dir\\agy.exe\" -ErrorAction SilentlyContinue"
    ],
    "bin": "agy.exe",
    "checkver": {
        "url": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_amd64.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_amd64.json"
            },
            "arm64": {
                "url": "https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_arm64.json"
            }
        }
    }
}
