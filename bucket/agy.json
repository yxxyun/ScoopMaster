{"version":"1.0.10","description":"Antigravity CLI - AI agent runtime manager","homepage":"https://github.com/google-antigravity/antigravity-cli","license":"MIT","notes":["agy 具有内置自更新能力，安装后会自行管理版本更新。","scoop update agy 仅更新 manifest 中的指向，实际二进制由 agy 自身管理。"],"architecture":{"64bit":{"url":"https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_amd64.json","hash":"38f57bbe9bad861d16947f954f2326eef5a5c1fe2d7f66e4fb6f4c22013a99b7"},"arm64":{"url":"https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_arm64.json","hash":"8c7fa6e54559d6cd0fbddfc95614b77cb1b68b4412c8f090d9d5397bce63b67e"}},"pre_install":["# 读取 manifest（Scoop 刚刚下载的 JSON 文件）","$manifest = Get-Content \"$dir\\$fname\" -Encoding UTF8 | ConvertFrom-Json","","# 从 manifest 中的 url 下载实际二进制","Write-Host \"Downloading agy $($manifest.version)...\"","Invoke-WebRequest -Uri $manifest.url -OutFile \"$dir\\agy.exe\"","","# 校验 SHA512","$hash = (Get-FileHash \"$dir\\agy.exe\" -Algorithm SHA512).Hash.ToLower()","if ($hash -ne $manifest.sha512.ToLower()) {","    error 'Antigravity CLI: checksum mismatch, the downloaded binary may be corrupted or compromised!'","    break","}","","Unblock-File -Path \"$dir\\agy.exe\" -ErrorAction SilentlyContinue"],"bin":"agy.exe","checkver":{"url":"https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_amd64.json","jsonpath":"$.version"},"autoupdate":{"architecture":{"64bit":{"url":"https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_amd64.json"},"arm64":{"url":"https://antigravity-cli-auto-updater-974169037036.us-central1.run.app/manifests/windows_arm64.json"}}},"from":"https://github.com/Arama0517/scoop-bucket"}
