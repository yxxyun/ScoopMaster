    "pre_install": [
        "# Termua MSI 解包到 PFiles\\termua\\bin，将 bin 内文件移回根目录，使 bin 生效",
        "Get-ChildItem \"$dir\\PFiles\\termua\\bin\" | Move-Item -Destination \"$dir\" -Force",
        "Remove-Item \"$dir\\PFiles\" -Recurse -Force -ErrorAction SilentlyContinue"
    ],
    "checkver": {
        "github": "https://github.com/iamazy/termua"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/iamazy/termua/releases/download/v$version/termua-$version-windows.x86_64.msi",
                "hash": {
                    "url": "https://api.github.com/repos/iamazy/termua/releases/tags/v$version",
                    "jp": "$.assets[?(@.name=='termua-$version-windows.x86_64.msi')].digest"
                }
            },
            "arm64": {
                "url": "https://github.com/iamazy/termua/releases/download/v$version/termua-$version-windows.aarch64.msi",
