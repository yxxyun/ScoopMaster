{
    "version": "4.3.0.1242",
    "description": "A utility for experienced users to clean up corrupted installations of Adobe software.",
    "homepage": "https://helpx.adobe.com/creative-cloud/apps/troubleshoot/diagnostics-repair-tools/run-creative-cloud-cleaner-tool.html",
    "license": "Unknown",
    "url": "https://swupmf.adobe.com/webfeed/CleanerTool/win/AdobeCreativeCloudCleanerTool.exe#/dl.7z",
    "hash": "23700b61ee527d11e22e9fb86ecd67110fded4f81c8dfa5656306a33ff3105db",
    "pre_install": "Rename-Item -Path \"$dir\\ACToolMain.exe\" -NewName 'AdobeCreativeCloudCleanerTool.exe'",
    "bin": "AdobeCreativeCloudCleanerTool.exe",
    "checkver": {
        "url": "https://swupmf.adobe.com/webfeed/CleanerTool/win/AdobeCreativeCloudCleanerTool.exe",
        "script": [
            "$tmp = \"$env:TEMP\\accc_$([System.IO.Path]::GetRandomFileName())\"",
            "[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12",
            "Invoke-WebRequest -Uri 'https://swupmf.adobe.com/webfeed/CleanerTool/win/AdobeCreativeCloudCleanerTool.exe' -OutFile $tmp -UseBasicParsing",
            "$ver = [System.Diagnostics.FileVersionInfo]::GetVersionInfo($tmp).FileVersion",
            "Remove-Item $tmp -Force -ErrorAction SilentlyContinue",
            "Write-Output $ver"
        ],
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "hash": {
            "mode": "download"
        }
    }
}
