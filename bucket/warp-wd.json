{
    "version": "0.1",
    "description": "Pure bash port/implementation of wd from ZSH.",
    "homepage": "https://github.com/TheCheerfulDev/warp-wd",
    "license": "Apache-2.0",
    "notes": [
        "It must be used inside a Bash/Zsh session,",
        "The easiest Windows option is Git Bash.",
        "(Experimental) To keep the right tools first, add these to the TOP of your System PATH",
        "  $env:SCOOP\\apps\\git\\current\\bin",
        "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "url": "https://github.com/TheCheerfulDev/warp-wd/archive/refs/tags/v0.1.zip",
    "hash": "066fd7a51387b94073a3ce93e6d0027b3005832da6ae1cc4002d5de8a114a5f8",
    "extract_dir": "warp-wd-0.1\\bin",
    "pre_install": [
        "New-Item -Path \"$dir\\warp-wd.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\warp-wd.cmd\" -Value \"bash $env:SCOOP\\apps\\warp-wd\\current\\warp %*\""
    ],
    "bin": "warp-wd.cmd",
    "post_install": "iwr 'https://raw.githubusercontent.com/TheCheerfulDev/warp-wd/refs/tags/v0.1/LICENSE' -OutFile \"$dir\\LICENSE\"",
    "checkver": {
        "url": "https://api.github.com/repos/TheCheerfulDev/warp-wd/tags",
        "jsonpath": "$[0].name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/TheCheerfulDev/warp-wd/archive/refs/tags/v$version.zip"
    }
}
