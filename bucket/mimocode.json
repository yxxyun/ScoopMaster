{
    "version": "0.1.4",
    "description": "MiMo Code: Where Models and Agents Co-Evolve. A terminal-native AI coding assistant with persistent memory.",
    "homepage": "https://github.com/XiaomiMiMo/MiMo-Code",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v0.1.4/mimocode-windows-x64.zip",
            "hash": "sha256:6df50f071dac5fcc9d7b9c98924d68437619802d9c72e0a74bada62fb1f617cb"
        }
    },
    "bin": "mimo.exe",
    "pre_install": [
        "# 将 ~/.config/mimocode 软链接到 persist/config，升级时数据不丢失",
        "$mimo_dir = Join-Path $env:USERPROFILE \".config\\mimocode\"",
        "$persist_config = Join-Path $persist_dir \"config\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\link.ps1\" $mimo_dir $persist_config"
    ],
    "post_uninstall": [
        "$mimo_dir = Join-Path $env:USERPROFILE \".config\\mimocode\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\unlink.ps1\" $mimo_dir"
    ],
    "persist": ["config"],
    "checkver": {
        "github": "https://github.com/XiaomiMiMo/MiMo-Code"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/XiaomiMiMo/MiMo-Code/releases/download/v$version/mimocode-windows-x64.zip"
            }
        }
    }
}
