{
  "version": "1.0.10",
  "description": "A git client based on the IntelliJ platform.",
  "homepage": "https://github.com/DetachHead/rebased",
  "license": "Apache-2.0",
  "architecture": {
    "64bit": {
      "url": "https://github.com/DetachHead/rebased/releases/download/1.0.10/rebased.exe",
      "hash": "f8a2f4ac0bac2b446283fe1b0f19957df605d1e8f1b7949cfa56a308e7d035ef"
    }
  },
  "installer": {
    "script": [
      "$installer = Get-ChildItem \"$dir\\rebased.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
      "if ($installer) {",
      "    $extract = Join-Path $dir '_extract'",
      "    if (Test-Path $extract) { Remove-Item $extract -Recurse -Force -ErrorAction SilentlyContinue }",
      "    New-Item -ItemType Directory -Path $extract | Out-Null",
      "    Start-Process -FilePath $installer.FullName -ArgumentList '/S', \"/D=$extract\" -Wait -NoNewWindow",
      "    if (Test-Path \"$extract\\*\") {",
      "        Move-Item \"$extract\\*\" \"$dir\\\" -Force",
      "    }",
      "    Remove-Item $extract -Recurse -Force -ErrorAction SilentlyContinue",
      "}"
    ]
  },
  "post_install": "if (Test-Path \"$dir\\rebased.exe\") { Remove-Item \"$dir\\rebased.exe\" -Force -ErrorAction SilentlyContinue }",
  "bin": "bin\\idea64.exe",
  "shortcuts": [
    [
      "bin\\idea64.exe",
      "Rebased"
    ]
  ],
  "checkver": {
    "github": "https://github.com/DetachHead/rebased"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/DetachHead/rebased/releases/download/$version/rebased.exe"
      }
    }
  }
}
