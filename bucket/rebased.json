    "license": {
        "identifier": "Apache-2.0",
        "url": "https://github.com/DetachHead/rebased/raw/refs/heads/master/LICENSE.txt"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/DetachHead/rebased/releases/download/1.1.1/rebased.exe#/dl.7z",
            "hash": "e807bf9e033519903b35e0910651da9d9981324ab1533a747337438f39861dbe"
        }
    },
    "post_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": [
        [
            "bin\\idea64.exe",
            "rebased"
        ]
    ],
    "shortcuts": [
        [
            "bin\\idea64.exe",
            "Rebased"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\apeiraco\\bin\\persist-utils.ps1\"",
            "Set-PersistLinks -PersistDir $persist_dir -LinkMap @{ 'appdata' = '$env:APPDATA\\detachhead\\IdeaIC1.0'; 'cache' = '$env:LOCALAPPDATA\\detachhead\\IdeaIC1.0' }"
        ]
    },
    "uninstaller": {
        "script": [
            ". \"$bucketsdir\\apeiraco\\bin\\persist-utils.ps1\"",
            "Remove-PersistLinks -PersistDir $persist_dir -LinkMap @{ 'appdata' = '$env:APPDATA\\detachhead\\IdeaIC1.0'; 'cache' = '$env:LOCALAPPDATA\\detachhead\\IdeaIC1.0' }"
        ]
    },
    "checkver": {
        "github": "https://github.com/DetachHead/rebased"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/DetachHead/rebased/releases/download/$version/rebased.exe#/dl.7z"
            }
        }
    }
