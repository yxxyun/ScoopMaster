{
    "version": "v0.4.0",
    "description": "Simple Downloader Wrapper for curl",
    "homepage": "https://github.com/Syndim/downloader-wrapper",
    "license": "MIT",
    "depends": "curl-orig",
    "architecture": {
        "64bit": {
            "url": "https://gh.llkk.cc/https://github.com/Syndim/downloader-wrapper/releases/download/v0.4.0/downloader-wrapper-windows-amd64.zip",
            "hash": "9545d51b3dd0a67f9643394da9c190fe4a24008c5b037079d705aaa0f19eef88"
        }
    },
    "pre_install": [
        "Write-Host 'Renaming curl-wrapper.exe to curl.exe'",
        "Rename-Item \"$dir\\curl-wrapper.exe\" \"curl.exe\" -ErrorAction SilentlyContinue"
    ],
    "bin": "curl.exe",
    "checkver": {
        "github": "https://github.com/Syndim/downloader-wrapper",
        "regex": "releases/tag/(v[\\d\\.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gh.llkk.cc/https://github.com/Syndim/downloader-wrapper/releases/download/$version/downloader-wrapper-windows-amd64.zip"
            }
        }
    }
}
