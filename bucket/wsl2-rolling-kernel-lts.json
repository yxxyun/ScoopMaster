            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.29/Image-arm64",
            "hash": "dc524cd22fe5ad915fae474a45fe85756d057557b093e4d35eae1f8254b2bd8d",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\Image-arm64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
