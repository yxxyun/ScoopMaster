            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.28/Image-arm64",
            "hash": "2b99edf338ab57862d8ade8ceb7dc1e9bdb85b0deecd086e2905cd5e85727c60",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\Image-arm64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
