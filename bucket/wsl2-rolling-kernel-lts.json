{
    "version": "6.18.28",
    "description": "Rolling Release LTS Kernel for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS",
    "license": "GPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.28/bzImage-x86_64",
            "hash": "9786679b2b2684fecc9021ee8e3fdee72f8ed60b37552c9336afe347071a91c1",
            "post_install": [
                "###########################################",
                "# Set WSL2 rolling kernel in `.wslconfig` #",
                "#       Channel: LTS | Arch: x86_64       #",
                "###########################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelInstall -UsingNamespace System.Text",
                "$kernel_path=\"$original_dir\\bzImage-x86_64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "##############################################",
                "# Remove WSL2 rolling kernel in `.wslconfig` #",
                "##############################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.28/Image-arm64",
            "hash": "2b99edf338ab57862d8ade8ceb7dc1e9bdb85b0deecd086e2905cd5e85727c60",
            "post_install": [
                "###########################################",
                "# Set WSL2 rolling kernel in `.wslconfig` #",
                "#        Channel: LTS | Arch: arm64       #",
                "###########################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelInstall -UsingNamespace System.Text",
                "$kernel_path=\"$original_dir\\Image-arm64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "##############################################",
                "# Remove WSL2 rolling kernel in `.wslconfig` #",
                "##############################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/latest",
        "regex": "linux-wsl-lts-([\\d.]+)"
    },
