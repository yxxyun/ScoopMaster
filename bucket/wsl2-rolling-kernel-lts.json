            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.38/Image-arm64",
            "hash": "e8394f7e34b8065da990cae6128b8a7ccb2b99b530fc2ed89e7e37cdacd3c620",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\Image-arm64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
