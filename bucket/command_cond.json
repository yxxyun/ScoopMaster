{"version":"05f3cb2","description":"A simple mpv script that run different commands under different conditions.","homepage":"https://github.com/zhongfly/command_cond","license":"MIT","notes":"Read $dir\\README.md and edit settings.conf to configure, better to set 'configs' to '~~/input_settings.conf'.","url":"https://github.com/zhongfly/command_cond/archive/refs/heads/main.zip","hash":"075cd95c392748c59e317b7624b1964db0deefe425fdf75e260711f5dd8ff294","depends":["mpv"],"extract_dir":"command_cond-main","post_install":["$Target = $(appdir mpv $global) + \"\\current\\portable_config\"","Copy-Item -Destination $Target\\scripts -Path $dir\\command_cond.lua","if ( !( Test-Path $Target\\input_settings.conf ) ){ New-Item -Path $Target\\input_settings.conf -ItemType File | Out-Null }"],"uninstaller":{"script":["$Target = $(appdir mpv $global) + \"\\current\\portable_config\"","Remove-Item -Path $Target\\scripts\\command_cond.lua"]},"checkver":{"url":"https://api.github.com/repos/zhongfly/command_cond/commits","jsonpath":"$.[0].sha","regex":"([a-z\\d]{7})"},"autoupdate":{"url":"https://github.com/zhongfly/command_cond/archive/refs/heads/main.zip"},"from":"https://github.com/Arama0517/scoop-bucket"}
