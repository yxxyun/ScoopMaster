            "Remove-Junction -Path \"$env:APPDATA\\r2modmanPlus-local\""
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/ebkr/r2modmanPlus/releases/download/v$version/r2modman-$version.exe#/r2modman.exe"
    }
