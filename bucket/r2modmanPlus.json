    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\doge\\scripts\\utils.ps1\"",
            "Set-Junction -Source \"$persist_dir\\r2modman\" -Target \"$env:APPDATA\\r2modman\"",
