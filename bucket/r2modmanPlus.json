    "url": "https://github.com/ebkr/r2modmanPlus/releases/download/v3.2.18/r2modman-3.2.18.exe#/r2modman.exe",
    "hash": "50c30f6947ae3e3d9773f8e1c7c30d601b54f892be00e77e814fe08c186b3cb7",
    "shortcuts": [
        [
            "r2modman.exe",
            "r2modman"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\doge\\scripts\\utils.ps1\"",
            "Set-Junction -Source \"$persist_dir\\r2modman\" -Target \"$env:APPDATA\\r2modman\"",
            "Set-Junction -Source \"$persist_dir\\r2modmanPlus-local\" -Target \"$env:APPDATA\\r2modmanPlus-local\""
        ]
    },
    "uninstaller": {
        "script": [
            ". \"$bucketsdir\\doge\\scripts\\utils.ps1\"",
            "Remove-Junction -Path \"$env:APPDATA\\r2modman\"",
            "Remove-Junction -Path \"$env:APPDATA\\r2modmanPlus-local\""
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/ebkr/r2modmanPlus/releases/download/v$version/r2modman-$version.exe#/r2modman.exe"
    }
