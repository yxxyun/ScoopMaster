{
    "homepage": "https://uu.163.com/",
    "description": "Netease Online Game accelerator",
    "version": "6.12.1",
    "license": {
        "identifier": "Proprietary",
        "url": "https://uu.163.com/agreement.html"
    },
    "url": "https://adl.netease.com/d/g/uu/c/gw?type=pc",
    "pre_install": [
        "$resp = Invoke-RestMethod 'https://adl.netease.com/d/g/uu/c/gw?type=pc'",
        "$m = [regex]::Match($resp, 'pc_link\\s*=\\s*\"([^\"]+)\"')",
        "if (!$m.Success) { error 'Failed to extract download URL from API'; exit 1 }",
        "Invoke-WebRequest -Uri $m.Groups[1].Value -OutFile \"$dir\\UU.7z\"",
        "Expand-7zipArchive -Path \"$dir\\UU.7z\" -DestinationPath $dir",
        "Remove-Item \"$dir\\gw\", \"$dir\\UU.7z\" -Force"
    ],
    "shortcuts": [
        [
            "uu_launcher.exe",
            "UU加速器"
        ]
    ],
    "checkver": {
        "url": "https://adl.netease.com/d/g/uu/c/gw?type=pc",
        "regex": "UU-([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "url": "https://adl.netease.com/d/g/uu/c/gw?type=pc"
    }
}
