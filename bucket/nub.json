{
    "version": "0.5.0",
    "description": "A fast all-in-one toolkit that augments Node.js instead of replacing it",
    "homepage": "https://nubjs.com/docs",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/nubjs/nub/releases/download/v0.5.0/nub-win32-x64.zip#/nub.zip",
            "hash": "a8a2fe530dd93c6402ecffb12a4ce33e3b39d761cd5115fe3252aba1342912b0"
        }
    },
    "bin": [
        "bin/nub.exe",
        "bin/nubx.exe",
        [
            "bin/nub.exe",
            "pnpm"
        ]
    ],
    "checkver": {
        "github": "https://github.com/nubjs/nub"
    },
    "pre_install": [
        "# 将 ~/.cache/nub 软链接到 persist/cache，升级时数据不丢失",
        "$nub_cache = Join-Path $env:USERPROFILE \".cache\\nub\"",
        "$persist_cache = Join-Path $persist_dir \"cache\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $nub_cache $persist_cache",
        "",
        "# 将 $env:LOCALAPPDATA\\nub 软链接到 persist/data，升级时数据不丢失",
        "$nub_data = Join-Path $env:LOCALAPPDATA \"nub\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $nub_data $persist_data"
    ],
    "post_uninstall": [
        "## 卸载时清理链接",
        "$nub_cache = Join-Path $env:USERPROFILE \".cache\\nub\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $nub_cache",
        "$nub_data = Join-Path $env:LOCALAPPDATA \"nub\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $nub_data"
    ],
    "persist": [
        "cache",
        "data"
    ],
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nubjs/nub/releases/download/v$version/nub-win32-x64.zip#/nub.zip"
            }
        },
        "hash": {
            "url": "$baseurl.sha256"
        }
    }
}
