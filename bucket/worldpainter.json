{
    "version": "2.27.0",
    "description": "Interactive map generator for Minecraft Java Edition",
    "homepage": "https://www.worldpainter.net/",
    "license": "GPL-3.0-only",
    "notes": "WorldPainter 64-bit requires Java 21, 32-bit requires Java 17. Install with 'scoop install temurin21-jdk' (64-bit) or 'scoop install temurin17-jdk' (32-bit).",
    "suggest": {
        "JDK": "java/temurin21-jdk"
    },
    "architecture": {
        "64bit": {
            "url": "https://www.worldpainter.net/files/worldpainter_2.27.0.zip",
            "hash": "78c1d2b0d33411fdfb71c367143caa91cde777610f7a28260485193183968d0d",
            "extract_dir": "WorldPainter"
        },
        "32bit": {
            "url": "https://www.worldpainter.net/files/worldpainter_32_2.27.0.zip",
            "hash": "663f9be7e7a73e44cddc36c8766a9da252e794d3ae2172e9f612596d46016322",
            "extract_dir": "WorldPainter"
        }
    },
    "bin": [
        "worldpainter.exe",
        "wpscript.exe"
    ],
    "shortcuts": [
        ["worldpainter.exe", "WorldPainter"],
        ["wpscript.exe", "WorldPainter Script (wpscript)"]
    ],
    "checkver": {
        "url": "https://www.worldpainter.net/",
        "regex": "worldpainter_([\\d.]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.worldpainter.net/files/worldpainter_$version.zip"
            },
            "32bit": {
                "url": "https://www.worldpainter.net/files/worldpainter_32_$version.zip"
            }
        },
        "hash": {
            "url": "https://www.worldpainter.net/files/sha256sums",
            "regex": "$sha256\\s+\\*worldpainter_$version\\.zip"
        }
    }
}
