{
    "version": "0.0.2",
    "description": "Switch between two keyboard.",
    "homepage": "https://github.com/scillidan/AHK-KeyboardSwitch",
    "license": "MIT",
    "notes": [
        "You can start \"Keyboard Switch\" with Windows by running:",
        "reg import \"$dir\\add-startup.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/scillidan/AHK-KeyboardSwitch/releases/download/v0.0.2/KeyboardSwitch.zip",
            "hash": "f94a14bca6dc8b7596d109580cb38498a7cebc539581f3c23e1e5b5af69a89b5"
        }
    },
    "post_install": [
        "$dirpath = $dir.Replace('\\', '\\\\')",
        "'add-startup.reg', 'remove-startup.reg' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\pile\\scripts\\$app\\$_\") {",
        "        $content = Get-Content \"$bucketsdir\\pile\\scripts\\$app\\$_\"",
        "        $content = $content.Replace('$dir', $dirpath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content -Path \"$dir\\$_\"",
        "    }",
        "}"
    ],
    "post_uninstall": "if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }",
    "shortcuts": [
        [
            "KeyboardSwitch.exe",
            "Keyboard Switch"
        ]
    ],
    "persist": "KeyboardSwitch.ini",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/scillidan/AHK-KeyboardSwitch/releases/download/v$version/KeyboardSwitch.zip"
            }
        }
    }
}
