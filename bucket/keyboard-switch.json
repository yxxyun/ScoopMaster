{"version":"0.2.5","description":"Switch between two keyboard.","homepage":"https://github.com/scillidan/AHK-KeyboardSwitch","license":"MIT","notes":["You can start \"Keyboard Switch\" with Windows by running:","reg import \"$dir\\add-startup.reg\"","Or enable it from the tray menu.","PS: If app crashes, please check the configuration file (.ini)."],"architecture":{"64bit":{"url":"https://github.com/scillidan/AHK-KeyboardSwitch/releases/download/v0.2.5/KeyboardSwitch.zip","hash":"2725ed74cf75b7e1386a1b77f1036b2c12690f6ba5feaf4d8555673fee4ee478"}},"post_install":["$dirpath = $dir.Replace('\\', '\\\\')","'add-startup.reg', 'remove-startup.reg' | ForEach-Object {","    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_\") {","        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_\"","        $content = $content.Replace('$dir', $dirpath)","        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }","        $content | Set-Content -Path \"$dir\\$_\"","    }","}"],"post_uninstall":"if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }","shortcuts":[["KeyboardSwitch.exe","Keyboard Switch"]],"persist":"KeyboardSwitch.ini","checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/scillidan/AHK-KeyboardSwitch/releases/download/v$version/KeyboardSwitch.zip"}}},"from":"https://github.com/Arama0517/scoop-bucket"}
