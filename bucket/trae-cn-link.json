{
    "version": "2.3.10745",
    "description": "An AI-powered IDE that makes programming more enjoyable and efficient.",
    "homepage": "https://www.trae.com.cn",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://raw.githubusercontent.com/morning-start/code-bucket/refs/heads/master/scripts/placeholder.txt"
        }
    },
    "pre_install": [
        "# 处理用户配置目录",
        "$config_dirs = @(",
        "    '.trae-cn',",
        "    '.trae-aicc'",
        ")",
        "foreach ($config_dir in $config_dirs) {",
        "    $target_dir = Join-Path $env:USERPROFILE $config_dir",
        "    $link_dir = Join-Path $persist_dir $config_dir",
        "    & \"$bucketsdir\\code\\scripts\\link.ps1\" $target_dir $link_dir",
        "}",
        "",
        "# 链接 $env:APPDATA\\Trae CN 到 persist_dir/data",
        "$appdata_dir = Join-Path $env:APPDATA \"Trae CN\"",
        "$persist_data_dir = Join-Path $persist_dir data",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $appdata_dir $persist_data_dir"
    ],
    "post_uninstall": [
        "$config_dirs = @(",
        "    '.trae-cn',",
        "    '.trae-aicc'",
        ")",
        "foreach ($config_dir in $config_dirs) {",
        "    $target_dir = Join-Path $env:USERPROFILE $config_dir",
        "    & \"$bucketsdir\\code\\scripts\\unlink.ps1\" $target_dir",
        "}",
        "",
        "$appdata_dir = Join-Path $env:APPDATA \"Trae CN\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $appdata_dir"
    ],
    "persist": [
        "data",
        ".trae",
        ".trae-cn",
        ".trae-aicc"
    ],
    "checkver": {
        "url": "https://api.trae.com.cn/icube/api/v1/package/check_update?mid=7&packageType=stable_cn&platform=Win&tenant=marscode&appVersion=1.0.0&iid=1&branch=release_desktop_yoma_win32_cn",
        "jsonpath": "$.data.manifest.win32.version"
    }
}
