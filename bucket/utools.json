{
    "version": "7.6.0",
    "description": "Your productive tools set and launcher.",
    "homepage": "https://u.tools/",
    "license": {
        "identifier": "Proprietary",
        "url": "http://u.tools/agreement.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://open.u-tools.cn/download/uTools-7.6.0.exe#/dl.7z",
            "hash": "ced9f084d810e850ab1e52f8ad5070c17f4b8e82249128c6741fb957d2cab058",
            "installer": {
                "script": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR/app-64.7z\" \"$dir\""
            }
        },
        "32bit": {
            "url": "https://open.u-tools.cn/download/uTools-7.6.0-ia32.exe#/dl.7z",
            "hash": "af5d301cdbbed89a3ae7be1b7e36791f4965b8128c2187d0841d89c0e48c807a",
            "installer": {
                "script": "Expand-7zipArchive \"$dir\\`$PLUGINSDIR/app-32.7z\" \"$dir\""
            }
        }
    },
    "post_install": [
        "@('$PLUGINSDIR') | ForEach-Object { Remove-Item \"$dir\\$_\" -Recurse -Force -ErrorAction SilentlyContinue }",
        "if (!(Test-Path \"$dir\\User Data\\*\") -and (Test-Path \"$env:AppData\\uTools\")) {",
        "    info '[Portable Mode]: Copying user data...'",
        "    Copy-Item \"$env:AppData\\uTools\\*\" \"$dir\\User Data\" -Recurse",
        "}"
    ],
    "shortcuts": [
        [
            "uTools.exe",
            "uTools"
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "url": "https://u.tools/download/",
        "regex": "uTools-([\\d.]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://open.u-tools.cn/download/uTools-$version.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://open.u-tools.cn/download/uTools-$version-ia32.exe#/dl.7z"
            }
        }
    }
}
