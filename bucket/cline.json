{
    "version": "3.0.40",
    "description": "CLI utility for Cline",
    "homepage": "https://cline.bot/cli",
    "license": "Apache-2.0",
    "depends": "versions/nodejs24",
    "architecture": {
        "64bit": {
            "url": "https://registry.npmjs.org/cline/-/cline-3.0.40.tgz",
            "hash": "sha1:0f024b83725ce778ac7f548ec11ac3c0f0e76d81"
        }
    },
    "pre_install": [
        "if (-not (Get-Command node -ErrorAction SilentlyContinue)) {",
        "  Write-Error 'Node.js v24 non è installato. Installa prima Node.js v24.'",
        "  exit 1",
        "}"
    ],
    "installer": {
        "script": [
            "Remove-Item \"$dir\\package\" -Force -Recurse",
            "# Installing packages",
            "npm install --prefix \"$dir\" cline"
        ]
    },
    "uninstaller": {
        "script": [
            "# Uninstalling packages",
            "npm uninstall --prefix \"$dir\" cline"
        ]
    },
    "bin": [
        [
            "node_modules/.bin/cline.cmd",
            "cline"
        ]
    ],
    "checkver": {
        "url": "https://registry.npmjs.org/cline",
        "jsonpath": "$.['dist-tags'].latest"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://registry.npmjs.org/cline/-/cline-$version.tgz",
                "hash": {
                    "mode": "json",
                    "url": "https://registry.npmjs.org/cline/$version",
                    "jsonpath": "$.dist.shasum"
                }
            }
        }
    }
}
