{
    "version": "1.9577.43",
    "description": "The first agentic IDE, and then some. The Windsurf Editor is where the work of developers and AI truly flow together, allowing for a coding experience that feels like literal magic.",
    "homepage": "https://codeium.com/windsurf",
    "license": {
        "identifier": "Proprietary",
        "url": "https://codeium.com/privacy-policy"
    },
    "architecture": {
        "64bit": {
            "url": "https://windsurf-stable.codeiumdata.com/win32-x64/stable/745a6c1ac471cc11f782a05d2c3ceacbc1de308f/WindsurfSetup-x64-1.9577.43.exe",
            "hash": "3f3b27bbdcbfcd8b8d67f5f3691f24927c2bf76f6bb787c03dbb0e5c18d009e0"
        },
        "arm64": {
            "url": "https://windsurf-stable.codeiumdata.com/win32-arm64/stable/745a6c1ac471cc11f782a05d2c3ceacbc1de308f/WindsurfSetup-arm64-1.9577.43.exe",
            "hash": "8b6a4dd270a497ebf36c6b3849c743862770676d528d90ad1556d19bfdbb0e07"
        }
    },
    "pre_install": [
        "$setupfile = (Get-ChildItem \"$dir\" 'WindsurfSetup-*.exe' | Select-Object -First 1).FullName",
        "Expand-InnoArchive \"$setupfile\" \"$dir\" -ExtractDir \"{app}\"",
        "Expand-InnoArchive \"$setupfile\" \"$dir\" -ExtractDir \"{code_GetDestDir}\"",
        "Remove-Item \"$dir\\WindsurfSetup-*.exe\" -Force"
    ],
    "post_install": [
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse",
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.windsurf\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.windsurf\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Windsurf\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Windsurf\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=windsurf-code(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "bin": "bin/windsurf.cmd",
    "shortcuts": [
        [
            "Windsurf.exe",
            "Windsurf AI Editor",
            "--user-data-dir=\"$dir\\data\\user-data\" --extensions-dir=\"$dir\\data\\extensions\""
        ]
    ],
    "persist": "data",
    "checkver": {
        "url": "https://windsurf.com/editor/releases",
        "regex": "win32-x64-user/stable/(?<Code>[\\w]+)/WindsurfUserSetup-x64-([\\d.]+).exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://windsurf-stable.codeiumdata.com/win32-x64/stable/$matchCode/WindsurfSetup-x64-$version.exe"
            },
            "arm64": {
                "url": "https://windsurf-stable.codeiumdata.com/win32-arm64/stable/$matchCode/WindsurfSetup-arm64-$version.exe"
            }
        }
    }
}
