            "https://github.com/lxgw/LxgwWenKai-Screen/releases/download/v$version/LXGWWenKaiGBScreen.ttf",
            "https://github.com/lxgw/LxgwWenKai-Screen/releases/download/v$version/LXGWWenKaiMonoGBScreen.ttf"
        ]
    }
}
