{
    "version": "2.1.0",
    "description": "paint.net plugin which adds reading support for WIC codecs",
    "homepage": "https://github.com/ReneSlijkhuis/paint.net-wic-plugin",
    "license": "MIT",
    "depends": "extras/paint.net",
    "url": "http://www.slijkhuis.org/PaintDotNet/WicDecoder.zip",
    "hash": "865a91782a51efd315d70bbecbe79b28b66fabe57999dd0024b450fa7ff1be8c",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\\WicDecoder\"",
        "New-Item \"$paintdotnet\" -ItemType Directory -Force",
        "Move-Item -Path \"$dir\\*\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\\WicDecoder\"",
            "Remove-Item \"$paintdotnet\" -Force -Recurse"
        ]
    },
    "checkver": {
        "url": "https://github.com/ReneSlijkhuis/paint.net-wic-plugin/tags",
        "regex": "/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "url": "http://www.slijkhuis.org/PaintDotNet/WicDecoder.zip"
    }
}
