{"version":"5.2.2.32209","description":"Beyond Compare 是一款用于比较文件和文件夹的实用程序。它可以帮助您查找和协调源代码、文件夹、图像和数据中的差异，即使您的文件包含在 zip 压缩文件中或位于远程服务 (例如 FTP 站点) 上。它可以同步您的文件夹并验证您的副本。","homepage":"https://www.scootersoftware.com/index.php","license":{"identifier":"Shareware","url":"https://www.scootersoftware.com/kb/licensev5"},"notes":"Add Beyond Compare as a context menu option by running: '$dir\\install-context.reg'","url":"https://www.scootersoftware.com/files/BCompare-zh-5.2.2.32209.exe#/setup.exe","hash":"7d7f7dc17ee854ae64bcbc55bc7e2866ba180b305cc14b7499893d28b6db4b96","installer":{"args":["/VERYSILENT","/NORESTART","/PORTABLE","/DISABLEUPDATES","/DIR=$dir"]},"post_install":["$dir_escaped = \"$dir\".Replace('\\', '\\\\')","\"install-context-$architecture\", \"uninstall-context\" | ForEach-Object {","  if (Test-Path \"$bucketsdir\\$bucket\\scripts\\beyondcompare\\$_.reg\") {","    $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\beyondcompare\\$_.reg\"","    $content = $content.Replace('$install_dir', $dir_escaped)","    $outfile_no_arch = $_.Replace(\"-$architecture\", \"\")","    $content | Set-Content -Path \"$dir\\$outfile_no_arch.reg\"","  }","}"],"pre_uninstall":["Stop-Process -Name 'BCompare.exe' -ErrorAction SilentlyContinue","if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-context.reg\" }"],"bin":["Bcomp.exe","BCompare.exe"],"shortcuts":[["BCompare.exe","Beyond Compare 5"]],"checkver":{"url":"https://www.scootersoftware.com/download.php","regex":"/BCompare-zh-([\\d.]+)\\.exe"},"autoupdate":{"url":"https://www.scootersoftware.com/files/BCompare-zh-$version.exe#/setup.exe"},"from":"https://github.com/wwvl/Emma"}
