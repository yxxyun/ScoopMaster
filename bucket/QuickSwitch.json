{
    "version": "0.5",
    "description": "Uses opened file manager folders in File dialogs.",
    "homepage": "https://github.com/fenchai23/QuickSwitch",
    "license": "Unlicense",
    "suggest": {
        "AutoHotkey 1.1": "Versions/autohotkey1.1"
    },
    "notes": "In $dir, run \"Ahk2Exe /in QuickSwitch.ahk /icon res/icon.ico /out QuickSwitch.exe\" to build EXE (x64).",
    "url": "https://github.com/fenchai23/QuickSwitch/archive/refs/tags/v0.5.zip",
    "hash": "f1ddd4e1ea09aba1c83461317e48fa9b78d66a9089b3199e5a009746fefd1f62",
    "extract_dir": "QuickSwitch-0.5",
    "pre_install": [
        "Remove-Item \"$dir\\QuickSwitch.ini\"",
        "New-Item -Path \"$dir\\QuickSwitch.ini\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\QuickSwitch.ini\" -Value \"[Preferences]`nAlways Auto Switch=1\""
    ],
    "checkver": {
        "url": "https://api.github.com/repos/fenchai23/QuickSwitch/tags",
        "regex": "\"name\":\\s*\"v([\\d.]+)\"",
        "replace": "$1"
    },
    "autoupdate": {
        "url": "https://github.com/fenchai23/QuickSwitch/archive/refs/tags/v$version.zip",
        "extract_dir": "QuickSwitch-$version"
    }
}
