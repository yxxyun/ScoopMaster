{
    "version": "v0.3.5",
    "description": "Simple Downloader Wrapper for aria2",
    "homepage": "https://github.com/Syndim/downloader-wrapper",
    "license": "MIT",
    "depends": "aria2-orig",
    "architecture": {
        "64bit": {
            "url": "https://gh.llkk.cc/https://github.com/Syndim/downloader-wrapper/releases/download/v0.3.5/downloader-wrapper-windows-amd64.zip",
            "hash": "3271f8514ce32acca164556bf473ce49ad7aa3b090893266290249a93d7b1bc7"
        }
    },
    "pre_install": [
        "Write-Host 'Renaming aria2-wrapper.exe to aria2c.exe'",
        "Rename-Item \"$dir\\aria2-wrapper.exe\" \"aria2c.exe\" -ErrorAction SilentlyContinue"
    ],
    "bin": "aria2c.exe",
    "checkver": {
        "github": "https://github.com/Syndim/downloader-wrapper",
        "regex": "releases/tag/(v[\\d\\.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gh.llkk.cc/https://github.com/Syndim/downloader-wrapper/releases/download/$version/downloader-wrapper-windows-amd64.zip"
            }
        }
    }
}
