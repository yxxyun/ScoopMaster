{"version":"1.31.0","description":"Linear desktop app for issue tracking and project planning.","homepage":"https://linear.app","license":"Proprietary","architecture":{"64bit":{"url":"https://releases.linear.app/windows#/Linear-Setup-1.31.0.exe","hash":"928310526e6e6c67417f4e3a615773b456a8c39f10c0ae3da581aacecefdc0c0"}},"installer":{"args":["/S","/D=$dir"]},"post_install":["# Disable built-in updates so Scoop remains the update manager.","$yaml = \"$dir\\resources\\app-update.yml\"","if (Test-Path $yaml) {","    $content = Get-Content $yaml -Encoding ASCII | ForEach-Object {","        if ($_.StartsWith('url')) { \"$($_.Replace('url', '# url')) # Disabled by Scoop\" } else { $_ }","    }","    Set-Content $yaml -Value $content -Encoding ASCII","}","$updaterCache = Join-Path $env:LOCALAPPDATA '@lineardesktop-updater'","Remove-Item $updaterCache -Recurse -Force -ErrorAction SilentlyContinue"],"uninstaller":{"script":"if ($cmd -eq 'uninstall') { Remove-Item (Join-Path $env:LOCALAPPDATA '@lineardesktop-updater') -Recurse -Force -ErrorAction SilentlyContinue }"},"shortcuts":[["Linear.exe","Linear"]],"checkver":{"script":["Add-Type -AssemblyName System.Net.Http","$client = [System.Net.Http.HttpClient]::new()","$request = [System.Net.Http.HttpRequestMessage]::new([System.Net.Http.HttpMethod]::Head, 'https://releases.linear.app/windows')","try {","    $response = $client.SendAsync($request).GetAwaiter().GetResult()","    $response.Content.Headers.ContentDisposition.FileName","} finally {","    if ($response) { $response.Dispose() }","    $request.Dispose()","    $client.Dispose()","}"],"regex":"Linear Setup ([\\d.]+)\\.exe"},"autoupdate":{"architecture":{"64bit":{"url":"https://releases.linear.app/windows#/Linear-Setup-$version.exe"}},"hash":{"mode":"download"}},"from":"https://github.com/Arama0517/scoop-bucket"}
