{"version":"1.31.0","description":"Linear desktop app for issue tracking and project planning.","homepage":"https://linear.app","license":{"identifier":"Proprietary","url":"https://linear.app/terms"},"architecture":{"64bit":{"url":"https://releases.linear.app/windows#/Linear-Setup-1.31.0.exe","hash":"928310526e6e6c67417f4e3a615773b456a8c39f10c0ae3da581aacecefdc0c0"}},"installer":{"args":["/S","/D=$dir"]},"post_install":["# Disable built-in updates so Scoop remains the update manager.","$yaml = \"$dir\\resources\\app-update.yml\"","if (Test-Path $yaml) {","    $content = Get-Content $yaml -Encoding ASCII | ForEach-Object {","        if ($_.StartsWith('url')) { \"$($_.Replace('url', '# url')) # Disabled by Scoop\" } else { $_ }","    }","    Set-Content $yaml -Value $content -Encoding ASCII","}","# Linear hardcodes its updater feed in app.asar via autoUpdater.setFeedURL(...).","$asar = \"$dir\\resources\\app.asar\"","$oldFeed = 'https://releases.linear.app/'","$disabledFeed = 'http://127.0.0.1:9/disabled0'","if ($oldFeed.Length -ne $disabledFeed.Length) { throw 'Linear updater feed patch length mismatch' }","if (Test-Path $asar) {","    $oldBytes = [System.Text.Encoding]::UTF8.GetBytes($oldFeed)","    $newBytes = [System.Text.Encoding]::UTF8.GetBytes($disabledFeed)","    $bytes = [System.IO.File]::ReadAllBytes($asar)","    $patched = $false","    for ($i = 0; $i -le ($bytes.Length - $oldBytes.Length); $i++) {","        $matched = $true","        for ($j = 0; $j -lt $oldBytes.Length; $j++) {","            if ($bytes[$i + $j] -ne $oldBytes[$j]) { $matched = $false; break }","        }","        if ($matched) {","            [Array]::Copy($newBytes, 0, $bytes, $i, $newBytes.Length)","            $patched = $true","            $i += $oldBytes.Length - 1","        }","    }","    if ($patched) { [System.IO.File]::WriteAllBytes($asar, $bytes) } else { Write-Host 'Linear updater feed URL not found in app.asar; skipping patch.' }","}","$updaterCache = Join-Path $env:LOCALAPPDATA '@lineardesktop-updater'","Remove-Item $updaterCache -Recurse -Force -ErrorAction SilentlyContinue"],"uninstaller":{"script":"if ($cmd -eq 'uninstall') { Remove-Item (Join-Path $env:LOCALAPPDATA '@lineardesktop-updater') -Recurse -Force -ErrorAction SilentlyContinue }"},"shortcuts":[["Linear.exe","Linear"]],"checkver":{"script":["Add-Type -AssemblyName System.Net.Http","$client = [System.Net.Http.HttpClient]::new()","$request = [System.Net.Http.HttpRequestMessage]::new([System.Net.Http.HttpMethod]::Head, 'https://releases.linear.app/windows')","try {","    $response = $client.SendAsync($request).GetAwaiter().GetResult()","    $response.Content.Headers.ContentDisposition.FileName","} finally {","    if ($response) { $response.Dispose() }","    $request.Dispose()","    $client.Dispose()","}"],"regex":"Linear Setup ([\\d.]+)\\.exe"},"autoupdate":{"architecture":{"64bit":{"url":"https://releases.linear.app/windows#/Linear-Setup-$version.exe"}},"hash":{"mode":"download"}},"from":"https://github.com/CNDY1390/scoop-bucket-cndy"}
