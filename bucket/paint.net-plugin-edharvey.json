{
    "version": "2022-12-24",
    "description": "Collection of paint.net plugins by Ed Harvey",
    "homepage": "https://forums.getpaint.net/topic/18811-ed-harvey-effects-v-50-2022-12-24/",
    "license": "MIT",
    "depends": "extras/paint.net",
    "url": "https://raw.githubusercontent.com/instinctualjealousy/holes/refs/heads/master/mirror/EdHarveyEffects.7z",
    "hash": "203c1133408f16cab71201a3d0ff8093bb6ac605df63714516769164473d6316",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\\EdHarvey\"",
        "New-Item \"$paintdotnet\" -ItemType Directory -Force",
        "Move-Item -Path \"$dir\\*\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\\EdHarvey\"",
            "Remove-Item \"$paintdotnet\" -Force -Recurse"
        ]
    }
}
