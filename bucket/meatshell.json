{
    "version": "0.5.3",
    "description": "A lightweight FinalShell-style SSH/terminal client written in Rust + Slint",
    "homepage": "https://github.com/jeff141/meatshell",
    "license": "MIT OR Apache-2.0",
    "notes": [
        "MeatShell 是基于 Rust + Slint 构建的原生 SSH/SFTP/串口终端客户端",
        "用户数据位置: %LOCALAPPDATA%\\meatshell\\meatshell\\",
        "此软件包通过 Junction 链接持久化 sessions.json、secret.key 和 error.log"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/jeff141/meatshell/releases/download/v0.5.3/meatshell-v0.5.3-windows-x86_64.zip",
            "hash": "cbdf3cd0c2e9e2049280502a864023e443a0a89be1282596aa2c1203bb921d53",
            "extract_dir": "meatshell-v0.5.3-windows-x86_64"
        }
    },
    "bin": "meatshell.exe",
    "shortcuts": [
        [
            "meatshell.exe",
            "MeatShell"
        ]
    ],
    "post_install": [
        "$source = Join-Path $persist_dir 'data'",
        "$target = Join-Path $env:LOCALAPPDATA 'meatshell\\meatshell'",
        "ensure $source",
        "if (Test-Path $target) {",
        "    $item = Get-Item -LiteralPath $target -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host 'Junction already exists: $target'",
        "    } elseif (-not $item.PSIsContainer) {",
        "        throw \"Path exists and is not a directory: $target\"",
        "    } else {",
        "        & robocopy $target $source /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) { throw \"Migration failed: $target\" }",
        "        $backup = \"$target.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        Move-Item -LiteralPath $target -Destination $backup -Force",
        "        Write-Host \"Backed up original: $backup\"",
        "        New-Item -Path $target -ItemType Junction -Value $source -Force | Out-Null",
        "    }",
        "} else {",
        "    $parent = Split-Path $target -Parent",
        "    if (-not (Test-Path $parent)) { New-Item -Path $parent -ItemType Directory -Force | Out-Null }",
        "    New-Item -Path $target -ItemType Junction -Value $source -Force | Out-Null",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$target = Join-Path $env:LOCALAPPDATA 'meatshell\\meatshell'",
            "if (Test-Path $target) {",
            "    $item = Get-Item -LiteralPath $target -Force",
            "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
            "        Remove-Item -LiteralPath $target -Force",
            "    }",
            "}"
        ]
    },
    "persist": "data",
    "checkver": {
        "github": "https://github.com/jeff141/meatshell"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jeff141/meatshell/releases/download/v$version/meatshell-v$version-windows-x86_64.zip",
                "extract_dir": "meatshell-v$version-windows-x86_64"
            }
        }
    }
}
