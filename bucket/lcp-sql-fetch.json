{
    "version": "1.0.1",
    "description": "A tool to execute local SQL scripts on Liferay Cloud via lcp shell.",
    "homepage": "https://github.com/peterrichards-lr/lcp-sql-fetch",
    "license": "MIT",
    "url": "https://github.com/peterrichards-lr/lcp-sql-fetch/archive/refs/tags/v1.0.1.tar.gz",
    "hash": "5901b8e0e3e856eb73da87c577726820e41d692013fd0ff410ecf804121c6f90",
    "extract_dir": "lcp-sql-fetch-1.0.1",
    "depends": "rustup",
    "installer": {
        "script": [
            "Set-Location \"$dir\"",
            "cargo install --path . --root \"$dir\""
        ]
    },
    "bin": "bin/lcp-sql-fetch.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/peterrichards-lr/lcp-sql-fetch/archive/refs/tags/v$version.tar.gz",
        "extract_dir": "lcp-sql-fetch-$version",
        "hash": {
            "url": "$url",
            "mode": "download"
        }
    }
}
