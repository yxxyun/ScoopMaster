{
    "version": "1.2.5",
    "description": "Scoop 下载加速器. 支持将 GitHub、SourceForge、Node.js 的请求重定向至国内高速镜像, 告别下载超时.",
    "homepage": "https://github.com/Arama0517/scoop-url-switcher",
    "url": "https://raw.giteeusercontent.com/arama0517/scoop-url-switcher/raw/v1.2.5/scoop-url-switcher.psm1",
    "hash": "dd235a37b5e4ec764581daf17f915c9d58dff4bca5a5a89115effe1f56f167ea",
    "license": "MIT",
    "notes": [
        "运行以下命令以自动在 Powershell 中导入 scoop-url-switcher:",
        "$dir\\add-profile-content.ps1"
    ],
    "post_install": [
        "Import-Module scoop-url-switcher",
        "$BucketDir = Find-BucketDirectory -Root -Name $bucket",
        "$UtilsPath = $BucketDir | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (Test-Path $UtilsPath) {",
        "    Unblock-File $UtilsPath",
        "    Import-Module $UtilsPath",
        "    New-ProfileModifier -Type ImportModule -Name scoop-url-switcher -BucketDir $BucketDir",
        "    New-ProfileModifier -Type RemoveModule -Name scoop-url-switcher -BucketDir $BucketDir",
        "    Remove-Module ModifyPSProfile -ErrorAction SilentlyContinue",
        "} else {",
        "    throw '缺少文件, 请更新 bucket 并重新安装此应用.'",
        "}"
    ],
    "pre_uninstall": [
        "Remove-Module scoop-url-switcher -ErrorAction SilentlyContinue",
        "$UtilsPath = Find-BucketDirectory -Root -Name $install.bucket | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (($cmd -eq 'uninstall') -and (Test-Path \"$dir\\remove-profile-content.ps1\") -and (Test-Path $UtilsPath)) {",
        "    Unblock-File $UtilsPath",
        "    & \"$dir\\remove-profile-content.ps1\"",
        "}"
    ],
    "psmodule": {
        "name": "scoop-url-switcher"
    },
    "checkver": {
        "github": "https://github.com/Arama0517/scoop-url-switcher"
    },
    "autoupdate": {
        "url": "https://raw.giteeusercontent.com/arama0517/scoop-url-switcher/raw/v$version/scoop-url-switcher.psm1"
    }
}
