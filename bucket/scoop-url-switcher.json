{
    "version": "1.2.3",
    "description": "Scoop 下载加速器. 支持将 GitHub、SourceForge、Node.js 的请求重定向至国内高速镜像, 告别下载超时.",
    "homepage": "https://github.com/Arama0517/scoop-url-switcher",
    "url": [
        "https://gitee.com/arama0517/scoop-url-switcher/releases/download/v1.2.3/scoop-url-switcher.psm1",
        "https://gitee.com/arama0517/scoop-url-switcher/releases/download/v1.2.3/scoop-url-switcher.psd1"
    ],
    "hash": [
        "32bc2e0c48af13f7722347cb9d5598093cc0d7ef956ce12a0f33552fa8dffc61",
        "1d434aa4b58bcfb41fc7897146b1a8dc1a9e899e8f308de1f9d14481a66cd781"
    ],
    "license": "MIT",
    "notes": [
        "运行以下命令以自动在 Powershell 中导入 scoop-url-switcher:",
        "$dir\\add-profile-content.ps1"
    ],
    "pre_install": "if (!(Test-Path \"$bucketsdir\\extras\")) { throw '请先安装 extras bucket: scoop bucket add extras' }",
    "post_install": [
        "Import-Module scoop-url-switcher",
        "$BucketDir = Find-BucketDirectory -Root -Name extras",
        "$UtilsPath = $BucketDir | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (Test-Path $UtilsPath) {",
        "    Unblock-File $UtilsPath",
        "    Import-Module $UtilsPath",
        "    New-ProfileModifier -Type ImportModule -Name scoop-url-switcher -BucketDir $BucketDir",
        "    New-ProfileModifier -Type RemoveModule -Name scoop-url-switcher -BucketDir $BucketDir",
        "    Remove-Module ModifyPSProfile -ErrorAction SilentlyContinue",
        "} else {",
        "    throw '缺少文件, 请更新 scoop bucket 并重新安装此应用.'",
        "}"
    ],
    "pre_uninstall": [
        "Remove-Module scoop-url-switcher -ErrorAction SilentlyContinue",
        "$UtilsPath = Find-BucketDirectory -Root -Name extras | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (($cmd -eq 'uninstall') -and (Test-Path \"$dir\\remove-profile-content.ps1\") -and (Test-Path $UtilsPath)) {",
        "    Unblock-File $UtilsPath",
        "    & \"$dir\\remove-profile-content.ps1\"",
        "}"
    ],
    "psmodule": {
        "name": "scoop-url-switcher"
    },
    "checkver": {
        "github": "https://github.com/Arama0517/scoop-url-switcher"
    },
    "autoupdate": {
        "url": [
            "https://gitee.com/arama0517/scoop-url-switcher/releases/download/v$version/scoop-url-switcher.psm1",
            "https://gitee.com/arama0517/scoop-url-switcher/releases/download/v$version/scoop-url-switcher.psd1"
        ]
    }
}
