{
    "version": "8.6.3.101",
    "description": "百度网盘，百度公司推出的云存储服务",
    "homepage": "https://pan.baidu.com/download",
    "license": "Proprietary",
    "url": "http://issuecdn.baidupcs.com/issue/netdisk/yunguanjia/BaiduNetdisk_8.6.3.101.exe#dl.7z",
    "hash": "36204b3a74bcd4f99212f7f5e91e12152ec403d8546fc7cef7fa636b7a583140",
    "bin": "BaiduNetdisk.exe",
    "shortcuts": [
        [
            "BaiduNetdisk.exe",
            "百度网盘"
        ]
    ],
    "persist": "users",
    "pre_install": [
        "Remove-Item \"$dir\\`$TEMP\" -Force -Recurse",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
        "Remove-Item \"$dir\\AutoUpdate\\Autoupdate.exe\" -Force -Recurse"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Require-Admin",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        ". \"$bucketsdir\\$bucket\\scripts\\baidunetdisk\\uninstall.ps1\""
    ],
    "checkver": {
        "url": "https://pan.baidu.com/disk/cmsdata?do=client",
        "regex": "BaiduNetdisk_(\\d+.\\d+.\\d+.\\d+).exe"
    },
    "autoupdate": {
        "url": "http://issuecdn.baidupcs.com/issue/netdisk/yunguanjia/BaiduNetdisk_$version.exe#dl.7z"
    },
    "notes": "User data is persisted in \"$persist_dir\"."
}
