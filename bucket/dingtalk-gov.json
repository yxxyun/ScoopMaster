{
    "version": "2.31.0-Release.20",
    "description": "浙政钉",
    "homepage": "https://www.ding.zj.gov.cn/pc/index.html",
    "license": {
        "identifier": "EULA"
    },
    "url": "https://gov-cdn-pro.ding.zj.gov.cn/pc/DingTalkGov_v2.31.0-Release.20.exe#/dl.7z",
    "hash": "6ca08d6026de3bd76b99a7e52665d4343984a8ef831af57a6c373f4b4d0b3364",
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Remove-Item \"$dir\\DingTalkGovUpdater.exe\" -Force",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nPersisting $env:APPDATA\\DingTalkGov ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\DingTalkGov\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "$localPaths = @(",
        "    \"$env:APPDATA\\DingTalkGov\"",
        "    \"$env:APPDATA\\utForpc\"",
        "    \"$env:LOCALAPPDATA\\DingTalkGov_91\"",
        "    \"$env:LOCALAPPDATA\\DingTalkGov_108\"",
        ")",
        "$userSID = [System.Security.Principal.WindowsIdentity]::GetCurrent().User.Value",
        "$registryPaths = @(",
        "    'Registry::HKEY_LOCAL_MACHINE\\SOFTWARE\\Wow6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\浙政钉'",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\DingTalk\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\DingTalkGov\"",
        ")",
        "Remove-AppData -LocalPaths $localPaths -RegistryPaths $registryPaths"
    ],
    "shortcuts": [
        [
            "DingTalkGovLauncher.exe",
            "浙政钉"
        ]
    ],
    "checkver": {
        "url": "https://www.ding.zj.gov.cn/pc/index.html",
        "regex": "\"downloadLinkAddress\":\"[^\"]*?DingTalkGov_v(?<version>[\\d.]+-Release\\.\\d+)\\.exe\""
    },
    "autoupdate": {
        "url": "https://gov-cdn-pro.ding.zj.gov.cn/pc/DingTalkGov_v$version.exe#/dl.7z"
    },
    "notes": "User data is persisted in \"$persist_dir\"."
}
