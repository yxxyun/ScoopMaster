{
    "version": "17.14",
    "description": "Microsoft Visual Studio Build Tools 2022",
    "homepage": "https://visualstudio.microsoft.com/downloads/#build-tools-for-visual-studio-2022",
    "license": "https://visualstudio.microsoft.com/license-terms/mlt031519/",
    "url": "https://aka.ms/vs/17/release/vs_BuildTools.exe",
    "hash": "b1f0ca92a41bf111c73718e61fdde1e4fac9dfd18d569a47275d79523d1380e3",
    "installer": {
        "script": [
            "Invoke-ExternalCommand -FilePath \"$dir\\vs_buildtools.exe\" -Args @('--installPath', \"$dir\\vs\\\", '--quiet', '--norestart', '--wait', '--add', 'Microsoft.VisualStudio.Workload.VCTools', '--add', 'Microsoft.VisualStudio.Component.VC.ATL', '--add', 'Microsoft.VisualStudio.Workload.MSBuildTools', '--includeRecommended') -RunAs | Out-Null",
            "$msvcDir = Get-ChildItem \"$dir\\vs\\VC\\Tools\\MSVC\" -Directory | Select-Object -First 1",
            "$msvcBin = Join-Path $msvcDir.FullName 'bin\\Hostx64\\x64'",
            "$wrapperDir = \"$dir\\bin_wrappers\"",
            "New-Item -ItemType Directory -Force -Path $wrapperDir | Out-Null",
            "$tools = @('cl', 'link', 'lib', 'nmake', 'ml64', 'dumpbin', 'editbin')",
            "foreach ($tool in $tools) {",
            "    $cmd = \"@echo off`ncall `\"%~dp0..\\vs\\VC\\Auxiliary\\Build\\vcvars64.bat`\" >nul 2>&1`n`\"$msvcBin\\$tool.exe`\" %*\"",
            "    $cmd | Out-File -FilePath (Join-Path $wrapperDir \"$tool.cmd\") -Encoding ascii",
            "}"
        ]
    },
    "uninstaller": {
        "script": "Invoke-ExternalCommand -FilePath \"$dir\\vs_buildtools.exe\" -Args @('uninstall', '--installPath', \"$dir\\vs\\\", '--quiet', '--norestart', '--wait') -RunAs | Out-Null"
    },
    "env_add_path": [
        "vs\\Common7\\Tools",
        "vs\\Common7\\IDE",
        "vs\\MSBuild\\Current\\bin"
    ],
    "bin": [
        "vs\\Common7\\Tools\\LaunchDevCmd.bat",
        "vs\\Common7\\Tools\\VsDevCmd.bat",
        "vs\\Common7\\Tools\\VsMSBuildCmd.bat",
        "vs\\Common7\\Tools\\Launch-VsDevShell.ps1",
        "bin_wrappers\\cl.cmd",
        "bin_wrappers\\link.cmd",
        "bin_wrappers\\lib.cmd",
        "bin_wrappers\\nmake.cmd",
        "bin_wrappers\\ml64.cmd",
        "bin_wrappers\\dumpbin.cmd",
        "bin_wrappers\\editbin.cmd"
    ],
    "checkver": {
        "url": "https://learn.microsoft.com/en-us/visualstudio/releases/2022/release-notes",
        "regex": "Feature list for <strong>([\\d.]+)</strong>"
    },
    "autoupdate": {
        "url": "https://aka.ms/vs/17/release/vs_BuildTools.exe"
    }
}
