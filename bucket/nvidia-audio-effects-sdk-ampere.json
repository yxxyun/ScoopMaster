    "hash": "731ec874965a5ffe8e1dd1336ffbee98f2d191f241ff63e219041ed9e4d76d7a",
    "installer": {
        "script": [
            "if (-not (is_admin)) { error \"$app requires admin rights to $cmd\"; break }",
            "if ([environment]::OSVersion.Version.Major -lt 10) { error 'This package requires Windows 10/11 to install'; break }",
            "",
            "$success = Invoke-ExternalCommand -Path \"$dir\\setup.exe\" @Args('-s', '-noreboot', '-noeula', '-nofinish', '-clean', \"-log:$dir\\logs\", '-loglevel:4')",
            "if (!$success) { error \"setup.exe failed, check logs at '$dir\\logs'\" ; break }",
            "Remove-Item \"$dir\\logs\" -Force -Recurse"
        ]
    },
    "uninstaller": {
        "script": [
            "if ($cmd -ne 'uninstall') { return }",
            "$exe = 'C:\\Windows\\SysWOW64\\RunDll32.EXE'",
            "$args = @('\"C:\\Program Files\\NVIDIA Corporation\\Installer2\\InstallerCore\\NVI2.DLL\",UninstallPackage', 'AudioEffects', '-silent', '-n', '-deviceinitiated')",
            "Invoke-ExternalCommand $exe -ArgumentList $args -RunAs"
        ]
    },
    "checkver": {
        "regex": "data-href=.*?(?<date>\\d{4}-\\d{2}-\\d{2}).*?v([\\d.]+)-GA_Ampere\\.exe"
    },
    "autoupdate": {
        "url": "https://international.download.nvidia.com/Windows/broadcast/sdk/AFX/$matchDate_NVIDIA_AFX_SDK_Win_v$version-GA_Ampere.exe#/nvidia_afx_sdk_ampere.7z"
    }
