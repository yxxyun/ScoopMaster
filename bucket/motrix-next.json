{
    "version": "3.6.3",
    "description": "Full-featured download manager rebuilt with Tauri 2 and aria2 sidecar",
    "homepage": "https://github.com/AnInsomniacy/motrix-next",
    "license": "MIT",
    "notes": [
        "源码与 Tauri 配置确认核心数据目录：%APPDATA%\\com.motrix.next\\",
        "  - config.json：前端偏好设置（主题、语言、目录历史、托盘/窗口选项等）",
        "  - system.json：aria2 运行参数快照（端口、代理、BT/HTTP 设置等）",
        "  - user.json：Rust 侧用户配置 store",
        "  - history.db（以及 -wal / -shm）：已完成/失败任务历史",
        "  - download.session：aria2 活动/暂停任务会话",
        "源码与 Tauri 配置确认日志目录：%LOCALAPPDATA%\\com.motrix.next\\logs\\motrix-next.log",
        "安装目录内的 binaries\\aria2.conf 与 motrixnext-aria2c.exe 属于程序资源/sidecar，不是用户数据，不纳入 Scoop persist",
        "Scoop 采用解包安装；magnet/thunder 协议、.torrent/.metalink 文件关联和应用内自更新链路不会由 bucket 接管，建议通过 scoop update motrix-next 更新",
        "本包会将上述核心数据目录和日志目录持久化到 Scoop persist，并在原路径创建 Junction"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.6.3/MotrixNext_3.6.3_x64-setup.exe#/dl.7z",
            "hash": "ad413a2857bba08aceaba3346db63a52b21bdd81e63359ac6e1f343c35ce481b"
        },
        "arm64": {
            "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v3.6.3/MotrixNext_3.6.3_arm64-setup.exe#/dl.7z",
            "hash": "9271cd5b5f76dd8ef431df10aaa24f1f88429fdbe3eec27be857d2d8acdfe4a9"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": [
        [
            "motrix-next.exe",
            "motrix-next"
        ]
    ],
    "shortcuts": [
        [
            "motrix-next.exe",
            "Motrix Next"
        ]
    ],
    "post_install": [
        "$ensureJunction = {",
        "    param([string]$Source, [string]$Target)",
        "    ensure $Target",
        "    $parent = Split-Path $Source -Parent",
        "    if ($parent) {",
        "        New-Item -ItemType Directory -Path $parent -Force | Out-Null",
        "    }",
        "",
        "    if (Test-Path $Source) {",
        "        $item = Get-Item -LiteralPath $Source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$Source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$Source\"",
        "        }",
        "",
        "        & robocopy $Source $Target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$Source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$Source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $Source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$Source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $Source -ItemType Junction -Value $Target | Out-Null",
        "}",
        "",
        "$dataSource = Join-Path $env:APPDATA 'com.motrix.next'",
        "$logsSource = Join-Path (Join-Path $env:LOCALAPPDATA 'com.motrix.next') 'logs'",
        "& $ensureJunction $dataSource (Join-Path $persist_dir 'data')",
        "& $ensureJunction $logsSource (Join-Path $persist_dir 'logs')"
    ],
    "post_uninstall": [
        "$paths = @(",
        "    (Join-Path $env:APPDATA 'com.motrix.next'),",
        "    (Join-Path (Join-Path $env:LOCALAPPDATA 'com.motrix.next') 'logs')",
        ")",
        "foreach ($path in $paths) {",
        "    if (Test-Path $path) {",
        "        $item = Get-Item -LiteralPath $path -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Remove-Item -LiteralPath $path -Force",
        "        }",
        "    }",
        "}"
    ],
    "persist": [
        "data",
        "logs"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/AnInsomniacy/motrix-next/releases/download/v$version/MotrixNext_$version_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
