        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninst*\" -Force -Recurse",
    "installer": {
        "script": [
            "ensure \"$persist_dir\" | Out-Null",
            "$targetPath = \"$env:APPDATA\\com.motrix.next\"",
            "$linkType = (Get-Item -Path $targetPath -ErrorAction SilentlyContinue).LinkType",
            "if (Test-Path $targetPath) {",
            "    if ($linkType -eq 'Junction') {",
            "        Remove-Item -Path $targetPath -Force",
            "    } else {",
            "        Get-ChildItem -Path $targetPath -Force | Move-Item -Destination $persist_dir -Force",
            "        Remove-Item -Path $targetPath -Force -Recurse",
            "    }",
            "}",
            "New-Item \"$env:APPDATA\\com.motrix.next\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
        ]
    },
    "uninstaller": {
        "script": [
            "Remove-Item \"$env:APPDATA\\com.motrix.next\" -Recurse -Force -ErrorAction 'SilentlyContinue'",
            "Remove-Item \"$env:LOCALAPPDATA\\com.motrix.next\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
        ]
    },
    "shortcuts": [
        [
            "motrix-next.exe",
            "Motrix Next"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
