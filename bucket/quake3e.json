   if ($sameDrive) { New-Item -ItemType HardLink -Path $dst -Target $src | Out-Null }","      else { New-Item -ItemType SymbolicLink -Path $dst -Target $src | Out-Null }","    } catch { Copy-Item $src $dst -Force }","  }","  Write-Host ('Linked {0} binaries into: {1}' -f $names.Count, $target) -ForegroundColor Green","  Write-Host 'Note: Symlinks across drives may need Developer Mode/admin; fallback is copy.' -ForegroundColor DarkGray","  $menuDir = Join-Path ([Environment]::GetFolderPath('ApplicationData')) 'Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps'","  if (!(Test-Path $menuDir)) { New-Item -ItemType Directory -Path $menuDir -Force | Out-Null }","  $shortcutPath = Join-Path $menuDir 'Quake3e.lnk'","  $targetExe = @('quake3e.x64.exe','quake3e.exe') | ForEach-Object { Join-Path $target $_ } | Where-Object { Test-Path $_ } | Select-Object -First 1","  if ($targetExe) {","    $shell = New-Object -ComObject WScript.Shell","    $shortcut = $shell.CreateShortcut($shortcutPath)","    $shortcut.TargetPath = $targetExe","    $shortcut.WorkingDirectory = $target","    $shortcut.IconLocation = $targetExe","    $shortcut.Save()","    Write-Host ('Created Start Menu shortcut: {0}' -f $shortcutPath) -ForegroundColor Green","  }","}"],"pre_uninstall":["$menuDir = Join-Path ([Environment]::GetFolderPath('ApplicationData')) 'Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps'","$shortcutPath = Join-Path $menuDir 'Quake3e.lnk'","if (Test-Path $shortcutPath) { try { Remove-Item $shortcutPath -Force } catch {} }","$cfgDir = Join-Path $persist_dir 'config'","$cfg = Join-Path $cfgDir 'link_target.txt'","$legacyCfg = Join-Path $persist_dir 'link_target.txt'","if (!(Test-Path $cfg -PathType Leaf) -and (Test-Path $legacyCfg -PathType Leaf)) {","  $cfg = $legacyCfg","}","if (Test-Path $cfg -PathType Leaf) {","  $target = (Get-Content $cfg -Raw).Trim()","  if (Test-Path $target) {","    $names = @(","      'quake3e.exe','quake3e-vulkan.exe','quake3e.ded.exe',","      'quake3e.x6