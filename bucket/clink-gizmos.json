{
    "##": "Maifest based on github.com/gigberg/localbucket/blob/main/bucket/clink-gizmos.json",
    "version": "0.2026.07.11",
    "homepage": "https://github.com/chrisant996/clink-gizmos",
    "description": "A library of Lua scripts for use with Clink",
    "license": "MIT",
    "depends": "clink",
    "url": "https://github.com/chrisant996/clink-gizmos/archive/13f9e0c35ae93df6d1cbe2b0ecd0c5d28f80fcbb.zip",
    "hash": "3315eae6730ab8f19a91ec05197f1f5e1eb1984e38557d16d2521af6ab8f7a8a",
    "extract_dir": "clink-gizmos-13f9e0c35ae93df6d1cbe2b0ecd0c5d28f80fcbb",
    "installer": {
        "script": [
            "$luapath = Join-Path (Split-Path -Path \"$dir\" -Parent) \"current\"",
            "if (Get-Command clink -ErrorAction SilentlyContinue) {",
            "   clink installscripts \"$luapath\"",
            "} elseif ($Env:CMDER_ROOT) {",
            "   & \"$Env:CMDER_ROOT\\vendor\\clink\\clink.bat\" installscripts \"$luapath\"",
            "} else {",
            "   warn 'Clink or Cmder installation not found. Please manually install these scripts.'",
            "}"
        ]
    },
    "uninstaller": {
        "script": [
            "$luapath = Join-Path (Split-Path -Path \"$dir\" -Parent) \"current\"",
            "if (Get-Command clink -ErrorAction SilentlyContinue) {",
            "   clink uninstallscripts \"$luapath\"",
            "} elseif ($Env:CMDER_ROOT) {",
            "   & \"$Env:CMDER_ROOT\\vendor\\clink\\clink.bat\" uninstallscripts \"$luapath\"",
            "}"
        ]
    },
    "checkver": {
        "url": "https://github.com/chrisant996/clink-gizmos/commits/main.atom",
        "regex": "(?s)>(\\d+)-(\\d+)-(\\d+)T.*?/(?<sha>[0-9a-f]{40})",
        "replace": "0.${1}.${2}.${3}"
    },
    "autoupdate": {
        "url": "https://github.com/chrisant996/clink-gizmos/archive/$matchSha.zip",
        "extract_dir": "clink-gizmos-$matchSha"
    }
}
