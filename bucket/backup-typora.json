{"version":"0.11.18","description":"Typora. A truly minimal markdown editor.","homepage":"https://typora.io","license":{"identifier":"Proprietary","url":"https://support.typora.io/License-Agreement/"},"notes":["1.第一次运行跳出弹窗后","2.打开注册表，找到'HKEY_CURRENT_USER\\SOFTWARE\\Typora'","3.设置过期日期","4.右击—>权限, 把所有用户的权限都设为拒绝"],"post_install":["if ((Test-Path \"$HOME\\AppData\\Roaming\\Typora\")) {","    info '[backup-typora] delete existing profiles...'","    Remove-Item -Path \"$HOME\\AppData\\Roaming\\Typora\" -Recurse","}","mkdir \"$persist_dir\"","New-Item -ItemType Junction -Path \"$HOME\\AppData\\Roaming\\Typora\" -Target \"$persist_dir\""],"architecture":{"64bit":{"url":"http://10.67.238.213:81/typora-update-x64-1117.exe","hash":"51ddc37ddac94eeb0d92d0fef6fea02cf9339628472c9ddf7c3e13a7694be738"}},"innosetup":true,"bin":"Typora.exe","shortcuts":[["Typora.exe","Typora"]],"from":"https://github.com/tom-temp/backup-scoop"}
