            "hash": "2d2fecec6d8296bf3428f1cf875d9d12dd69aad10a70c0a234d9553f4c9bb57a",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
