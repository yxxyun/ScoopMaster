{
    "version": "6.18.30",
    "description": "Rolling Release LTS Real-Time Kernel Addon Packages (Modules, Headers, Docs) for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS",
    "license": "GPL-2.0",
    "notes": "This kernel addon package require WSL v2.5.1 or later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.30/bzImage-x86_64-rt-addon.vhdx.7z",
            "hash": "21f8fb7c7f33abbf950587e82ddaf0402786cd462b51a1ec3010a5536a008e23",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
                "$kernel_addon_file = \"$original_dir\\bzImage-x86_64-rt-addon.vhdx\"",
                "SetVhdxAcl -Path $kernel_addon_file",
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_addon_path = $kernel_addon_file -replace \"\\\\\", \"\\\\\"",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.30/Image-arm64-rt-addon.vhdx.7z",
            "hash": "c53907c1c2b2d0bf0dcace4d5b1f41a3bf056c2ecbc676b071817a94e8b11e0e",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
                "$kernel_addon_file = \"$original_dir\\Image-arm64-rt-addon.vhdx\"",
                "SetVhdxAcl -Path $kernel_addon_file",
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_addon_path = $kernel_addon_file -replace \"\\\\\", \"\\\\\"",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/latest",
        "regex": "linux-wsl-lts-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-$version/bzImage-x86_64-rt-addon.vhdx.7z"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-$version/Image-arm64-rt-addon.vhdx.7z"
