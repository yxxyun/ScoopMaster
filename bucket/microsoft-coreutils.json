            "hash": "9e789d8f6de41e3cf9d659c976232f6ca88f3008f25dd540f65dbebadae21fab"
        }
    },
    "innosetup": true,
    "pre_install": [
        "$coreutils = Join-Path $dir 'coreutils.exe'",
        "$bin = Join-Path $dir 'bin'",
        "$cmd = Join-Path $dir 'cmd'",
        "New-Item -ItemType Directory -Path $bin, $cmd -Force | Out-Null",
        "$names = & $coreutils --list | Where-Object { $_ -and $_ -ne '[' }",
        "foreach ($name in $names) {",
        "    New-Item -ItemType HardLink -Path (Join-Path $bin \"$name.exe\") -Target $coreutils -Force | Out-Null",
        "    New-Item -ItemType HardLink -Path (Join-Path $cmd \"$name.cmd\") -Target $coreutils -Force | Out-Null",
        "}"
    ],
