{
    "version": "2026.5.29",
    "description": "UNIX-style core utilities for Windows (Microsoft-maintained build of uutils/coreutils, findutils, and grep)",
    "homepage": "https://github.com/microsoft/coreutils",
    "license": "MIT",
    "notes": [
        "This project is in preview. See shell conflicts: https://github.com/microsoft/coreutils#shell-conflicts",
        "PowerShell 7.4+ is required for glob/quoting integration. To enable it, run:",
        "  pwsh -NoProfile -ExecutionPolicy Bypass -File \"$dir\\pwsh-install.ps1\" -Action Install -Scope CurrentUser -CmdDir \"$dir\\cmd\"",
        "To remove PowerShell integration:",
        "  pwsh -NoProfile -ExecutionPolicy Bypass -File \"$dir\\pwsh-install.ps1\" -Action Uninstall"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/microsoft/coreutils/releases/download/v2026.5.29/coreutils-2026.5.29-x64.exe",
            "hash": "23b019d0664f1f5aa2a0c503435f8b52d3c8eea2aec1c0609ce21fce18667281"
        },
        "arm64": {
