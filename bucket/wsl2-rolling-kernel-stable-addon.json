{
    "version": "7.0.3",
    "description": "Rolling Release Stable Kernel Addon Packages (Modules, Headers, Docs) for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "notes": "This kernel addon package require WSL v2.5.1 or later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.0.3/bzImage-x86_64-addon.vhdx.7z",
            "hash": "d489d0d1ee9f86e7721d8051c032f0c1c8fbd11235d56c9e8c998dc9606c9ac0",
            "post_install": [
                "##########################################################",
                "# Set WSL2 rolling kernel addon packages in `.wslconfig` #",
                "#             Channel: STABLE | Arch: x86_64             #",
                "##########################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageInstall -UsingNamespace System.Text",
                "$kernel_addon_path=\"$original_dir\\bzImage-x86_64-addon.vhdx\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "#############################################################",
                "# Remove WSL2 rolling kernel addon packages in `.wslconfig` #",
                "#############################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.0.3/Image-arm64-addon.vhdx.7z",
            "hash": "2b4e4474543e57e0404d26322c80f8482fab27010f9b56946eac0bf3e399aea7",
            "post_install": [
                "##########################################################",
                "# Set WSL2 rolling kernel addon packages in `.wslconfig` #",
                "#              Channel: STABLE | Arch: arm64             #",
                "##########################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageInstall -UsingNamespace System.Text",
                "$kernel_addon_path=\"$original_dir\\Image-arm64-addon.vhdx\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "#############################################################",
                "# Remove WSL2 rolling kernel addon packages in `.wslconfig` #",
                "#############################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64-addon.vhdx.7z"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64-addon.vhdx.7z"
            }
        }
    }
}
