{
    "version": "7.1.3",
    "description": "Rolling Release Stable Kernel Addon Packages (Modules, Headers, Docs) for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "notes": "This kernel addon package require WSL v2.5.1 or later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.1.3/bzImage-x86_64-addon.vhdx.7z",
            "hash": "f8674d2ed2f6163344f61adf07c3b976c9a3f3b16bf67d8c0bb8618512d3d527",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
                "$kernel_addon_file = \"$original_dir\\bzImage-x86_64-addon.vhdx\"",
                "SetVhdxAcl -Path $kernel_addon_file",
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_addon_path = $kernel_addon_file -replace \"\\\\\", \"\\\\\"",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.1.3/Image-arm64-addon.vhdx.7z",
            "hash": "f4679b937287e6070de3e1dbb0c729e55b5ee3a7a77385edca42d956ab7e94d6",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
                "$kernel_addon_file = \"$original_dir\\Image-arm64-addon.vhdx\"",
                "SetVhdxAcl -Path $kernel_addon_file",
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_addon_path = $kernel_addon_file -replace \"\\\\\", \"\\\\\"",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64-addon.vhdx.7z"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64-addon.vhdx.7z"
            }
        }
    }
}
