{
    "##": "ltguillaume/schep",
    "version": "1.1.0",
    "description": "A complete Getting Things Done (GTD) productivity system for desktop and mobile. Portable.",
    "homepage": "https://github.com/dongdongbh/Mindwtr",
    "license": "AGPL-3.0-only",
    "notes": "In case the window does not open, you may have to install extras/webview2.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/dongdongbh/Mindwtr/releases/download/v1.1.0/mindwtr_1.1.0_windows_x64_portable.zip",
            "hash": "13071abfe2cfcb56210f661842161e5d17857431a596e12469a88d5a0d422420"
        }
    },
    "pre_install": [
        "$data = '{
\"settings\": {
\"analytics\": {
\"heartbeatEnabled\": false
}
}
}'",
        "Set-Content -Path \"$dir\\profile\\data\\data.json\" -Value $data"
    ],
    "bin": "mindwtr.exe",
    "shortcuts": [
        [
            "mindwtr.exe",
            "Mindwtr"
        ]
    ],
    "post_uninstall": "Remove-Item \"$Env:LocalAppData\\tech.dongdongbh.mindwtr\" -Force -Recurse 2>$null",
    "persist": "profile",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dongdongbh/Mindwtr/releases/download/v$version/mindwtr_$version_windows_x64_portable.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHA256SUMS",
            "regex": "$sha256\\s+$basename"
        }
    }
}
