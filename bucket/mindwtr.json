{
    "##": "ltguillaume/schep",
    "version": "1.0.5",
    "description": "A complete Getting Things Done (GTD) productivity system for desktop and mobile. Portable.",
    "homepage": "https://github.com/dongdongbh/Mindwtr",
    "license": "AGPL-3.0-only",
    "notes": "In case the window does not open, you may have to install extras/webview2.",
    "architecture": {
        "64bit": {
            "url": "https://github.com/dongdongbh/Mindwtr/releases/download/v1.0.5/mindwtr_1.0.5_windows_x64_portable.zip",
            "hash": "4b640d3d3bcd7ab250a503608484444e3e6dbef6dd5461a26ecfecc995e89d9b"
        }
    },
    "pre_install": [
        "$data = '{\n\"settings\": {\n\"analytics\": {\n\"heartbeatEnabled\": false\n}\n}\n}'",
        "Set-Content -Path \"$dir\\profile\\data\\data.json\" -Value $data"
    ],
    "bin": "mindwtr.exe",
    "shortcuts": [
        [
            "mindwtr.exe",
            "Mindwtr"
        ]
    ],
    "post_uninstall": [
        "Remove-Item \"$Env:LocalAppData\\tech.dongdongbh.mindwtr\" -Force -Recurse 2>$null"
    ],
    "persist": "profile",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/dongdongbh/Mindwtr/releases/download/v$version/mindwtr_$version_windows_x64_portable.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHA256SUMS",
            "regex": "$sha256\\s+$basename"
        }
    }
}
