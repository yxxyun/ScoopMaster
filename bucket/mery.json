{
    "version": "3.8.7",
    "description": "A free Japanese text editor for Windows.",
    "homepage": "https://www.haijin-boys.com/wiki/",
    "license": "zlib",
    "architecture": {
        "64bit": {
            "url": "http://www.haijin-boys.com/download/MeryPortable-x64-3.8.7.zip",
            "hash": "41aedda0593c2a98254586c12689dbf8ace3064bf8d9d7803dedae9f3124a4de"
        }
    },
    "extract_dir": "Mery",
    "pre_install": [
        "$manifest.persist | ForEach-Object {",
        "    if (-not (Test-Path \"$persist_dir\\$_\")) { New-Item \"$dir\\$_\" -ItemType file | Out-Null }",
        "}"
    ],
    "bin": "Mery.exe",
    "shortcuts": [
        [
            "Mery.exe",
            "Mery"
        ]
    ],
    "persist": [
        "Mery.ini",
        "Mery.his"
    ],
    "checkver": {
        "url": "https://www.haijin-boys.com/software/mery",
        "regex": "Mery.*(?:Ver |v)([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "http://www.haijin-boys.com/download/MeryPortable-x64-$version.zip"
            }
        }
    }
}
