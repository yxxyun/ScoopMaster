{
    "version": "20231025",
    "description": "AutoHotKey script to turn screen on and off with keyboard shortcut.",
    "homepage": "https://github.com/ArturTkaczuk/toggle-screen-autohotkey",
    "license": "MIT",
    "suggest": {
        "AutoHotkey 1.1": "Versions/autohotkey1.1"
    },
    "notes": [
        "Start Toggle screen with Windows by running:",
        "reg import \"$dir\\add-startup.reg\""
    ],
    "url": "https://github.com/ArturTkaczuk/toggle-screen-autohotkey/archive/main.zip",
    "hash": "93130CD101A9770EC1130B82C986F30757D316790D82E37AF1534E5A33B92CBB",
    "extract_dir": "toggle-screen-autohotkey-main",
    "pre_install": "& \"$env:SCOOP\\apps\\autohotkey1.1\\current\\Compiler\\Ahk2Exe.exe\" /in \"$dir\\Toggle screen.ahk\" /out \"$dir\\Toggle screen.exe\"",
    "post_install": [
        "$shortcutPath = \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Toggle screen.lnk\"",
        "$targetPath = \"$dir\\Toggle screen.exe\"",
        "$WshShell = New-Object -ComObject WScript.Shell",
        "$Shortcut = $WshShell.CreateShortcut($shortcutPath)",
        "$Shortcut.TargetPath = $targetPath",
        "$Shortcut.WorkingDirectory = $dir",
        "$Shortcut.Save()",
        "$dirpath = $dir.Replace('\\', '\\\\')",
        "'add-startup.reg', 'remove-startup.reg' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\shovel\\scripts\\$app\\$_\") {",
        "        $content = Get-Content \"$bucketsdir\\shovel\\scripts\\$app\\$_\"",
        "        $content = $content.Replace('$dir', $dirpath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content -Path \"$dir\\$_\"",
        "    }",
        "}"
    ],
    "post_uninstall": [
        "Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Toggle screen.lnk\" -ErrorAction SilentlyContinue",
        "if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/ArturTkaczuk/toggle-screen-autohotkey/commits?per_page=1",
        "jsonpath": "$[0].commit.author.date",
        "regex": "(\\d{4})-(\\d{2})-(\\d{2}).*",
        "replace": "$1$2$3"
    },
    "autoupdate": {
        "url": "https://github.com/ArturTkaczuk/toggle-screen-autohotkey/archive/main.zip"
    }
}
