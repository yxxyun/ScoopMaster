{
    "version": "4.0.3",
    "description": "A paint.net effect that provides integration with G'MIC-Qt",
    "homepage": "https://github.com/0xC0000054/pdn-gmic",
    "license": "GPL-3.0-only",
    "depends": "extras/paint.net",
    "url": "https://github.com/0xC0000054/pdn-gmic/releases/download/v4.0.3/Gmic_win64.zip",
    "hash": "49bf29c3c3a3ccf676e4e902829d984eb30611b69256fc73bf280619811c1ff5",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\\G'MIC\"",
        "New-Item \"$paintdotnet\" -ItemType Directory -Force",
        "Move-Item -Path \"$dir\\*\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\\G'MIC\"",
            "Remove-Item \"$paintdotnet\" -Force -Recurse"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/0xC0000054/pdn-gmic/releases/download/v$version/Gmic_win64.zip"
    }
}
