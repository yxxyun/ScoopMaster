    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\\G'MIC\"",
            "Remove-Item \"$paintdotnet\" -Force -Recurse"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/0xC0000054/pdn-gmic/releases/download/v$version/Gmic_win64.zip"
    }
