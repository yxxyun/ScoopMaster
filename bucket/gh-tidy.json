{
    "version": "20260430",
    "description": "Github CLI extension for cleaning up your Git workspace to get ready for the day!",
    "homepage": "https://github.com/HaywardMorihara/gh-tidy",
    "license": "Unlicense",
    "suggest": {
        "Git": "main/git"
    },
    "notes": [
        "It must be used inside a Bash/Zsh session,",
        "The easiest Windows option is Git Bash.",
        "(Experimental) To keep the right tools first, add these to the TOP of your System PATH",
        "  $env:SCOOP\\apps\\git\\current\\bin",
        "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "url": "https://github.com/HaywardMorihara/gh-tidy/archive/main.zip",
    "hash": "1edd6a0873748a1b471cc52e11b9fc60e30d92f434964ae869204a0188a703bf",
    "extract_dir": "gh-tidy-main",
    "pre_install": [
        "Remove-Item -Path \"$dir\\*\" -Exclude 'gh-tidy', 'LICENSE' -Recurse -Force",
        "New-Item -Path \"$dir\\gh-tidy.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\gh-tidy.cmd\" -Value \"bash $env:SCOOP\\apps\\gh-tidy\\current\\gh-tidy %*\""
    ],
    "bin": "gh-tidy.cmd",
    "checkver": {
        "url": "https://api.github.com/repos/HaywardMorihara/gh-tidy/commits?per_page=1",
        "jsonpath": "$[0].commit.author.date",
        "regex": "(\\d{4})-(\\d{2})-(\\d{2}).*",
        "replace": "$1$2$3"
    },
    "autoupdate": {
        "url": "https://github.com/HaywardMorihara/gh-tidy/archive/main.zip"
    }
}
