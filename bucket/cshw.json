{"version":"1.0.6.3","description":"cshw -- C Shell for Windows. A modern, single-binary csh-compatible shell with a full POSIX bc/dc, opt-in exact-rational tier, and complex-number arithmetic.","homepage":"https://github.com/tropibyte/CSHW","license":{"identifier":"PolyForm-Small-Business-1.0.0","url":"https://polyformproject.org/licenses/small-business/1.0.0"},"notes":["cshw installs to %ProgramFiles%\\Tropibyte\\cshw and the installer adds that directory to PATH.","Open a new shell after install so the updated PATH takes effect, then type `cshw` to launch."],"architecture":{"64bit":{"url":"https://github.com/tropibyte/cshw-releases/releases/download/v1.0.6.3/cshw-setup-1.0.6.3.exe","hash":"10c7fa461cbef0cc366cee0302af064a31a8071fa4c3e003c814326287d1cb4f"}},"installer":{"script":["$installer = \"$dir\\cshw-setup-1.0.6.3.exe\"","Start-Process -Wait -FilePath $installer -ArgumentList @('/VERYSILENT', '/SUPPRESSMSGBOXES', '/NORESTART')"]},"uninstaller":{"script":["$installDir = Join-Path $env:ProgramFiles 'Tropibyte\\cshw'","if (Test-Path $installDir) {","    $uninstaller = Get-ChildItem -Path $installDir -Filter 'unins*.exe' -ErrorAction SilentlyContinue | Select-Object -First 1","    if ($uninstaller) {","        Start-Process -Wait -FilePath $uninstaller.FullName -ArgumentList @('/VERYSILENT', '/SUPPRESSMSGBOXES', '/NORESTART')","    }","}"]},"checkver":{"github":"https://github.com/tropibyte/cshw-releases"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/tropibyte/cshw-releases/releases/download/v$version/cshw-setup-$version.exe"}},"installer":{"script":["$installer = \"$dir\\cshw-setup-$version.exe\"","Start-Process -Wait -FilePath $installer -ArgumentList @('/VERYSILENT', '/SUPPRESSMSGBOXES', '/NORESTART')"]}},"from":"https://github.com/tropibyte/scoop-cshw"}
