{
    "version": "14.0.02",
    "description": "Steam 商店与社区加速工具",
    "homepage": "https://www.dogfight360.com/blog/18682/",
    "license": "Freeware",
    "url": "https://www.dogfight360.com/blog/wp-content/uploads/2026/02/steamcommunity_302_AMD64_V14.0.02.zip",
    "hash": "d911105fbf56a6cfcf0322e3feeb97a65a005bb9bfb2021aade45e8a11f9a8e8",
    "extract_dir": "Steamcommunity_302",
    "post_install": "Get-ChildItem $persist_dir -File | ForEach-Object { Copy-Item $_.FullName (Join-Path $dir $_.Name) -Force }",
    "pre_uninstall": [
        "if ((Get-Process -Name 'Steamcommunity_302' -ErrorAction SilentlyContinue) -or (Get-Process -Name 'steamcommunity_302.cli' -ErrorAction SilentlyContinue) -or (Get-Process -Name 'steamcommunity_302.caddy' -ErrorAction SilentlyContinue)) {",
        "    throw '请先关闭服务和UI再进行卸载.'",
        "}"
    ],
    "uninstaller": {
        "script": [
            "$files = @('pac_user.txt', 'S302.ini', 'S302_rules.ini', 'S302.log', 'dns_blacklist.txt', 'dns_hosts.txt', 'steamcommunity.crt', 'steamcommunity.csr', 'steamcommunity.key', 'steamcommunityCA.crl', 'steamcommunityCA.key', 'steamcommunityCA.pem')",
            "foreach ($f in $files) {",
            "    $src = Join-Path $dir $f",
            "    $dst = Join-Path $persist_dir $f",
            "    if (Test-Path $src -PathType Leaf) { Copy-Item $src $dst -Force }",
            "}"
        ]
    },
    "persist": "None",
    "shortcuts": [["steamcommunity_302.exe", "SteamCommunity 302"]],
    "checkver": {
        "url": "https://www.dogfight360.com/blog/18682",
        "regex": "uploads/(?<date>[\\d/]+)/steamcommunity_302_AMD64_V([\\d.]+).zip"
    },
    "autoupdate": {
        "url": "https://www.dogfight360.com/blog/wp-content/uploads/$matchDate/steamcommunity_302_AMD64_V$version.zip"
    }
}
