            "hash": "ace861f360c6de2babedc1607d0f454b6b09a820dbc8182dc15af927e4df9589"
        },
        "32bit": {
            "url": "https://github.com/astral-sh/uv/releases/download/0.11.21/uv-i686-pc-windows-msvc.zip",
