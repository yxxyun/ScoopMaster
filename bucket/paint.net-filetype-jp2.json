    "hash": "7a33ed4ea2a4ac9ee1328607090aa7176b0eb41198e11807f8f92734d56d71a3",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\"",
        "Move-Item -Path \"$dir\\Jpeg2000Filetype\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\"",
            "Remove-Item \"$paintdotnet\\Jpeg2000Filetype\" -Force -Recurse"
        ]
    },
