{"version":"3.6.0","description":"Lightweight open-source alternative to Logitech Options+ for remapping Logitech HID++ mice","homepage":"https://github.com/TomBadash/Mouser","license":"MIT","notes":["App config: %APPDATA%\\Mouser\\config.json (single file, not managed by Scoop persist to avoid folder name conflict)","App logs: %APPDATA%\\Mouser\\logs\\ (persisted via Junction to Scoop persist)","Update cache: %LOCALAPPDATA%\\Mouser\\updates\\ (temp data, not persisted)","Start-at-login uses HKCU Run registry key; after Scoop install the app auto-detects its path","Must quit Logitech Options+ before launching Mouser (both fight over HID++ access)"],"architecture":{"64bit":{"url":"https://github.com/TomBadash/Mouser/releases/download/v3.6.0/Mouser-Windows.zip","hash":"10bf9be3cbd5a10e130fe7e24cb3375265250d810c50557f7e27b36f00d3c58a","extract_dir":"Mouser"}},"bin":"Mouser.exe","shortcuts":[["Mouser.exe","Mouser"]],"post_install":["$source = Join-Path $env:APPDATA 'Mouser\\logs'","$target = Join-Path $persist_dir 'logs'","ensure $target","","if (Test-Path $source) {","    $item = Get-Item -LiteralPath $source -Force","    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {","        Write-Host \"检测到已存在的联接点：$source，跳过创建\"","        return","    }","    if (-not $item.PSIsContainer) {","        throw \"配置路径已存在且不是目录：$source\"","    }","","    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null","    if ($LASTEXITCODE -gt 7) {","        Write-Host \"迁移失败，保留原目录：$source\"","        return","    }","","    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"","    try {","        Move-Item -LiteralPath $source -Destination $backup -Force","        Write-Host \"已备份原配置目录：$backup\"","    } catch {","        Write-Host \"无法重命名原目录：$source\"","        return","    }","}","","New-Item -Path $source -ItemType Junction -Value $target | Out-Null"],"post_uninstall":["$source = Join-Path $env:APPDATA 'Mouser\\logs'","if (Test-Path $source) {","    $item = Get-Item -LiteralPath $source -Force","    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {","        Remove-Item -LiteralPath $source -Force","    }","}"],"persist":"logs","checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/TomBadash/Mouser/releases/download/v$version/Mouser-Windows.zip","extract_dir":"Mouser"}},"hash":{"mode":"download"}},"from":"https://github.com/maqibg/MQBucket"}
