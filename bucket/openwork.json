{
    "homepage": "https://openwork.software/",
    "version": "0.12.8",
    "description": "An open-source alternative to Claude Cowork, powered by opencode ",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/different-ai/openwork/releases/download/v0.12.8/openwork-desktop-windows-x64.msi",
            "hash": "b5e9f7d9e9b8eaef6c1ac5cd22e6cf8652842e4a57172e3f2f3e321463e25372"
        }
    },
    "extract_dir": "PFiles\\OpenWork",
    "shortcuts": [
        [
            "OpenWork-Dev.exe",
            "openwork (different-ai)"
        ]
    ],
    "post_install": [
        "if (!(Test-Path \"$persist_dir\")) {",
        "    ensure \"$persist_dir\" | Out-Null",
        "}",
        "if (!(Test-Path \"$persist_dir\\data\")) {",
        "    ensure \"$persist_dir\\data\" | Out-Null",
        "}",
        "New-Item $env:AppData\\com.differentai.openwork -ItemType Junction -Target \"$persist_dir\\data\" | Out-Null"
    ],
    "pre_uninstall": [
        "if (Test-Path \"$Env:AppData\\com.differentai.openwork\\*\") {",
        "    Remove-Item $env:APPDATA\\com.differentai.openwork -Force -Recurse",
        "}"
    ],
    "checkver": {
        "url": "https://github.com/different-ai/openwork/releases",
        "regex": "/releases/tag/v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/different-ai/openwork/releases/download/v$version/openwork-desktop-windows-x64.msi"
            }
        }
    }
}
