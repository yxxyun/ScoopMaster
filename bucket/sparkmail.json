{
    "version": "3.29.2.139046",
    "license": "Proprietary",
    "description": "Spark is a cross-platform email client designed to filter out the noise and help you focus on what's important",
    "homepage": "https://www.sparkmailapp.com/",
    "architecture": {
        "64bit": {
            "url": "https://downloads.sparkmailapp.com/Spark3/win/dist/3.29.2.139046/Spark.exe",
            "hash": "16f32aabbc86fb833d24dd058b6dca06540a6bbb5bd192c9d6f4736733808771",
            "installer": {
                "args": [
                    "/S",
                    "/currentuser"
                ]
            }
        }
    },
    "post_install": [
        "$shortcutPath = \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Spark Mail.lnk\"",
        "$targetPath = \"$env:LOCALAPPDATA\\Programs\\SparkDesktop\\Spark Desktop.exe\"",
        "if (Test-Path $targetPath) {",
        "    $WScriptShell = New-Object -ComObject WScript.Shell",
        "    $shortcut = $WScriptShell.CreateShortcut($shortcutPath)",
        "    $shortcut.TargetPath = $targetPath",
        "    $shortcut.Save()",
        "}"
    ],
    "pre_uninstall": "Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\Spark Mail.lnk\" -ErrorAction SilentlyContinue",
    "uninstaller": {
        "script": "Start-Process -FilePath \"$env:LOCALAPPDATA\\Programs\\SparkDesktop\\Uninstall Spark Desktop.exe\" -ArgumentList '/currentuser', '/S' -Wait"
    },
    "checkver": {
        "url": "https://downloads.sparkmailapp.com/Spark3/win/dist/appcast.xml",
        "regex": "Version ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.sparkmailapp.com/Spark3/win/dist/$version/Spark.exe"
            }
        }
    }
}
