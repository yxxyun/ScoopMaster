    "hash": "72aad99a88121e4555906d987d6c0756489d07d34fd87c2be4db86ccc1832fe7",
    "innosetup": true,
    "shortcuts": [
        [
            "quark.exe",
            "夸克"
        ]
    ],
    "installer": {
        "script": [
            "Move-Item -Path \"$dir\\{code_GetAppExeDestName}\" -Destination \"$dir\\quark.exe\" -Force",
            "Move-Item -Path \"$dir\\{code_GetAppProxyExeDestName}\" -Destination \"$dir\\quark_proxy.exe\" -Force",
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "Write-Host \"`nPersisting $env:LOCALAPPDATA\\Quark ... \" -NoNewline",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\Quark\" \"$persist_dir\\LocalAppData\" -Migrate"
        ]
    },
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nDeleting $env:LOCALAPPDATA\\QuarkUpdater ... \") -f DarkGray -NoNewline",
        "Remove-Item \"$env:LOCALAPPDATA\\QuarkUpdater\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
        "Write-Host (\"`nDeleting $env:LOCALAPPDATA\\QuarkCloudDrive ... \") -f DarkGray -NoNewline",
        "Remove-Item \"$env:LOCALAPPDATA\\QuarkCloudDrive\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
        "Write-Host (\"`nDeleting $env:WINDIR\\system32\\Tasks\\QuarkUpdaterUser ... \") -f DarkGray -NoNewline",
        "Remove-Item \"$env:WINDIR\\system32\\Tasks\\QuarkUpdaterUser\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
        "Write-Host (\"`nDeleting $env:APPDATA\\The Quark Authors ... \") -f DarkGray -NoNewline",
        "Remove-Item \"$env:APPDATA\\The Quark Authors\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
        "Write-Host (\"`nDeleting $env:APPDATA\\Quark ... \") -f DarkGray -NoNewline",
        "Remove-Item \"$env:APPDATA\\Quark\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null",
        "Write-Host (\"`nDeleting $env:LOCALAPPDATA\\Quark ... \") -f DarkGray -NoNewline",
        "Remove-Junction \"$env:LOCALAPPDATA\\Quark\" -ErrorAction SilentlyContinue | Out-Null"
    ],
    "checkver": {
        "script": [
            "$api = 'https://coral2.uc.cn/aggregation/quarkPcDownloadPackage?req_services=%5B%7B%22module%22%3A%22diamond%22%2C%22key%22%3A%22quark-pc-download-package%22%7D%5D&sceneCode=quark-pc-download-package&uc_param_str=dnfrpfbivessbtbmnilauputogpintnwmtsvcppcprsnnnchmicckp'",
            "$entry = 'https://download.quark.cn/download/quarkpc?platform=pc&ch=pcquark@homepage_oficial'",
            "$resolved = (Invoke-WebRequest -Uri $entry -Method Head -MaximumRedirection 5 -UseBasicParsing).BaseResponse.RequestMessage.RequestUri.AbsoluteUri",
            "return $resolved"
        ],
        "regex": "(?<url>https?://.*?/QuarkPC_V([\\d.]+)_pc_pf30002_\\(zh-cn\\)_.*?\\.exe)"
    },
    "autoupdate": {
        "url": "$matchUrl",
        "hash": {
            "mode": "download"
        }
    }
}
