   "checkver": {
      "script": [
         "$baseUrl = 'https://api.github.com/repos/WerWolv/ImHex-Patterns/commits'",
         "(Invoke-RestMethod $baseUrl) | ForEach-Object -Begin { $sha = '' } -Process {",
         "   if ($sha.Length -eq 0) {",
         "      if ((Invoke-RestMethod \"$baseUrl/$($_.sha)/check-suites\").check_suites |",
         "         ForEach-Object -Begin { $result = $true } -Process {",
         "            $result = $result -and $_.conclusion -eq 'success'",
         "         } -End { $result }) {",
         "         $sha = $_.sha",
         "      }",
         "   }",
         "} -End { $sha }"
      ],
      "regex": "(.+)"
   },
   "autoupdate": {
      "url": "https://github.com/WerWolv/ImHex-Patterns/archive/$version.zip",
      "extract_dir": "ImHex-Patterns-$version"
