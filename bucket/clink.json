{
    "version": "1.9.28",
    "description": "Powerful Bash-style command line editing for cmd.exe",
    "homepage": "https://chrisant996.github.io/clink/",
    "license": "GPL-3.0-only",
    "notes": [
        "Run 'clink inject' to start clink on the current cmd",
        "Run 'clink autorun install' to auto start clink"
    ],
    "url": "https://github.com/chrisant996/clink/releases/download/v1.9.28/clink.1.9.28.ae0f63.zip",
    "hash": "451b8f0fcd5efb64fc1e417813c6deb8c51451dc913a009e442657849cc4b946",
    "bin": "clink.bat",
    "installer": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name localbucket) scripts/LocalUtils.psm1)",
            "Mount-ExternalRuntimeData -Source \"$persist_dir\\data\" -Target \"$env:LOCALAPPDATA\\clink\"",
            "Remove-Module -Name LocalUtils"
        ]
    },
    "uninstaller": {
        "script": [
            "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name localbucket) scripts/LocalUtils.psm1)",
            "Dismount-ExternalRuntimeData -Target \"$env:LOCALAPPDATA\\clink\"",
            "Remove-Module -Name LocalUtils"
        ]
    },
    "checkver": {
        "github": "https://github.com/chrisant996/clink",
        "regex": "/v(?<tag>[\\d.]+)/clink\\.([\\d.]+)\\.(?<commit>[\\w.]+)\\.zip"
    },
    "autoupdate": {
        "url": "https://github.com/chrisant996/clink/releases/download/v$matchTag/clink.$version.$matchCommit.zip"
    }
}
