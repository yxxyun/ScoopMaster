    "url": "https://github.com/rime/weasel/releases/download/0.17.4/weasel-0.17.4.0-installer.exe",
    "hash": "cf509534a8f5f8af9c98ed7cbb8f135439f145a8cbe7e50ede42bb5b5ab45c29",
    "persist": "user",
    "architecture": {
        "64bit": {
            "installer": {
                "script": [
                    "# 64-bit files before 32-bit",
                    "Expand-7zipArchive -Path \"$dir\\$fname\" -Overwrite Skip -Removal | Out-Null",
                    "Invoke-ExternalCommand \"$dir\\WeaselSetup.exe\" -ArgumentList '/s'"
                ]
            }
        },
        "32bit": {
            "installer": {
                "script": [
                    "# 32-bit files after 64-bit",
                    "Expand-7zipArchive -Path \"$dir\\$fname\" -Overwrite All -Removal | Out-Null",
                    "Invoke-ExternalCommand \"$dir\\WeaselSetup.exe\" -ArgumentList '/s'"
                ]
            }
        }
    },
    "pre_uninstall": [
        "Invoke-ExternalCommand \"$dir\\WeaselServer.exe\" -ArgumentList '/quit'",
        "Invoke-ExternalCommand \"$dir\\WeaselSetup.exe\" -ArgumentList '/u'"
    ],
    "shortcuts": [
        [
            "WeaselServer.exe",
            "WeaselServer"
        ]
    ],
    "checkver": {
        "github": "https://github.com/rime/weasel"
    },
    "autoupdate": {
        "url": "https://github.com/rime/weasel/releases/download/$matchHead/weasel-$version-installer.exe"
    }
}
