    "license": "MIT,LGPL-2.1-or-later,GPL-2.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zhongfly/mpv-winbuild/releases/download/2026-04-08-e2180e5/mpv-x86_64-v3-20260408-git-e2180e5.7z",
            "hash": "53e06cd410d55273ceee367c6d41a0b99c170d7c27c1d08667d42336861edcf0"
        }
    },
    "suggest": {
        "yt-dlp": "yt-dlp"
