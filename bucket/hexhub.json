{
    "version": "5.1.1",
    "description": "一站式开发运维中枢",
    "homepage": "https://www.hexhub.cn/",
    "license": {
        "identifier": "Proprietary"
    },
    "architecture": {
        "64bit": {
            "url": "https://oss.hexhub.cn/plugin/HexHub-Client-windows-amd64-portable-5.1.1-202605121411.exe#/dl.7z",
            "hash": "f5df91e659b5b0387ba08b39550af5bff7a6d228b0f3cf4c0b55e11d39a87f5b"
        }
    },
    "shortcuts": [
        [
            "HexHub.exe",
            "HexHub"
        ]
    ],
    "extract_dir": "$_0_",
    "persist": ".hexhub",
    "checkver": {
        "script": [
            "$headers = @{",
            "    Origin = 'https://www.hexhub.cn'",
            "    Referer = 'https://www.hexhub.cn/'",
            "}",
            "$json = Invoke-RestMethod 'https://api.hexhub.cn/client/version/latest-non-hot-detail?env=production' -Headers $headers",
            "$item = $json.data.'windows-amd64-portable'",
            "$version = $item.versionName",
            "$url = $item.downloadUrl",
            "Write-Output \"$version|$url\""
        ],
        "regex": "^(?<version>[^|]+)\\|(?<url>.+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchUrl#/dl.7z"
            }
        }
    }
}
