{
    "version": "2.8",
    "description": "Happytime SRT Client – a simple SRT streaming client.",
    "homepage": "https://www.happytimesoft.com/products/srt-client/",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://www.happytimesoft.com/downloads/happytime-srt-client-x64-setup.exe",
            "hash": "eb4ad5030b40743fba60ab3ebb9bc6536cb677b4918c4d0d16786901c97aad14",
            "installer": {
                "script": [
                    "Expand-InnoArchive \"$dir\\happytime-srt-client-x64-setup.exe\" \"$dir\"",
                    "if (!(Test-Path \"$persist_dir\")) { New-Item -Path \"$persist_dir\" -ItemType Directory | Out-Null }",
                    "foreach ($folder in @('snapshot','record')) {",
                    "    $path = Join-Path $persist_dir $folder",
                    "    if (!(Test-Path $path)) { New-Item -Path $path -ItemType Directory | Out-Null }",
                    "}"
                ]
            }
        }
    },
    "shortcuts": [
        [
            "SrtClient.exe",
            "Happytime SRT Client"
        ]
    ],
    "persist": [
        "snapshot",
        "record"
    ],
    "notes": "SRT Client stores its settings at \"HKCU\\SOFTWARE\\happytimesoft\\srtclient\"."
}
