{"version":"2.8","description":"Happytime SRT Client – a simple SRT streaming client","homepage":"https://www.happytimesoft.com/products/srt-client/","license":"Freeware","innosetup":true,"architecture":{"64bit":{"url":"https://www.happytimesoft.com/downloads/happytime-srt-client-x64-setup.exe","hash":"eb4ad5030b40743fba60ab3ebb9bc6536cb677b4918c4d0d16786901c97aad14","installer":{"script":["# --- Binary patch: locate and null out embedded URL string ---","$exe = Join-Path $dir 'SrtClient.exe'","$bytes = [System.IO.File]::ReadAllBytes($exe)","$pattern = [byte[]](0x68,0x74,0x74,0x70,0x73,0x3A,0x2F,0x2F,0x68,0x61,0x70,0x70,0x79,0x74,0x69,0x6D,0x65,0x73,0x6F,0x66,0x74,0x2E,0x63,0x6F,0x6D)","$index = -1","for ($i = 0; $i -le $bytes.Length - $pattern.Length; $i++) {","    $match = $true","    for ($j = 0; $j -lt $pattern.Length; $j++) {","        if ($bytes[$i + $j] -ne $pattern[$j]) { $match = $false; break }","    }","    if ($match) { $index = $i; break }","}","if ($index -ge 0) {","    $fs = [System.IO.File]::Open($exe, 'Open', 'ReadWrite')","    $fs.Seek($index, 'Begin') | Out-Null","    $nulls = New-Object byte[] $pattern.Length","    $fs.Write($nulls, 0, $nulls.Length)","    $fs.Close()","    Write-Host \"`nExecutable patched to remove webpage autoload at startup.\"","} else {","    Write-Host \"`nURL pattern not found; no patch applied.\"","}","if (!(Test-Path \"$persist_dir\")) { New-Item -Path \"$persist_dir\" -ItemType Directory | Out-Null }","foreach ($folder in @('snapshot','record')) {","    $path = Join-Path $persist_dir $folder","    if (!(Test-Path $path)) { New-Item -Path $path -ItemType Directory | Out-Null }","}"]}}},"shortcuts":[["SrtClient.exe","Happytime SRT Client"]],"persist":["snapshot","record"],"notes":"SRT Client stores its settings at \"HKCU\\SOFTWARE\\happytimesoft\\srtclient\".","from":"https://github.com/instinctualjealousy/holes"}
