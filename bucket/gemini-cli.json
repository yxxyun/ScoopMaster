{
    "version": "0.39.1",
    "description": "An open-source AI agent that brings the power of Gemini directly into your terminal",
    "homepage": "https://github.com/google-gemini/gemini-cli",
    "license": "Apache-2.0",
    "depends": "nodejs",
    "url": "https://registry.npmjs.org/@google/gemini-cli/-/gemini-cli-0.39.1.tgz",
    "hash": "f6afd726bd2e4510e8407c9dda3c34a3fa63d5f4baea7cff10375269ef974216",
    "extract_dir": "package",
    "installer": {
        "script": [
            "# Install npm dependencies",
            "$env:npm_config_loglevel = 'error'",
            "Push-Location \"$dir\"",
            "npm install --production --no-optional 2>&1 | Out-Null",
            "Pop-Location",
            "# Create gemini.cmd shim",
            "Set-Content -Path \"$dir\\gemini.cmd\" -Value '@echo off' -Encoding ASCII",
            "Add-Content -Path \"$dir\\gemini.cmd\" -Value '\"node\" \"%~dp0bundle\\gemini.js\" %*' -Encoding ASCII"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item \"$dir\\node_modules\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null"
    },
    "bin": "gemini.cmd",
    "checkver": {
        "url": "https://registry.npmjs.org/@google/gemini-cli/latest",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://registry.npmjs.org/@google/gemini-cli/-/gemini-cli-$version.tgz"
    },
    "notes": [
        "Gemini CLI requires Node.js >= 20.",
        "Run 'gemini' to start the AI agent in your terminal.",
        "You need a Google account to authenticate on first use."
    ]
}
