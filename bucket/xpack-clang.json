{
    "version": "21.1.8-1",
    "description": "A binary distribution of the LLVM clang compiler infrastructure from xPack.",
    "homepage": "https://xpack-dev-tools.github.io/clang-xpack",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/xpack-dev-tools/clang-xpack/releases/download/v21.1.8-1/xpack-clang-21.1.8-1-win32-x64.zip",
            "hash": "b23d38e2c1c539182919e147e7158fd8b4e8bdd9e6ddc5dfe06f6488c6d9d516"
        }
    },
    "extract_dir": "xpack-clang-21.1.8-1",
    "env_add_path": "bin",
    "checkver": {
        "github": "https://github.com/xpack-dev-tools/clang-xpack",
        "regex": "releases/tag/v([\\d.]+-[\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xpack-dev-tools/clang-xpack/releases/download/v$version/xpack-clang-$version-win32-x64.zip"
            }
        },
        "hash": {
            "url": "$url.sha",
            "regex": "^([a-fA-F0-9]+)"
        },
        "extract_dir": "xpack-clang-$version"
    }
}
