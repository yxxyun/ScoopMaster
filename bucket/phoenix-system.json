{
    "##": "Only for non-scoop Firefox",
    "version": "2026.03.31.1",
    "description": "Phoenix is a suite of configurations & advanced modifications for Mozilla Firefox, designed to put the user first - with a focus on privacy, security, freedom, & usability.",
    "homepage": "https://phoenix.celenity.dev/",
    "license": "GPL-3.0-or-later",
    "notes": "After Phoenix is installed, you MUST restart Firefox after its first run with Phoenix installed. This ensures all of Phoenix's changes are applied.",
    "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip",
    "hash": "9afe8d82e32d387fd95e3fe2690ff9f15775277f47e6e82c07c7f900e531ab8c",
    "pre_install": [
        "# Locate Firefox installations",
        "$regPaths = @(",
        "    'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',",
        "    'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',",
        "    'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'",
        ")",
        "foreach ($regPath in $regPaths) {",
        "    Get-ItemProperty $regPath -ErrorAction SilentlyContinue | ForEach-Object {",
        "        if ($_.InstallLocation -match 'Firefox') {",
        "            $installedFirefox += [PSCustomObject]@{",
        "                Name = $_.DisplayName",
        "                Location = $_.InstallLocation",
        "            }",
        "        }",
        "    }",
        "}",
        "if (-not $installedFirefox) {",
        "   abort 'No supported Firefox package is installed.'",
        "}",
        "",
        "$configFile = Join-Path $persist_dir 'phoenix-system-target.txt'",
        "if (Test-Path $configFile) {",
        "   info \"Using persisted package choice: $(Get-Content $configFile)\"",
        "} else {",
        "   Write-Host \"`nApply Phoenix to:\"",
        "   for ($i = 0; $i -lt $installedFirefox.Count; $i++) {",
        "       $inst = $installedFirefox[$i]",
        "       Write-Host \"  [$($i+1)] $($inst.Name) - $($inst.Location)\"",
        "   }",
        "   $choice = Read-Host 'Enter package number'",
        "   $index = [int]$choice - 1",
        "   if ($index -lt 0 -or $index -ge $installedFirefox.Count) {",
        "       abort 'Invalid choice'",
        "   }",
        "   $chosen = $installedFirefox[$index].Location",
        "   success \"Saving package choice: $chosen\"",
        "   ensure $persist_dir | Out-Null",
        "   $chosen | Out-UTF8File -FilePath $configFile",
        "}"
    ],
    "post_install": [
        "$configFile = Join-Path $dir 'phoenix-system-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort 'Phoenix config file missing. Cannot retrieve target.`nPlease reinstall.'",
        "}",
        "$targetPath = Get-Content $configFile",
        "if (-not (Test-Path $targetPath)) {",
        "    abort \"No target path found at \"$targetPath\"\"",
        "}",
        "if (-not (is_admin)) {",
        "   error \"$app requires admin rights to operate in the target path\"; break",
        "} else {",
        "   Copy-Item -Path \"$dir\\*\" -Destination $targetPath -Exclude '*.txt', 'README.md' -Force -Recurse",
        "}"
    ],
    "pre_uninstall": [
        "$configFile = Join-Path $dir 'phoenix-system-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort 'Phoenix config file missing. Cannot retrieve target.`nPlease reinstall.'",
        "}",
        "$targetPath = Get-Content $configFile",
        "if (-not (Test-Path $targetPath)) {",
        "    abort \"No target path found at \"$targetPath\"\"",
        "}",
        "if (-not (is_admin)) {",
        "   error \"$app requires admin rights to operate in the target path\"; break",
        "} else {",
        "   Get-ChildItem -Path \"$dir\\*\" -Recurse | Sort-Object FullName -Descending | ForEach-Object {",
        "       $item = Join-Path $targetPath $_.FullName.Substring($dir.Length + 1)",
        "       if (Test-Path $_ -PathType Leaf) { Remove-Item $item -Force -ErrorAction SilentlyContinue }",
        "       else { try { [System.IO.Directory]::Delete($item, $false) } catch { } }",
        "   }",
        "}"
    ],
    "persist": "phoenix-system-target.txt",
    "checkver": {
        "url": "https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest",
        "jsonpath": "$.tag_name"
    },
    "autoupdate": {
        "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip"
    }
}
