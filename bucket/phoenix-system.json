{"##":"Only for non-scoop Firefox","version":"2026.06.10.1","description":"Phoenix is a suite of configurations & advanced modifications for Mozilla Firefox, designed to put the user first - with a focus on privacy, security, freedom, & usability.","homepage":"https://phoenix.celenity.dev/","license":"GPL-3.0-or-later","notes":"After Phoenix is installed, you MUST restart Firefox after its first run with Phoenix installed. This ensures all of Phoenix's changes are applied.","url":"https://releases.celenity.dev/phoenix/releases/2026.06.10.1/windows/phoenix-2026.06.10.1-windows.zip","hash":"sha512:678420264b4d1b5603bb9282eb361807b83d73cc8aff8c6d07a2e389374fa824d1e3b48f580722fde94a1bfc1b75f1708bae6ef8cbc93cabb715e47edcbf6a63","pre_install":["# --- Skip when Target already selected ---","$configFile = Join-Path $persist_dir 'phoenix-system-target.txt'","if (Test-Path $configFile) {","   info \"Using persisted package choice: $(Get-Content $configFile)\"","   return","}","# --- Locate package installations ---","$regPaths = @(","    'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',","    'HKLM:\\SOFTWARE\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*',","    'HKCU:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*'",")","$installedFirefox = $regPaths | Get-ItemProperty -ErrorAction SilentlyContinue |","   Where-Object { $_.InstallLocation -match 'Firefox' } |","   Select-Object @{Name = 'Name'; Expression = { $_.DisplayName } }, @{Name = 'Location'; Expression = { $_.InstallLocation } }","","if ($installedFirefox.Count -eq 0) {","   abort 'No supported Firefox package is installed.'","}","# --- List packages and prompt for user selection ---","Write-Host \"`nApply Phoenix to:\"","for ($i = 0; $i -lt $installedFirefox.Count; $i++) {","    $item = $installedFirefox[$i]","    Write-Host \" [$($i+1)]`t$($item.Name) - $($item.Location)\"","} do {","   $choice = Read-Host \"`n(Type '0' to exit)`nEnter package number\"","   if ($choice -eq 0) { exit 0 }","} while ($choice -notmatch '^\\d+$' -or $choice -lt 1 -or $choice -gt $installedFirefox.Count)","# --- Persist selection ---","$chosen = $installedFirefox[$choice - 1].Location","success \"Saving package choice: $chosen\"","ensure $persist_dir | Out-Null","$chosen | Out-UTF8File -FilePath $configFile"],"post_install":["# --- Get and check target info ---","$configFile = Join-Path $dir 'phoenix-system-target.txt'","if (-not (Test-Path $configFile)) {","   abort \"Phoenix config file missing. Cannot retrieve target.`nPlease reinstall.\"","}","$targetPath = Get-Content $configFile","if (-not (Test-Path $targetPath)) {","    abort \"Cannot $cmd $app for $(fname $targetPath) `nNo target found at \"$targetPath\"\"","}","# --- Copy files to target ---","info \"Applying Phoenix to $(fname $targetPath)\"","try {","   Copy-Item -Path \"$dir\\*\" -Destination $targetPath -Exclude '*.txt', 'README.md' -Force -Recurse -ErrorAction Stop","} catch [System.UnauthorizedAccessException] {","   error \"$app requires admin rights to operate in the target path\"; break","} catch { <# -ErrorAction SilentlyContinue #> }"],"pre_uninstall":["# --- Get and check target info ---","$configFile = Join-Path $dir 'phoenix-system-target.txt'","if (-not (Test-Path $configFile)) {","   abort \"Phoenix config file missing. Cannot retrieve target.`nPlease reinstall.\"","}","$targetPath = Get-Content $configFile","if (-not (Test-Path $targetPath)) {","   abort \"Skipping $cmd of $app for $(fname $targetPath) `nMissing: \"$targetPath\"\"","}","# --- Fetch items, sort by type and depth and try to delete files and only empty folders ---","info \"Unapplying Phoenix from $(fname $targetPath)\"","Get-ChildItem -Path $dir -Recurse | Sort-Object PSIsContainer, @{ Expression = { ($_.FullName -split '\\\\').Count }; Descending = $true } |","ForEach-Object {","   $item = Join-Path $targetPath $_.FullName.Substring($dir.Length)","   if (-not $_.PSIsContainer -or -not (Get-ChildItem $item -Force)) {","       try {","           Remove-Item $item -ErrorAction Stop","       } catch [System.UnauthorizedAccessException] { ","           error \"$app requires admin rights to operate in the target path\"; break","       } catch { <# -ErrorAction SilentlyContinue #> }","   }","}"],"persist":"phoenix-system-target.txt","checkver":{"url":"https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest","jsonpath":"$.tag_name"},"autoupdate":{"url":"https://releases.celenity.dev/phoenix/releases/$version/windows/phoenix-$version-windows.zip","hash":{"url":"$url-sha512sum.txt"}},"from":"https://github.com/anxshi/various-infills"}
