{
    "version": "1.0.1",
    "description": "JPEG filetype plugin based on mozjpeg for paint.net",
    "homepage": "https://github.com/0xC0000054/pdn-mozjpeg",
    "license": "MIT",
    "depends": "extras/paint.net",
    "url": "https://github.com/0xC0000054/pdn-mozjpeg/releases/download/v1.0.1/MozJpegFileType.zip",
    "hash": "9257ac103333b45ecade3b039ac86e44b7d3e308eeb8c62f18accb103dc15a57",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\\MozJpegFileType\"",
        "New-Item \"$paintdotnet\" -ItemType Directory -Force",
        "Move-Item -Path \"$dir\\*\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\\MozJpegFileType\"",
            "Remove-Item \"$paintdotnet\" -Force -Recurse"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/0xC0000054/pdn-mozjpeg/releases/download/v$version/MozJpegFileType.zip"
    }
}
