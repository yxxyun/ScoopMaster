{
    "version": "2026.03.31.1",
    "description": "Phoenix is a suite of configurations & advanced modifications for Mozilla Firefox, designed to put the user first - with a focus on privacy, security, freedom, & usability.",
    "homepage": "https://phoenix.celenity.dev/",
    "license": "GPL-3.0-or-later",
    "notes": [
        "To select another Firefox installation, be sure to run 'scoop uninstall phoenix --purge',",
        "as this ensures the persisted .ini file is deleted.",
        "For Scooped Firefox Users only:",
        "Please be aware to run 'scoop update phoenix --force' after every Firefox update."
    ],
    "url": "https://codeberg.org/celenity/Phoenix/raw/branch/dev/archives/phoenix-windows.zip",
    "hash": "9afe8d82e32d387fd95e3fe2690ff9f15775277f47e6e82c07c7f900e531ab8c",
    "pre_install": [
        "# If a previous browser selection exists, skip preinstall script",
        "if (Test-Path \"$persist_dir\\InstallConfig.ini\") {return}",
        "",
        "# ---- Helper: get non-Scoop Firefox installations from registry ----",
        "function Get-NonScoopFirefox {",
        "    $found = @()",
        "    $regPaths = @(",
        "        \"HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*\",",
        "        \"HKLM:\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*\",",
        "        \"HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*\"",
        "    )",
        "",
        "    foreach ($path in $regPaths) {",
        "        Get-ItemProperty -Path $path -ErrorAction SilentlyContinue | ForEach-Object {",
        "            $installLoc = $_.InstallLocation",
        "            # Use InstallLocation for checking (as requested)",
        "            if ($installLoc -and $installLoc -match 'firefox') {",
        "                # Ensure the path exists (optional sanity check)",
        "                if (Test-Path $installLoc) {",
        "                    $displayName = if ($_.DisplayName) { $_.DisplayName } else { \"Firefox (non‑Scoop)\" }",
        "                    $appName = \"$displayName ($installLoc)\"",
        "                    $found += [PSCustomObject]@{",
        "                        appname  = $appName",
        "                        location = $installLoc",
        "                        source   = \"registry\"",
        "                    }",
        "                }",
        "            }",
        "        }",
        "    }",
        "    # Remove possible duplicates (same InstallLocation)",
        "    $found | Sort-Object location -Unique",
        "}",
        "",
        "# ---- 1. Scoop-managed Firefox packages ----",
        "$scoopFirefox = @()",
        "$firefoxApps = installed_apps | Where-Object { $_ -match 'firefox' }",
        "",
        "foreach ($appName in $firefoxApps) {",
        "    $ver = Select-CurrentVersion -AppName $appName",
        "    $installInfoPath = \"$(versiondir $appName $ver)\\install.json\"",
        "    $bucket = $null",
        "    if (Test-Path $installInfoPath) {",
        "        $installInfo = parse_json $installInfoPath",
        "        $bucket = $installInfo.bucket",
        "    }",
        "    if (-not $bucket) { $bucket = \"<unknown>\" }",
        "    $scoopFirefox += [PSCustomObject]@{",
        "        appname  = $appName",
        "        location = $bucket",
        "        source   = \"scoop\"",
        "    }",
        "}",
        "",
        "# ---- 2. Non-Scoop Firefox installations from registry ----",
        "$registryFirefox = Get-NonScoopFirefox",
        "",
        "# ---- 3. Combine and present choices ----",
        "$allChoices = $scoopFirefox + $registryFirefox",
        "",
        "if ($allChoices.Count -eq 0) {",
        "    abort \"No Firefox installation found (neither via Scoop nor in the registry).\"",
        "}",
        "",
        "success \"`nFound Firefox package(s):\"",
        "$numberedChoices = @()",
        "for ($i = 0; $i -lt $allChoices.Count; $i++) {",
        "    $choice = $allChoices[$i]",
        "    $display = if ($choice.source -eq \"scoop\") {",
        "        \"Scoop: $($choice.location)/$($choice.appname)\"",
        "    } else {",
        "        \"System: $($choice.appname)\"",
        "    }",
        "    Write-Host \"  $($i+1). $display\"",
        "    $numberedChoices += [PSCustomObject]@{",
        "        Number = $i + 1",
        "        Source = $choice.source",
        "        AppName = $choice.appname",
        "        Location = $choice.location",
        "    }",
        "}",
        "",
        "# ---- 4. Prompt for selection ----",
        "do {",
        "    $selection = Read-Host \"`nEnter the number of the Firefox package to use\"",
        "    $valid = $selection -match '^\\d+$' -and [int]$selection -ge 1 -and [int]$selection -le $allChoices.Count",
        "    if (-not $valid) {",
        "        warn \"Invalid input. Please enter a number between 1 and $($allChoices.Count).\"",
        "    }",
        "} while (-not $valid)",
        "",
        "$selected = $numberedChoices[[int]$selection - 1]",
        "",
        "# ---- 5. Save selection to InstallConfig.ini (will be persisted by Scoop) ----",
        "$configContent = @(",
        "    '[BROWSER]'",
        "    \"source=$($selected.Source)\"",
        "    \"appname=$($selected.AppName)\"",
        "    \"location=$($selected.Location)\"",
        ")",
        "Set-Content -Path \"$dir\\InstallConfig.ini\" -Value $configContent",
        "",
        "success \"Selected browser: $($selected.AppName)\""
    ],
    "post_install": [
        "# Parse the INI file (simple key=value lines, ignoring section headers)",
        "$ini = @{}",
        "Get-Content \"$dir\\InstallConfig.ini\" | ForEach-Object {",
        "    if ($_ -match '^([^=]+)=(.*)$') {",
        "        $key = $matches[1].Trim()",
        "        $value = $matches[2].Trim()",
        "        $ini[$key] = $value",
        "    }",
        "}",
        "",
        "$source   = $ini['source']",
        "$appname  = $ini['appname']",
        "$location = $ini['location']",
        "",
        "if ($source -eq 'scoop') {",
        "    $firefoxPath = \"$(appdir $appname)\\current\"",
        "} elseif (is_admin) {",
        "    $firefoxPath = $location",
        "} else {",
        "    abort \"`n$app requires admin rights for $location\"",
        "}",
        "# Apply Phoenix",
        "Copy-Item \"$dir\\phoenix.cfg\" \"$firefoxPath\" -Force | Out-Null",
        "Copy-Item \"$dir\\defaults\\pref\\phoenix.js\" \"$firefoxPath\\defaults\\pref\" -Force | Out-Null",
        "if (-not (Test-Path \"$firefoxPath\\distribution\")) {",
        "    New-Item -ItemType Directory -Path \"$firefoxPath\\distribution\" | Out-Null",
        "}",
        "Copy-Item \"$dir\\distribution\\policies.json\" \"$firefoxPath\\distribution\" -Force | Out-Null"
    ],
    "pre_uninstall": [
        "# Parse the INI file (simple key=value lines, ignoring section headers)",
        "$ini = @{}",
        "Get-Content \"$dir\\InstallConfig.ini\" | ForEach-Object {",
        "    if ($_ -match '^([^=]+)=(.*)$') {",
        "        $key = $matches[1].Trim()",
        "        $value = $matches[2].Trim()",
        "        $ini[$key] = $value",
        "    }",
        "}",
        "",
        "$source   = $ini['source']",
        "$appname  = $ini['appname']",
        "$location = $ini['location']",
        "",
        "if ($source -eq 'scoop') {",
        "    $firefoxPath = \"$(appdir $appname)\\current\"",
        "} elseif (is_admin) {",
        "    $firefoxPath = $location",
        "} else {",
        "    abort \"`n$app requires admin rights for $location\"",
        "}",
        "if (-not (Test-Path $firefoxPath)) {",
        "    warn \"Firefox directory not found: $firefoxPath - nothing to remove.\"",
        "    return",
        "}",
        "",
        "# Unapply Phoenix",
        "Remove-Item \"$firefoxPath\\phoenix.cfg\" -Force | Out-Null",
        "Remove-Item \"$firefoxPath\\defaults\\pref\\phoenix.js\" -Force | Out-Null",
        "Remove-Item \"$firefoxPath\\distribution\\policies.json\" -Force | Out-Null"
    ],
    "persist": "InstallConfig.ini",
    "checkver": {
        "url": "https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest",
        "jsonpath": "$.tag_name"
    },
    "autoupdate": {
        "url": "https://codeberg.org/celenity/Phoenix/raw/branch/dev/archives/phoenix-windows.zip"
    }
}
