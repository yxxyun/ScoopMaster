{
    "##": "Only for scooped Firefox",
    "version": "2026.03.31.1",
    "description": "Phoenix is a suite of configurations & advanced modifications for Mozilla Firefox, designed to put the user first - with a focus on privacy, security, freedom, & usability.",
    "homepage": "https://phoenix.celenity.dev/",
    "license": "GPL-3.0-or-later",
    "notes": "After Phoenix is installed, you MUST force-update Firefox to ensure all of Phoenix's changes are applied.",
    "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip",
    "hash": "9afe8d82e32d387fd95e3fe2690ff9f15775277f47e6e82c07c7f900e531ab8c",
    "pre_install": [
        "$installedFirefox = @(@(installed_apps) | Where-Object { $_ -match 'firefox(-|$)'})",
        "if (-not $installedFirefox) {",
        "   abort 'No supported Firefox package is installed.'",
        "}",
        "",
        "$configFile = Join-Path $persist_dir 'phoenix-target.txt'",
        "if (Test-Path $configFile) {",
        "   info \"Using persisted package choice: $(Get-Content $configFile)\"",
        "} else {",
        "   Write-Host \"`nApply Phoenix to:\"",
        "   for ($i = 0; $i -lt $installedFirefox.Count; $i++) {",
        "       Write-Host \"  [$($i+1)] $($installedFirefox[$i])\"",
        "   }",
        "   $choice = Read-Host 'Enter package number'",
        "   $index = [int]$choice - 1",
        "   if ($index -lt 0 -or $index -ge $installedFirefox.Count) {",
        "       abort 'Invalid choice'",
        "   }",
        "   $chosen = $installedFirefox[$index]",
        "   success \"Saving package choice: $chosen\"",
        "   ensure $persist_dir | Out-Null",
        "   $chosen | Out-UTF8File -FilePath $configFile",
        "}"
    ],
    "post_install": [
        "$configFile = Join-Path $dir 'phoenix-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort 'Phoenix config file missing. Cannot retrieve target package.`nPlease reinstall.'",
        "}",
        "$targetApp = Get-Content $configFile",
        "$Addition = Join-Path (persistdir $targetApp) 'addition'",
        "ensure $Addition | Out-Null",
        "Copy-Item -Path \"$dir\\*\" -Destination $Addition -Exclude '*.txt', 'README.md' -Force -Recurse"
    ],
    "pre_uninstall": [
        "$configFile = Join-Path $dir 'phoenix-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort 'Phoenix config file missing. Cannot retrieve target App.`nPlease reinstall.'",
        "}",
        "$targetApp = Get-Content $configFile",
        "$Addition = Join-Path (persistdir $targetApp) 'addition'",
        "Get-ChildItem -Path \"$dir\\*\" -Recurse | ForEach-Object {",
        "   $file = Join-Path $Addition $_.Name",
        "   Remove-Item $file -Recurse -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "persist": "phoenix-target.txt",
    "checkver": {
        "url": "https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest",
        "jsonpath": "$.tag_name"
    },
    "autoupdate": {
        "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip"
    }
}
