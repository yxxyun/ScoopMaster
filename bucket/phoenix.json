{
    "##": "Only for scooped Firefox",
    "version": "2026.03.31.1",
    "description": "Phoenix is a suite of configurations & advanced modifications for Mozilla Firefox, designed to put the user first - with a focus on privacy, security, freedom, & usability.",
    "homepage": "https://phoenix.celenity.dev/",
    "license": "GPL-3.0-or-later",
    "notes": "After Phoenix is installed, you MUST restart Firefox after its first run with Phoenix installed. This ensures all of Phoenix's changes are applied.",
    "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip",
    "hash": "9afe8d82e32d387fd95e3fe2690ff9f15775277f47e6e82c07c7f900e531ab8c",
    "pre_install": [
        "#--- Skip when Target already selected ---",
        "$configFile = Join-Path $persist_dir 'phoenix-target.txt'",
        "if (Test-Path $configFile) {",
        "   info \"Using persisted package choice: $(Get-Content $configFile)\"",
        "   return",
        "}",
        "",
        "# --- Fetch installed packages ---",
        "# $installedFirefox = installed_apps | Where-Object { $_ -match 'firefox(-|$)'}",
        "# unlike the above solution, this ensures only packages are used who utilize the 'Addition' folder.",
        "$installedFirefox = @(installed_apps | Where-Object { $_ -notmatch 'bird' -and (Get-Manifest $_).post_install -match 'additional'})",
        "if ($installedFirefox.Count -eq 0) {",
        "   abort 'No supported Firefox package is installed.'",
        "}",
        "# --- List packages and prompt for user selection ---",
        "Write-Host \"`nApply Phoenix to:\"",
        "for ($i = 0; $i -lt $installedFirefox.Count; $i++) {",
        "    Write-Host \" [$($i+1)]`t$($installedFirefox[$i])\"",
        "} do {",
        "   $choice = Read-Host \"`n(Type '0' to exit)`nEnter package number\"",
        "   if ($choice -eq 0) { exit 0 }",
        "} while ($choice -notmatch '^\\d+$' -or $choice -lt 1 -or $choice -gt $installedFirefox.Count)",
        "# --- Persist selection ---",
        "$chosen = $installedFirefox[$choice - 1]",
        "success \"Saving package choice: $chosen\"",
        "ensure $persist_dir | Out-Null",
        "$chosen | Out-UTF8File -FilePath $configFile"
    ],
    "post_install": [
        "# --- Get and check target info ---",
        "$configFile = Join-Path $dir 'phoenix-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort \"Phoenix config file missing. Cannot retrieve target package.`nPlease reinstall.\"",
        "}",
        "$targetApp = Get-Content $configFile",
        "if (-not (installed $targetApp)) {",
        "   abort \"$targetApp not installed. Cannot $cmd $app\"",
        "}",
        "# --- Copy files to target ---",
        "$Addition = Join-Path (persistdir $targetApp) 'addition'",
        "ensure $Addition | Out-Null",
        "info \"Applying Phoenix to $targetApp ...\"",
        "Copy-Item -Path \"$dir\\*\" -Destination $Addition -Exclude '*.txt', 'README.md' -Force -Recurse",
        "",
        "# --- Trigger post_install script of target app ---",
        "$dir, $persist_dir = (currentdir $targetApp), (persistdir $targetApp)",
        "$manifest = Get-Manifest $targetApp",
        "$architecture = Get-SupportedArchitecture $manifest (Get-DefaultArchitecture)",
        "Invoke-HookScript post_install $manifest $architecture 6>$null"
    ],
    "pre_uninstall": [
        "# --- Get and check target info ---",
        "$configFile = Join-Path $dir 'phoenix-target.txt'",
        "if (-not (Test-Path $configFile)) {",
        "   abort \"Phoenix config file missing. Cannot retrieve target package.`nPlease reinstall.\"",
        "}",
        "$targetApp = Get-Content $configFile",
        "if (-not (Test-Path (persistdir $targetApp))) {",
        "   warn \"$targetApp not installed.`n Skipping $cmd ...\"",
        "   return",
        "}",
        "# --- Fetch items, sort by type and depth and try to delete files and only empty folders ---",
        "info \"Unapplying Phoenix from $targetApp ...\"",
        "$Addition = Join-Path (persistdir $targetApp) 'addition'",
        "Get-ChildItem -Path $dir -Recurse | Sort-Object PSIsContainer, @{ Expression = { ($_.FullName -split '\\\\').Count }; Descending = $true } |",
        "ForEach-Object {",
        "   $item = Join-Path $Addition $_.FullName.Substring($dir.Length)",
        "   if (-not $_.PSIsContainer -or -not (Get-ChildItem $item -Force)) {",
        "       try {",
        "           Remove-Item $item -ErrorAction Stop",
        "       } catch [System.UnauthorizedAccessException] { ",
        "           error \"$app requires admin rights to operate in the target path\"; break",
        "       } catch { <# -ErrorAction SilentlyContinue #> }",
        "   }",
        "}",
        "# --- Cleanup persist dir",
        "Remove-Item (Join-Path (Split-Path $Addition -Parent) \"\\distribution\\policies.json\") -Force -ErrorAction SilentlyContinue",
        "if (-not (Get-ChildItem $Addition -Force)) {",
        "   Remove-Item $Addition -Force -ErrorAction SilentlyContinue",
        "}"
    ],
    "persist": "phoenix-target.txt",
    "checkver": {
        "url": "https://codeberg.org/api/v1/repos/celenity/phoenix/releases/latest",
        "jsonpath": "$.tag_name"
    },
    "autoupdate": {
        "url": "https://phoenix.celenity.dev/archives/phoenix-windows.zip"
    }
}
