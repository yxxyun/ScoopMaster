{
    "version": "1.0.0.83",
    "description": "DGDemux is a standalone demuxer for BluRay/UHD disks.",
    "homepage": "https://www.rationalqm.us/dgdemux/dgdemux.html",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://www.videohelp.com/download/DGDemux_1.0.0.83.zip",
            "hash": "2923bd9b1e8b33bb9b0d295c9c9bb0895ff4667be9057d068c22730fc4fccebe"
        }
    },
    "suggest": {
        "dovi-tool": "extras/dovi-tool",
        "mediainfo": "mediainfo"
    },
    "bin": [
        "DGDemux.exe",
        "DGMVCCombine.exe"
    ],
    "shortcuts": [
        [
            "DGDemuxGUI.exe",
            "DGDemuxGUI"
        ],
        [
            "DGDemuxGUI_Files.exe",
            "DGDemuxGUI Files"
        ]
    ],
    "pre_install": [
        "Expand-Archive \"$dir\\thdmerge_*.zip\"; Remove-Item \"$dir\\thdmerge_*.zip\"",
        "\"finished.wav\", \"dovi_tool.exe\", \"dovi_tool.txt\", \"MediaInfoCLI.exe\", \"MediaInfoCLI.txt\", \"thdmerge.cpp\" | ForEach-Object { $file = \"$dir\\$_\"; Remove-Item $file }"
    ],
    "persist": [
        "DGDemux.ini",
        "DGDemux_Files.ini"
    ],
    "checkver": {
        "url": "https://www.videohelp.com/software/DGDemux",
        "regex": "DGDemux_([\\d.]+).zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.videohelp.com/download/DGDemux_$version.zip"
            }
        }
    }
}
