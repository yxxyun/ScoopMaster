{
    "version": "1.0.0.83",
    "description": "DGDemux is a standalone demuxer for BluRay/UHD disks.",
    "homepage": "https://www.rationalqm.us/dgdemux/dgdemux.html",
    "license": "Freeware",
    "suggest": {
        "dovi-tool": "extras/dovi-tool"
    },
    "url": "https://www.videohelp.com/download/DGDemux_1.0.0.83.zip",
    "hash": "2923bd9b1e8b33bb9b0d295c9c9bb0895ff4667be9057d068c22730fc4fccebe",
    "pre_install": [
        "Expand-Archive \"$dir\\thdmerge_*.zip\" \"$dir\"",
        "\"finished.wav\", \"dovi_tool.exe\", \"dovi_tool.txt\", \"MediaInfoCLI.exe\", \"MediaInfoCLI.txt\", \"thdmerge_*.zip\", \"thdmerge.cpp\" | ForEach-Object { Remove-Item \"$dir\\$_\" }"
    ],
    "bin": [
        "DGDemux.exe",
        "DGMVCCombine.exe"
    ],
    "shortcuts": [
        [
            "DGDemuxGUI.exe",
            "DGDemux/DGDemuxGUI"
        ],
        [
            "DGDemuxGUI_Files.exe",
            "DGDemux/DGDemuxGUI Files"
        ]
    ],
    "persist": [
        "DGDemux.ini",
        "DGDemux_Files.ini"
    ],
    "checkver": {
        "url": "https://www.videohelp.com/software/DGDemux",
        "regex": "DGDemux_([\\d.]+).zip"
    },
    "autoupdate": {
        "url": "https://www.videohelp.com/download/DGDemux_$version.zip"
    }
}
