    },
    "architecture": {
        "64bit": {
            "url": "https://downloads.affinity.studio/Affinity%20x64.msix#/dl.7z",
            "hash": "2f11720cb240f02820eb433c6334786a454a33aa6cbc4e2a3a32994a651869cc"
        },
        "arm64": {
