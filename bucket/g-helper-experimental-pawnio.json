{
    "version": "0.264",
    "description": "Lightweight control tool for Asus laptops. (Manual fan control)",
    "homepage": "https://github.com/seerge/g-helper-experimental-release",
    "license": "unknown",
    "notes": "Asus System Control Interface v3+ and .NET Desktop Runtime 7 are required.",
    "depends": "pawnio",
    "suggest": {
        ".NET Desktop Runtime 8.0": "versions/windowsdesktop-runtime-8.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/seerge/g-helper-experimental-release/releases/download/v0.264/GHelperPawn.zip",
            "hash": "0a4792de9a0d421d3295c0637153b2da8857af6aac92142d111651a3cea9d1fb"
        }
    },
    "pre_install": "if ((installed 'g-helper') -or (installed 'g-helper-experimental')) { throw 'Only 1 g-helper can be install.' }",
    "post_install": [
        "if (Test-Path $env:APPDATA\\GHelper) {",
        "    Copy-Item -Path $env:APPDATA\\GHelper\\* -Destination \"$persist_dir\\data\" -Force -Recurse",
        "    Remove-Item $env:APPDATA\\GHelper -Force -Recurse",
        "}",
        "New-Item -ItemType Junction -Path $env:APPDATA\\GHelper -Target $persist_dir\\data | Out-Null"
    ],
    "uninstaller": {
        "script": "Remove-Item $env:APPDATA\\GHelper -Force -Recurse"
    },
    "bin": "GHelper.exe",
    "shortcuts": [
        [
            "GHelper.exe",
            "G-Helper"
        ]
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/seerge/g-helper-experimental-release/"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/seerge/g-helper-experimental-release/releases/download/v$version/GHelperPawn.zip"
            }
        }
    }
}
