{
    "homepage": "https://tomcat.apache.org",
    "version": "9.0.116",
    "checkver": {
        "url": "https://www.apache.org/dist/tomcat/tomcat-9/?C=M;O=D",
        "re": "v(?<version>[\\d.]+)"
    },
    "autoupdate": {
        "extract_dir": "apache-tomcat-$version",
        "architecture": {
            "32bit": {
                "url": "https://www.apache.org/dist/tomcat/tomcat-9/v$version/bin/apache-tomcat-$version-windows-x86.zip"
            },
            "64bit": {
                "url": "https://www.apache.org/dist/tomcat/tomcat-9/v$version/bin/apache-tomcat-$version-windows-x64.zip"
            }
        },
        "hash": {
            "url": "$url.sha512"
        }
    },
    "extract_dir": "apache-tomcat-9.0.116",
    "bin": "bin\\catalina.bat",
    "env_set": {
        "CATALINA_HOME": "$dir",
        "CATALINA_BASE": "$dir"
    },
    "suggest": {
        "JRE": "java/openjdk"
    },
    "architecture": {
        "64bit": {
            "url": "https://www.apache.org/dist/tomcat/tomcat-9/v9.0.116/bin/apache-tomcat-9.0.116-windows-x64.zip",
            "hash": "sha512:9bb0a37117feb0325511f56a9517a67387cce4054753b6e7d3184a76f47d422eda997a414fb310304fe6a456c00da1be2bfbe319eec82bdbb266bee35e4d94e8"
        },
        "32bit": {
            "url": "https://www.apache.org/dist/tomcat/tomcat-9/v9.0.116/bin/apache-tomcat-9.0.116-windows-x86.zip",
            "hash": "sha512:08dc63a2044fe149131e494900fac0acabfbd57103820be0c750737bc13dc06c2d8278685e2daeebb035519c0df10c5bfb00c3a0fa274d290ac463be741f49a3"
        }
    }
}
