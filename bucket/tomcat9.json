{
    "homepage": "https://tomcat.apache.org",
    "version": "9.0.117",
    "checkver": {
        "url": "https://www.apache.org/dist/tomcat/tomcat-9/?C=M;O=D",
        "re": "v(?<version>[\\d.]+)"
    },
    "autoupdate": {
        "extract_dir": "apache-tomcat-$version",
        "architecture": {
            "32bit": {
                "url": "https://www.apache.org/dist/tomcat/tomcat-9/v$version/bin/apache-tomcat-$version-windows-x86.zip"
            },
            "64bit": {
                "url": "https://www.apache.org/dist/tomcat/tomcat-9/v$version/bin/apache-tomcat-$version-windows-x64.zip"
            }
        },
        "hash": {
            "url": "$url.sha512"
        }
    },
    "extract_dir": "apache-tomcat-9.0.117",
    "bin": "bin\\catalina.bat",
    "env_set": {
        "CATALINA_HOME": "$dir",
        "CATALINA_BASE": "$dir"
    },
    "suggest": {
        "JRE": "java/openjdk"
    },
    "architecture": {
        "64bit": {
            "url": "https://www.apache.org/dist/tomcat/tomcat-9/v9.0.117/bin/apache-tomcat-9.0.117-windows-x64.zip",
            "hash": "sha512:f8b6e8ca5d703fbab508cf09e0e9589f556a80c1ac5e5d3b62ef2e643e7e4598c20b4b6ef9e04a280827dc21199d48d73fa42608396971c5263adee5242d0084"
        },
        "32bit": {
            "url": "https://www.apache.org/dist/tomcat/tomcat-9/v9.0.117/bin/apache-tomcat-9.0.117-windows-x86.zip",
            "hash": "sha512:9fe47ec063b67319b8e4006853947556648a7d8ea5cf07a890a556998710c3b8bb46c385e241fd8cb0e4fdef2ba3a4eab34402cf3cb6fcf38be127f474597eee"
        }
    }
}
