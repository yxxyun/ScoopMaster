{
    "version": "0.1.12",
    "description": "Native Rust linux.do accelerator with CLI and desktop GUI",
    "homepage": "https://github.com/fjh1997/Linux.do-Accelerator",
    "license": "MIT",
    "notes": [
        "源码确认 Windows 默认配置目录：%APPDATA%\\linuxdo\\linuxdo-accelerator\\config\\linuxdo-accelerator.toml",
        "源码确认 Windows 默认数据目录：%LOCALAPPDATA%\\linuxdo\\linuxdo-accelerator\\data\\",
        "  - runtime\\service-state.json、linuxdo-accelerator.pid、operations.log、hosts.backup、hosts.backup.json",
        "  - certs\\linuxdo-accelerator-root-ca.crt、linuxdo-accelerator-server.crt、linuxdo-accelerator-server.key",
        "源码使用 eframe 原生 GUI，未发现 WebView2 / localStorage / SQLite 等额外持久化目录",
        "本包会将 config 与 data 两个默认目录持久化到 Scoop persist，并在原路径创建 Junction",
        "程序运行时对系统 hosts 和证书库的修改属于系统状态，不直接纳入 Scoop persist；其恢复元数据与本地证书文件已包含在 persist\\data 内",
        "若你手动通过 --config 指向其他目录，运行数据会随新配置目录变化，不在本包默认托管范围"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/fjh1997/Linux.do-Accelerator/releases/download/v0.1.12/linuxdo-accelerator_0.1.12_x64-setup.exe#/dl.7z",
            "hash": "f7b54831eac242c2a85ff889bb56cb7e024be4bb0fbf36873109341c4a19ed5c"
        },
        "arm64": {
            "url": "https://github.com/fjh1997/Linux.do-Accelerator/releases/download/v0.1.12/linuxdo-accelerator_0.1.12_arm64-setup.exe#/dl.7z",
            "hash": "360f3360792abe869a3c1bd09c669a5fde420f6de503c316a78eea6974dc82e0"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\uninstall.exe\" -Force -ErrorAction SilentlyContinue"
    ],
    "bin": [
        [
            "linuxdo-accelerator.exe",
            "linuxdo-accelerator"
        ]
    ],
    "shortcuts": [
        [
            "linuxdo-accelerator.exe",
            "Linux.do Accelerator"
        ]
    ],
    "post_install": [
        "$ensureJunction = {",
        "    param([string]$Source, [string]$Target)",
        "    ensure $Target",
        "    $parent = Split-Path $Source -Parent",
        "    if ($parent) {",
        "        New-Item -ItemType Directory -Path $parent -Force | Out-Null",
        "    }",
        "",
        "    if (Test-Path $Source) {",
        "        $item = Get-Item -LiteralPath $Source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$Source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$Source\"",
        "        }",
        "",
        "        & robocopy $Source $Target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$Source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$Source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $Source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$Source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $Source -ItemType Junction -Value $Target | Out-Null",
        "}",
        "",
        "$configSource = Join-Path (Join-Path (Join-Path $env:APPDATA 'linuxdo') 'linuxdo-accelerator') 'config'",
        "$dataSource = Join-Path (Join-Path (Join-Path $env:LOCALAPPDATA 'linuxdo') 'linuxdo-accelerator') 'data'",
        "& $ensureJunction $configSource (Join-Path $persist_dir 'config')",
        "& $ensureJunction $dataSource (Join-Path $persist_dir 'data')"
    ],
    "post_uninstall": [
        "$paths = @(",
        "    (Join-Path (Join-Path (Join-Path $env:APPDATA 'linuxdo') 'linuxdo-accelerator') 'config'),",
        "    (Join-Path (Join-Path (Join-Path $env:LOCALAPPDATA 'linuxdo') 'linuxdo-accelerator') 'data')",
        ")",
        "foreach ($path in $paths) {",
        "    if (Test-Path $path) {",
        "        $item = Get-Item -LiteralPath $path -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Remove-Item -LiteralPath $path -Force",
        "        }",
        "    }",
        "}"
    ],
    "persist": [
        "config",
        "data"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/fjh1997/Linux.do-Accelerator/releases/latest",
        "regex": "\"tag_name\"\\s*:\\s*\"v(?<version>[^\"]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/fjh1997/Linux.do-Accelerator/releases/download/v$version/linuxdo-accelerator_$version_x64-setup.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/fjh1997/Linux.do-Accelerator/releases/download/v$version/linuxdo-accelerator_$version_arm64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
