{
    "version": "2.4.5",
    "description": "an easytier-cli-completion generator",
    "homepage": "https://github.com/woyxiang/slug",
    "url": "http://www.msftconnecttest.com/connecttest.txt",
    "hash": "5e9a7996fe94d7be10595d7133748760bf8348198b71b7a50fd8affaa980ac61",
    "license": "MIT",
    "installer": {
        "script": [
            "ensure ~/.config/pwsh/completions",
            "Remove-Item $dir\\connecttest.txt",
            "easytier-cli gen-autocomplete powershell > ~/.config/pwsh/completions/easytier-cli-completion.ps1"
        ]
    },
    "uninstaller": {
        "script": "Remove-Item ~\\.config\\pwsh\\completions\\easytier-cli-completion.ps1 -ErrorAction SilentlyContinue"
    },
    "checkver": {
        "github": "https://github.com/EasyTier/EasyTier"
    },
    "autoupdate": {
        "url": "http://www.msftconnecttest.com/connecttest.txt"
    }
}
