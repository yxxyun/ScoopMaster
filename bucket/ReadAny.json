{
    "version": "1.1.6",
    "description": "AI-powered e-book reader with semantic search, intelligent chat, and local knowledge management",
    "homepage": "https://github.com/codedogQBY/ReadAny",
    "license": "GPL-3.0-or-later",
    "notes": [
        "桌面端应用数据目录：%APPDATA%\\com.readany.app\\",
        "  - readany.db / vectors.db：主库与向量库",
        "  - books\\ / covers\\：导入书籍与封面",
        "  - readany-store\\*.json：settings、tts、vector-model、library-books、library-tags 等持久化状态",
        "桌面端 localStorage、同步密码、翻译缓存与 Transformers.js Cache API 会落到程序目录旁的 ReadAny.exe.WebView2\\",
        "本包会将 %APPDATA%\\com.readany.app 建立 Junction 到 Scoop persist，并同时持久化 ReadAny.exe.WebView2"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/codedogQBY/ReadAny/releases/download/v1.1.6/ReadAny_1.1.6_x64-setup.exe#/dl.7z",
            "hash": "67cc7da4d7a58594e47c080bcc34512ee4f994d8b2ff92b6eeabe49206912a78"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\ReadAny.exe\" -Force -ErrorAction SilentlyContinue",
        "Rename-Item \"$dir\\app.exe\" \"ReadAny.exe\" -Force",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "ReadAny.exe",
    "shortcuts": [
        [
            "ReadAny.exe",
            "ReadAny"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'com.readany.app'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "post_uninstall": [
        "$source = Join-Path $env:APPDATA 'com.readany.app'",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Remove-Item -LiteralPath $source -Force",
        "    }",
        "}"
    ],
    "persist": [
        "data",
        [
            "ReadAny.exe.WebView2",
            "webview2"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/codedogQBY/ReadAny/releases/latest",
        "regex": "\"tag_name\"\\s*:\\s*\"v(?<version>[^\"]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/codedogQBY/ReadAny/releases/download/v$version/ReadAny_$version_x64-setup.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
