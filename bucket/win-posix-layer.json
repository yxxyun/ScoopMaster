{
    "version": "win2",
    "description": "A POSIX layer with Linux-like methods for PowerShell on Windows",
    "homepage": "https://github.com/omardev29/win-posix-layer",
    "license": "MIT",
    "url": "https://github.com/omardev29/win-posix-layer/archive/refs/tags/win2.zip",
    "hash": "update-after-download",
    "extract_dir": "win-posix-layer-win2",
    "checkver": {
        "github": "https://github.com/omardev29/win-posix-layer"
    },
    "autoupdate": {
        "url": "https://github.com/omardev29/win-posix-layer/archive/refs/tags/$version.zip",
        "extract_dir": "win-posix-layer-$version"
    },
    "post_install": [
        "$profileDir = \"$env:USERPROFILE\\Documents\\PowerShell\"",
        "New-Item $profileDir -ItemType Directory -Force | Out-Null",
        "$profilePath = Join-Path $profileDir \"Microsoft.PowerShell_profile.ps1\"",
        "$moduleFile = Get-ChildItem \"$dir\" -Filter WinPosixLayer.psd1 -Recurse | Select-Object -First 1",
        "if (-not $moduleFile) { Write-Error \"Module not found\"; exit 1 }",
        "$modulePath = $moduleFile.FullName",
        "if (Test-Path $profilePath) {",
        "    $content = Get-Content $profilePath -Raw",
        "    if ($content -notlike \"*$modulePath*\") {",
        "        Add-Content $profilePath \"\"",
        "        Add-Content $profilePath \"Import-Module '$modulePath'\"",
        "    }",
        "}",
        "else {",
        "    Set-Content $profilePath \"Import-Module '$modulePath'\"",
        "}"
    ],
    "notes": "The module has been added to your PowerShell profile. Restart PowerShell or run . $PROFILE to load it. External tools like eza, bat, ripgrep, duf, zoxide, and superfile are recommended for full functionality."
}
