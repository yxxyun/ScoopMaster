{
    "version": "2018-07-30",
    "description": "A paint.net plugin by xod for aligning congruent pixels within a selection",
    "homepage": "https://forums.getpaint.net/topic/112095-align-object/",
    "license": "Unknown",
    "depends": "extras/paint.net",
    "url": "https://raw.githubusercontent.com/instinctualjealousy/holes/refs/heads/master/mirror/AlignObject.7z",
    "hash": "ab93d45a6f6fbc7c8f6ec409ef1d070bc0d6f097524124ad61d2c395b26e98bb",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\"",
        "Move-Item -Path \"$dir\\Align Object.dll\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\"",
            "Remove-Item \"$paintdotnet\\Align Object.dll\" -Force"
        ]
    }
}
