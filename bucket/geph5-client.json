                "}"
            ]
        },
        "32bit": {
            "url": "https://github.com/touhoured/geph5-autobuild/releases/download/geph5-client-v0.2.102/geph5-client-i686-pc-windows-msvc-v0.2.102.zip",
            "hash": "f9345547aa052756b770a676b3bc320b576d00aaac4660bc097ca056a9ab439e",
