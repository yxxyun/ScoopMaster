{
    "version": "1.0.1",
    "description": "Cascadia Next Nerd Font - Traditional Chinese (TC) variant. A Nerd Font patched version of Microsoft Cascadia Next font, with perfect 2:1 CJK-to-Latin width ratio.",
    "homepage": "https://github.com/LiLittleCat/Cascadia-Next-Nerd-Font",
    "license": "OFL-1.1",
    "url": "https://github.com/LiLittleCat/Cascadia-Next-Nerd-Font/releases/download/v1.0.1/CascadiaNextTCNF-ttf.zip",
    "hash": "61114cecb42ade16532d5355c0dd9bc6c282cbaecd70b2bbd43108e637212dcf",
    "installer": {
        "script": [
            "Get-ChildItem $dir -Recurse -Filter '*.ttf' | ForEach-Object {",
            "    $fontName = $_.Name",
            "    $fontPath = Join-Path $env:windir 'Fonts' $fontName",
            "    if (!(Test-Path $fontPath)) {",
            "        Copy-Item $_.FullName $fontPath -Force",
            "        New-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $fontName -PropertyType String -Value $fontName -Force | Out-Null",
            "    }",
            "}"
        ]
    },
    "uninstaller": {
        "script": [
            "Get-ChildItem $dir -Recurse -Filter '*.ttf' | ForEach-Object {",
            "    $fontName = $_.Name",
            "    $fontPath = Join-Path $env:windir 'Fonts' $fontName",
            "    if (Test-Path $fontPath) {",
            "        Remove-Item $fontPath -Force",
            "        Remove-ItemProperty -Path 'HKLM:\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $fontName -Force -ErrorAction SilentlyContinue",
            "    }",
            "}"
        ]
    },
    "checkver": {
        "github": "https://github.com/LiLittleCat/Cascadia-Next-Nerd-Font"
    },
    "autoupdate": {
        "url": "https://github.com/LiLittleCat/Cascadia-Next-Nerd-Font/releases/download/v$version/CascadiaNextTCNF-ttf.zip"
    }
}
