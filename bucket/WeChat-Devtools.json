{
    "version": "2.01.2510290",
    "description": "To help developers develop and debug Weixin Mini Programs more simply and efficiently.",
    "homepage": "https://developers.weixin.qq.com/miniprogram/dev/devtools/download.html",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://dldir1.qq.com/WechatWebDev/release/be1ec64cf6184b0fa64091919793f068/wechat_devtools_2.01.2510290_win32_x64.exe#/dl.7z",
            "hash": "f817db8dd71c9a9b27583c18a17c300144314162ca7b7f944b6262c458b127f7"
        },
        "32bit": {
            "url": "https://dldir1.qq.com/WechatWebDev/release/be1ec64cf6184b0fa64091919793f068/wechat_devtools_2.01.2510290_win32_ia32.exe#/dl.7z",
            "hash": "b221ca766c951bd195944517039b829ca2c98df784addc05b89201f9c6f96eac"
        }
    },
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Remove-Item -R -Path \"$dir\\`$PLUGINSDIR\" -ErrorAction SilentlyContinue | Out-Null",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host \"`nPersisting $env:APPDATA\\微信开发者工具 ... \" -NoNewline",
        "New-PersistDirectory \"$env:LOCALAPPDATA\\微信开发者工具\" \"$persist_dir\\微信开发者工具\" -Migrate"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nDeleting $env:APPDATA\\微信开发者工具 ... \") -f DarkGray -NoNewline",
        "Remove-Junction \"$env:APPDATA\\微信开发者工具\" -ErrorAction SilentlyContinue | Out-Null"
    ],
    "shortcuts": [
        [
            "微信开发者工具.exe",
            "微信开发者工具"
        ]
    ],
    "checkver": {
        "script": [
            "$req = [System.Net.HttpWebRequest]::Create('https://servicewechat.com/wxa-dev-logic/download_redirect?type=x64&from=mpwiki')",
            "$req.Method = 'HEAD'",
            "$req.AllowAutoRedirect = $false",
            "try { $res = $req.GetResponse() } catch { $res = $_.Exception.Response }",
            "if ($res) { $res.Headers['Location'] } else { '' }"
        ],
        "regex": "/(?<hash>[\\w]+)/wechat_devtools_(?<maj>\\d+)\\.(?<min>\\d+)\\.(?<patch>\\d+)_",
        "replace": "${maj}.${min}.${patch}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dldir1.qq.com/WechatWebDev/release/$matchHash/wechat_devtools_$matchMaj.$matchMin.$matchPatch_win32_x64.exe#/dl.7z"
            },
            "32bit": {
                "url": "https://dldir1.qq.com/WechatWebDev/release/$matchHash/wechat_devtools_$matchMaj.$matchMin.$matchPatch_win32_ia32.exe#/dl.7z"
            }
        }
    }
}
