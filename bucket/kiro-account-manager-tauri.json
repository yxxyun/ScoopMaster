    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/hj01857655/kiro-account-manager/releases/download/v1.8.8/KiroAccountManager_1.8.8_x64_zh-CN.msi",
            "hash": "766969783e1f4ffb50b02c24db235a2ec748f885560854e979a53fd5fc7e007a"
        }
    },
    "installer": {
        "script": "Start-Process msiexec -ArgumentList @('/i', \"`\"$dir\\$fname`\"\", '/qn', '/norestart') -Wait -NoNewWindow"
    },
    "shortcuts": [
        [
            "PFiles\\KiroAccountManager\\kiro-account-manager.exe",
            "Kiro Account Manager Tauri"
        ]
    ],
    "uninstaller": {
        "script": [
            "$productCode = Get-ItemProperty 'HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\*' | Where-Object { $_.DisplayName -like '*Kiro Account Manager*' } | Select-Object -ExpandProperty PSChildName",
            "if ($productCode) {",
            "    Start-Process msiexec -ArgumentList @('/x', $productCode, '/qn', '/norestart') -Wait -NoNewWindow",
            "} else {",
            "    warn 'Kiro Account Manager product code not found in registry'",
            "}"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hj01857655/kiro-account-manager/releases/download/v$version/KiroAccountManager_$version_x64_zh-CN.msi"
            }
        }
    }
}
