{"version":"1.1.5","description":"A collaboration friendly studio for NeRFs","homepage":"https://docs.nerf.studio/","license":"Apache-2.0","url":"https://github.com/nerfstudio-project/nerfstudio/archive/refs/tags/v1.1.5.zip","hash":"sha256:4815540d556a1c15c1057da4f6ade4957528ad02f666fe48da7d867842a8a540","extract_dir":"nerfstudio-1.1.5","depends":["pixi"],"checkver":"github","autoupdate":{"url":"https://github.com/nerfstudio-project/nerfstudio/archive/refs/tags/v$version.zip","extract_dir":"nerfstudio-$version"},"post_install":["cd \"$dir\"","conda create --yes --prefix \"$dir/env\" --channel conda-forge python=3.8","conda activate \"$dir/env\"","conda config --env --add channels conda-forge","conda config --env --set channel_priority strict","pip install torch==2.1.2+cu118 torchvision==0.16.2+cu118 --extra-index-url https://download.pytorch.org/whl/cu118","conda install --yes -c \"nvidia/label/cuda-11.8.0\" cuda-toolkit ","pip install git+https://github.com/NVlabs/tiny-cuda-nn/#subdirectory=bindings/torch","pip install ."],"notes":["nerfstudio requires a CUDA 11.8 compatible GPU and driver.","Visual Studio 2022 Build Tools (C++ Desktop Development) must be installed.","The environment is installed into the 'env' subdirectory of the app folder.","Installation takes 20-30 minutes due to heavy compilation requirements."],"from":"https://github.com/Arama0517/scoop-bucket"}
