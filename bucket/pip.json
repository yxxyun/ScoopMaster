{
    "homepage": "https://github.com/pypa/pip",
    "description": "The PyPA recommended tool for installing Python packages",
    "license": "MIT",
    "version": "26.1",
    "url": "https://bootstrap.pypa.io/pip/zipapp/pip-26.1.pyz",
    "hash": "893fd8d1732e609733ce0d649249d3ce1b97b28d8849bfef57b3ab96d641ee00",
    "installer": {
        "script": "New-Item -Type SymbolicLink -Path $scoopdir\\shims\\pip.pyz -Target $dir\\pip-$version.pyz"
    },
    "uninstaller": {
        "script": "Remove-Item -ErrorAction 0 -Path $scoopdir\\shims\\pip.pyz"
    },
    "checkver": {
        "url": "https://pypi.org/pypi/pip/json",
        "jsonpath": "$.info.version"
    },
    "autoupdate": {
        "url": "https://bootstrap.pypa.io/pip/zipapp/pip-$version.pyz"
    }
}
