{"version":"3.5.5","description":"全能协议分析工具：浏览器抓包 + MITM 代理 + 指纹伪装 + AI 分析 + MCP Server 无缝对接 AI Agent/IDE","homepage":"https://github.com/Mouseww/anything-analyzer","license":"MIT","notes":"首次运行工具时需要使用管理员权限，以便正确访问系统代理设置和证书存储。","architecture":{"64bit":{"url":"https://github.com/Mouseww/anything-analyzer/releases/download/v3.5.5/Anything-Analyzer-Setup-3.5.5.exe#/7z","hash":"71ecaf901379c0378976f5faf8005215abfc4ea1229bc78fd995b403f740fabd"}},"pre_install":["Get-ChildItem \"$dir\\`$PLUGINSDIR\\app*.7z\" | Rename-Item -NewName 'app.7z'","Expand-7zipArchive -Path \"$dir\\`$PLUGINSDIR\\app.7z\" \"$dir\"","Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"],"installer":{"script":["if (Test-Path \"$env:AppData\\anything-analyzer\") {","    info '[Persistent AppData]: Moving user data...'","    ensure \"$persist_dir\\UserData\" | Out-Null","    Copy-Item \"$env:AppData\\anything-analyzer\\*\" \"$persist_dir\\UserData\\\" -Recurse -Force -ErrorAction 'SilentlyContinue'","    Remove-Item \"$env:AppData\\anything-analyzer\" -Recurse -Force -ErrorAction 'SilentlyContinue'","}"]},"from":"https://github.com/LXTlogic/Scoop-Patch"}
