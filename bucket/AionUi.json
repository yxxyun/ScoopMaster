        "        }",
        "    }",
        "}",
        "#endregion",
        "Invoke-PortableMappings -Action Uninstall -Context @{ Dir = $dir; PersistDir = $persist_dir } -Mappings @(",
        "    @{ Label = 'roaming'; Source = 'AppData/AionUi'; Target = \"$persist_dir/roaming\"; Strategy = 'symlink'; EnsureTarget = $true; TargetType = 'directory' },",
        "    @{ Label = 'updater'; Source = 'LocalAppData/aionui-updater'; Target = \"$persist_dir/local/aionui-updater\"; Strategy = 'symlink'; EnsureTarget = $true; TargetType = 'file' }",
        ") -Log:$true"
    ]
}
