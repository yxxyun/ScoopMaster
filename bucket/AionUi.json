        "        Remove-Item $Link -Recurse -Force -ErrorAction SilentlyContinue",
        "    }",
        "    New-Item -ItemType SymbolicLink -Path $Link -Target $Target -Force | Out-Null",
        "}",
        "function Remove-PortableLink {",
        "    param(",
        "        [string]$Link,",
