{"version":"20230525","description":"Copy selected code and automatically remove comments, blank lines, and leading/trailing spaces from a selected code snippet.","homepage":"https://github.com/GithubUserAccountAmazing/ShortScript","license":"GPL-3.0-only","depends":"main/autohotkey1.1","notes":["Start ShortScript with Windows by running:","reg import \"$dir\\add-startup.reg\""],"url":"https://github.com/GithubUserAccountAmazing/ShortScript/archive/master.zip","hash":"b75687c4fb9cceff9b582edd27ce71a98a7de5cb86f4f60148915dec0a4a7042","extract_dir":"ShortScript-main","pre_install":"& \"$env:SCOOP\\apps\\autohotkey1.1\\current\\Compiler\\Ahk2Exe.exe\" /in \"$dir\\ShortScript.ahk\" /out \"$dir\\ShortScript.exe\"","post_install":["$shortcutPath = \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\ShortScript.lnk\"","$targetPath = \"$dir\\ShortScript.exe\"","$WshShell = New-Object -ComObject WScript.Shell","$Shortcut = $WshShell.CreateShortcut($shortcutPath)","$Shortcut.TargetPath = $targetPath","$Shortcut.WorkingDirectory = $dir","$Shortcut.Save()","$dirpath = $dir.Replace('\\', '\\\\')","'add-startup.reg', 'remove-startup.reg' | ForEach-Object {","    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_\") {","        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_\"","        $content = $content.Replace('$dir', $dirpath)","        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }","        $content | Set-Content -Path \"$dir\\$_\"","    }","}"],"post_uninstall":["Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\ShortScript.lnk\" -ErrorAction SilentlyContinue","if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }"],"checkver":{"url":"https://api.github.com/repos/GithubUserAccountAmazing/ShortScript/commits?per_page=1","jsonpath":"$[0].commit.author.date","regex":"(\\d{4})-(\\d{2})-(\\d{2}).*","replace":"$1$2$3"},"autoupdate":{"url":"https://github.com/GithubUserAccountAmazing/ShortScript/archive/master.zip"},"from":"https://github.com/scillidan/scoop-shovel"}
