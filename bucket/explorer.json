{
    "version": "0.16.0",
    "description": "Windows File Explorer for macOS, Linux, and Windows.",
    "homepage": "https://github.com/hmerritt/explorer",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/hmerritt/explorer/releases/download/0.16.0/explorer-0.16.0-windows-amd64.zip",
            "hash": "cfdc3757523050d9e30f79031745375a7765925ff32ad43f6a74f628db32832c"
        }
    },
    "pre_install": "if (!(Test-Path \"$dir\\file-explorer.exe\") -and (Test-Path \"$dir\\explorer.exe\")) { Rename-Item \"$dir\\explorer.exe\" 'file-explorer.exe' }",
    "post_install": "if ([version]$Manifest.version -ge [version]'0.16.0' -and (Test-Path \"$dir\\file-explorer.exe\")) { & \"$dir\\file-explorer.exe\" --register-file-associations }",
    "pre_uninstall": "if ([version]$Manifest.version -ge [version]'0.16.0' -and (Test-Path \"$dir\\file-explorer.exe\")) { & \"$dir\\file-explorer.exe\" --unregister-file-associations }",
    "bin": [["file-explorer.exe", "explorer"]],
    "shortcuts": [["file-explorer.exe", "Explorer"]]
}
