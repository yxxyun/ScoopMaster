iliMozi/openhanako"},"autoupdate":{"url":"https://github.com/liliMozi/openhanako/releases/download/v$version/HanaAgent-$version-Windows-x64.exe#/dl.7z","hash":{"url":"https://api.github.com/repos/liliMozi/openhanako/releases/tags/v$version","regex":"\"name\":\\s*\"HanaAgent-$version-Windows-x64\\.exe\"[^}]*\"digest\":\\s*\"sha256:([a-f0-9]{64})\""}},"from":"https://github.com/svier0/scoopbucket"}
