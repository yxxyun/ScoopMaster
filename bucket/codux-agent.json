{
    "version": "2.0.0-rc.5",
    "description": "Codux headless host agent for remote terminals, Git, and AI sessions over encrypted P2P/relay links",
    "homepage": "https://github.com/duxweb/codux",
    "license": "GPL-3.0",
    "notes": [
        "无界面主机端，可通过桌面端或手机远程连接。",
        "安装后运行 codux-agent config 完成配置，codux-agent install 注册为开机启动服务。"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/duxweb/codux/releases/download/v2.0.0-rc.5/codux-agent-2.0.0-rc.5-windows-x86_64.exe",
            "hash": "5ce144b04778543daba2fd8ff5e71cc59a76b9048cfcb86f42746b82d8bdb9cf"
        }
    },
    "installer": {
        "script": [
            "$exe = Get-ChildItem \"$dir\\codux-agent-*-windows-x86_64.exe\", \"$dir\\codux-windows-x86_64.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
            "if ($exe -and $exe.Name -ne 'codux-agent.exe') {",
            "    if (Test-Path \"$dir\\codux-agent.exe\") { Remove-Item \"$dir\\codux-agent.exe\" -Force }",
            "    Rename-Item $exe.FullName 'codux-agent.exe'",
            "}"
        ]
    },
    "bin": "codux-agent.exe",
    "checkver": {
        "github": "https://github.com/duxweb/codux"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/duxweb/codux/releases/download/v$version/codux-agent-$version-windows-x86_64.exe"
            }
        }
    }
}
