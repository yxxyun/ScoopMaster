{
    "version": "15.2.0-1",
    "description": "A binary distribution of the GNU Compiler Collection (GCC) from xPack.",
    "homepage": "https://xpack-dev-tools.github.io/gcc-xpack",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/xpack-dev-tools/gcc-xpack/releases/download/v15.2.0-1/xpack-gcc-15.2.0-1-win32-x64.zip",
            "hash": "be18e491c8da564f0b923d29ca0ffc8927f4a51c883d5827a8eb9c3d5386c5b0"
        }
    },
    "extract_dir": "xpack-gcc-15.2.0-1",
    "env_add_path": "bin",
    "checkver": {
        "github": "https://github.com/xpack-dev-tools/gcc-xpack",
        "regex": "releases/tag/v([\\d.]+-[\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xpack-dev-tools/gcc-xpack/releases/download/v$version/xpack-gcc-$version-win32-x64.zip"
            }
        },
        "hash": {
            "url": "$url.sha",
            "regex": "^([a-fA-F0-9]+)"
        },
        "extract_dir": "xpack-gcc-$version"
    }
}
