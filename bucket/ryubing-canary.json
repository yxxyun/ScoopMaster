{
    "version": "1.3.272",
    "description": "Ryubing Canary - A fork of Ryujinx, a Nintendo Switch emulator",
    "homepage": "https://git.ryujinx.app/Ryubing/Canary",
    "license": {
        "identifier": "MIT",
        "url": "https://git.ryujinx.app/projects/Ryubing/src/branch/master/LICENSE.txt"
    },
    "notes": [
        "ATTENTION: Ryujinx requires Nintendo Switch firmware and a prod.keys file to function.",
        "Learn more at https://git.ryujinx.app/projects/Ryubing/wiki/FAQ-%26-Troubleshooting"
    ],
    "architecture": {
        "64bit": {
            "url": "https://git.ryujinx.app/Ryubing/Canary/releases/download/1.3.272/ryujinx-canary-1.3.272-win_x64.zip"
        }
    },
    "extract_dir": "publish",
    "bin": "Ryujinx.exe",
    "checkver": {
        "url": "https://git.ryujinx.app/Ryubing/Canary/releases",
        "regex": "Canary ([\\d.]+)"
    },
    "shortcuts": [
        [
            "Ryujinx.exe",
            "Ryujinx"
        ]
    ],
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://git.ryujinx.app/Ryubing/Canary/releases/download/$version/ryujinx-canary-$version-win_x64.zip"
            }
        }
    }
}
