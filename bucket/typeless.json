{
    "version": "1.8.0",
    "description": "Typeless - AI智能语音听写输入法，说话即写作，速度比打字快4倍",
    "homepage": "https://www.typeless.com",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.typeless.com/terms"
    },
    "url": "https://typeless-static.com/desktop-release/Typeless-1.8.0-x64-Setup.exe",
    "hash": "7c0eabcc3380ff7b42459934fe04518d05accfea1bd4e66e5a3a94184819813d",
    "installer": {
        "script": [
            "7z e \"$dir\\$fname\" -o\"$dir\\_nsis_temp\" -tnsis -y | Out-Null",
            "$inner7z = Get-ChildItem \"$dir\\_nsis_temp\" -Filter 'app-64.7z' | Select-Object -First 1",
            "if ($inner7z) { 7z x $inner7z.FullName -o\"$dir\" -y | Out-Null }",
            "Remove-Item \"$dir\\_nsis_temp\" -Recurse -Force",
            "Remove-Item \"$dir\\$fname\" -Force"
        ]
    },
    "bin": "Typeless.exe",
    "shortcuts": [
        [
            "Typeless.exe",
            "Typeless"
        ]
    ],
    "checkver": {
        "url": "https://www.typeless.com/help/release-notes/windows",
        "regex": "([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://typeless-static.com/desktop-release/Typeless-$version-x64-Setup.exe"
    }
}
