{
    "version": "140.13.0",
    "description": "Extended Support Release of Firefox: the popular open source web browser. Default profile set.",
    "homepage": "https://www.mozilla.org/en-US/firefox/organizations/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/140.13.0esr/win64/en-US/Firefox%20Setup%20140.13.0esr.exe#/dl.7z",
            "hash": "sha512:3f2ac5d540587b438ca61bbe53525b65785d8e40e09c1e0634a06583e3cce40ea89ae9a711401afcfbb1df1dd7e361e756ae4ac382f78dfe69b7a671039ebb14"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/140.13.0esr/win32/en-US/Firefox%20Setup%20140.13.0esr.exe#/dl.7z",
            "hash": "sha512:3d9578f6db2c488b7c931ebd7fcae27052d521fc982d10a44258a560283f303d51fe7af4450c168227f43d38a950e0868ba6dd5e46b55ab400940cb9b5d7e6ae"
        }
    },
    "extract_dir": "core",
    "post_install": [
        "if (-Not (Test-Path \"$persist_dir\\profile\\prefs.js\")) {",
        "  Copy-Item \"$bucketsdir\\ru-school\\scripts\\firefox\\prefs.js\" \"$persist_dir\\profile\\prefs.js\" | Out-Null",
        "}",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "bin": [
        [
            "firefox.exe",
            "firefox-esr"
        ]
    ],
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox ESR",
            "-profile \"$persist_dir\\profile\""
        ],
        [
            "firefox.exe",
            "Firefox ESR Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://aus5.mozilla.org/update/6/Firefox/78.0/_/WINNT_x86_64-msvc-x64/en-US/esr/_/_/_/_/update.xml",
        "xpath": "/updates/update/@appVersion"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/win64/en-US/Firefox%20Setup%20$versionesr.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/SHA512SUMS",
                    "regex": "$sha512\\s+win64/en-US/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/win32/en-US/Firefox%20Setup%20$versionesr.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$versionesr/SHA512SUMS",
                    "regex": "$sha512\\s+win32/en-US/$basename"
                }
            }
        }
    }
}
