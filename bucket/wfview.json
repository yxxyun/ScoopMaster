{
    "version": "2.23",
    "description": "wfview is open-source software for the control of modern Icom radios",
    "homepage": "https://wfview.org",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://wfview.org/download/windows-x64-release-v2-23/?wpdmdl=1810/#dl.exe",
            "hash": "00bac32327779ff3f499b1f0d7c693289de661edce125e9bca65e53c4a03fc2d"
        },
        "32bit": {
            "url": "https://wfview.org/download/windows-x86-release-v2-23/?wpdmdl=1812/#dl.exe",
            "hash": "0fed3cbb5297641ad7469237223054378dcd64dfff3993e06684d59098fd48f9"
        }
    },
    "pre_install": "(Get-ChildItem \"$dir\\$fname\")[0] | Rename-Item -NewName \"$dir\\installer.exe\"",
    "installer": {
        "file": "installer.exe",
        "args": [
            "--root",
            "$dir\\wfview",
            "--accept-licenses",
            "--default-answer",
            "--confirm-command",
            "install"
        ]
    },
    "uninstaller": {
        "file": "wfview\\wfviewmaintenancetool.exe",
        "args": [
            "--confirm-command",
            "purge",
            "wfview"
        ]
    },
    "shortcuts": [
        [
            "wfview\\wfview.exe",
            "wfview"
        ]
    ],
    "checkver": {
        "script": [
            "$search_url = 'https://wfview.org/wp-json/wpdm/search';",
            "$j = Invoke-WebRequest $search_url -UseBasicParsing | ConvertFrom-Json;",
            "$win64 = ($j.packages | Where-Object post_title -match \".*Windows \\(x64\\).*\")[0];",
            "$win32 = ($j.packages | Where-Object post_title -match \".*Windows \\(x86\\).*\")[0];",
            "$win64.post_title -match '.*v([\\d.]+).*';",
            "$ver = $matches[1];",
            "Write-Output $ver $win64.id $win32.id"
        ],
        "regex": "(?<version>[\\d.]+)\\s+(?<win64>\\d+)\\s+(?<win32>\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://wfview.org/download/windows-x64-release-v$dashVersion/?wpdmdl=$matchWin64/#dl.exe"
            },
            "32bit": {
                "url": "https://wfview.org/download/windows-x86-release-v$dashVersion/?wpdmdl=$matchWin32/#dl.exe"
            }
        }
    }
}
