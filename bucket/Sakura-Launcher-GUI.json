{
    "version": "1.2.0-beta",
    "description": "A GUI Launcher for Sakura LLM",
    "homepage": "https://github.com/PiDanShouRouZhouXD/Sakura_Launcher_GUI",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/PiDanShouRouZhouXD/Sakura_Launcher_GUI/releases/download/v1.2.0-beta/Sakura_Launcher_GUI_v1.2.0-beta.exe",
            "hash": "9acd3bc186a30f2d6271a3e2bd49a5bc451086cb6f72e7d8ed83bbb7af46f3af"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\sakura-launcher_config.json\")) {",
        "    Set-Content \"$dir\\sakura-launcher_config.json\" '{\"llamacpp_path\": \"./llama\", \"model_search_paths\": \"./models/\"}' -Encoding UTF8",
        "}"
    ],
    "bin": "Sakura_Launcher_GUI_v1.2.0-beta.exe",
    "shortcuts": [
        [
            "Sakura_Launcher_GUI_v1.2.0-beta.exe",
            "Sakura Launcher GUI"
        ]
    ],
    "persist": [
        "sakura-launcher_config.json",
        "llama",
        "models"
    ],
    "checkver": {
        "github": "https://github.com/PiDanShouRouZhouXD/Sakura_Launcher_GUI",
        "regex": "/releases/tag/v([\\d.]+(?:-[a-zA-Z0-9]+)?)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PiDanShouRouZhouXD/Sakura_Launcher_GUI/releases/download/v$version/Sakura_Launcher_GUI_v$version.exe"
            }
        },
        "bin": "Sakura_Launcher_GUI_v$version.exe",
        "shortcuts": [
            [
                "Sakura_Launcher_GUI_v$version.exe",
                "Sakura Launcher GUI"
            ]
        ]
    }
}
