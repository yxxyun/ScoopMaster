{
    "version": "3.7",
    "description": "ADIF Master is a highly user-configurable Windows application for working with HAM radio logbooks in ADIF format.",
    "homepage": "https://www.dxshell.com/adif-master.html",
    "license": "Freeware",
    "url": "https://www.dxshell.com/downloads/ADIFMasterSetup.zip",
    "hash": "8614c479f2b58d6eec6567816bbbed1c133c601475611f6908724916fff1a81f",
    "depends": "innounp",
    "pre_install": [
        "if (Test-Path \"$dir\\setup.exe\") {",
        "    Write-Host 'Extracting Inno Setup binaries directly to bypass Admin requirements...'",
        "    & innounp -x -d\"$dir\" \"$dir\\setup.exe\" | Out-Null",
        "    Remove-Item \"$dir\\setup.exe\" -Force",
        "}"
    ],
    "installer": {
        "script": [
            "if (Test-Path \"$dir\\{app}\") {",
            "    Get-ChildItem \"$dir\\{app}\\*\" | Move-Item -Destination \"$dir\" -Force",
            "    Remove-Item \"$dir\\{app}\" -Recurse -Force",
            "}"
        ]
    },
    "shortcuts": [
        [
            "flamp.exe",
            "flamp"
        ]
    ],
    "shortcuts": [
        [
            "ADIFMaster.exe",
            "ADIF Master"
        ]
    ],
    "checkver": {
        "url": "https://www.dxshell.com/adif-master.html",
        "regex": "Current version: ([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://www.dxshell.com/downloads/ADIFMasterSetup.zip"
    }
}
