        "            }",
        "            if ($targetType -ne 'file') {",
        "                if ((Test-Path $sourcePath) -and -not (Get-Item $sourcePath -ErrorAction SilentlyContinue).LinkType) {",
        "                    Copy-PortableData -Source $sourcePath -Destination $targetPath",
