{
    "version": "2.0.1",
    "description": "Cross-platform screenshot tool for Windows, Mac, iOS, and Android",
    "homepage": "https://www.ntwind.com/software/screenshotremote.html",
    "license": "Proprietary",
    "url": "https://www.ntwind.com/download/ScreenshotRemote_2.0.1-win-x64.exe",
    "installer": {
        "script": [
            "Start-Process \"$dir\\$fname\" -ArgumentList '/S' -Wait",
            "Remove-Item \"$dir\\$fname\""
        ]
    },
    "uninstaller": {
        "script": [
            "$uninstall = Get-ItemProperty HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\* | Where-Object {$_.DisplayName -like '*Screenshot Remote*'}",
            "if ($uninstall) {",
            "    Start-Process $uninstall.UninstallString -ArgumentList '/S' -Wait",
            "}"
        ]
    },
    "checkver": {
        "url": "https://www.ntwind.com/download-all.html",
        "regex": "ScreenshotRemote_([\\d.]+)-win-x64\\.exe"
    },
    "autoupdate": {
        "url": "https://www.ntwind.com/download/ScreenshotRemote_$version-win-x64.exe"
    },
    "hash": "95d792e50d48b49214c87f07a3bdb67bd7fc2f0786f87bad9abcb84df631a62d"
}
