{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "1.0.0",
   "description": "This bridges communication between Pageant and Windows Subsystem for Linux (WSL).",
   "notes": [
      "Add to startup:",
      "New-ItemProperty -Path HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run -Name 'WSL SSH Pageant Bridge' -PropertyType String -Value 'conhost.exe --headless wsl-ssh-pageant-bridge.cmd'",
      "",
      "Remove from startup:",
      "Remove-ItemProperty -Path HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run -Name 'WSL SSH Pageant Bridge'"
   ],
   "suggest": {
      "Pageant": "silver886/pageant",
      "npiperelay": "extras/npiperelay"
   },
   "url": [
      "https://raw.githubusercontent.com/silver886/scoop/wsl-ssh-pageant-bridge/v1.0.0/assets/wsl-ssh-pageant-bridge/script.ps1",
      "https://raw.githubusercontent.com/silver886/scoop/wsl-ssh-pageant-bridge/v1.0.0/assets/wsl-ssh-pageant-bridge/launch.cmd"
   ],
   "hash": [
      "b000f06787393b8c5f3dcc35891ab8f26edaebee05e97f9ab3f10bea868a7bb0",
      "1e24ad26f8e9a14f73ada8a043d2d8b03b50b3277ae019361566c050730ae304"
   ],
   "pre_install": [
      "if (where.exe /q wsl || $true) {",
      "   error 'wsl should be installed'",
      "}",
      "if (where.exe /q pageant || $true) {",
      "   error 'Pageant should be installed'",
      "}",
      "if (where.exe /q npiperelay || $true) {",
      "   error 'npiperelay should be installed'",
      "}"
   ],
   "bin": [
      [
         "launch.cmd",
         "wsl-ssh-pageant-bridge"
      ]
   ],
   "env_set": {
      "WSL_SSH_PAGEANT_BRIDGE_SOCK": "`$HOME/.ssh/wsl-ssh-pageant-bridge",
      "WSLENV": "$($env:WSLENV):WSL_SSH_PAGEANT_BRIDGE_SOCK"
   },
   "checkver": {
      "url": "https://api.github.com/repos/silver886/scoop/tags",
      "regex": "\"name\": *\"wsl-ssh-pageant-bridge/v([\\d.]+)\","
   },
   "autoupdate": {
      "url": [
         "https://raw.githubusercontent.com/silver886/scoop/wsl-ssh-pageant-bridge/v$version/assets/wsl-ssh-pageant-bridge/script.ps1",
         "https://raw.githubusercontent.com/silver886/scoop/wsl-ssh-pageant-bridge/v$version/assets/wsl-ssh-pageant-bridge/launch.cmd"
      ]
   }
}
