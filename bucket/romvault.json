{
    "version": "3.7.6",
    "description": "Multi-DAT ROM management software",
    "homepage": "https://www.romvault.com/",
    "license": "Freeware",
    "url": "https://www.romvault.com/download/ROMVault_V3.7.6.zip",
    "hash": "7dec2392b5b67b41f5480898491b8d0c2dfa8a01efdf726a4020ce5315ac4943",
    "persist": [
        "config",
        "graphics.zip",
        "DATRoot",
        "ROMRoot",
        "ToSort"
    ],
    "pre_install": [
        "Get-ChildItem $dir -Filter ROMVault*.exe | ForEach-Object { Rename-Item $_.FullName ROMVault.exe }",
        "if (Test-Path \"$persist_dir\\RomVault3.Cache\") { Copy-Item \"$persist_dir\\RomVault3.Cache\" \"$persist_dir\\RomVault3.Cache.old\" }"
    ],
    "post_install": "if (Test-Path \"$persist_dir\\RomVault3.Cache\") { Copy-Item \"$persist_dir\\RomVault3.Cache\" \"$dir\\\" }",
    "pre_uninstall": "Copy-Item $dir\\RomVault3.Cache $persist_dir\\RomVault3.Cache",
    "shortcuts": [
        [
            "ROMVault.exe",
            "ROMVault"
        ]
    ],
    "checkver": {
        "regex": "RomVault V([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://www.romvault.com/download/ROMVault_V$version.zip"
    }
}
