{
    "version": "2.0.1",
    "description": "Cross-platform clipboard sharing tool for Windows, Mac, iOS, and Android",
    "homepage": "https://www.ntwind.com/software/clipboardremote.html",
    "license": "Proprietary",
    "url": "https://www.ntwind.com/download/ClipboardRemote_2.0.1-win-x64.exe",
    "installer": {
        "script": [
            "Start-Process \"$dir\\$fname\" -ArgumentList '/S' -Wait",
            "Remove-Item \"$dir\\$fname\""
        ]
    },
    "uninstaller": {
        "script": [
            "$uninstall = Get-ItemProperty HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\* | Where-Object {$_.DisplayName -like '*Clipboard Remote*'}",
            "if ($uninstall) {",
            "    Start-Process $uninstall.UninstallString -ArgumentList '/S' -Wait",
            "}"
        ]
    },
    "checkver": {
        "url": "https://www.ntwind.com/download-all.html",
        "regex": "ClipboardRemote_([\\d.]+)-win-x64\\.exe"
    },
    "autoupdate": {
        "url": "https://www.ntwind.com/download/ClipboardRemote_$version-win-x64.exe"
    },
    "hash": "fe0cc606ee9c427bd67d0939c8a4b6dc6a0dcb89fc67cf647d8adce229229a9d"
}
