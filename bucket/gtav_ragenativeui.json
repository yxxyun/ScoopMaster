{
    "version": "1.9.3",
    "description": "A library for RAGEPluginHook that helps you to quickly and easily build Rockstar-like menus and UIs",
    "homepage": "https://github.com/alexguirre/RAGENativeUI",
    "license": "MIT",
    "url": "https://github.com/alexguirre/RAGENativeUI/releases/download/1.9.3/RAGENativeUI.zip",
    "hash": "deea861389d9ad08934f7559a27fb602147ef8607d865d13fa03337282d203ce",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "Move-Item \"$dir\\RAGENativeUI.dll\" \"$env:GTAV_PATH\" -Force",
        "Remove-Item \"$dir\\*\""
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/alexguirre/RAGENativeUI/releases/download/$version/RAGENativeUI.zip"
    }
}
