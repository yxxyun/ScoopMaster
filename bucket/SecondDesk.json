{
    "version": "1.3.0",
    "description": "A modern Windows desktop file manager built with Rust + Tauri 2.x + Vue 3, featuring drawer-style design for quick access to desktop files",
    "homepage": "https://github.com/Ryanisgood/SecondDesk",
    "license": "GPL-3.0-only",
    "notes": [
        "Second Desk 是一款现代化的 Windows 桌面文件管理工具",
        "采用抽屉式设计，通过屏幕边缘触发或全局快捷键快速呼出",
        "用户数据目录：%LOCALAPPDATA%\\com.seconddesk.app\\",
        "  - drawer_config.json : 抽屉配置（边缘触发、快捷键、动画等）",
        "  - logs/ : 应用日志",
        "  - icon_cache/ : 文件图标缓存",
        "本包会将该目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Ryanisgood/SecondDesk/releases/download/v1.3.0/SecondDesk-v1.3.0-Windows-Setup.exe#/dl.7z",
            "hash": "7d5cdce9211b9471890d3684dc0d3c33dfe59bfa33da570a7afb8c60b17d5ff8"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninstall.exe\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": "second-desk.exe",
    "shortcuts": [
        [
            "second-desk.exe",
            "Second Desk"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:LOCALAPPDATA 'com.seconddesk.app'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/Ryanisgood/SecondDesk"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Ryanisgood/SecondDesk/releases/download/v$version/SecondDesk-v$version-Windows-Setup.exe#/dl.7z"
            }
        }
    }
}
