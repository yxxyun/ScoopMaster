{
    "version": "1.3.1",
    "description": "A voice-to-text paste utility for Windows with local AI processing.",
    "homepage": "https://github.com/infiniV/VoiceFlow",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/infiniV/VoiceFlow/releases/download/v1.3.1/VoiceFlowSetup-1.3.1.exe",
            "hash": "22FD6AD2D5E15F3594B7EB24BE2F610B1A83FBDA1766630BEF9560067A1A1827"
        }
    },
    "installer": {
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
            "/NORESTART",
            "/SP-",
            "/NOICONS",
            "/DIR=\"$dir\""
        ]
    },
    "uninstaller": {
        "file": "unins000.exe",
        "args": [
            "/VERYSILENT",
            "/SUPPRESSMSGBOXES",
