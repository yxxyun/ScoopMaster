        ]
    },
    "bin": "VoiceFlow.exe",
    "shortcuts": [
        [
            "VoiceFlow.exe",
            "VoiceFlow"
        ]
    ],
    "checkver": {
        "github": "https://github.com/infiniV/VoiceFlow",
        "regex": "VoiceFlowSetup-(?<version>[\\d.]+)\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/infiniV/VoiceFlow/releases/download/v$version/VoiceFlowSetup-$version.exe",
                "hash": {
                    "mode": "json",
                    "url": "https://api.github.com/repos/infiniV/VoiceFlow/releases/latest",
                    "jsonpath": "$.assets[?(@.name == 'VoiceFlowSetup-$version.exe')].digest"
                }
            }
        }
    }
