{
    "version": "0.1.56",
    "description": "Cross-platform download manager with multi-protocol (HTTP/2/HTTPS/FTP/BitTorrent) support, resumable & segmented downloading, zero ads, zero tracking, local-first privacy design. [Portable Edition]",
    "homepage": "https://fluxdown.zerx.dev/",
    "license": {
        "identifier": "Freeware",
        "url": "https://fluxdown.zerx.dev/terms"
    },
    "architecture": {
        "64bit": {
            "url": "https://fluxdown.zerx.dev/api/download/FluxDown-0.1.56-windows-x64-portable.zip",
            "hash": "ad51808d93a244aee1f72d5f28c997e0a0f81fd554f690a72a638573a1583fa4"
        },
        "arm64": {
            "url": "https://fluxdown.zerx.dev/api/download/FluxDown-0.1.56-windows-arm64-portable.zip",
            "hash": "f8c3c74d5ffccfd3a43b330e79715a864ebd616b943004b41ab0b89a832d2ef2"
        }
    },
    "bin": "flux_down.exe",
    "shortcuts": [
        [
            "flux_down.exe",
            "FluxDown"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\FluxDown\" \"$persist_dir\\AppData\" -Migrate",
            "# The portable FluxDown saves SQLite database in program directory.",
            "# To avoid data loss, we turn it into non-portable.",
            "Remove-Item \"$dir\\portable\" -Force",
            "New-PersistDirectory \"$env:LOCALAPPDATA\\FluxDown\" \"$persist_dir\\LocalAppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\FluxDown\"",
        "Remove-Junction \"$env:LOCALAPPDATA\\FluxDown\""
    ],
    "checkver": {
        "url": "https://fluxdown.zerx.dev/api/release",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://fluxdown.zerx.dev/api/download/FluxDown-$version-windows-x64-portable.zip"
            },
            "arm64": {
                "url": "https://fluxdown.zerx.dev/api/download/FluxDown-$version-windows-arm64-portable.zip"
            }
        }
    }
}
