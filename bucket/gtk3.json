{"version":"2026.6.0","description":"GTK stack for Windows (GTK 3)","homepage":"https://github.com/wingtk/gvsbuild","license":"GPL-2.0","url":"https://github.com/wingtk/gvsbuild/releases/download/2026.6.0/GTK3_Gvsbuild_2026.6.0_x64.zip","hash":"24a422da5e44d168d13b8b8161a37f3c0a0598f1fd54c76a0fd87a3f4b85ef82","post_install":["$bin_path = Join-Path $dir \"bin\"","$lib_path = Join-Path $dir \"lib\"","$inc_path = Join-Path $dir \"include\"","$inc_paths = @(","    Join-Path $inc_path \"cairo\"","    Join-Path $inc_path \"glib-2.0\"","    Join-Path $inc_path \"gobject-introspection-1.0\"","    Join-Path $lib_path \"glib-2.0\\include\"",")","$env_key = (Get-Item -Path 'HKCU:').OpenSubKey('Environment', $true)","$env_key.SetValue(\"Path\", \"${bin_path};$($env:Path)\", \"ExpandString\")","$env_key.SetValue(\"LIB\", \"${lib_path};$($env:LIB)\", \"ExpandString\")","$env_key.SetValue(\"INCLUDE\", \"${inc_path};$($inc_paths -join \";\");$($env:INCLUDE)\", \"ExpandString\")"],"checkver":{"github":"https://github.com/wingtk/gvsbuild"},"autoupdate":{"url":"https://github.com/wingtk/gvsbuild/releases/download/$version/GTK3_Gvsbuild_$version_x64.zip"},"from":"https://github.com/fraizdev/scoop"}
