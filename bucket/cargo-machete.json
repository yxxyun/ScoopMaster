{
  "version": "0.9.2",
  "description": "Remove unused Rust dependencies.",
  "homepage": "https://github.com/bnjbvr/cargo-machete",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/bnjbvr/cargo-machete/releases/download/v0.9.2/cargo-machete-v0.9.2-x86_64-pc-windows-msvc.tar.gz",
      "hash": "996120ac70afe405c58fce508a476f25bb71032c6fb8013aa0123bba36429c76",
      "extract_dir": "cargo-machete-v0.9.2-x86_64-pc-windows-msvc"
    }
  },
  "bin": "cargo-machete.exe",
  "checkver": {
    "github": "https://github.com/bnjbvr/cargo-machete",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/bnjbvr/cargo-machete/releases/download/v$version/cargo-machete-v$version-x86_64-pc-windows-msvc.tar.gz",
        "extract_dir": "cargo-machete-v$version-x86_64-pc-windows-msvc"
      }
    },
    "hash": {
      "url": "$url.sha256",
      "regex": "([a-fA-F0-9]{64})"
    }
  }
}
