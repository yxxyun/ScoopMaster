{
    "version": "4.25.6",
    "description": "Open-source AI Coding Agent in your terminal. Alternative to Claude Code / Cursor Agent.",
    "homepage": "https://atomcode.atomgit.com/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://atomgit.com/atomgit_atomcode/atomcode/releases/download/v4.25.2/atomcode-v4.25.2-windows-x64.exe#/atomcode.exe"
        },
        "arm64": {
            "url": "https://atomgit.com/atomgit_atomcode/atomcode/releases/download/v4.25.2/atomcode-v4.25.2-windows-arm64.exe#/atomcode.exe"
        }
    },
    "bin": "atomcode.exe",
    "pre_install": [
        "# 将 ~/.atomcode 软链接到 persist/data，升级时数据不丢失",
        "$atomcode_dir = Join-Path $env:USERPROFILE \".atomcode\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $atomcode_dir $persist_data"
    ],
    "post_uninstall": [
        "$atomcode_dir = Join-Path $env:USERPROFILE \".atomcode\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $atomcode_dir"
    ],
    "persist": ["data"],
    "checkver": {
        "url": "https://api.atomgit.com/api/v5/repos/atomgit_atomcode/atomcode/releases/latest",
        "jsonpath": "$.tag_name",
        "re": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://atomgit.com/atomgit_atomcode/atomcode/releases/download/v$version/atomcode-v$version-windows-x64.exe#/atomcode.exe"
            },
            "arm64": {
                "url": "https://atomgit.com/atomgit_atomcode/atomcode/releases/download/v$version/atomcode-v$version-windows-arm64.exe#/atomcode.exe"
            }
        }
    }
}
