{"_comment":"This is a template for the Scoop manifest. The version and hash are updated automatically by the release workflow.","version":"0.3.0","description":"A CLI tool with a TUI to quickly and safely switch environment variables in a PowerShell session.","homepage":"https://github.com/gennobou/gnb-envswap","license":"MIT","architecture":{"64bit":{"url":"https://github.com/GennoBou/gnb-envswap/releases/download/v0.3.0/gnb-envswap-v0.3.0.zip","hash":"a00b56179f023a7f2cacbc9ca4ccdf4a8ec726ad7e05866a68cc9ada0bc43336"}},"bin":"gnb-envswap.exe","checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/GennoBou/gnb-envswap/releases/download/v0.3.0/gnb-envswap-v0.3.0.zip"}}},"post_install":["$profile = $PROFILE","if (!(Test-Path $profile)) {","    Write-Host \"Creating PowerShell profile: $profile\"","    New-Item -Path $profile -ItemType File -Force | Out-Null","}","$funcDef = \"function envswap { gnb-envswap | Invoke-Expression }\"","$content = Get-Content $profile -Raw","if ($content -notmatch 'function\\s+envswap\\s*\\{') {","    $block = \"`n# Added by gnb-envswap installer`n$funcDef`n\"","    Add-Content -Path $profile -Value $block","    Write-Host \"'envswap' function added to your PowerShell profile. Please restart your shell or run '. $profile' to use it.\"","} else {","    Write-Host \"'envswap' function already exists in your PowerShell profile. No changes were made.\"","}"],"post_uninstall":["$profile = $PROFILE","if (Test-Path $profile) {","    $content = Get-Content $profile -Raw","    $pattern = '(?sm)^\\s*# Added by gnb-envswap installer\\s*?.*?function envswap\\s*\\{.*?\\}\\s*?`n?'","    if ($content -match $pattern) {","        $newContent = $content -replace $pattern, ''","        $newContent.Trim() | Set-Content -Path $profile -NoNewline","        Write-Host \"'envswap' function removed from your PowerShell profile.\"","    }","}"],"from":"https://github.com/GennoBou/scoop-bucket"}
