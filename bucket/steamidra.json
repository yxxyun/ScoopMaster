{
    "version": "6.4.2",
    "description": "Advanced Steam game setup and management tool featuring manifest handling, Lua integrations, LumaCore deployment, multiplayer fixes, DLC unlocking, backups, game fixes, and an easy-to-use GUI",
    "homepage": "https://github.com/Midrags/SFF",
    "license": "GPL-3.0",
    "url": "https://github.com/Midrags/SFF/releases/download/v6.4.2/SteaMidra-6.4.2-Setup.exe#/dl.7z",
    "hash": "20b7f164ed48aaaded578903f9a2ee0fabfc50ffcf42451ace98aeae92f294cc",
    "pre_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\SteaMidra.ico\", \"$dir\\Uninstall.exe\" -Force -Recurse",
        "",
        "if (!(Test-Path \"$persist_dir\\settings.bin\")) {",
        "    Write-Host 'File settings.bin does not exists. Creating.' -f Yellow",
        "    Start-Process -FilePath \"$dir\\SteaMidra_GUI.exe\" -WindowStyle Hidden",
        "    while (!(Test-Path \"$dir\\settings.bin\")) {",
        "        Start-Sleep -Milliseconds 500",
        "    }",
        "    Stop-Process -Name 'SteaMidra_GUI' -Force",
        "}"
    ],
    "shortcuts": [
        [
            "SteaMidra_GUI.exe",
            "SteaMidra"
        ]
    ],
    "persist": [
        "manifests",
        "save_backups",
        "saved_lua",
        "settings.bin"
    ],
    "pre_uninstall": [
        "Stop-Process -Name 'SteaMidra_GUI' -Force -ErrorAction SilentlyContinue",
        "Copy-Item \"$dir\\settings.bin\" \"$persist_dir\" -Force"
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/Midrags/SFF/releases/download/v$version/SteaMidra-$version-Setup.exe#/dl.7z"
    }
}
