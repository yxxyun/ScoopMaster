{
    "version": "6.2.6",
    "description": "Full-featured Steam manifest tool with GUI, DLC unlockers, multiplayer fixes, GreenLuma AppList management, library scanner, backups, and more",
    "homepage": "https://github.com/Midrags/SFF",
    "license": "GPL-3.0",
    "url": "https://github.com/Midrags/SFF/releases/download/v6.2.6/SteaMidra-6.2.6-Setup.exe#/dl.7z",
    "hash": "b12f00bfa56797c9f89fbb72f3a94299f08bb6c570800045479997b1e91c2afc",
    "pre_install": [
        "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\SteaMidra.ico\" -Force -Recurse",
        "",
        "if (!(Test-Path \"$persist_dir\\settings.bin\")) {",
        "    Write-Host 'File settings.bin does not exists. Creating.' -f Yellow",
        "    Start-Process -FilePath \"$dir\\SteaMidra_GUI.exe\"",
        "    while (!(Test-Path \"$dir\\settings.bin\")) {",
        "        Start-Sleep -Milliseconds 500",
        "    }",
        "    Stop-Process -Name 'SteaMidra_GUI' -Force",
        "}"
    ],
    "shortcuts": [
        [
            "SteaMidra_GUI.exe",
            "SteaMidra"
        ]
    ],
    "persist": [
        "manifests",
        "saved_lua",
        "settings.bin"
    ],
    "pre_uninstall": "Stop-Process -Name 'SteaMidra_GUI' -Force -ErrorAction SilentlyContinue",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/Midrags/SFF/releases/download/v$version/SteaMidra-$version-Setup.exe#/dl.7z"
    }
}
