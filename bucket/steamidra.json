{
    "version": "6.0.4",
    "description": "Full-featured Steam manifest tool with GUI, DLC unlockers, multiplayer fixes, GreenLuma AppList management, library scanner, backups, and more",
    "homepage": "https://github.com/Midrags/SFF",
    "license": "GPL-3.0",
    "url": "https://github.com/Midrags/SFF/releases/download/v6.0.4/SteaMidra-6.0.4-windows.zip",
    "hash": "e503370135af15436a06c19b02a03ae4510392ef35b7203a07c858283abce731",
    "extract_dir": "SteaMidra_GUI",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\greenluma\")) {",
        "   New-item \"$dir\\greenluma\" -ItemType Directory | Out-Null",
        "   New-item \"$dir\\greenluma\\applist\" -ItemType Directory | Out-Null",
        "}",
        "if ((Test-Path \"$persist_dir\\settings.bin\") -and !(Test-Path \"$dir\\settings.bin\")) {",
        "   Copy-Item \"$persist_dir\\settings.bin\" \"$dir\"",
        "}"
    ],
    "shortcuts": [
        [
            "SteaMidra_GUI.exe",
            "SteaMidra"
        ]
    ],
    "persist": [
        "applist_profiles",
        "greenluma",
        "manifests",
        "saved_lua"
    ],
    "pre_uninstall": "Copy-Item \"$dir\\settings.bin\" \"$persist_dir\" -Force -ErrorAction SilentlyContinue",
    "checkver": {
        "github": "https://github.com/Midrags/SFF",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/Midrags/SFF/releases/download/v$version/SteaMidra-$version-windows.zip"
    }
}
