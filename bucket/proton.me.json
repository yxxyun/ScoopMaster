{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "0.2.2",
   "description": "Wraps https://proton.me/.",
   "homepage": "https://github.com/silver886/NEST/",
   "license": "MIT",
   "url": [
      "https://github.com/silver886/NEST/releases/download/v0.2.2/me.proton.exe",
      "https://github.com/silver886/NEST/archive/refs/tags/v0.2.2.zip"
   ],
   "hash": [
      "224fd9deaeb28d4f6e2da68272f3a717f6776ff00711cfe0d703a6a0adff2da6",
      "dc43c00826e1df2e2a7aeba902154a00b65f29b6cb720bc07a036e1c4afe9945"
   ],
   "extract_dir": "nest-0.2.2\\icon\\proton\\ico",
   "extract_to": "",
   "installer": {
      "script": [
         "$protonExe = \"$dir\\me.proton.exe\"",
         "$protonMailIcon = \"$dir\\mail.ico\"",
         "$protonMailName = 'Proton Mail'",
         "$protonMailDescription = 'Keeps your conversations private with encrypted email service.'",
         "$protonMailClassId = \"mailto-mail.$app\"",
         "$registryPath = \"Registry::HKCU\\Software\\Classes\\$protonMailClassId\"",
         "New-Item -Force -Path \"$registryPath\" > $null",
         "Set-Item -Force -Path \"$registryPath\" -Value \"$protonMailName\" > $null",
         "$registryPath = \"Registry::HKCU\\Software\\Classes\\$protonMailClassId\\DefaultIcon\"",
         "New-Item -Force -Path \"$registryPath\" > $null",
         "Set-Item -Force -Path \"$registryPath\" -Value \"$protonMailIcon\" > $null",
         "$registryPath = \"Registry::HKCU\\Software\\Classes\\$protonMailClassId\\Capabilities\"",
         "New-Item -Force -Path \"$registryPath\" > $null",
         "New-ItemProperty -Force -Path \"$registryPath\" -Name 'ApplicationDescription' -PropertyType String -Value \"$protonMailDescription\" > $null",
         "New-ItemProperty -Force -Path \"$registryPath\" -Name 'ApplicationIcon' -PropertyType String -Value \"$protonMailIcon\" > $null",
         "New-ItemProperty -Force -Path \"$registryPath\" -Name 'ApplicationName' -PropertyType String -Value \"$protonMailName\" > $null",
         "$registryPath = \"Registry::HKCU\\Software\\Classes\\$protonMailClassId\\Capabilities\\URLAssociations\"",
         "New-Item -Force -Path \"$registryPath\" > $null",
         "New-ItemProperty -Force -Path \"$registryPath\" -Name 'mailto' -PropertyType String -Value \"$protonMailClassId\" > $null",
         "$registryPath = \"Registry::HKCU\\Software\\Classes\\$protonMailClassId\\shell\\open\\command\"",
         "New-Item -Force -Path \"$registryPath\" > $null",
         "Set-Item -Force -Path \"$registryPath\" -Value \"`\"$protonExe`\" `\"%1`\"\"",
         "New-ItemProperty -Force -Path 'Registry::HKCU\\Software\\RegisteredApplications' -Name \"$protonMailName\" -PropertyType String -Value \"Software\\Classes\\$protonMailClassId\\Capabilities\" > $null"
      ]
   },
   "uninstaller": {
      "script": [
         "$protonMailClassId = \"mailto-mail.$app\"",
         "$protonMailName = 'Proton Mail'",
         "Remove-Item -Force -Recurse -Path \"Registry::HKCU\\Software\\Classes\\$protonMailClassId\"",
         "Remove-ItemProperty -Force -Path 'Registry::HKCU\\Software\\RegisteredApplications' -Name \"$protonMailName\""
      ]
   },
   "bin": [
      [
         "me.proton.exe",
         "proton"
      ]
   ],
