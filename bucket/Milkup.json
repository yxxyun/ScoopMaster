{
    "version": "1.0.10",
    "description": "A Markdown editor built with Milkup core and Vue.js",
    "homepage": "https://github.com/Auto-Plugin/milkup",
    "license": "MIT",
    "notes": [
        "milkup 是一个基于 Milkup core 和 Vue.js 的 Markdown 编辑器",
        "上游主进程将更新缓存、无文件场景下的本地图片资源等写入 Electron 的 userData 目录",
        "结合 package.json 中 name=milkup 与 build.productName=milkup，可确认用户数据目录为 %APPDATA%\\milkup\\",
        "本包会将该目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Auto-Plugin/milkup/releases/download/v1.0.10/milkup.Setup.1.0.10.exe#/dl.7z",
            "hash": "99140e69d3bc44fcbea9fa7579a2a26759a57eb7100b17913e09e0e603e3d312"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "milkup.exe",
    "shortcuts": [
        [
            "milkup.exe",
            "milkup"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'milkup'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/Auto-Plugin/milkup"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Auto-Plugin/milkup/releases/download/v$version/milkup.Setup.$version.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
