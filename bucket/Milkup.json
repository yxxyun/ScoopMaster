{
    "version": "1.0.18",
    "description": "A Markdown editor built with Milkup core and Vue.js",
    "homepage": "https://github.com/maqibg/milkup",
    "license": "MIT",
    "notes": [
        "fork 源码确认应用自管理数据通过 Electron userData 和前端 localStorage 持久化",
        "  - userData 下会写入 updates\\ 更新缓存，以及无当前文件场景下的本地图片目录（默认 /assets 相对 userData）",
        "  - 前端配置项如 milkup-config、milkup-ai-config、custom-themes、theme-name 等通过 localStorage 持久化，实际也落在 Electron userData 下",
        "结合 package.json 中 name=milkup、build.productName=milkup，且源码未覆盖 app.setPath('userData', ...)，可由 Scoop 接管的个人数据根目录为 %APPDATA%\\milkup\\",
        "用户自己选择的 Markdown 文件、工作区目录，以及相对当前文件保存的图片资源属于用户文档，不纳入 Scoop persist",
        "源码中的更新检查当前请求 maqibg/milkup 的 latest release API，且 Windows 端优先选择 Setup.exe 资产；建议在应用设置中关闭自动检查更新/自动更新，避免与 Scoop 更新流程冲突",
        "本包使用 fork 官方发布的 milkup-win-x64.zip，并将 %APPDATA%\\milkup 持久化到 Scoop 的 persist，在原路径创建 Junction"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/maqibg/milkup/releases/download/v1.0.18/milkup-win-x64.zip",
            "hash": "6f14359e10b3d57231d02243c4e840b5a7a60a39e4466e9850917125c91dd1d0"
        }
    },
    "bin": "milkup.exe",
    "shortcuts": [
        [
            "milkup.exe",
            "milkup"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'milkup'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "post_uninstall": [
        "$source = Join-Path $env:APPDATA 'milkup'",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Remove-Item -LiteralPath $source -Force",
        "    }",
        "}"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/maqibg/milkup"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/maqibg/milkup/releases/download/v$version/milkup-win-x64.zip"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
