{
    "version": "0.114.0",
    "description": "A new type of shell, written in Rust, that takes a structured approach to your command line",
    "homepage": "https://www.nushell.sh",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/nushell/nushell/releases/download/0.114.0/nu-0.114.0-x86_64-pc-windows-msvc.zip",
            "hash": "sha256:f34858d797aa229079bc9c78dd30221bc75042f0308984d23b4b1679abd97758"
        },
        "arm64": {
            "url": "https://github.com/nushell/nushell/releases/download/0.114.0/nu-0.114.0-aarch64-pc-windows-msvc.zip",
            "hash": "sha256:3a29534481b99b33dadcea6f36bc28dd77c15e843339b34900622a415cfacaae"
        }
    },
    "persist":["data"],
    "pre_install": [
        "# 将 $env:APPDATA\\nushell 软链接到 persist/data，升级时配置不丢失",
        "$nushell_data = Join-Path $env:APPDATA \"nushell\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $nushell_data $persist_data"
    ],
    "post_uninstall": [
        "$nushell_data = Join-Path $env:APPDATA \"nushell\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $nushell_data"
    ],
    "bin": "nu.exe",
    "shortcuts": [
        [
            "nu.exe",
            "NuShell"
        ]
    ],
    "checkver": {
        "github": "https://github.com/nushell/nushell"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/nushell/nushell/releases/download/$version/nu-$version-x86_64-pc-windows-msvc.zip"
            },
            "arm64": {
                "url": "https://github.com/nushell/nushell/releases/download/$version/nu-$version-aarch64-pc-windows-msvc.zip"
            }
        }
    }
}
