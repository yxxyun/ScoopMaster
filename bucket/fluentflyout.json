{
    "version": "2.10.0",
    "description": "The modern Flyout app for Windows 11, built with Fluent 2 Design principles. Media Flyouts, Taskbar Widgets and more.",
    "homepage": "https://fluentflyout.com/",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/unchihugo/FluentFlyout/releases/download/v2.10.0/FluentFlyout_2.10.0_x64_Installer.zip",
            "hash": "00af37d3f1b4f6f833d6afb15a8b5073e75985d4d5e0c8ad0da8596454539044"
        }
    },
    "pre_install": [
        "$bundle = Get-ChildItem \"$dir\\SystemFiles\\*.msixbundle\" | Select-Object -First 1",
        "Expand-7zipArchive $bundle.FullName \"$dir\\SystemFiles\"",
        "$msix = Get-ChildItem \"$dir\\SystemFiles\\*.msix\" | Select-Object -First 1",
        "Expand-7zipArchive $msix.FullName \"$dir\\app\"",
        "Remove-Item \"$dir\\SystemFiles\" -Recurse -Force",
        "Remove-Item \"$dir\\*.cer\",\"$dir\\*.appxsym\",\"$dir\\*.ps1\",\"$dir\\*.bat\" -ErrorAction SilentlyContinue"
    ],
    "shortcuts": [
        [
            "app\\FluentFlyout\\FluentFlyout.exe",
            "FluentFlyout"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/unchihugo/FluentFlyout/releases/download/v$version/FluentFlyout_$version_x64_Installer.zip"
            }
        }
    }
}
