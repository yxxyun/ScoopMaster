{
    "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
    "version": "0.46.035",
    "description": "A drag-and-drop CAD package for beginners.",
    "homepage": "https://cadoodlecad.com/",
    "license": "CC0-1.0",
    "depends": "zulufx25-jre-isolate",
    "architecture": {
        "64bit": {
            "url": [
                "https://github.com/CommonWealthRobotics/CaDoodle-Application/releases/download/0.46.035/CaDoodle-Application.jar",
                "https://github.com/CommonWealthRobotics/CaDoodle-Application/releases/download/0.46.035/jvm.json"
            ],
            "hash": [
                "9bdeb7eca9714bf11b319e7d53cefd9d4f99df10789e20cff22f48abea0cc0d7",
                "3abe7d696d1ff5ab951f3ed731c743aa0f974a0168b78bcec303fbc2e9ca572f"
            ]
        }
    },
    "pre_install": [
        "$jvm = Get-Content \"$dir\\jvm.json\" -Raw | ConvertFrom-Json",
        "$a = $jvm.'Windows-x64'.jvmargs -join ' '",
        "$lines = '@echo off', 'set \"JW=%~dp0..\\..\\zulufx25-jre-isolate\\current\\bin\\javaw.exe\"', 'if not exist \"%JW%\" set \"JW=javaw\"', ('start \"\" \"%JW%\" ' + $a + ' -jar \"%~dp0CaDoodle-Application.jar\" %*')",
        "Set-Content -Path \"$dir\\cadoodle.bat\" -Value $lines -Encoding Ascii",
        "if ($bucket) { $ic = Join-Path (Find-BucketDirectory $bucket -Root) 'icons\\cadoodle.ico'; if (Test-Path $ic) { Copy-Item $ic \"$dir\\cadoodle.ico\" -Force } }"
    ],
    "bin": "cadoodle.bat",
    "shortcuts": [
        [
            "cadoodle.bat",
            "CaDoodle",
            "",
            "cadoodle.ico"
        ]
    ],
    "checkver": {
        "github": "https://github.com/CommonWealthRobotics/CaDoodle-Application"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://github.com/CommonWealthRobotics/CaDoodle-Application/releases/download/$version/CaDoodle-Application.jar",
                    "https://github.com/CommonWealthRobotics/CaDoodle-Application/releases/download/$version/jvm.json"
                ]
            }
        }
    }
}
