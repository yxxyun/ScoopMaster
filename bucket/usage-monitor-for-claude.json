{
    "version": "1.12.0",
    "description": "Monitor Claude AI API usage and costs in real time on Windows",
    "homepage": "https://github.com/jens-duttke/usage-monitor-for-claude",
    "license": "MIT",
    "url": "https://github.com/jens-duttke/usage-monitor-for-claude/releases/download/v1.12.0/UsageMonitorForClaude.exe",
    "hash": "b2ecc29a4af81bef47804441e07a374d0d4d0b2e689fc2ee19fe233b65c4609d",
    "pre_install": [
        "if (!(Test-Path \"$dir\\usage-monitor-settings.json\")) {",
        "    Set-Content -Path \"$dir\\usage-monitor-settings.json\" -Value '{\"language\": \"en\"}' -Encoding UTF8",
        "}"
    ],
    "post_install": [
        "@('@echo off', 'echo Refreshing Claude Code authentication...', 'call \"%APPDATA%\\npm\\claude.cmd\" update >nul 2>&1', 'echo Starting Usage Monitor...', 'start \"\" \"%~dp0UsageMonitorForClaude.exe\"') | Set-Content -Path \"$dir\\LaunchMonitor.cmd\" -Encoding ASCII",
        "New-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'UsageMonitorForClaude' -Value \"$dir\\UsageMonitorForClaude.exe\" -PropertyType String -Force | Out-Null",
        "Write-Host 'Autostart registered.'"
    ],
    "pre_uninstall": [
        "Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run' -Name 'UsageMonitorForClaude' -ErrorAction SilentlyContinue"
    ],
    "bin": [
        ["UsageMonitorForClaude.exe", "usage-monitor-for-claude"]
    ],
    "shortcuts": [
        ["UsageMonitorForClaude.exe", "Usage Monitor for Claude"]
    ],
    "persist": "usage-monitor-settings.json",
    "checkver": {
        "github": "https://github.com/jens-duttke/usage-monitor-for-claude"
    },
    "autoupdate": {
        "url": "https://github.com/jens-duttke/usage-monitor-for-claude/releases/download/v$version/UsageMonitorForClaude.exe"
    }
}
