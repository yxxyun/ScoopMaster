{
    "version": "26.05.0",
    "description": "A utility tool powered by fzf for using git interactively.",
    "homepage": "https://github.com/wfxr/forgit",
    "license": "MIT",
    "suggest": {
        "Git": "main/git"
    },
    "notes": [
      "It must be used inside a Bash/Zsh session,",
      "The easiest Windows option is Git Bash.",
      "To keep the right tools first, add these to the TOP of your System PATH",
      "  $env:SCOOP\\apps\\git\\current\\bin",
      "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/wfxr/forgit/archive/refs/tags/26.05.0.zip",
            "hash": "84370662bf1739140b0005c6d0d9a61fdf02c1caafe344e6861bc8e21deb5a50",
            "extract_dir": "forgit-26.05.0\\bin"
        }
    },
    "pre_install": [
        "New-Item -Path \"$dir\\forgit.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\forgit.cmd\" -Value \"bash $env:SCOOP\\apps\\forgit\\current\\git-forgit %*\""
    ],
    "bin": "forgit.cmd",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/wfxr/forgit/archive/refs/tags/$version.zip",
                "extract_dir": "forgit-$version\\bin"
            }
        }
    }
}
