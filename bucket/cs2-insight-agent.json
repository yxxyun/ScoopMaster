{
    "version": "2.2.1",
    "description": "自动解析 Demo 录像，提取高光 / 下饭 / 梗死亡时刻，可调用 LLM 生成毒舌锐评与评分，并通过 OBS 全自动控制 CS2 回放录制成片，开箱即用",
    "homepage": "https://github.com/DrEAmSs59/CS2-insight-agent",
    "license": "PolyForm-Noncommercial-1.0.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/DrEAmSs59/CS2-insight-agent/releases/download/V2.2.1/CS2.Insight.Agent.Setup.2.2.1.exe#/dl.7z",
            "hash": "dd51ffd8934409afe74dbcc9b253c3bcccfa5575a87ab54abb958725a298aeb4"
        }
    },
    "extract_dir": "$PLUGINSDIR",
    "pre_install": [
        "Remove-Item $dir\\* -Exclude *.7z",
        "Expand-7zipArchive -Path $dir\\app-64.7z -DestinationPath $dir -Removal"
    ],
    "installer": {
        "script": [
            "$targetPath = \"$persist_dir\\cs2-insight-agent\"",
            "$configPath = \"$env:APPDATA\\cs2-insight-agent\"",
            "ensure $targetPath | Out-Null",
            "$linkType = (Get-Item -Path $configPath -ErrorAction SilentlyContinue).LinkType",
            "if (Test-Path $configPath) {",
            "    if ($linkType -eq 'Junction') {",
            "        Remove-Item -Path $configPath -Force",
            "    } else {",
            "        Get-ChildItem -Path $configPath -Force | Move-Item -Destination $targetPath -Force",
            "        Remove-Item -Path $configPath -Force -Recurse",
            "    }",
            "}",
            "New-Item $configPath -ItemType Junction -Target $targetPath | Out-Null"
        ]
    },
    "shortcuts": [
        [
            "CS2 Insight Agent.exe",
            "CS2 Insight Agent"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/DrEAmSs59/CS2-insight-agent/releases/download/V$version/CS2.Insight.Agent.Setup.$version.exe#/dl.7z"
            }
        }
    }
}
