{
    "version": "1.3.0",
    "description": "Ship of Harkinain build supporting Archipelago randomizer",
    "homepage": "https://github.com/HarbourMasters/Archipelago-SoH",
    "license": "MIT",
    "notes": "Ship of Harkinian fork with support for the Archipelago randomizer",
    "suggest": {
        "archipelago": "spiraster/archipelago"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/HarbourMasters/Archipelago-SoH/releases/download/SoH_1.3.0/SoH_Archipelago_1-3-x_Windows.zip",
            "hash": "cb133137e21bdef94c1fa9229bbebf7a638d567c812d4abe969a0152c66c60a4"
        }
    },
    "pre_install": [
        "'shipofharkinian.json', 'imgui.ini' | % {",
        "   if (!(Test-Path \"$persist_dir\\$_\")) {",
        "      New-Item \"$dir\\$_\" | Out-Null",
        "   }",
        "}"
    ],
    "post_install": [
        "'oot.o2r', 'oot-mq.o2r' | % {",
        "   if (Test-Path \"$persist_dir\\$_\") {",
        "       Copy-Item \"$persist_dir\\$_\" \"$dir\\$_\" -Force",
        "   }",
        "}"
    ],
    "shortcuts": [
        [
            "soh.exe",
            "Ship of Harkinian (AP)"
        ]
    ],
    "persist": [
        "logs",
        "mods",
        "Randomizer",
        "Save",
        "shipofharkinian.json",
        "imgui.ini"
    ],
    "pre_uninstall": [
        "'oot.o2r', 'oot-mq.o2r' | % {",
        "   if (Test-Path \"$dir\\$_\") {",
        "       Copy-Item \"$dir\\$_\" \"$persist_dir\\$_\" -Force",
        "   }",
        "}"
    ],
    "checkver": "SoH_([\\d\\.]+)",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/HarbourMasters/Archipelago-SoH/releases/download/SoH_$version/SoH_Archipelago_$majorVersion-$minorVersion-x_Windows.zip"
            }
        }
    }
}
