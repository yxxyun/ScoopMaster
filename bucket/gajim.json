{
    "##": "ltguillaume/schep",
    "version": "2.5.0",
    "description": "A fully-featured XMPP client. Fully portable version.",
    "homepage": "https://gajim.org",
    "license": "GPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://gajim.org/downloads/2.5/Gajim-Portable-2.5.0-64bit.exe#/gajim-portable.exe",
            "hash": "452d80f76062f360d4ec38bbd08015831f91ec588410ee0263ac83708e4c2f9f"
        }
    },
    "bin": "bin/Gajim.exe",
    "shortcuts": [
        [
            "bin/Gajim.exe",
            "Gajim"
        ]
    ],
    "persist": [
        "UserData",
        [
            "share/hunspell",
            "hunspell"
        ]
    ],
    "installer": {
        "file": "gajim-portable.exe",
        "args": "\" /S /LANG=en /D=$dir \""
    },
    "checkver": {
        "url": "https://gajim.org/current-version.json",
        "jsonpath": "$.current_version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://gajim.org/downloads/$majorVersion.$minorVersion/Gajim-Portable-$version-64bit.exe#/gajim-portable.exe"
            }
        }
    }
}
