{"version":"26.1.0","description":"Cinc Workstation is a free-as-in-beer, open source build of Chef Workstation.","homepage":"https://cinc.sh","license":"Apache-2.0","architecture":{"64bit":{"url":"https://packages.cinc.sh/files/stable/cinc-workstation/26.1.0/windows/2012r2/cinc-workstation-26.1.0-1-x64.msi","hash":"bb48f468ba857e7d6d2414d145af0e3b33bcb57ab6051b082c3e224d1390fe2a"}},"depends":"7zip","extract_dir":"cinc-project","pre_install":"Expand-7zipArchive \"$dir\\cinc-workstation.zip\" -Removal","post_install":["$shim_content = @'","@(ECHO OFF","SETLOCAL ENABLEEXTENSIONS","SET POPD=","CALL :DriveIsSame \"%CD%\" \"%USERPROFILE%\" || (","    IF NOT EXIST \"%USERPROFILE%\\.cinc\\Temp\" MKDIR \"%USERPROFILE%\\.cinc\\Temp\"","    PUSHD \"%USERPROFILE%\\.cinc\\Temp\"","    SET POPD=1",")","\"%~dp0..\\embedded\\bin\\ruby.exe\" \"%~dpn0\" %*",")","(","    IF DEFINED POPD POPD","    REM %ERRORLEVEL% is expanded at the start of the block,","    REM so it preserves the value before POPD is executed.","    EXIT /B %ERRORLEVEL%",")","EXIT /B",":DriveIsSame","@(","    IF /I \"%~d1\"==\"%~d2\" EXIT /B","EXIT /B 1",")","'@","$shim_path = \"$dir\\bin\\patched_shim.bat\"","$shim_content = $shim_content -replace \"`r?`n\", \"`r`n\"","Set-Content -Path $shim_path -Value $shim_content -Encoding Ascii","","$original_content = @'","@ECHO OFF","\"%~dp0..\\embedded\\bin\\ruby.exe\" \"%~dpn0\" %*","'@","","Get-ChildItem \"$dir\\bin\\*.bat\" | ForEach-Object {","    if ($_.Name -ne 'patched_shim.bat') {","        $content = Get-Content $_.FullName -Raw","        if ($content -and ($content -replace '\\s+', ' ').Trim() -eq ($original_content -replace '\\s+', ' ').Trim()) {","            Remove-Item $_.FullName -Force","            New-Item -ItemType HardLink -Path $_.FullName -Value $shim_path | Out-Null","        }","    }","}"],"env_add_path":"bin","checkver":{"url":"https://omnitruck.cinc.sh/stable/cinc-workstation/metadata?p=windows&pv=11&m=x86_64&v=latest","regex":"url\\s+(?<url>https?://[^\\s]+)\\s+version\\s+(?<version>[\\d.]+)"},"autoupdate":{"architecture":{"64bit":{"url":"$matchUrl","hash":{"url":"https://omnitruck.cinc.sh/stable/cinc-workstation/metadata?p=windows&pv=11&m=x86_64&v=$version","regex":"sha256\\s+([a-fA-F0-9]{64})"}}}},"from":"https://github.com/LogicDaemon/ScoopInstaller-manifest-fixes"}
