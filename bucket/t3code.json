{
    "##": "Why here? It is in alpha, which does meet Scoop extras bucket criterias.",
    "version": "0.0.9",
    "description": "A minimal web GUI for coding agents",
    "homepage": "https://t3.codes/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/pingdotgg/t3code/releases/download/v0.0.9/T3-Code-0.0.9-x64.exe#t3code.7z",
            "hash": "e7d0a6a847bf291844a8778c4e158aecc2968198503e1941e98d9b5041c1d305",
            "pre_install": "Expand-7zipArchive -Path \"$dir\\`$PLUGINSDIR\\app-64.7z\" -DestinationPath \"$dir\""
        }
    },
    "post_install": [
        "# Clean up leftovers",
        "$Directories = [string[]](",
        "    \"$dir\\`$PLUGINSDIR\",",
        "    \"$dir\\`$R0\"",
        ")",
        "Start-Sleep -Milliseconds 50",
        "$Directories.ForEach{",
        "    if ([System.IO.Directory]::Exists($_)) {",
        "        $null = [System.IO.Directory]::Delete($_,$true)",
        "        debug \"Deleted '$_'.\"",
        "    }",
        "}"
    ],
    "bin": "T3 Code (Alpha).exe",
    "shortcuts": [
        [
            "T3 Code (Alpha).exe",
            "T3 Code (Alpha)",
            "--user-data-dir=\"$dir\\data\""
        ]
    ],
    "persist": "data",
    "post_uninstall": [
        "# Inform of leftover directories if any was found",
        "$LeftoverDirs = [string[]](",
        "    Get-ChildItem -Path ([System.IO.Directory]::GetParent($env:APPDATA).FullName) -Directory -Depth 1 |",
        "        Where-Object -Property 'Name' -Like 'T3 Code*' |",
        "        Select-Object -ExpandProperty 'FullName'",
        ")",
        "if ($LeftoverDirs.Count -gt 0) {",
        "    $Message = [string] \"`r`nFound some leftover directories you might want to delete:\"",
        "    $LeftoverDirs.ForEach{",
        "        $Message += \"`r`n* '{0}'\" -f $_",
        "    }",
        "    info $Message",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/pingdotgg/t3code"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pingdotgg/t3code/releases/download/v$version/T3-Code-$version-x64.exe#t3code.7z"
            }
        }
    }
}
