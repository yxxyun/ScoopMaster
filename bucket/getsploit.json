{
    "version": "1.0.0",
    "description": "命令行工具，用于搜索和下载漏洞利用代码",
    "homepage": "https://github.com/vulnersCom/getsploit",
    "license": "LGPL-3.0-only",
    "suggest": {
        "python": "sec/miniconda3"
    },
    "url": "https://github.com/vulnersCom/getsploit/archive/refs/tags/1.0.0.zip#/getsploit.zip",
    "hash": "21b416e963ece95f8e47686481c0b3cc77f312b1cd57d00b397e16040fbd1737",
    "post_install": [
        "Move-Item -Path \"$dir\\getsploit-$version\\getsploit\\*\" -Destination \"$dir\\\"",
        "Remove-Item \"$dir\\getsploit-$version\" -Force -Recurse",
        "Set-Content \"$dir\\getsploit.bat\" '@pushd %~dp0', '@call conda activate python3env', '@python \"getsploit.py\" %*', '@popd' -Encoding Ascii"
    ],
    "bin": "getsploit.bat",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/vulnersCom/getsploit/archive/refs/tags/$version.zip#/getsploit.zip"
    },
    "notes": [
        "【工具类型】: 安全测试",
        "【主要功能】: 搜索和下载漏洞利用代码",
        "【适用场景】: 安全测试、漏洞验证",
        "【技术特点】: 基于 Python 开发，命令行工具",
        "【注意事项】: 需要创建名为 python3env 的 conda 环境"
    ]
}

