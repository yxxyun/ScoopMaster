    "hash": "f2d589a16fb47297ecc243803d84385c4c1a5346c0c005cb7163e56b1b1758c1",
    "pre_install": [
        "Get-ChildItem -Path $dir -Filter 'Open.Video.Downloader*.exe' | Rename-Item -NewName 'Open.Video.Downloader.exe'",
        "if (-not (Test-Path (Join-Path -Path $persist_dir -ChildPath '/ovd-portable/config.store.json'))) {",
        "    $cfg_json_stub = @{ 'config' = @{ 'update' = [ordered]@{ 'updateApp' = $false; 'updateBinaries' = $true; } } }",
        "    Set-Content -Path (Join-Path -Path $dir -ChildPath '/ovd-portable/config.store.json') -Value (ConvertTo-Json -InputObject $cfg_json_stub -Depth 99) -Encoding 'ASCII'",
        "}"
    ],
    "shortcuts": [
        [
            "Open.Video.Downloader.exe",
            "Open Video Downloader"
        ]
    ],
    "persist": "ovd-portable",
    "checkver": {
        "url": "https://api.github.com/repositories/252325835/releases",
        "jsonpath": "$[?(@.prerelease == false)].tag_name",
        "regex": "app-v(?<version>[\\d\\.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/jely2002/youtube-dl-gui/releases/download/app-v$version/Open.Video.Downloader_$version_x64-portable.zip"
    }
}
