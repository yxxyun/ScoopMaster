{
    "version": "0.2026.03.28",
    "description": "Xget URL rewriting utility.",
    "homepage": "https://github.com/xixu-me/skills/blob/main/skills/xget",
    "license": "MIT",
    "url": "https://raw.githubusercontent.com/xixu-me/skills/f9f48b61204353c7490f2074d33c7396bf9363a5/skills/xget/scripts/xget.mjs",
    "hash": "e6b23fe9c8182985c2a50e83a11e4a8f7c159b2fbb94c283287ab5ce34e29854",
    "pre_install": [
        "$path = Convert-Path \"$dir\\xget.mjs\"",
        "\"@bun `\"$path`\" %*\" | Out-UTF8File \"$dir\\xget.cmd\""
    ],
    "bin": "xget.cmd",
    "checkver": {
        "url": "https://github.com/xixu-me/skills/commits/main/skills/xget/scripts/xget.mjs.atom",
        "regex": "(?s)>(\\d+)-(\\d+)-(\\d+)T.*?/(?<sha>[0-9a-f]{40})",
        "replace": "0.${1}.${2}.${3}"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/xixu-me/skills/$matchSha/skills/xget/scripts/xget.mjs"
    }
}
