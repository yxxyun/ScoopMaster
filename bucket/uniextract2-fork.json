{
    "version": "3.0.2",
    "description": "Decompress and extract files from any type of archive or installer.",
    "homepage": "https://github.com/gvp9000/UniExtract2",
    "license": "GPL-2.0-or-later",
    "url": "https://github.com/gvp9000/UniExtract2/releases/download/v3.0.2/UniExtract2.zip",
    "hash": "f18220004644bd9b123c3b49de55c2be7c8bad61efb2bd355f0d1747a4bdfdff",
    "extract_dir": "UniExtract2",
    "post_install": [
        "$ini = Get-Content \"$dir\\UniExtract.ini\" -Raw",
        "# Set 'updateinterval' to 999999 and 'nightlyupdates' to 0 if not already present",
        "$new = $ini -replace '(?m)^updateinterval=\\d+', 'updateinterval=999999' -replace '(?m)^nightlyupdates=1', 'nightlyupdates=0'",
        "if ($new -ne $ini) { $new | Set-Content \"$dir\\UniExtract.ini\" -Encoding Ascii }"
    ],
    "bin": "UniExtract.exe",
    "persist": [
        "log",
        "UniExtract.ini"
    ],
    "shortcuts": [
        [
            "UniExtract.exe",
            "Universal Extractor"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/gvp9000/UniExtract2/releases/download/v$version/UniExtract2.zip"
    }
}
