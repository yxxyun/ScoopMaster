{
    "version": "0.2026.03.14",
    "description": "RIME 词库增强",
    "homepage": "https://github.com/iorest/rime-dict",
    "license": {
        "identifier": "Freeware"
    },
    "depends": "rime-weasel",
    "url": "https://github.com/iorest/rime-dict/archive/a2057baecf53e5a45dfd5b72f1ec50773d8c9271.zip",
    "hash": "eb34350cf7bf22f7da50147547f7ce3e80a76fd2ddd3c8928831a1c2d6bdae50",
    "extract_dir": "rime-dict-a2057baecf53e5a45dfd5b72f1ec50773d8c9271",
    "post_install": [
        "$null, $bucket = find_manifest($appName)",
        "$bucketdir = Find-BucketDirectory($bucket)",
        "$evalDir = \"$(appdir rime-weasel $global)\\current\".Replace('/', '\\')",
        "",
        "Write-Host \"S1. Copy to your rime install directory...\" -ForegroundColor DarkCyan",
        "cp \"$dir\\*\" \"$evalDir\\AppData\" -Exclude '*.log' -Recurse -force",
        ""
    ],
    "checkver": {
        "url": "https://github.com/iorest/rime-dict/commits/master.atom",
        "regex": "(?s)>(\\d+)-(\\d+)-(\\d+)T.*?/(?<sha>[0-9a-f]{40})",
        "replace": "0.${1}.${2}.${3}"
    },
    "autoupdate": {
        "url": "https://github.com/iorest/rime-dict/archive/$matchSha.zip",
        "extract_dir": "rime-dict-$matchSha"
    }
}
