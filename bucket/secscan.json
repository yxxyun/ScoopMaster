{"version":"0.22.0","description":"Multi-scanner security CLI — deps/sast/secrets/dast/iast/sbom/image/apifuzz/supply/config.","homepage":"https://github.com/shunsukesuetsugu-prog/secscan","license":"MIT","depends":"python","url":"https://files.pythonhosted.org/packages/9b/45/afb6da24fceb75c175b32db4a4af39437d1eedb0c27cc0a15c4c50f0649f/shun_secscan-0.22.0-py3-none-any.whl","hash":"sha256:56bcbe4bc5322ea3e680d13d7bcf861cae9a1ca4a163d53e4c73184fd8f4810e","extract_dir":"","installer":{"script":["$pyExe = (Get-Command python).Source","Write-Host \"Creating venv at $dir\\venv using $pyExe ...\"","& $pyExe -m venv \"$dir\\venv\"","if ($LASTEXITCODE -ne 0) { throw 'venv creation failed' }","Write-Host 'Installing shun-secscan into venv ...'","& \"$dir\\venv\\Scripts\\python.exe\" -m pip install --quiet --no-warn-script-location \"$dir\\shun_secscan-0.22.0-py3-none-any.whl\"","if ($LASTEXITCODE -ne 0) { throw 'pip install failed' }"]},"uninstaller":{"script":["if (Test-Path \"$dir\\venv\") { Remove-Item -Recurse -Force \"$dir\\venv\" }"]},"bin":"venv\\Scripts\\secscan.exe","checkver":{"url":"https://pypi.org/pypi/shun-secscan/json","jsonpath":"$.info.version"},"_update_note":"After ``checkver`` reports a new version, manually edit ``url``, ``hash`` (sha256:...) and the wheel filename in the installer script. PyPI URLs contain a per-file hash prefix that Scoop's autoupdate template-substitution cannot reproduce, so we do not declare ``autoupdate`` to avoid a misleading half-working integration.","from":"https://github.com/shunsukesuetsugu-prog/scoop-secscan"}
