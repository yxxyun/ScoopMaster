{
    "version": "1.21.6b",
    "description": "A open-source browser based on the Firefox engine",
    "homepage": "https://www.zen-browser.app/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.6b/zen.installer.exe#/dl.7z",
            "hash": "bee30f718d1c595986cfd246edf094d323fa5b34eee9aefbefc2524546dfdf21"
        },
        "arm64": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.21.6b/zen.installer-arm64.exe#/dl.7z",
            "hash": "654b959e755c6bf159cde77ccf865e5f1c443e673207f3b9228baef5eb903ff7"
        }
    },
    "extract_dir": "core",
    "post_install": "rm -force -ea 0 \"$env:appdata\\microsoft\\windows\\start menu\\programs\\{-brand-shortcut-name} Private Browsing.lnk\"",
    "bin": "zen.exe",
    "shortcuts": [
        [
            "zen.exe",
            "Zen Browser"
        ],
        [
            "zen.exe",
            "Zen Browser Profile Manager",
            "-P"
        ]
    ],
    "pre_uninstall": "if (Get-Process -name zen -ea 0) {stop-process -name zen -force -ea 0; wait-process -name zen -ea 0; start-sleep 0.5}",
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/tags",
        "regex": "releases/tag/([ab\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer-arm64.exe#/dl.7z"
            }
        }
    }
}
