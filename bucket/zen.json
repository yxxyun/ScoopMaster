{
    "version": "1.19.4b",
    "description": "A open-source browser based on the Firefox engine",
    "homepage": "https://www.zen-browser.app/",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.19.4b/zen.installer.exe#/dl.7z",
            "hash": "690c377b933d2f67b1adb18bfccb5265bb7d0859e889719d5df5e97dd75c3675"
        },
        "arm64": {
            "url": "https://github.com/zen-browser/desktop/releases/download/1.19.4b/zen.installer-arm64.exe#/dl.7z",
            "hash": "bb8c238e054f49324e50fa1a4753dc03b882feb6deb5a9b53fd0e63b0b5268dc"
        }
    },
    "extract_dir": "core",
    "post_install": "rm -force -ea 0 \"$env:appdata\\microsoft\\windows\\start menu\\programs\\{-brand-shortcut-name} Private Browsing.lnk\"",
    "bin": "zen.exe",
    "shortcuts": [
        [
            "zen.exe",
            "Zen Browser"
        ],
        [
            "zen.exe",
            "Zen Browser Profile Manager",
            "-P"
        ]
    ],
    "pre_uninstall": "if (get-process -name zen -ea 0) {stop-process -name zen -force -ea 0}",
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/tags",
        "regex": "releases/tag/([ab\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer-arm64.exe#/dl.7z"
            }
        }
    }
}
