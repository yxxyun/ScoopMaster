{"version":"9.22.0.52","description":"NVIDIA CUDA Deep Neural Network library (cuDNN) for CUDA 13 on Windows x86_64.","homepage":"https://developer.nvidia.com/cudnn","license":{"identifier":"NVIDIA-cuDNN","url":"https://docs.nvidia.com/deeplearning/cudnn/sla/index.html"},"architecture":{"64bit":{"url":"https://developer.download.nvidia.com/compute/cudnn/redist/cudnn/windows-x86_64/cudnn-windows-x86_64-9.22.0.52_cuda13-archive.zip","hash":"11f714ad2699f1d548546fe8797ca563c498d4c66d5a4e9b6c2948325ca8da7d","extract_dir":"cudnn-windows-x86_64-9.22.0.52_cuda13-archive"}},"env_add_path":"bin\\x64","env_set":{"CUDNN_HOME":"$dir"},"post_install":["Write-Host 'cuDNN has been installed to:' $dir","Write-Host 'CUDNN_HOME is set to:' $dir","Write-Host 'bin\\x64 has been added to PATH for DLL discovery.'"],"checkver":{"script":["$root = 'https://developer.download.nvidia.com/compute/cudnn/redist/'","$index = Invoke-RestMethod $root","$labels = [regex]::Matches($index, 'redistrib_([0-9]+(?:\\.[0-9]+)+)\\.json') | ForEach-Object { $_.Groups[1].Value } | Sort-Object { [version]$_ } -Descending","foreach ($label in $labels) {","  $j = Invoke-RestMethod ($root + 'redistrib_' + $label + '.json')","  if ($j.cudnn.'windows-x86_64'.cuda13) { $j.cudnn.version; break }","}"]},"notes":["This package installs cuDNN headers, import libraries, DLLs, and LICENSE under Scoop's app directory.","Most build systems can use CUDNN_HOME, include, lib\\x64, and bin\\x64 directly.","If an application requires DLLs next to CUDA Toolkit binaries, copy the DLLs manually instead of overwriting files blindly."],"from":"https://github.com/Arama0517/scoop-bucket"}
