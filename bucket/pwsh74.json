{
    "##": [
        "Why here? I want multiple PowerShell versions side by side.",
        "Strategy for having multiple versions installed side by side:",
        "* Add all versions to PATH (env_add_path), because a shim (bin) does not carry over the icon.",
        "* Rename all versions but the current newest stable one to avoid naming conflict."
    ],
    "version": "7.4.16",
    "description": "Latest stable PowerShell 7.4.x. Cross-platform automation and configuration tool/framework, known as Powershell Core, that works well with existing tools and is optimized for dealing with structured data.",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": "MIT",
    "architecture": {
        "32bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.4.16/PowerShell-7.4.16-win-x86.zip",
            "hash": "9e77e3793807b1f8e2e13cab9188f12a5967182399d1f4bb7010b15d00069085"
        },
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.4.16/PowerShell-7.4.16-win-x64.zip",
            "hash": "4799a560b7c312fbc1ae5209724a5cddd3f1e626257685af43b6bb57112758e3"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.4.16/PowerShell-7.4.16-win-arm64.zip",
            "hash": "cd3fcd7a79f644ca63bd7e1f8e06083b14dbe91b1752b8f17e85adea84f09314"
        }
    },
    "pre_install": [
        "# Rename and add to path instead of shimming, as the shim will not show the app icon",
        "Rename-Item -Path \"$dir\\pwsh.exe\" -NewName \"pwshp74.exe\"",
        "# Delete some included modules",
        "$Directories = [string[]](",
        "    [System.IO.Path]::Combine($dir,'Modules','Microsoft.PowerShell.PSResourceGet')",
        ")",
        "$Directories.ForEach{",
        "    if ([System.IO.Directory]::Exists($_)) {",
        "        $null = [System.IO.Directory]::Delete($_,$true)",
        "    }",
        "}"
    ],
    "env_add_path": ".",
    "shortcuts": [
        [
            "pwsh74.exe",
            "PowerShell 7.4",
            "-WorkingDirectory ~"
        ],
        [
            "pwsh74.exe",
            "PowerShell 7.4 -NoProfile",
            "-WorkingDirectory ~ -NoProfile"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/PowerShell/PowerShell/releases",
        "jsonpath": "$[?(@.prerelease == false)].tag_name",
        "regex": "v(7\\.4\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x86.zip"
            },
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-arm64.zip"
            }
        }
    }
}
