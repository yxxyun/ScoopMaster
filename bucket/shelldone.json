  "bin": "bin/shelldone",
  "post_install": [
    "Write-Host 'shelldone installed!' -ForegroundColor Green",
    "Write-Host 'Add to your shell profile: eval \"$(shelldone init bash)\"' -ForegroundColor Cyan"
  ],
  "checkver": {
    "github": "https://github.com/nareshnavinash/shelldone"
  },
  "autoupdate": {
