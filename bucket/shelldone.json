{
  "version": "1.4.1",
  "description": "Terminal process completion notifier - OS-native notifications when commands finish",
  "homepage": "https://github.com/nareshnavinash/shelldone",
  "license": "MIT",
  "url": "https://github.com/nareshnavinash/shelldone/archive/refs/tags/v1.4.1.tar.gz",
  "hash": "ce0badb25bbce13cb1bc9cd69c1b1931300789f0d7a248fd53aa0997c343e721",
  "extract_dir": "shelldone-1.4.1",
  "bin": "bin/shelldone",
  "post_install": [
    "Write-Host 'shelldone installed!' -ForegroundColor Green",
    "Write-Host 'Add to your shell profile: eval \"$(shelldone init bash)\"' -ForegroundColor Cyan"
  ],
  "checkver": {
    "github": "https://github.com/nareshnavinash/shelldone"
  },
  "autoupdate": {
    "url": "https://github.com/nareshnavinash/shelldone/archive/refs/tags/v$version.tar.gz",
    "hash": {
      "url": "https://github.com/nareshnavinash/shelldone/releases/download/v$version/checksums.txt",
      "regex": "([a-fA-F0-9]{64})\\s+shelldone-.*\\.tar\\.gz"
    },
    "extract_dir": "shelldone-$version"
  }
}
