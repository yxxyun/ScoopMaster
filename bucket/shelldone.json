    "hash": {
      "url": "https://github.com/nareshnavinash/shelldone/releases/download/v$version/checksums.txt",
      "regex": "([a-fA-F0-9]{64})\\s+shelldone-.*\\.tar\\.gz"
    },
    "extract_dir": "shelldone-$version"
  }
}
