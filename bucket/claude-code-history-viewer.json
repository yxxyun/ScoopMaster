{
    "version": "1.20.0",
    "description": "A desktop app to browse, search, and analyze your Claude Code conversation history",
    "homepage": "https://jhlee0409.github.io/claude-code-history-viewer/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/jhlee0409/claude-code-history-viewer/releases/download/v1.20.0/Claude.Code.History.Viewer_1.20.0_x64-portable.zip",
            "hash": "59a2575397dab5b7837ac9d73970e30621c1ade0e71103e107df7d9410d2a5d8"
        }
    },
    "shortcuts": [
        [
            "claude-code-history-viewer.exe",
            "Claude Code History Viewer"
        ]
    ],
    "installer": {
        "script": [
            "$targetPath = \"$persist_dir\\.claude-code-history-viewer\"",
            "$configPath = \"$HOME\\.claude-history-viewer\"",
            "ensure $targetPath | Out-Null",
            "$linkType = (Get-Item -Path $configPath -ErrorAction SilentlyContinue).LinkType",
            "if (Test-Path $configPath) {",
            "    if ($linkType -eq 'Junction') {",
            "        Remove-Item -Path $configPath -Force",
            "    } else {",
            "        Get-ChildItem -Path $configPath -Force | Move-Item -Destination $targetPath -Force",
            "        Remove-Item -Path $configPath -Force -Recurse",
            "    }",
            "}",
            "New-Item $configPath -ItemType Junction -Target $targetPath | Out-Null"
        ]
    },
    "checkver": {
        "github": "https://github.com/jhlee0409/claude-code-history-viewer"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/jhlee0409/claude-code-history-viewer/releases/download/v$version/Claude.Code.History.Viewer_$version_x64-portable.zip"
            }
        }
    }
}
