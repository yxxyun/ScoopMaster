                "hash": {
                    "mode": "json",
                    "jsonpath": "$.[0].assets[?(@.name=='helium_$version_arm64-windows.zip')].digest",
                    "find": "sha256:*",
                    "url": "https://api.github.com/repos/imputnet/helium-windows/releases"
                }
