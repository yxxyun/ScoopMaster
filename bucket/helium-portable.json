{
    "version": "0.14.8.2",
    "description": "The Chromium-based web browser made for people, with love. Best privacy by default, unbiased ad-blocking, no bloat and no noise.",
    "homepage": "https://helium.computer",
    "license": "BSD-3-Clause, GPL-3.0-or-later",
    "depends": "chrome-plus",
    "architecture": {
        "64bit": {
            "url": "https://github.com/imputnet/helium-windows/releases/download/0.14.8.2/helium_0.14.8.2_x64-windows.zip",
            "hash": "ff2cf9d3f882fb63140d085943ad6285a9a40ef8136dfd723cde9221e175a887",
            "extract_dir": "helium_0.14.8.2_x64-windows"
        },
        "arm64": {
            "url": "https://github.com/imputnet/helium-windows/releases/download/0.14.8.2/helium_0.14.8.2_arm64-windows.zip",
            "hash": "e220d5bb89bd9b55e66b6d8bb38c253c46fd5ff9988d66bdefef3b009548b8ef",
            "extract_dir": "helium_0.14.8.2_arm64-windows"
        }
    },
    "pre_install": [
        "New-Item -ItemType Directory -Path \"$dir\\App\" -Force | Out-Null",
        "Move-Item -Path \"$dir\\*\" -Destination \"$dir\\App\\\" -ErrorAction SilentlyContinue",
        "$chromeArch = switch ($architecture) {",
        "    '32bit' { 'x86' }",
        "    '64bit' { 'x64' }",
        "    'arm64' { 'arm64' }",
        "}",
        "Copy-Item -Path \"$scoopdir\\apps\\chrome-plus\\current\\$chromeArch\\*\" -Destination \"$dir\" -Recurse -ErrorAction SilentlyContinue"
    ],
    "persist": [
        "App\\chrome++.ini",
        "Cache",
        "Data"
    ],
    "bin": [
        [
            "App\\chrome.exe",
            "helium"
        ]
    ],
    "shortcuts": [
        [
            "App\\chrome.exe",
            "Helium"
        ]
    ],
    "checkver": {
        "github": "https://github.com/imputnet/helium-windows"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imputnet/helium-windows/releases/download/$version/helium_$version_x64-windows.zip",
                "extract_dir": "helium_$version_x64-windows"
            },
            "arm64": {
                "url": "https://github.com/imputnet/helium-windows/releases/download/$version/helium_$version_arm64-windows.zip",
                "extract_dir": "helium_$version_arm64-windows"
            }
        }
    }
}
