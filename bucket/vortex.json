{
    "version": "1.16.5",
    "description": "Open-source mod manager from Nexus Mods",
    "homepage": "https://www.nexusmods.com/about/vortex",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nexus-Mods/Vortex/releases/download/v1.16.5/vortex-setup-1.16.5.exe",
            "hash": "sha512:48a016a3e2250dfadf5160664957ced9c6b12f58144bed4c37739c7b0ddea7defaa8a643d68b175c55e24ad8e7252c32d54ff5f7243cb445db71e1b57d5441da",
            "installer": {
                "script": [
                    "$args = @('/S')",
                    "Start-Process \"$dir\\$fname\" -ArgumentList $args -Wait -Verb RunAs | Out-Null",
                    "Remove-Item \"$dir\\$fname\""
                ]
            }
        }
    },
    "checkver": {
        "github": "https://github.com/Nexus-Mods/Vortex"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nexus-Mods/Vortex/releases/download/v$version/vortex-setup-$version.exe"
            }
        },
        "hash": {
            "url": "$baseurl/latest.yml",
            "regex": "sha512: $base64"
        }
    }
}
