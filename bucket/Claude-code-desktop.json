{
    "version": "1.11187.4",
    "description": "Claude Desktop App (Portable)",
    "homepage": "https://claude.ai",
    "license": "Proprietary",
    "innosetup": false,
    "architecture": {
        "64bit": {
            "url": "https://api.anthropic.com/api/desktop/win32/x64/msix/latest/redirect#/dl.msix",
            "hash": null
        }
    },
    "pre_install": [
        "Write-Host '正在解压 MSIX 安装包为绿色版...' -ForegroundColor Cyan",
        "Expand-7ZipArchive \"$dir\\dl.msix\" \"$dir\\_temp_extract\" | Out-Null",
        "Get-ChildItem \"$dir\\_temp_extract\\*\" -Exclude 'Appx*' | ForEach-Object {",
        "    Move-Item \"$_\" \"$dir\" -Force",
        "}",
        "Remove-Item \"$dir\\_temp_extract\" -Recurse -Force",
        "Remove-Item \"$dir\\dl.msix\" -Force"
    ],
    "shortcuts": [
        [
            "Claude.exe",
            "Claude Desktop"
        ]
    ],
    "checkver": {
        "url": "https://api.anthropic.com/api/desktop/win32/x64/msix/latest/redirect",
        "regex": "releases/win32/x64/([\\d.]+)/"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://api.anthropic.com/api/desktop/win32/x64/msix/latest/redirect#/dl.msix",
                "hash": {
                    "type": "sha256"
                }
            }
        }
    }
}
