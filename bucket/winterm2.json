{
    "version": "1.0.12",
    "description": "Windows terminal emulator inspired by macOS iTerm2, with split panes, tabs, themes and WebGL rendering",
    "homepage": "https://github.com/maqibg/Winterm2",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://github.com/maqibg/Winterm2/releases/download/v1.0.12/WinTerm2.Setup.1.0.12.exe#/dl.7z",
            "hash": "64184aae1cb24746b2ee0ece3c035efaee723f153b2a53e8a7ed9c585edcd9df"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "WinTerm2.exe",
    "shortcuts": [
        [
            "WinTerm2.exe",
            "WinTerm2"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'WinTerm2'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "post_uninstall": [
        "$source = Join-Path $env:APPDATA 'WinTerm2'",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        (Get-Item $source).Delete()",
        "        Write-Host \"Removed junction: $source\"",
        "    }",
        "}"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/maqibg/Winterm2"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/maqibg/Winterm2/releases/download/v$version/WinTerm2.Setup.$version.exe#/dl.7z"
            }
        }
    }
}
