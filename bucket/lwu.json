{
    "version": "1.0.2",
    "description": "A CLI tool to automatically update Liferay Workspace components to their latest versions",
    "homepage": "https://github.com/peterrichards-lr/liferay-workspace-updater",
    "license": "MIT",
    "url": "https://github.com/peterrichards-lr/liferay-workspace-updater/archive/refs/tags/v1.0.2.tar.gz",
    "hash": "464ad955ff78b82ff7451b30d9fd42f4900f10a5a9a9e784a27149dbd4165550",
    "extract_dir": "liferay-workspace-updater-1.0.2",
    "depends": "rustup",
    "installer": {
        "script": [
            "Set-Location \"$dir\"",
            "cargo install --path . --root \"$dir\""
        ]
    },
    "bin": "bin/lwu.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/peterrichards-lr/liferay-workspace-updater/archive/refs/tags/v$version.tar.gz",
        "extract_dir": "liferay-workspace-updater-$version",
        "hash": {
            "url": "$url",
            "mode": "download"
        }
    }
}
