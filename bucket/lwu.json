{
    "version": "1.0.1",
    "description": "A CLI tool to automatically update Liferay Workspace components to their latest versions",
    "homepage": "https://github.com/peterrichards-lr/liferay-workspace-updater",
    "license": "MIT",
    "url": "https://github.com/peterrichards-lr/liferay-workspace-updater/archive/refs/tags/v1.0.1.tar.gz",
    "hash": "5ead9aa9a2ccbb1a5e972ea22b2257944899f9699c0c005863ed6924585934f5",
    "extract_dir": "liferay-workspace-updater-1.0.1",
    "depends": "rustup",
    "installer": {
        "script": [
            "Set-Location \"$dir\"",
            "cargo install --path . --root \"$dir\""
        ]
    },
    "bin": "bin/lwu.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/peterrichards-lr/liferay-workspace-updater/archive/refs/tags/v$version.tar.gz",
        "extract_dir": "liferay-workspace-updater-$version",
        "hash": {
            "url": "$url",
            "mode": "download"
        }
    }
}
