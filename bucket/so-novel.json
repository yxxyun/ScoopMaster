{
    "version": "1.10.0",
    "description": "网文下载器",
    "homepage": "https://github.com/freeok/so-novel",
    "license": "AGPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/freeok/so-novel/releases/download/v1.10.0/sonovel-windows.tar.gz",
            "hash": "0dec61fad57472dcb9f140fc55051060110fe503e6b591f58eeb42743bbba534"
        }
    },
    "extract_dir": "SoNovel",
    "persist": [
        "config.ini",
        "rules"
    ],
    "pre_install": [
        "# 创建启动脚本，让用户能直接输入 sonovel 启动程序（当前终端前台运行）",
        "$bat = @(",
        "  '@echo off',",
        "  'cd /d \"%~dp0\"',",
        "  '\"sonovel.exe\" %*'",
        ")",
        "Set-Content \"$dir\\sonovel.bat\" $bat -Encoding Ascii"
    ],
    "bin": [
        [
            "sonovel.bat",
            "sonovel"
        ]
    ],
    "shortcuts": [
        [
            "sonovel.exe",
            "SoNovel"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/freeok/so-novel/releases",
        "jsonpath": "$[0].tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/freeok/so-novel/releases/download/v$version/sonovel-windows.tar.gz"
            }
        }
    },
    "notes": [
        "📘 使用前请阅读 `readme.txt`。",
        "🛠️ 最新配置文件为 `config.ini.original`。",
        "💡 安装后可直接在终端输入 `sonovel` 运行程序。"
    ]
}
