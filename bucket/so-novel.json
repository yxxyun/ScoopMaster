{
  "version": "1.10.0",
  "description": "小说下载器",
  "homepage": "https://github.com/freeok/so-novel",
  "license": "AGPL-3.0",
  "architecture": {
    "64bit": {
      "url": "https://github.com/freeok/so-novel/releases/download/v1.10.0/sonovel-windows.tar.gz",
      "hash": "0426B6E26AC40994888E2A54621B4D9247E9C55B592D0DF93870A76A28810D55"
    }
  },
  "extract_dir": "SoNovel",
  "persist": [
    "config.ini",
    "rules"
  ],
  "pre_install": [
    "# 创建启动脚本，让用户能直接输入 sonovel 启动程序（当前终端前台运行）",
    "$bat = @(",
    "  '@echo off',",
    "  'cd /d \"%~dp0\"',",
    "  '\"sonovel.exe\" %*'",
    ")",
    "Set-Content \"$dir\\sonovel.bat\" $bat -Encoding Ascii"
  ],
  "bin": [
    [
      "sonovel.bat",
      "sonovel"
    ]
  ],
  "shortcuts": [
    [
      "sonovel.exe",
      "SoNovel"
    ]
  ],
  "checkver": {
    "url": "https://api.github.com/repos/freeok/so-novel/releases",
    "jsonpath": "$[0].tag_name",
    "regex": "v([\\d.]+)"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/freeok/so-novel/releases/download/v$version/sonovel-windows.tar.gz"
      }
    }
  },
  "notes": [
    "📘 使用前请阅读 readme.txt",
    "🛠️ 最新配置文件是 config.ini.original",
    "🛠️ 最新书源文件在 rules 目录下",
    "💡 安装后可直接在终端输入 sonovel 运行程序"
  ]
}
