{
    "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
    "version": "0.5.2",
    "description": "WYSIWYG editor for TikZ diagrams in LaTeX",
    "homepage": "https://tikz.dev/editor/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/DominikPeters/tikz-editor/releases/download/app-v0.5.2/TikZ.Editor_0.5.2_x64-setup.exe#/dl.7z",
            "hash": "f8db47f8a2557370a24f2a5af8a79c61b814febac7720d26d28ef027f8c0e17e"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse",
    "bin": "tikz-editor.exe",
    "shortcuts": [
        [
            "tikz-editor.exe",
            "TikZ Editor"
        ]
    ],
    "checkver": {
        "github": "https://github.com/DominikPeters/tikz-editor",
        "regex": "/releases/tag/app-(?:v|V)?([\\d.]+)"
    },
    "autoupdate": {
