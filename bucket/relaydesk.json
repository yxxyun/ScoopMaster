{
    "version": "0.2.2",
    "description": "Desktop console for routing trusted messaging channels to local AI coding agents",
    "homepage": "https://github.com/jinxb/RelayDesk",
    "license": "MIT",
    "url": "https://github.com/jinxb/RelayDesk/releases/download/v0.2.2/RelayDesk_0.2.2_x64-setup.exe#/dl.7z",
    "hash": "1e7606c0720e5e46cc7a9524c91d4c69ab2a723e31bd311b30f4c01f8980affa",
    "notes": [
        "源码确认默认用户数据根目录：%USERPROFILE%\\.relaydesk\\",
        "  - config.json：主配置，包含渠道、AI 工具、工作目录、超时和环境变量等设置",
        "  - logs\\：RelayDesk 运行日志",
        "  - 其余 APP_HOME 下的会话、探测结果、活动路由和运行状态文件也由应用自己读写",
        "%TEMP%\\relaydesk-images 是临时图片目录，不纳入 Scoop persist",
        "~/.claude/settings.json 与 ~/.claude.json 属于 Claude 自身配置，不属于 RelayDesk 应用数据，不纳入 Scoop persist",
        "本包会将 %USERPROFILE%\\.relaydesk 持久化到 Scoop 的 persist，并在原路径创建 Junction"
    ],
    "bin": "relaydesk.exe",
    "shortcuts": [
        [
            "relaydesk.exe",
            "RelayDesk"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:USERPROFILE '.relaydesk'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "post_uninstall": [
        "$source = Join-Path $env:USERPROFILE '.relaydesk'",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Remove-Item -LiteralPath $source -Force",
        "    }",
        "}"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/jinxb/RelayDesk"
    },
    "autoupdate": {
        "url": "https://github.com/jinxb/RelayDesk/releases/download/v$version/RelayDesk_$version_x64-setup.exe#/dl.7z",
        "hash": {
            "mode": "download"
        }
    }
}
