{"version":"0.2.2","description":"nomifun ai workstation.","homepage":"https://www.nomifun.com","license":"Apache-2.0","url":"https://github.com/nomifun/nomifun-tauri/releases/download/v0.2.1/NomiFun_0.2.1_x64-setup.exe#/dl.7z","hash":"9c890d47e0297edea2714a6c7cf75373b84c5c2f0cea72003a91e24c156a90bf","installer":{"script":["Get-ChildItem \"$dir\" -Directory | Where-Object Name -in '$PLUGINSDIR' | Remove-Item -Recurse -Force","","# 将运行时目录重定向到 persist_dir，避免污染系统","function New-Junction { param([string]$Path, [string]$Target)","    if (Test-Path $Path) {","        $item = Get-Item $Path","        if (-not $item.LinkType) {","            if (Test-Path \"$Path\\*\") { Move-Item \"$Path\\*\" \"$Target\\\" -Force }","            Remove-Item $Path -Recurse -Force","        } else { Remove-Item $Path -Recurse -Force }","    }","    New-Item -ItemType Junction -Path $Path -Target $Target -Force | Out-Null","}","New-Item -ItemType Directory -Path \"$persist_dir\\localappdata\" -Force | Out-Null","New-Junction \"$env:LOCALAPPDATA\\NomiFun\" \"$persist_dir\\localappdata\"",""]},"uninstaller":{"script":["@( \"$env:LOCALAPPDATA\\NomiFun\" ) | ForEach-Object {","    if (Test-Path $_) {","        $item = Get-Item $_","        if ($item.LinkType -eq 'Junction') { Remove-Item $_ -Force }","    }","}"]},"bin":"nomifun-desktop.exe","shortcuts":[["nomifun-desktop.exe","NomiFun"]],"checkver":{"github":"https://github.com/nomifun/nomifun-tauri"},"autoupdate":{"url":"https://github.com/nomifun/nomifun-tauri/releases/download/v0.2.1/NomiFun_0.2.1_x64-setup.exe#/dl.7z","hash":{"url":"https://api.github.com/repos/nomifun/nomifun-tauri/releases/tags/v$version","regex":"\"name\":\\s*\"NomiFun_$version_x64-setup\\.exe\"[^}]*\"digest\":\\s*\"sha256:([a-f0-9]{64})\""}},"from":"https://github.com/svier0/scoopbucket"}
