    "shortcuts": [
        [
            "pdf_as.exe",
            "pdf_as"
        ]
    ],
    "persist": "pdf_as.ini",
    "checkver": {
        "url": "https://forest.watch.impress.co.jp/library/software/pdf_as/",
        "regex": "<dd>v(?<version>[\\d.]+)"
    },
    "autoupdate": {
        "url": "https://dforest.watch.impress.co.jp/library/p/pdf_as/11126/pdfas$majorVersion$minorVersion.zip"
