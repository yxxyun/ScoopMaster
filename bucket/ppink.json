{
    "version": "1.9.100",
    "description": "On-screen annotation software under Windows, forked from gInk",
    "homepage": "https://github.com/pubpub-zz/ppInk",
    "license": "MIT",
    "url": "https://github.com/pubpub-zz/ppInk/releases/download/v1.9.100/ppInk.1.9.100.zip",
    "hash": "3d7317bee4dd396b3b088bd116008b605938902512d1246a5dcb9df7a735b2ff",
    "extract_dir": "ppink",
    "pre_install": [
        "if (-not (Test-Path \"$persist_dir\\config.ini\")) {",
        "    $cur = \"$persist_dir\\Snapshots\\\" -replace '\\\\', '/'",
        "    $c = (Get-Content \"$dir\\config.ini\") -replace '^(Snapshot_Path =).*$', \"`$1 $cur\"",
        "    Set-Content  \"$dir\\config.ini\" $c -Encoding Ascii -Force",
        "}"
    ],
    "bin": "ppInk.exe",
    "shortcuts": [
        [
            "ppInk.exe",
            "ppInk"
        ]
    ],
    "persist": [
        "Snapshots",
        "config.ini",
        "hotkeys.ini",
        "pens.ini"
    ],
    "checkver": {
        "url": "https://github.com/pubpub-zz/ppInk",
        "regex": "/pubpub-zz/ppInk/releases/tag/v([\\w.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/pubpub-zz/ppInk/releases/download/v$version/ppInk.$version.zip",
        "hash": {
            "url": "https://api.github.com/repos/pubpub-zz/ppInk/releases/latest",
            "jsonpath": "$.assets[?(@.name == 'ppInk.$version.zip')].digest",
            "type": "sha256"
        },
        "extract_dir": "ppink"
    }
}
