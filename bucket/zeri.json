{
    "version": "1.0.1-alpha",
    "description": "TUI multi-language REPL with offline AI context",
    "homepage": "https://github.com/ilmartotch/ZeriReplEngine",
    "license": "MIT",
    "notes": [
        "Language runtimes are optional. Install any you want to use:",
        "  Python:  winget install Python.Python.3",
        "  Bun:     winget install Oven-sh.Bun",
        "  LuaJIT:  scoop install luajit",
        "  Ruby:    winget install RubyInstallerTeam.Ruby",
        "Custom paths: ZERI_PYTHON_PATH, ZERI_BUN_PATH, ZERI_LUAJIT_PATH, ZERI_RUBY_PATH",
        "For AI context ($ai): https://ollama.com"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/ilmartotch/ZeriReplEngine/releases/download/v1.0.1-alpha/zeri-windows-amd64.zip",
            "hash": "e7321c4585dde22719ae75106148f86287753eabe1443418eee242294a7379d8"
        }
    },
    "bin": "zeri.exe",
    "post_uninstall": [
        "$zeriConfig = Join-Path $env:APPDATA 'Zeri'",
        "$pointer = Join-Path $zeriConfig 'location.json'",
        "$dataRoot = $null",
        "if (Test-Path $pointer) {",
        "    try { $dataRoot = (Get-Content $pointer -Raw | ConvertFrom-Json).data_root } catch { $dataRoot = $null }",
        "    Remove-Item $pointer -Force -ErrorAction SilentlyContinue",
        "}",
        "if ([string]::IsNullOrWhiteSpace($dataRoot)) { $dataRoot = $zeriConfig }",
        "Write-Host ''",
        "Write-Host 'Zeri onboarding state was removed; the first-run setup will run again on next install.'",
        "Write-Host \"Your scripts and sessions were preserved at: $dataRoot\"",
        "Write-Host 'Delete that folder manually if you also want to remove your data.'"
    ],
    "checkver": {
        "github": "https://github.com/ilmartotch/ZeriReplEngine",
        "regex": "tag_name.:.v([\\d\\w.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ilmartotch/ZeriReplEngine/releases/download/v$version/zeri-windows-amd64.zip"
            }
        }
    }
}
