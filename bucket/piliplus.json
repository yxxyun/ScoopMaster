{
    "version": "2.1.0",
    "description": "使用 Flutter 开发的 BiliBili 第三方客户端",
    "homepage": "https://github.com/bggRGjQaUbCoE/PiliPlus",
    "architecture": {
        "64bit": {
            "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/2.1.0/PiliPlus_windows_2.1.0+5109_x64_portable.zip",
            "hash": "2a224047f55e1431910d527efe63a23828c701b8622e8c314d4e2102aa13349d"
        }
    },
    "extract_dir": "PiliPlus-Win",
    "shortcuts": [
        [
            "piliplus.exe",
            "PiliPlus"
        ]
    ],
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nPersisting $env:APPDATA\\com.example ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\com.example\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        ". \"$bucketsdir\\$bucket\\scripts\\piliplus\\uninstall.ps1\""
    ],
    "checkver": {
        "url": "https://api.github.com/repos/bggRGjQaUbCoE/PiliPlus/releases/latest",
        "jsonpath": "$.assets[*].name",
        "regex": "PiliPlus_windows_(?<version>[\\d.]+)\\+(?<build>\\d+)_x64_portable\\.zip"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/bggRGjQaUbCoE/PiliPlus/releases/download/$version/PiliPlus_windows_$version+$matchBuild_x64_portable.zip"
            }
        }
    }
}
