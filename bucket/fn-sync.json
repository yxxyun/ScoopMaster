{
    "version": "0.2.1",
    "description": "飞牛同步客户端，文件自动同步工具",
    "homepage": "https://fnnas.com/download?key=fn-sync-client",
    "license": {
        "identifier": "Proprietary",
        "url": "https://fnnas.com/pc-sync-client-privacy.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://iso.liveupdate.fnnas.com/pc/fn-sync_0.2.1_x64-setup.exe?sign=416e556c6c64b7593f402b67bf4c29cc&t=1783004549#/dl.7z",
            "hash": "c295a133f5287fb574fc53da6009bddd51c300eec11b97ec3cdd1e791a4e1d19"
        }
    },
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse -ErrorAction SilentlyContinue",
        "Remove-Item \"$dir\\uninstall.exe\" -Force -ErrorAction SilentlyContinue",
        "Write-Host (\"Persisting $env:APPDATA\\com.fn-sync-client.app ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\com.fn-sync-client.app\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Require-Admin",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        ". \"$bucketsdir\\$bucket\\scripts\\fn-sync\\uninstall.ps1\""
    ],
    "bin": "fn-sync-client.exe",
    "shortcuts": [
        [
            "fn-sync-client.exe",
            "飞牛同步"
        ]
    ],
    "checkver": {
        "script": [
            "$page = Invoke-WebRequest -Uri 'https://fnnas.com/download?key=fn-sync-client' -UseBasicParsing",
            "if ($page.Content -match 'fn-sync_([\\d.]+)_x64-setup\\.exe') {",
            "  $ver = $Matches[1]",
            "  $rawUrl = \"https://iso.liveupdate.fnnas.com/pc/fn-sync_${ver}_x64-setup.exe\"",
            "  $body = @{url=$rawUrl} | ConvertTo-Json",
            "  $signed = (Invoke-RestMethod -Uri 'https://fnnas.com/api/download-sign' -Method POST -Body $body -ContentType 'application/json').url",
            "  Write-Output $signed",
            "}"
        ],
        "regex": "fn-sync_(?<version>[\\d.]+)_x64-setup\\.exe\\?(?<query>sign=[^#]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://iso.liveupdate.fnnas.com/pc/fn-sync_$version_x64-setup.exe?$matchQuery#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    },
    "notes": [
        "User data are persisted in \"$persist_dir\".",
        "Please manually disable fnSync's auto-update feature in the settings. (Set it once and it will remember)"
    ]
}
