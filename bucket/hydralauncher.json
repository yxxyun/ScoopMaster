{
    "version": "4.0.5",
    "description": "Hydra is a game launcher with its own embedded bittorrent client",
    "homepage": "https://hydra-launcher.net/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/hydralauncher/hydra/releases/download/v4.0.5/hydralauncher-4.0.5-setup.exe#/dl.7z",
            "hash": "sha512:1f2f7046575bf83f3adc5aee20ee88ed3dbb22938497e02e6b11f86caef595e3aeeac28d28cd24c355deb5a80b870cf33db2544ab4402439bde26308fca6f466",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\" -Recurse"
            ]
        }
    },
    "shortcuts": [
        [
            "Hydra.exe",
            "Hydra",
            "--user-data-dir=\"$dir\\User Data\""
        ]
    ],
    "persist": "User Data",
    "checkver": {
        "github": "https://github.com/hydralauncher/hydra"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/hydralauncher/hydra/releases/download/v$version/hydralauncher-$version-setup.exe#/dl.7z",
                "hash": {
                    "url": "$baseurl/latest.yml",
                    "regex": "sha512:\\s+$base64"
                }
            }
        }
    }
}
