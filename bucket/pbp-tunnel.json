        }
    },
    "pre_install": [
        "$exe = Get-ChildItem -LiteralPath $dir -File | Where-Object Name -like 'pbp-tunnel-*.exe' | Select-Object -First 1",
        "if (-not $exe) { throw \"pbp-tunnel executable not found in $dir\" }",
        "Rename-Item -LiteralPath $exe.FullName -NewName 'pbp-tunnel.exe' -Force",
        "if (-not (Test-Path -LiteralPath \"$dir\\pbp-tunnel.exe\")) { throw 'Rename failed: pbp-tunnel.exe not found after rename' }"
    ],
    "bin": "pbp-tunnel.exe",
    "checkver": {
        "url": "https://api.github.com/repos/PoweredByPumP/pbp-tunnel/releases/latest",
        "regex": "\"tag_name\":\\s*\"([\\d.]+)\""
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/PoweredByPumP/pbp-tunnel/releases/download/$version/pbp-tunnel-$version.exe"
            },
            "arm64": {
                "url": "https://github.com/PoweredByPumP/pbp-tunnel/releases/download/$version/pbp-tunnel-$version-arm64.exe"
            }
        },
        "hash": {
            "url": "https://github.com/PoweredByPumP/pbp-tunnel/releases/download/$version/pbp-tunnel-$version.exe.sha256",
            "regex": "([a-fA-F0-9]{64})"
        }
    }
