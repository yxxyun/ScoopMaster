{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "1.0.4",
   "description": "An implementation of figlet written in Python.",
   "homepage": "https://github.com/pwaller/pyfiglet",
   "license": {
      "identifier": "MIT",
      "url": "https://github.com/pwaller/pyfiglet/blob/master/LICENSE"
   },
   "depends": "main/python",
   "url": "https://github.com/pwaller/pyfiglet/archive/v1.0.4.zip",
   "hash": "f0c52c57d301f8e84da59c68fd3ba63bda3edbb25f55e19f2ede8f1233dad8ea",
   "installer": {
      "script": [
         "python -m venv \"$dir\"",
         ".\"$dir\\Scripts\\pip.exe\" install --requirement \"$dir\\pyfiglet-$version\\requirements.txt\"",
         "Move-Item -Path \"$dir\\pyfiglet-$version\\pyfiglet\" -Destination \"$dir\" -Force",
         "New-Item -Type Directory -Path \"$dir\\pyfiglet\\fonts\\\" > $null",
         "Move-Item -Path \"$dir\\pyfiglet\\fonts-contrib\\*\",\"$dir\\pyfiglet\\fonts-standard\\*\" -Destination \"$dir\\pyfiglet\\fonts\" -Force",
         "Remove-Item -Path \"$dir\\pyfiglet-$version\",\"$dir\\pyfiglet\\fonts-contrib\",\"$dir\\pyfiglet\\fonts-standard\" -Recurse -Force",
         "Set-Content -Value \".'$dir\\Scripts\\python.exe' -m pyfiglet `$args\" -Path \"$dir\\pyfiglet.ps1\""
      ]
   },
   "bin": "pyfiglet.ps1",
   "checkver": {
      "github": "https://github.com/pwaller/pyfiglet"
   },
   "autoupdate": {
      "url": "https://github.com/pwaller/pyfiglet/archive/v$version.zip"
   }
}
