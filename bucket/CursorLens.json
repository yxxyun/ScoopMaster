{
    "version": "1.2.9",
    "description": "Open-source desktop screen recorder and editor for creating product demos, tutorials, and walkthrough videos",
    "homepage": "https://github.com/blueberrycongee/CursorLens",
    "license": "MIT",
    "notes": [
        "CursorLens 是一个开源桌面屏幕录制和编辑工具",
        "用户数据目录：%APPDATA%\\CursorLens\\",
        "本包会将该目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/blueberrycongee/CursorLens/releases/download/v1.2.9/CursorLens.exe",
            "hash": "e041ede4fb968877e86ecf7c00a283faf2b917d8d5c623c596bdce59dc3cfca0"
        }
    },
    "bin": "CursorLens.exe",
    "shortcuts": [
        [
            "CursorLens.exe",
            "CursorLens"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'CursorLens'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/blueberrycongee/CursorLens"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/blueberrycongee/CursorLens/releases/download/v$version/CursorLens.exe"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
