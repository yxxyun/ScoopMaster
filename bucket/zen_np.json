{
    "version": "1.21.7b",
    "description": "Zen Browser Nonportable (works with 1Password integration)",
    "homepage": "https://www.zen-browser.app/",
    "license": "MPL-2.0",
    "url": "https://github.com/zen-browser/desktop/releases/download/1.21.7b/zen.installer.exe#/setup.exe",
    "hash": "27641411f3387639f47dedcff81670ab3ee4e05a72789bcf4890c73b3db85dde",
    "installer": {
        "file": "setup.exe",
        "args": "/S /DIR='C:\\program files\\zen browser'"
    },
    "bin": "C:\\program files\\zen browser\\zen.exe",
    "shortcuts": [
        [
            "C:\\program files\\zen browser\\zen.exe",
            "Zen Browser Profile Manager",
            "-P"
        ]
    ],
    "pre_uninstall": "if (Get-Process -name zen -ea 0) {stop-process -name zen -force -ea 0; wait-process -name zen -ea 0; start-sleep 0.5}",
    "uninstaller": {
        "script": "start-process -wait 'C:\\program files\\zen browser\\uninstall\\helper.exe' -a '/S'"
    },
    "checkver": {
        "url": "https://github.com/zen-browser/desktop/tags",
        "regex": "releases/tag/([ab\\d.-]+)"
    },
    "autoupdate": {
        "url": "https://github.com/zen-browser/desktop/releases/download/$version/zen.installer.exe#/setup.exe"
    }
}
