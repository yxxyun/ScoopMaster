{
    "version": "1.125.0-af4e93b",
    "description": "Visual Studio Code is a lightweight but powerful source code editor (Exploration, Portable Edition).",
    "homepage": "https://code.visualstudio.com/",
    "license": {
        "identifier": "Freeware",
        "url": "https://code.visualstudio.com/License/"
    },
    "notes": [
        "Add Visual Studio Code as a context menu option by running:",
        "reg import \"$dir\\install-context.reg\"",
        "For file associations, run:",
        "reg import \"$dir\\install-associations.reg\""
    ],
    "architecture": {
        "64bit": {
            "url": "https://vscode.download.prss.microsoft.com/dbazure/download/exploration/af4e93b1a949d6891f2c636af28319d3b8e43752/VSCode-win32-x64-1.125.0-exploration.zip",
            "hash": "733e5c5d4e1d6f2aa87397b8eaf6c3f4fc4642611a41425d63b613a9ca04e579"
        },
        "arm64": {
            "url": "https://vscode.download.prss.microsoft.com/dbazure/download/exploration/af4e93b1a949d6891f2c636af28319d3b8e43752/VSCode-win32-arm64-1.125.0-exploration.zip",
            "hash": "61b547accb2f4c6d50a11dcd35ae8b07e443809383a5c5311748ff0b92f2e4ed"
        }
    },
    "post_install": [
        "$dirpath = \"$dir\".Replace('\\', '\\\\')",
        "$exepath = \"$dir\\Code - Exploration.exe\".Replace('\\', '\\\\')",
        "'install-associations', 'uninstall-associations', 'install-context', 'uninstall-context' | ForEach-Object {",
        "  if (Test-Path \"$bucketsdir\\extras\\scripts\\vscode\\$_.reg\") {",
        "    $content = Get-Content \"$bucketsdir\\extras\\scripts\\vscode\\$_.reg\"",
        "    $content = $content.Replace('$codedir', $dirpath)",
        "    $content = $content.Replace('$code', $exepath)",
        "    $content = $content.Replace('&Code', 'Code &Exploration')",
        "    if ($global) {",
        "      $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE')",
        "    }",
        "    $content | Set-Content -Path \"$dir\\$_.reg\"",
        "  }",
        "}",
        "if (!(Test-Path \"$dir\\data\\extensions\") -and (Test-Path \"$env:USERPROFILE\\.vscode-exploration\\extensions\")) {",
        "    info '[Portable Mode] Copying extensions...'",
        "    Copy-Item \"$env:USERPROFILE\\.vscode-exploration\\extensions\" \"$dir\\data\" -Recurse",
        "}",
        "if (!(Test-Path \"$dir\\data\\user-data\") -and (Test-Path \"$env:AppData\\Code - Exploration\")) {",
        "    info '[Portable Mode] Copying user data...'",
        "    Copy-Item \"$env:AppData\\Code - Exploration\" \"$dir\\data\\user-data\" -Recurse",
        "}",
        "$extensions_file = \"$dir\\data\\extensions\\extensions.json\"",
        "if ((Test-Path \"$extensions_file\")) {",
        "    info 'Adjusting path in extensions file...'",
        "    (Get-Content \"$extensions_file\") -replace '(?<=vscode-exploration(/|\\\\\\\\)).*?(?=(/|\\\\\\\\)data(/|\\\\\\\\)extensions)', $version | Set-Content \"$extensions_file\"",
        "}"
    ],
    "env_add_path": "bin",
    "shortcuts": [
        [
            "Code - Exploration.exe",
            "Visual Studio Code - Exploration"
        ]
    ],
    "persist": "data",
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { reg import \"$dir\\uninstall-context.reg\" }"
    },
    "checkver": {
        "url": "https://update.code.visualstudio.com/api/update/win32-x64-archive/exploration/latest",
        "jsonpath": "$..['version', 'productVersion']",
        "regex": "^\\[\"(?<commit>(?<commitShort>[0-9a-f]{7})[0-9a-f]*)\",\"(?<productVersion>.+)-exploration\"",
        "replace": "${productVersion}-${commitShort}"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://vscode.download.prss.microsoft.com/dbazure/download/exploration/$matchCommit/VSCode-win32-x64-$matchHead-exploration.zip",
                "hash": {
                    "url": "https://update.code.visualstudio.com/api/update/win32-x64-archive/exploration/latest",
                    "jsonpath": "$.sha256hash"
                }
            },
            "arm64": {
                "url": "https://vscode.download.prss.microsoft.com/dbazure/download/exploration/$matchCommit/VSCode-win32-arm64-$matchHead-exploration.zip",
                "hash": {
                    "url": "https://update.code.visualstudio.com/api/update/win32-arm64-archive/exploration/latest",
                    "jsonpath": "$.sha256hash"
                }
            }
        }
    }
}
