            "hash": "f3513bc29819cba0bc17f86bcc0a1b05ec963a58b8b96443d3fd38c75f883938"
        }
    },
    "installer": {
        "script": [
            "$exe = Get-ChildItem \"$dir\\CodexPlusPlus-*-windows-x64-setup.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
            "if ($exe) { Start-Process -FilePath $exe.FullName -ArgumentList '/S', \"/D=$dir\" -Wait -NoNewWindow }"
        ]
    },
    "post_install": "Remove-Item \"$dir\\CodexPlusPlus-*-windows-x64-setup.exe\", \"$dir\\uninstall.exe\" -Force -ErrorAction SilentlyContinue",
    "bin": "codex-plus-plus.exe",
    "shortcuts": [
        [
            "codex-plus-plus.exe",
            "Codex++"
        ],
        [
            "codex-plus-plus-manager.exe",
            "Codex++ Manager"
        ]
    ],
    "checkver": {
        "github": "https://github.com/BigPizzaV3/CodexPlusPlus"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/BigPizzaV3/CodexPlusPlus/releases/download/v$version/CodexPlusPlus-$version-windows-x64-setup.exe"
            }
        }
    }
}
