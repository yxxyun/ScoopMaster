{
    "version": "2.0.4",
    "description": "Convert your full OG Xbox ISO dumps into split ISO images",
    "homepage": "https://github.com/Team-Resurgent/Repackinator",
    "license": "GPL-3.0-only",
    "notes": [
        "Repackinator has a very annoying bug where it rewrites the contents of RepackList.json after operations.",
        "This will lead to truncated game database lists (missing Alt or Main).",
        "A backup of this file was created for your convenience, alongside the original."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Team-Resurgent/Repackinator/releases/download/V2.0.4/Repackinator-win-x64.zip",
            "hash": "ec7e25f115521034e88a7ee158d620fa938273227cd506b388e01d37fce755a0"
        }
    },
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.json\")) { Set-Content \"$dir\\config.json\" '{}' }",
        "if (!(Test-Path \"$persist_dir\\settings.ini\")) { New-Item \"$dir\\settings.ini\" | Out-Null }"
    ],
    "persist": [
        "config.json",
        "settings.ini"
    ],
    "shortcuts": [
        [
            "repackinator.exe",
            "Repackinator"
        ]
    ],
    "bin": "repackinator.exe",
    "post_install": [
        "Write-Host \"`nBacking up RepackList.json to RepackList_backup.json...\" -ForegroundColor Yellow",
        "Copy-Item -Path \"$dir\\RepackList.json\" -Destination \"$dir\\RepackList_backup.json\" -Force"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Team-Resurgent/Repackinator/releases/download/V$version/Repackinator-win-x64.zip"
            }
        }
    }
}
