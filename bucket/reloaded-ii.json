{
    "version": "1.30.2",
    "description": "Universal .NET-powered modding framework for any native x86/x64 game",
    "homepage": "https://reloaded-project.github.io/Reloaded-II/",
    "license": {
        "identifier": "GPL-3.0-or-later",
        "url": "https://github.com/Reloaded-Project/Reloaded-II/blob/master/LICENSE.md"
    },
    "notes": [
        "Custom PowerShell scripts are included in this manifest for profile management, so be sure to create & enable your new profile for user config persistence before using the app.",
        "",
        "If you get a missing dependencies error when installing mods, try connecting to the Cloudflare WARP VPN and reopen the app."
    ],
    "suggest": {
        ".NET Desktop Runtime 9.0": "versions/windowsdesktop-runtime-9.0"
    },
    "url": "https://github.com/Reloaded-Project/Reloaded-II/releases/download/1.30.2/Release.zip",
    "hash": "7446899fe80d27d46aada46d8a0582b5b96456dde79e75a919ba069306403c49",
    "pre_install": [
        "if (Test-Path \"$persist_dir\\Theme\") {",
        "   Copy-Item \"$dir\\Theme\" \"$persist_dir\" -Force -Recurse",
        "   Remove-Item \"$dir\\Theme\" -Force -Recurse",
        "}",
        "Copy-Item \"$bucketsdir\\$bucket\\scripts\\reloaded-ii\\*\" \"$dir\" -Include *.ps1",
        "New-Item \"$dir\\portable.txt\" -ItemType File | Out-Null"
    ],
    "architecture": {
        "32bit": {
            "bin": [
                "r2-add-profile.ps1",
                "r2-delete-profile.ps1",
                "r2-enable-profile.ps1",
                "r2-list.ps1",
                "r2-rename-profile.ps1",
                [
                    "Reloaded-II32.exe",
                    "reloaded-ii"
                ]
            ],
            "shortcuts": [
                [
                    "Reloaded-II32.exe",
                    "Reloaded-II"
                ]
            ]
        },
        "64bit": {
            "bin": [
                "r2-add-profile.ps1",
                "r2-delete-profile.ps1",
                "r2-enable-profile.ps1",
                "r2-list.ps1",
                "r2-rename-profile.ps1",
                [
                    "Reloaded-II.exe",
                    "reloaded-ii"
                ]
            ],
            "shortcuts": [
                [
                    "Reloaded-II.exe",
                    "Reloaded-II"
                ]
            ]
        }
    },
    "persist": [
        "_Profiles",
        "Mods",
        "Plugins",
        "Theme"
    ],
    "checkver": {
        "github": "https://github.com/Reloaded-Project/Reloaded-II"
    },
    "autoupdate": {
        "url": "https://github.com/Reloaded-Project/Reloaded-II/releases/download/$version/Release.zip"
    }
}
