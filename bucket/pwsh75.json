{
    "##": [
        "Why here? I want multiple PowerShell versions side by side.",
        "Strategy for having multiple versions installed side by side:",
        "* Add all versions to PATH (env_add_path), because a shim (bin) does not carry over the icon.",
        "* Rename all versions but the current newest stable one to avoid naming conflict."
    ],
    "version": "7.5.9",
    "description": "Latest stable PowerShell 7.5.x. Cross-platform automation and configuration tool/framework, known as Powershell Core, that works well with existing tools and is optimized for dealing with structured data.",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": "MIT",
    "architecture": {
        "32bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.9/PowerShell-7.5.9-win-x86.zip",
            "hash": "3d14184dd7d27c2f838fffbc602e439524e93da687ecac37f6bd5d934e825f6d"
        },
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.9/PowerShell-7.5.9-win-x64.zip",
            "hash": "1e769394e2cde496bf6c55797a51a88873091415a853fa3b56255b2329fa3ef8"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.9/PowerShell-7.5.9-win-arm64.zip",
            "hash": "c7dd8b6fbff92840bebf66060afb242b7e77c46b4b0ef67ceb0a1ff3fd65a64c"
        }
    },
    "pre_install": [
        "# Rename and add to path instead of shimming, as the shim will not show the app icon",
        "Rename-Item -Path \"$dir\\pwsh.exe\" -NewName \"pwsh75.exe\"",
        "# Delete some included modules",
        "$ModulesToRemove = [string[]](",
        "    'Microsoft.PowerShell.PSResourceGet',",
        "    'PackageManagement',",
        "    'PowerShellGet'",
        ")",
        "$ModulesToRemove.ForEach{",
        "    $Path = [System.IO.Path]::Combine($dir, 'Modules', $_)",
        "    if ([System.IO.Directory]::Exists($Path)) {",
        "        info ('Removing included module \"{0}\".' -f $_)",
        "        $null = [System.IO.Directory]::Delete($Path, $true)",
        "    }",
        "}"
    ],
    "env_add_path": ".",
    "env_set": {
        "POWERSHELL_UPDATECHECK": "Off"
    },
    "shortcuts": [
        [
            "pwsh75.exe",
            "PowerShell 7.5",
            "-WorkingDirectory ~"
        ],
        [
            "pwsh75.exe",
            "PowerShell 7.5 -NoProfile",
            "-WorkingDirectory ~ -NoProfile"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/PowerShell/PowerShell/releases",
        "jsonpath": "$[?(@.prerelease == false)].tag_name",
        "regex": "v(7\\.5\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x86.zip"
            },
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-arm64.zip"
            }
        }
    }
}
