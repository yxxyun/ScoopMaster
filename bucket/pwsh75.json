{
    "##": [
        "Why here? I want multiple PowerShell versions side by side.",
        "Strategy: Add current stable version of PowerShell to PATH (env_add_path), the others as Scoop shims (bin)."
    ],
    "version": "7.5.5",
    "description": "Cross-platform automation and configuration tool/framework, known as Powershell Core, that works well with existing tools and is optimized for dealing with structured data.",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": "MIT",
    "architecture": {
        "32bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.5/PowerShell-7.5.5-win-x86.zip",
            "hash": "2106bffb6c42b2ab8b23a0e10573d0770cbf0b3731eb1cd108e59b64f9ceb17c"
        },
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.5/PowerShell-7.5.5-win-x64.zip",
            "hash": "9d4c9247fa5d8b090470b5c676b1ce6e22029eeab8a5cb1d11480e3840172c99"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.5.5/PowerShell-7.5.5-win-arm64.zip",
            "hash": "e36b5a5f9b1511beebe1b7589e5a5adff955349f635e411021c03aef4432c505"
        }
    },
    "post_install": [
        "$Directories = [string[]](",
        "    [System.IO.Path]::Combine($dir,'Modules','Microsoft.PowerShell.PSResourceGet')",
        ")",
        "$Directories.ForEach{",
        "    if ([System.IO.Directory]::Exists($_)) {",
        "        $null = [System.IO.Directory]::Delete($_,$true)",
        "    }",
        "}"
    ],
    "env_add_path": ".",
    "env_set": {
        "POWERSHELL_UPDATECHECK": "Off"
    },
    "shortcuts": [
        [
            "pwsh.exe",
            "PowerShell 7.5",
            "-WorkingDirectory ~"
        ],
        [
            "pwsh.exe",
            "PowerShell 7.5 -NoProfile",
            "-WorkingDirectory ~ -NoProfile"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/PowerShell/PowerShell/releases",
        "regex": "v(7\\.5\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "32bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x86.zip"
            },
            "64bit": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/PowerShell/PowerShell/releases/download/v$version/PowerShell-$version-win-arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/hashes.sha256"
        }
    }
}
