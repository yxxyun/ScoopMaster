{
    "version": "0.2.2",
    "description": "League of Legends ARAM assistant with read-only LCU recommendations, augment OCR, and in-game data overlays",
    "homepage": "https://github.com/valkia/aramgg_client",
    "license": "Unknown",
    "notes": [
        "应用需要 League of Legends 客户端运行，LCU 推荐链路只读，部分功能会自动截图和执行 OCR",
        "安装版运行数据目录由源码按 exe 路径解析为 aramgg_client-data，本包将其持久化到 Scoop persist\\data",
        "electron-store 配置目录为 %APPDATA%\\aramgg_client\\config，本包将整个 %APPDATA%\\aramgg_client 目录持久化到 persist\\user-data"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/valkia/aramgg_client/releases/download/v0.2.2/aramgg_client.Setup.0.2.2.exe#/dl.7z",
            "hash": "cc6c62675447a433d9678345344e0c2a0701536619c2bdd70a3ad382067c2ddb"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$*\", \"$dir\\Uninstall*\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "aramgg_client.exe",
    "shortcuts": [
        [
            "aramgg_client.exe",
            "aramgg_client"
        ]
    ],
    "post_install": [
        "function Ensure-ManagedJunction {",
        "    param([string]$source, [string]$target)",
        "    ensure $target",
        "    $backup = $null",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            $expected = [IO.Path]::GetFullPath($target).TrimEnd('\\')",
        "            $actual = @($item.Target) | Select-Object -First 1",
        "            if ($actual -and [IO.Path]::GetFullPath($actual).TrimEnd('\\') -ieq $expected) {",
        "                Write-Host \"Junction already managed by Scoop: $source\"",
        "                return",
        "            }",
        "            throw \"Path is an existing reparse point not managed by this package: $source\"",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"Path exists and is not a directory: $source\"",
        "        }",
        "        & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        $copyExitCode = $LASTEXITCODE",
        "        if ($copyExitCode -gt 7) {",
        "            throw \"Migration failed with robocopy exit code ${copyExitCode}: $source\"",
        "        }",
        "        $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"Backed up original data directory: $backup\"",
        "    }",
        "    try {",
        "        New-Item -Path $source -ItemType Junction -Value $target -Force | Out-Null",
        "    } catch {",
        "        if ($backup -and (Test-Path $backup) -and -not (Test-Path $source)) {",
        "            Move-Item -LiteralPath $backup -Destination $source -Force",
        "        }",
        "        throw",
        "    }",
        "}",
        "",
        "$installRoot = Split-Path -Parent $dir",
        "$installSideData = Join-Path $installRoot 'aramgg_client-data'",
        "$defaultUserData = Join-Path $env:APPDATA 'aramgg_client'",
        "Ensure-ManagedJunction $installSideData (Join-Path $persist_dir 'data')",
        "Ensure-ManagedJunction $defaultUserData (Join-Path $persist_dir 'user-data')"
    ],
    "post_uninstall": [
        "function Remove-ManagedJunction {",
        "    param([string]$source, [string]$target)",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            $expected = [IO.Path]::GetFullPath($target).TrimEnd('\\')",
        "            $actual = @($item.Target) | Select-Object -First 1",
        "            if ($actual -and [IO.Path]::GetFullPath($actual).TrimEnd('\\') -ieq $expected) {",
        "                Remove-Item -LiteralPath $source -Force",
        "            }",
        "        }",
        "    }",
        "}",
        "",
        "$installRoot = Split-Path -Parent $dir",
        "Remove-ManagedJunction (Join-Path $installRoot 'aramgg_client-data') (Join-Path $persist_dir 'data')",
        "Remove-ManagedJunction (Join-Path $env:APPDATA 'aramgg_client') (Join-Path $persist_dir 'user-data')"
    ],
    "persist": [
        "data",
        "user-data"
    ],
    "checkver": {
        "github": "https://github.com/valkia/aramgg_client"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/valkia/aramgg_client/releases/download/v$version/aramgg_client.Setup.$version.exe#/dl.7z"
            }
        }
    }
}
