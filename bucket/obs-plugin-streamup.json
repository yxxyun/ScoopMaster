{
    "version": "2.2.3",
    "homepage": "https://github.com/StreamUPTips/obs-streamup",
    "description": "This toolkit that makes OBS less annoying. Product installation, plugin update checking, scene organisation, custom docks, a toolbar, dedicated hotkeys, a source type, a full WebSocket API, and a pile of quality of life bits. All in one plugin.",
    "license": "GPL-2.0",
    "notes": "If you don't have any obs-studio version installed in your computer, please install one of the following below. Then uninstall this app and install it again.",
    "suggest": {
        "OBS": [
            "extras/obs-studio",
            "extras/obs-studio-small",
            "versions/obs-studio-pre"
        ]
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/StreamUPTips/obs-streamup/releases/download/2.2.3/streamup-2.2.3-windows-x64.zip",
            "hash": "92e542348f994b359af5a2197c3f17a78089320da274a55700729f7140b3a2e6"
        }
    },
    "pre_install": [
        "'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {",
        "    $obs = \"$(appdir $_ $global)\"",
        "    if (Test-Path $obs) {",
        "       info \"Install for $_\"",
        "       Copy-Item \"$dir\\data\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue",
        "       Copy-Item \"$dir\\obs-plugins\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue",
        "   }",
        "}"
    ],
    "pre_uninstall": [
        "'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {",
        "    $obs = \"$(appdir $_ $global)\"",
        "    if (Test-Path $obs) {",
        "        info \"Uninstall for $_\"",
        "        Remove-Item \"$obs\\current\\data\\obs-plugins\\streamup\" -Force -Recurse -ErrorAction SilentlyContinue",
        "        Remove-Item \"$obs\\current\\obs-plugins\\64bit\\streamup.*\" -Force -ErrorAction SilentlyContinue",
        "    }",
        "}"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/StreamUPTips/obs-streamup/releases/download/$version/streamup-$version-windows-x64.zip"
            }
        }
    }
}
