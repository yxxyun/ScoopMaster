{
    "version": "7.1.4",
    "description": "Rolling Release Stable Real-Time Kernel Addon Packages (Modules, Headers, Docs) for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "notes": "This kernel addon package require WSL v2.5.1 or later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.1.4/bzImage-x86_64-rt-addon.vhdx.7z",
            "hash": "1e5779ec059d8444dff2bb9b882795bc38f11dfd0b7c4c4e538e1f0cc92b0c6e",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
                "$kernel_addon_file = \"$original_dir\\bzImage-x86_64-rt-addon.vhdx\"",
                "SetVhdxAcl -Path $kernel_addon_file",
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_addon_path = $kernel_addon_file -replace \"\\\\\", \"\\\\\"",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.1.4/Image-arm64-rt-addon.vhdx.7z",
            "hash": "d921e6ae750f0e3c667cd2cb0ed79e4b320d6440e30249f7e932a7ee6bbd9f58",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\SetVhdxAcl.ps1",
                "$kernel_addon_file = \"$original_dir\\Image-arm64-rt-addon.vhdx\"",
                "SetVhdxAcl -Path $kernel_addon_file",
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_addon_path = $kernel_addon_file -replace \"\\\\\", \"\\\\\"",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64-rt-addon.vhdx.7z"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64-rt-addon.vhdx.7z"
            }
        }
    }
}
