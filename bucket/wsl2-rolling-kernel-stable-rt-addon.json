{
    "version": "7.0.1",
    "description": "Rolling Release Stable Real-Time Kernel Addon Packages (Modules, Headers, Docs) for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "notes": "This kernel addon package require WSL v2.5.1 or later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.0.1/bzImage-x86_64-rt-addon.vhdx.7z",
            "hash": "c78339e2b2693bb708037cafe4e9cbceb198fbc8b8743053d1191c77b339b780",
            "post_install": [
                "####################################################################",
                "# Set WSL2 rolling Real-Time kernel addon packages in `.wslconfig` #",
                "#                  Channel: STABLE | Arch: x86_64                  #",
                "####################################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageInstall -UsingNamespace System.Text",
                "$kernel_addon_path=\"$original_dir\\bzImage-x86_64-rt-addon.vhdx\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "#######################################################################",
                "# Remove WSL2 rolling Real-Time kernel addon packages in `.wslconfig` #",
                "#######################################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.0.1/Image-arm64-rt-addon.vhdx.7z",
            "hash": "ba29d18e35fde6d708c2b53c77922958327daeedfa08a9d1884503ae4c826e31",
            "post_install": [
                "####################################################################",
                "# Set WSL2 rolling Real-Time kernel addon packages in `.wslconfig` #",
                "#                  Channel: STABLE | Arch: arm64                   #",
                "####################################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageInstall -UsingNamespace System.Text",
                "$kernel_addon_path=\"$original_dir\\Image-arm64-rt-addon.vhdx\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "#######################################################################",
                "# Remove WSL2 rolling Real-Time kernel addon packages in `.wslconfig` #",
                "#######################################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelAddonPackageUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64-rt-addon.vhdx.7z"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64-rt-addon.vhdx.7z"
            }
        }
    }
}
