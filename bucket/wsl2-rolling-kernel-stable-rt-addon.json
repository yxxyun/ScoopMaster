{
    "version": "7.0.5",
    "description": "Rolling Release Stable Real-Time Kernel Addon Packages (Modules, Headers, Docs) for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "notes": "This kernel addon package require WSL v2.5.1 or later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.0.5/bzImage-x86_64-rt-addon.vhdx.7z",
            "hash": "5849e7198985c1a4fe15710256876d93aefc6f60cabfac93889e2f8c58b2ae3d",
            "post_install": [
                ". $bucketsdir\\$bucket\\script\\iniFile.ps1",
                "$kernel_addon_path=\"$original_dir\\bzImage-x86_64-rt-addon.vhdx\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [iniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\script\\iniFile.ps1",
                "$null = [iniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.0.5/Image-arm64-rt-addon.vhdx.7z",
            "hash": "086947145e26c40cf543a4ea79f34a0ed297fe96d99f5fb554a40ad000bf38c0",
            "post_install": [
                ". $bucketsdir\\$bucket\\script\\iniFile.ps1",
                "$kernel_addon_path=\"$original_dir\\Image-arm64-rt-addon.vhdx\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [iniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $kernel_addon_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\script\\iniFile.ps1",
                "$null = [iniFile]::WritePrivateProfileString(\"wsl2\", \"kernelModules\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64-rt-addon.vhdx.7z"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64-rt-addon.vhdx.7z"
            }
        }
    }
}
