{
    "version": "0.4.6",
    "description": "The open-source managed agents platform. Turn coding agents into real teammates — assign tasks, track progress, compound skills.",
    "homepage": "https://github.com/multica-ai/multica",
    "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/multica-ai/multica/releases/download/v0.4.6/multica-desktop-0.4.6-windows-x64.exe",
    "hash": "sha256:7080b9caf7187f4d304c204ec908351449b427d03a0c248d2a92ed3521ba36e7"
    }
  },
  "nsis": true,
  "pre_install": [
    "# Extract the NSIS installer",
    "$installer = Join-Path $dir 'multica-desktop-0.4.6-windows-x64.exe'",
    "$7zip = Get-Command '7z' -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source",
    "if (-not $7zip) { $7zip = Join-Path $env:SCOOP 'apps\\7zip\\current\\7z.exe' }",
    "Write-Host 'Extracting NSIS installer...' -ForegroundColor Green",
    "& $7zip x $installer \"-o$dir\" -y | Out-Null",
    "# Extract app-64.7z from $PLUGINSDIR",
    "$appArchive = Join-Path $dir '$PLUGINSDIR\\app-64.7z'",
    "if (Test-Path $appArchive) {",
    "    Write-Host 'Extracting app-64.7z...' -ForegroundColor Green",
    "    & $7zip x $appArchive \"-o$dir\" -y | Out-Null",
    "    # Clean up",
    "    Remove-Item (Join-Path $dir '$PLUGINSDIR') -Recurse -Force -ErrorAction SilentlyContinue",
    "    Remove-Item $installer -Force -ErrorAction SilentlyContinue",
    "    Write-Host 'Installation completed.' -ForegroundColor Green",
    "} else {",
    "    Write-Error 'Failed to extract installer'",
    "}"
  ],
    "bin": ["Multica.exe"],
    "shortcuts": [
        [
            "Multica.exe",
            "Multica Desktop"
        ]
    ],
    "checkver": {
        "github": "https://github.com/multica-ai/multica"
    },
    "autoupdate": {
        "url": "https://github.com/multica-ai/multica/releases/download/v$version/multica-desktop-v$version-windows-x64.exe",
		"hash": {
			"url": "$url.sha256"
		}
    }
}
