{
    "##": [
        "Why here? I want multiple PowerShell versions side by side.",
        "7.2 was deprecated 2024-11-08, thus checkver and autoupdate is removed.",
        "Strategy for having multiple versions installed side by side:",
        "* Add all versions to PATH (env_add_path), because a shim (bin) does not carry over the icon.",
        "* Rename all versions but the current newest stable one to avoid naming conflict."
    ],
    "version": "7.2.24",
    "description": "Latest stable PowerShell 7.2.x. Cross-platform automation and configuration tool/framework, known as Powershell Core, that works well with existing tools and is optimized for dealing with structured data.",
    "homepage": "https://github.com/PowerShell/PowerShell",
    "license": "MIT",
    "architecture": {
        "32bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.2.24/PowerShell-7.2.24-win-x86.zip",
            "hash": "6d9c88f5dcb0dad94d835329e9da104cd5e8aa4866c39c9a2f8303b4343a23a8"
        },
        "64bit": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.2.24/PowerShell-7.2.24-win-x64.zip",
            "hash": "a1ccb6d8ad52f917470a136c3752af4465f261bcbe570cf44f52aa69ae6e867e"
        },
        "arm64": {
            "url": "https://github.com/PowerShell/PowerShell/releases/download/v7.2.24/PowerShell-7.2.24-win-arm64.zip",
            "hash": "c5d6cf97b19d28b583efb7f55d0a96cccf73b86c108efaeaf1d21944442fb574"
        }
    },
    "pre_install": [
        "# Rename and add to path instead of shimming, as the shim will not show the app icon",
        "Rename-Item -Path \"$dir\\pwsh.exe\" -NewName \"pwsh72.exe\"",
        "# Delete some included modules",
        "$Directories = [string[]](",
        "    [System.IO.Path]::Combine($dir,'Modules','Microsoft.PowerShell.PSResourceGet')",
        ")",
        "$Directories.ForEach{",
        "    if ([System.IO.Directory]::Exists($_)) {",
        "        $null = [System.IO.Directory]::Delete($_,$true)",
        "    }",
        "}"
    ],
    "env_add_path": ".",
    "shortcuts": [
        [
            "pwsh72.exe",
            "PowerShell 7.2",
            "-WorkingDirectory ~"
        ],
        [
            "pwsh72.exe",
            "PowerShell 7.2 -NoProfile",
            "-WorkingDirectory ~ -NoProfile"
        ]
    ]
}
