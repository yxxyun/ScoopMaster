{
    "version": "1.1.1",
    "description": "Scoop 下载加速器. 支持将 GitHub、SourceForge、Node.js 的请求重定向至国内高速镜像, 告别下载超时.",
    "homepage": "https://github.com/Arama0517/scoop-proxy-cn",
    "url": [
        "https://raw.githubusercontent.com/Arama0517/scoop-proxy-cn/v1.1.1/scripts/scoop-proxy-cn/scoop-proxy-cn.psm1",
        "https://raw.githubusercontent.com/Arama0517/scoop-proxy-cn/v1.1.1/scripts/scoop-proxy-cn/scoop-proxy-cn.psd1"
    ],
    "hash": [
        "18aa73ed9b50875879293758520eb12f58e591f2573b934797a9b0892b865c1b",
        "67a9a8981a0e449b5a593aa85bc0462cd6aac92eeeb1d50410e0d4b6d0bdab59"
    ],
    "license": "MIT",
    "notes": [
        "运行以下命令以自动在 Powershell 中导入 scoop-proxy-cn:",
        "$dir\\add-profile-content.ps1"
    ],
    "pre_install": [
        "if (-not (Test-Path (Find-BucketDirectory -Root -Name extras))) {",
        "    throw '请先安装 extras bucket: scoop bucket add extras'",
        "}"
    ],
    "post_install": [
        "Import-Module scoop-proxy-cn",
        "$BucketDir = Find-BucketDirectory -Root -Name extras",
        "$UtilsPath = $BucketDir | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (Test-Path $UtilsPath) {",
        "    Unblock-File $UtilsPath",
        "    Import-Module $UtilsPath",
        "    New-ProfileModifier -Type ImportModule -Name scoop-proxy-cn -BucketDir $BucketDir",
        "    New-ProfileModifier -Type RemoveModule -Name scoop-proxy-cn -BucketDir $BucketDir",
        "    Remove-Module ModifyPSProfile -ErrorAction SilentlyContinue",
        "} else {",
        "    throw '缺少文件, 请更新 scoop bucket 并重新安装此应用.'",
        "}"
    ],
    "pre_uninstall": [
        "Remove-Module scoop-proxy-cn -ErrorAction SilentlyContinue",
        "$UtilsPath = Find-BucketDirectory -Root -Name $install.bucket | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (($cmd -eq 'uninstall') -and (Test-Path \"$dir\\remove-profile-content.ps1\") -and (Test-Path $UtilsPath)) {",
        "    Unblock-File $UtilsPath",
        "    & \"$dir\\remove-profile-content.ps1\"",
        "}"
    ],
    "psmodule": {
        "name": "scoop-proxy-cn"
    },
    "checkver": {
        "url": "https://api.github.com/repos/Arama0517/scoop-proxy-cn/tags",
        "jsonpath": "$[*].name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "url": [
            "https://raw.githubusercontent.com/Arama0517/scoop-proxy-cn/v$version/scripts/scoop-proxy-cn/scoop-proxy-cn.psm1",
            "https://raw.githubusercontent.com/Arama0517/scoop-proxy-cn/v$version/scripts/scoop-proxy-cn/scoop-proxy-cn.psd1"
        ]
    }
}
