{
    "version": "2.5.0",
    "description": "IBM Plex Mono",
    "homepage": "https://github.com/IBM/plex",
    "license": "OFL-1.1-RFN",
    "url": "https://github.com/IBM/plex/releases/download/%40ibm%2Fplex-mono%402.5.0/ibm-plex-mono.zip",
    "hash": "6d23f01257663d8cc49a0d64c22ced630b79e0e2a0ac08a0da86e9a38bbc481c",
    "depends": "unoun/scoop-helper",
    "pre_install": [
        "Get-ChildItem \"$dir\\*\" -Include *.ttf -Recurse | Remove-Item",
        "Get-ChildItem \"$dir\\*\" -Include *.otf -Recurse | where { $_.FullName -like \"*\\unhinted\\*\" } | Remove-Item"
    ],
    "installer": {
        "script": [
            "$helper = \"$(appdir scoop-helper)\\current\\scoop-font-helper.ps1\"",
            "if (!(Test-Path $helper)) { error 'File not found'; exit 1 }",
            ". $helper",
            "Install-Font($dir)"
        ]
    },
    "uninstaller": {
        "script": [
            "$helper = \"$(appdir scoop-helper)\\current\\scoop-font-helper.ps1\"",
            "if (!(Test-Path $helper)) { error 'File not found'; exit 1 }",
            ". $helper",
            "Uninstall-Font($dir)"
        ]
    },
    "checkver": {
        "url": "https://api.github.com/repos/IBM/plex/releases",
        "regex": "\"tag_name\":\"@ibm/plex-mono@([\\d.]+)"
    },
    "autoupdate": {
        "url": "https://github.com/IBM/plex/releases/download/%40ibm%2Fplex-mono%40$version/ibm-plex-mono.zip"
    }
}
