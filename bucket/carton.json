    "architecture": {
        "64bit": {
            "url": "https://github.com/821869798/carton/releases/download/v0.1.8/carton-0.1.8-win-x64-portable.zip",
            "hash": "f273b8f32409906bbb1519f13fae067da6cfa51207683e0df607246500bcfdef"
        },
        "arm64": {
            "url": "https://github.com/821869798/carton/releases/download/v0.1.8/carton-0.1.8-win-arm64-portable.zip",
            "hash": "02a9c09742c0530aeaea68dbcff2df7810a6c0b2e3f9fbad7e05657271aa7320"
        }
    },
    "shortcuts": [
        [
            "carton.exe",
            "Carton"
        ]
    ],
    "pre_install": [
        "$portableFlag = \"$dir\\.carton_portable_data\"",
        "if (!(Test-Path \"$portableFlag\")) {",
        "    Add-Content -Path \"$portableFlag\" -Value \"true\" -NoNewline",
        "}"
    ],
    "bin": "carton.exe",
    "env_add_path": "bin",
    "persist": [
        ".carton_portable_data",
        "data",
        "bin"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-x64-portable.zip"
            },
            "arm64": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-arm64-portable.zip"
            }
        }
    }
