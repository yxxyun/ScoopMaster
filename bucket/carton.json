    "env_add_path": "bin",
    "persist": [
        ".carton_portable_data",
        "data",
        "bin"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-x64-portable.zip"
            },
            "arm64": {
