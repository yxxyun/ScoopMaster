            "hash": "489fde9d3ea78edc9b18280299b93e17a74a67f761a0bb400efbeff72b593b90"
        },
        "arm64": {
            "url": "https://github.com/821869798/carton/releases/download/v0.2.0/carton-0.2.0-win-arm64-portable.zip",
            "hash": "cc9012b1cacf89cc6842232c9ae8dcc6221421c4d3387f9504a816faa06997cd"
        }
    },
    "shortcuts": [
        [
            "carton.exe",
            "Carton"
        ]
    ],
    "pre_install": [
        "$portableFlag = \"$dir\\.carton_portable_data\"",
        "if (!(Test-Path \"$portableFlag\")) {",
        "    Add-Content -Path \"$portableFlag\" -Value \"true\" -NoNewline",
        "}"
    ],
    "bin": "carton.exe",
    "env_add_path": "bin",
    "persist": [
        ".carton_portable_data",
        "data",
        "bin"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-x64-portable.zip"
            },
            "arm64": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-arm64-portable.zip"
            }
        }
    }
