{
    "version": "0.1.9",
    "description": "A Windows and Linux GUI client for sing-box.",
    "homepage": "https://github.com/821869798/carton",
    "license": "GPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/821869798/carton/releases/download/v0.1.9/carton-0.1.9-win-x64-portable.zip",
            "hash": "1c754b49cfb9066e235b17237e02d9a8ea660319853e853a485f40f440e5ddcd"
        },
        "arm64": {
            "url": "https://github.com/821869798/carton/releases/download/v0.1.9/carton-0.1.9-win-arm64-portable.zip",
            "hash": "b1f0734dba591fa91ed517efd28da2b245dc17668bd8ffa20d644165cecc12fd"
        }
    },
    "shortcuts": [
        [
            "carton.exe",
            "Carton"
        ]
    ],
    "pre_install": [
        "$portableFlag = \"$dir\\.carton_portable_data\"",
        "if (!(Test-Path \"$portableFlag\")) {",
        "    Add-Content -Path \"$portableFlag\" -Value \"true\" -NoNewline",
        "}"
    ],
    "bin": "carton.exe",
    "env_add_path": "bin",
    "persist": [
        ".carton_portable_data",
        "data",
        "bin"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-x64-portable.zip"
            },
            "arm64": {
                "url": "https://github.com/821869798/carton/releases/download/v$version/carton-$version-win-arm64-portable.zip"
            }
        }
    }
}
