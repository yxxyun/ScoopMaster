{"version":"2.0.0-dev.1","description":"Sinew Blender addons (NodeOSC + blender_mcp_addon) for the OSC mocap workflow. Sets BLENDER_SYSTEM_SCRIPTS so the scoop-installed Blender finds them.","homepage":"https://github.com/sinew-mocap","license":"MIT","url":["https://github.com/maybites/NodeOSC/archive/e981fd150248b2337c1b3d8139fabeb18b7e3573.zip","https://github.com/v-sekai-multiplayer-fabric/blender-mcp/releases/download/v2.0.0-dev.1/blender_mcp_addon-2.0.0-dev.1.zip"],"hash":["2316a9fe9f54d3c0c42b67b5917f5986a9132e3476a106b9d5e5269267823b7f","971078674a01e5bfad441f4c406c6920193722ea8d51a96f665078d2c729301b"],"post_install":["New-Item -ItemType Directory -Force \"$dir\\scripts\\addons\" | Out-Null","Move-Item -Force \"$dir\\NodeOSC-*\" \"$dir\\scripts\\addons\\NodeOSC\"","Move-Item -Force \"$dir\\blender_mcp_addon\" \"$dir\\scripts\\addons\\blender_mcp_addon\""],"env_set":{"BLENDER_SYSTEM_SCRIPTS":"$dir\\scripts"},"notes":["BLENDER_SYSTEM_SCRIPTS replaces Blender's default system scripts dir, so this","trades the bundled system addons for these. Restart Blender after install."],"from":"https://github.com/Arama0517/scoop-bucket"}
