{
    "version": "7.1.19",
    "description": "CLIProxyAPI - A proxy server that provides OpenAI/Gemini/Claude/Codex/Grok compatible API interfaces for CLI.",
    "homepage": "https://github.com/router-for-me/CLIProxyAPI",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.1.19/CLIProxyAPI_7.1.19_windows_amd64.zip",
            "hash": "97CB6B0F8302535D4837DF63ACE2A8097FB22C57AB602556F04280DD5F54EA25"
        }
    },
    "bin": [
        "cli-proxy-api.exe"
    ],
    "persist": [
        "config.yaml"
    ],
    "pre_install": [
        "if (-not (Test-Path \"$persist_dir/config.yaml\")) { Copy-Item \"$dir/config.example.yaml\" \"$persist_dir/config.yaml\" -Force }"
    ],
    "post_install": [
        "Set-Content -Path \"$env:SCOOP\\shims\\cli-proxy-api.ps1\" -Value @'\nparam()\n$exe = \"', $dir, '\\cli-proxy-api.exe\" -join \"\"\n$cfg = \"', $persist_dir, '\\config.yaml\" -join \"\"\nif ($args -notcontains \"--config\") {\n    & $exe --config $cfg @args\n} else {\n    & $exe @args\n}\n'@ -Encoding utf8"
    ],
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_amd64.zip"
            }
        }
    }
}
