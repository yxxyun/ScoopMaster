    "homepage": "https://github.com/router-for-me/CLIProxyAPI",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.1.25/CLIProxyAPI_7.1.25_windows_amd64.zip",
            "hash": "4e03829defb6a6cde7daebf21f3eb812ea46580037b7c6957b0aa693debe203b"
        }
    },
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "--config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": "config.yaml",
    "post_install": "if (Test-Path \"$dir\\config.example.yaml\") { if (-not (Test-Path \"$persist_dir\\config.yaml\")) { Copy-Item \"$dir\\config.example.yaml\" \"$persist_dir\\config.yaml\" } }",
    "checkver": {
        "github": "https://github.com/router-for-me/CLIProxyAPI"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_amd64.zip"
            }
        }
    }
}
