{
    "version": "5.07.2026041006",
    "description": "HBuilderX，简称HX，轻如编辑器、强如IDE",
    "homepage": "https://www.dcloud.io/hbuilderx.html",
    "license": {
        "identifier": "Freeware",
        "url": "https://dcloud.io/license/hbuilder.html"
    },
    "extract_dir": "HBuilderX",
    "url": "https://download1.dcloud.net.cn/download/HBuilderX.5.07.2026041006.zip",
    "hash": "859b188e5eb6f920507ef79e326de8e7f70bcb9615dda056c05005d521731051",
    "bin": [
        "HBuilderX.exe",
        [
            "HBuilderX.exe",
            "hx"
        ]
    ],
    "shortcuts": [
        [
            "HBuilderX.exe",
            "HBuilder X"
        ]
    ],
    "persist": "plugins",
    "pre_install": [
        "Remove-Item \"$dir\\Updater.exe\" -Force -ErrorAction SilentlyContinue | Out-Null",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nPersisting $env:APPDATA\\HBuilder X ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\HBuilder X\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "$localPaths = @(",
        "    \"$env:APPDATA\\HBuilder X\"",
        "    \"$env:LOCALAPPDATA\\HBuilder X\"",
        ")",
        "$userSID = [System.Security.Principal.WindowsIdentity]::GetCurrent().User.Value",
        "$rot13 = [char[]]\"$dir\\HBuilderX.exe\" | ForEach-Object { $c = [int]$_; if (($c -ge 65 -and $c -le 90)) { [char](($c - 65 + 13) % 26 + 65) } elseif (($c -ge 97 -and $c -le 122)) { [char](($c - 97 + 13) % 26 + 97) } else { $_ } }; $rot13Path = ($rot13 -join '') -replace '\\\\', '\\\\\\\\'",
        "$registryPaths = @(",
        "    'Registry::HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\RADAR\\HeapLeakDetection\\DiagnosedApplications\\node.exe'",
        "    'Registry::HKEY_LOCAL_MACHINE\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\{47DA3B0D-1E07-4CE6-9D99-77B099F0E198}'",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\.nvue\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\.uts\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\.uvue\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\hbuilder.edit.nvue\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\hbuilder.edit.uts\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\hbuilder.edit.uvue\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Classes\\hbuilderx\"",
        ")",
        "$registryValues = @(",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Explorer\\UserAssist\\{CEBFF5CD-ACE2-4F4F-9178-9926F41749EA}\\Count|$rot13Path\"",
        "    \"Registry::HKEY_USERS\\$userSID\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\AppCompatFlags\\Compatibility Assistant\\Store|$dir\\\\HBuilderX.exe\"",
        ")",
        "Remove-AppData -LocalPaths $localPaths -RegistryPaths $registryPaths -RegistryValues $registryValues"
    ],
    "checkver": {
        "url": "https://download1.dcloud.net.cn/hbuilderx/release.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://download1.dcloud.net.cn/download/HBuilderX.$version.zip"
    },
    "notes": "User data is persisted in \"$persist_dir\"."
}
