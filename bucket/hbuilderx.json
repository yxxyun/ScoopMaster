{
    "version": "5.06.2026033105",
    "description": "HBuilderX，简称HX，轻如编辑器、强如IDE",
    "homepage": "https://www.dcloud.io/hbuilderx.html",
    "license": {
        "identifier": "Freeware",
        "url": "https://dcloud.io/license/hbuilder.html"
    },
    "extract_dir": "HBuilderX",
    "url": "https://download1.dcloud.net.cn/download/HBuilderX.5.06.2026033105.zip",
    "hash": "4dd6b5987abf14adac3b18023e5162034cd885492ea31cea6fe30d27a9603575",
    "bin": [
        "HBuilderX.exe",
        [
            "HBuilderX.exe",
            "hx"
        ]
    ],
    "shortcuts": [
        [
            "HBuilderX.exe",
            "HBuilder X"
        ]
    ],
    "persist": "plugins",
    "pre_install": [
        "Remove-Item \"$dir\\Updater.exe\" -Force -ErrorAction SilentlyContinue | Out-Null",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nPersisting $env:APPDATA\\HBuilder X ... \") -NoNewline",
        "New-PersistDirectory \"$env:APPDATA\\HBuilder X\" \"$persist_dir\\AppData\" -Migrate"
    ],
    "post_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Write-Host (\"`nDeleting $env:APPDATA\\HBuilder X ... \") -f DarkGray -NoNewline",
        "Remove-Junction \"$env:APPDATA\\HBuilder X\" -ErrorAction SilentlyContinue | Out-Null",
        "Write-Host (\"`nDeleting $env:LOCALAPPDATA\\HBuilder X ... \") -f DarkGray -NoNewline",
        "Remove-Item \"$env:LOCALAPPDATA\\HBuilder X\" -Force -Recurse -ErrorAction SilentlyContinue | Out-Null"
    ],
    "checkver": {
        "url": "https://download1.dcloud.net.cn/hbuilderx/release.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "url": "https://download1.dcloud.net.cn/download/HBuilderX.$version.zip"
    }
}
