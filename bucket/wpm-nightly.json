            "hash": "f06143401df1a3beb04ed6de39bb693f6127f3c58934b6146e5d5049b748a097",
            "extract_dir": "x86_64-pc-windows-msvc/release"
        },
        "arm64": {
            "url": "https://nightly.link/LGUG2Z/wpm/actions/runs/26348485264/wpm-aarch64-pc-windows-msvc-c4c4940146163e03a4cb1872c31cdae701fd2df5.zip",
