            "hash": "c09352416cfc0ed9604078d52f5a4ebfbb49a88de5fe3fc079bccb635c6f1a78",
            "extract_dir": "x86_64-pc-windows-msvc/release"
        },
        "arm64": {
            "url": "https://nightly.link/LGUG2Z/wpm/actions/runs/24295540510/wpm-aarch64-pc-windows-msvc-c4c4940146163e03a4cb1872c31cdae701fd2df5.zip",
