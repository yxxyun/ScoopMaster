    },
    "architecture": {
        "64bit": {
            "url": "https://nightly.link/LGUG2Z/wpm/actions/runs/22810808014/wpm-x86_64-pc-windows-msvc-c4c4940146163e03a4cb1872c31cdae701fd2df5.zip",
            "hash": "b315b5ee651d7349bf50224596879b3b163d5dc668517f4fada2ddd224340b9c",
            "extract_dir": "x86_64-pc-windows-msvc/release"
        },
        "arm64": {
            "url": "https://nightly.link/LGUG2Z/wpm/actions/runs/22810808014/wpm-aarch64-pc-windows-msvc-c4c4940146163e03a4cb1872c31cdae701fd2df5.zip",
