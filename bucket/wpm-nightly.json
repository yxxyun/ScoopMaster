{
    "version": "23698225734",
    "description": "Simple user process management for Windows",
    "homepage": "https://github.com/LGUG2Z/wpm",
    "notes": "Check out the examples on https://github.com/LGUG2Z/wpm/tree/master/examples",
    "license": {
        "identifier": "Komorebi",
