            "hash": "8b8240682e23815ce673b1680fd81df00aa97f0f3ff395ba31c0ad55c6675ca3"
        },
        "arm64": {
            "url": "https://installers.lmstudio.ai/win32/arm64/0.4.12-1/LM-Studio-0.4.12-1-arm64.exe#/dl.7z",
            "hash": "6cfff6ea7f7d56e794f4cf798783453f0f9bf7d9be495a7449c6d12596cea068"
        }
    },
    "installer": {
        "script": [
            "$pkgfile = (Get-ChildItem \"$dir\" '*.nupkg' | Select-Object -First 1).FullName",
            "Expand-7ZipArchive \"$pkgfile\" \"$dir\" -Removal",
            "Move-Item \"$dir\\lib\\net45\\*\" \"$dir\""
        ]
    },
    "shortcuts": [
        [
            "LM Studio.exe",
            "LM Studio"
        ]
    ],
    "checkver": {
        "url": "https://formulae.brew.sh/api/cask/lm-studio.json",
        "regex": "\"version\":\\s*\"([\\d.]+),([\\d]+)\"",
        "replace": "$1-$2"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://installers.lmstudio.ai/win32/x64/$version/LM-Studio-$version-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://installers.lmstudio.ai/win32/arm64/$version/LM-Studio-$version-arm64.exe#/dl.7z"
            }
        }
    }
}
