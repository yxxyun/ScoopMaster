            "hash": "4c4e6c9738bca9904e5e21cb16258672bd7eba7680cb185d68aa5bcbb05f1b94"
        },
        "arm64": {
            "url": "https://installers.lmstudio.ai/win32/arm64/0.4.6-1/LM-Studio-0.4.6-1-arm64.exe#/dl.7z",
            "hash": "fd4342c32c25e72b3c1d72081d6904633e23ed272a92a25382eea415cd812b1b"
        }
    },
    "installer": {
        "script": [
            "$pkgfile = (Get-ChildItem \"$dir\" '*.nupkg' | Select-Object -First 1).FullName",
            "Expand-7ZipArchive \"$pkgfile\" \"$dir\" -Removal",
            "Move-Item \"$dir\\lib\\net45\\*\" \"$dir\""
        ]
    },
    "shortcuts": [
        [
            "LM Studio.exe",
            "LM Studio"
        ]
    ],
    "checkver": {
        "url": "https://formulae.brew.sh/api/cask/lm-studio.json",
        "regex": "\"version\":\\s*\"([\\d.]+),([\\d]+)\"",
        "replace": "$1-$2"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://installers.lmstudio.ai/win32/x64/$version/LM-Studio-$version-x64.exe#/dl.7z"
            },
            "arm64": {
                "url": "https://installers.lmstudio.ai/win32/arm64/$version/LM-Studio-$version-arm64.exe#/dl.7z"
            }
        }
    }
}
