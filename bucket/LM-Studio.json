{
    "version": "0.4.16-2",
    "description": "Run LLMs on your laptop, entirely offline.",
    "homepage": "https://lmstudio.ai",
    "license": {
        "identifier": "Freeware",
        "url": "https://lmstudio.ai/terms"
    },
    "architecture": {
        "64bit": {
            "url": "https://installers.lmstudio.ai/win32/x64/0.4.16-2/LM-Studio-0.4.16-2-x64.exe",
            "hash": "581d7cef9b08572188c149020d171eaf26296068ef34c92e55340eab2964c8c0"
        }
    },
    "installer": {
        "args": [
            "/S",
            "/D=$dir"
        ]
    },
    "post_install": [
        "# Disable built-in updates so Scoop remains the update manager.",
        "$yaml = \"$dir\\resources\\app-update.yml\"",
        "if (Test-Path $yaml) {",
        "    $content = Get-Content $yaml -Encoding ASCII | ForEach-Object {",
        "        if ($_ -match '^(provider|bucket|endpoint):') { \"# $_ # Disabled by Scoop\" } else { $_ }",
        "    }",
        "    Set-Content $yaml -Value $content -Encoding ASCII",
        "}",
        "$updaterCache = Join-Path $env:LOCALAPPDATA 'lm-studio-updater'",
        "Remove-Item $updaterCache -Recurse -Force -ErrorAction SilentlyContinue",
        "Get-Process -Name 'LM Studio' -ErrorAction SilentlyContinue | Stop-Process -Force",
        "$programs = Join-Path $env:APPDATA 'Microsoft\\Windows\\Start Menu\\Programs'",
        "$lmstudioShortcut = Join-Path $programs 'LM Studio'",
        "$scoopShortcut = Join-Path $programs 'Scoop Apps'",
        "if ((Test-Path $lmstudioShortcut) -and (Test-Path $scoopShortcut)) { Move-Item $lmstudioShortcut -Destination $scoopShortcut -Force }",
        "function Create-Junction { param ([string]$runtimeCache, [string]$runtimeCachePersist)",
        "    if (-not (Test-Path $runtimeCache)) { return }",
        "    if (Test-Path $runtimeCachePersist) {",
        "        Remove-Item $runtimeCache -Force -Recurse -ErrorAction SilentlyContinue",
        "        New-Item -Type Junction -Path $runtimeCache -Target $runtimeCachePersist | Out-Null",
        "    } else {",
        "        New-Item -ItemType Directory -Path (Split-Path $runtimeCachePersist) -Force | Out-Null",
        "        Move-Item $runtimeCache $runtimeCachePersist -Force",
        "        New-Item -Type Junction -Path $runtimeCache -Target $runtimeCachePersist | Out-Null",
        "    }",
        "}",
        "foreach ($folder in @('LM-Studio', 'LM Studio')) {",
        "    Create-Junction -runtimeCache \"$env:USERPROFILE\\$folder\" -runtimeCachePersist \"$persist_dir\\USERPROFILE\\$folder\"",
        "    Create-Junction -runtimeCache \"$env:LOCALAPPDATA\\$folder\" -runtimeCachePersist \"$persist_dir\\LOCALAPPDATA\\$folder\"",
        "    Create-Junction -runtimeCache \"$env:APPDATA\\$folder\" -runtimeCachePersist \"$persist_dir\\APPDATA\\$folder\"",
        "}"
    ],
    "post_uninstall": "Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Scoop Apps\\LM Studio\" -Force -Recurse -ErrorAction SilentlyContinue",
    "uninstaller": {
        "script": "if ($cmd -eq 'uninstall') { Remove-Item (Join-Path $env:LOCALAPPDATA 'lm-studio-updater') -Recurse -Force -ErrorAction SilentlyContinue }"
    },
    "persist": "LOCALAPPDATA",
    "checkver": {
        "script": [
            "Add-Type -AssemblyName System.Net.Http",
            "$handler = [System.Net.Http.HttpClientHandler]::new()",
            "$handler.AllowAutoRedirect = $false",
            "$client = [System.Net.Http.HttpClient]::new($handler)",
            "$request = [System.Net.Http.HttpRequestMessage]::new([System.Net.Http.HttpMethod]::Head, 'https://lmstudio.ai/download/latest/win32/x64')",
            "try {",
            "    $response = $client.SendAsync($request).GetAwaiter().GetResult()",
            "    $response.Headers.Location.AbsoluteUri",
            "} finally {",
            "    if ($response) { $response.Dispose() }",
            "    $request.Dispose()",
            "    $client.Dispose()",
            "    $handler.Dispose()",
            "}"
        ],
        "regex": "LM-Studio-([\\d.]+-\\d+)-x64\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://installers.lmstudio.ai/win32/x64/$version/LM-Studio-$version-x64.exe"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
