{"version":"26.07.01","description":"小黄条：可嵌入 Windows 桌面的跨平台待办清单。","homepage":"https://www.yynote.cn","license":"Freeware","url":"https://d.yynote.cn/windows/YYNote.exe","hash":"71c61966e8599a0ef68d0552793bd7b9d5e63c8e07dc8be45586be86ac60b35c","pre_install":["Rename-Item \"$dir\\YYNote.exe\" -NewName 'YYNote-setup.exe' -Force","$cmdLine = \"`\"$dir\\YYNote-setup.exe`\" /qn APPDIR=$dir\"","Start-Process -FilePath $env:ComSpec -ArgumentList @('/c', $cmdLine) -WorkingDirectory $dir -Wait -NoNewWindow","Remove-Item \"$dir\\YYNote-setup.exe\" -Force -ErrorAction SilentlyContinue"],"bin":"YYNote.exe","shortcuts":[["YYNote.exe","YYNote"]],"uninstaller":{"script":["$roots = @('HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall', 'HKLM:\\Software\\WOW6432Node\\Microsoft\\Windows\\CurrentVersion\\Uninstall', 'HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall')","foreach ($root in $roots) {","    if (!(Test-Path $root)) { continue }","    Get-ChildItem $root -ErrorAction SilentlyContinue | ForEach-Object {","        $p = Get-ItemProperty $_.PSPath","        if ($p.DisplayName -match '小黄条' -and $_.PSChildName -match '^\\{[A-F0-9-]+\\}$') {","            Start-Process msiexec.exe -ArgumentList '/x', $_.PSChildName, '/qn', '/norestart' -Wait -NoNewWindow","            return","        }","    }","}"]},"checkver":{"url":"https://www.yynote.cn","script":["$tmp = Join-Path $env:TEMP 'yynote-checkver.exe'","Invoke-WebRequest -Uri 'https://d.yynote.cn/windows/YYNote.exe' -OutFile $tmp -UseBasicParsing","$v = (Get-Item $tmp).VersionInfo.ProductVersion.Trim()","Remove-Item $tmp -Force -ErrorAction SilentlyContinue","Write-Output $v"],"regex":"([\\d.]+)"},"autoupdate":{"url":"https://d.yynote.cn/windows/YYNote.exe"},"from":"https://github.com/zhy617/my-scoop-bucket"}
