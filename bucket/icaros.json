{
    "version": "3.3.6",
    "description": "Lightweight Windows Shell Extension that provides thumbnails for MKV, FLV, AVI, MP4, MOV, RMVB, M2TS, OGM and many more video formats.",
    "homepage": "https://github.com/Xanashi/Icaros",
    "license": "Freeware",
    "notes": [
        "After installation, run 'Icaros Config' and enable the desired thumbnail and property handlers.",
        "A restart of Explorer.exe (or a reboot) may be required for thumbnails to appear."
    ],
    "url": "https://github.com/Xanashi/Icaros/releases/download/v3.3.6/Icaros_v3.3.6.zip",
    "hash": "18854b445420e7167b5f54696009c9ffbc0e7917da9d9a686eac71ea3c81d47a",
    "bin": "IcarosConfig.exe",
    "shortcuts": [
        ["IcarosConfig.exe", "Icaros Config"]
    ],
    "post_install": [
        "regsvr32 /s \"$dir\\64-bit\\IcarosThumbnailProvider.dll\"",
        "regsvr32 /s \"$dir\\64-bit\\IcarosPropertyHandler.dll\"",
        "regsvr32 /s \"$dir\\64-bit\\IcarosCache.dll\""
    ],
    "pre_uninstall": [
        "regsvr32 /u /s \"$dir\\64-bit\\IcarosThumbnailProvider.dll\"",
        "regsvr32 /u /s \"$dir\\64-bit\\IcarosPropertyHandler.dll\"",
        "regsvr32 /u /s \"$dir\\64-bit\\IcarosCache.dll\""
    ],
    "checkver": {
        "github": "https://github.com/Xanashi/Icaros"
    },
    "autoupdate": {
        "url": "https://github.com/Xanashi/Icaros/releases/download/v$version/Icaros_v$version.zip",
        "hash": {
            "url": "$url.sha256"
        }
    }
}
