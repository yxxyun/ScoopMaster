{
    "version": "5.0",
    "description": "OpenRaster filetype plugin for paint.net",
    "homepage": "https://github.com/Zagna/openraster_pdn",
    "license": "MIT",
    "depends": "extras/paint.net",
    "url": "https://raw.githubusercontent.com/instinctualjealousy/holes/refs/heads/master/mirror/OpenRasterFileType.7z",
    "hash": "a58cc4d54125a37448b2693f70a23ad7f5d8d125c070a2c91d7501404a221a52",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\"",
        "Move-Item -Path \"$dir\\OpenRasterFileType.dll\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\FileTypes\"",
            "Remove-Item \"$paintdotnet\\OpenRasterFileType.dll\" -Force"
        ]
    }
}
