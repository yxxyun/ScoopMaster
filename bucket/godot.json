{
    "version": "4.6.3",
    "description": "A feature-packed, cross-platform game engine to create 2D and 3D games from a unified interface.",
    "homepage": "https://godotengine.org/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/godotengine/godot/releases/download/4.6.3-stable/Godot_v4.6.3-stable_win64.exe.zip",
            "hash": "sha512:d44ea7ef5bab754cacd49d581b6062836b2eea12a82e1d183aebfad9cd8c7db2bd82513337bd657d6d2d5c04d46239c0570b029faf1343e81e8a2fa7b85dd83b"
        },
        "32bit": {
            "url": "https://github.com/godotengine/godot/releases/download/4.6.3-stable/Godot_v4.6.3-stable_win32.exe.zip",
            "hash": "sha512:3e11a10f8b0ddacabaa368c18fe70c278d2b63cc27a684e381a732dbb727cd3e981b26ea61f629e3c76d7f1ae54bc7ce6b9be8315a2f61bf3e4eb0edbc74a102"
        }
    },
    "persist": "editor_data",
    "persist_link": "$env:AppData\\Godot",
    "pre_install": [
        "Get-Item \"$dir\\Godot_*_console.exe\" | Rename-Item -NewName 'godot.console.exe'",
        "Get-Item \"$dir\\Godot_*.exe\" | Rename-Item -NewName 'godot.exe'",
        "New-Item \"$dir\\_sc_\" | Out-Null"
    ],
    "post_install": "Set-Value -File \"editor_data\\editor_settings-$version.tres\" -Type 'ini' -ValuePath 'resource', 'network/connection/engine_version_update_mode' -Value 0",
    "bin": [
        [
            "godot.console.exe",
            "godot"
        ]
    ],
    "shortcuts": [
        [
            "godot.exe",
            "Godot Engine"
        ]
    ],
    "checkver": {
        "url": "https://github.com/godotengine/godot/releases/latest",
        "regex": "(?<version>[\\d\\w.]+)-stable"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/godotengine/godot/releases/download/$version-stable/Godot_v$version-stable_win64.exe.zip"
            },
            "32bit": {
                "url": "https://github.com/godotengine/godot/releases/download/$version-stable/Godot_v$version-stable_win32.exe.zip"
            }
        },
        "hash": {
            "url": "$baseurl/SHA512-SUMS.txt"
        }
    }
}
