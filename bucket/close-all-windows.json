{
    "version": "6.0",
    "description": "Close all windows with just a single click",
    "homepage": "https://www.ntwind.com/software/closeall.html",
    "license": "Proprietary",
    "url": "https://www.ntwind.com/download/CloseAll_6.0-setup.exe",
    "hash": "2b11531b2b3d91358fb357eb947a890fbd79c0a4d34622a42f59e3a448bebc64",
    "depends": "main/7zip",
    "installer": {
        "script": [
            "7z e \"$dir\\$fname\" -o\"$dir\" -y | Out-Null",
            "Remove-Item \"$dir\\$fname\"",
            "Remove-Item \"$dir\\uninst.exe\" -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\*.dll\" -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\*.bmp\" -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\*.ini\" -ErrorAction SilentlyContinue"
        ]
    },
    "bin": [
        [
            "CloseAll.exe",
            "closeall"
        ]
    ],
    "shortcuts": [
        [
            "CloseAll.exe",
            "CloseAll"
        ]
    ],
    "checkver": {
        "url": "https://www.ntwind.com/download-all.html",
        "regex": "CloseAll_([\\d.]+)-setup\\.exe"
    },
    "autoupdate": {
        "url": "https://www.ntwind.com/download/CloseAll_$version-setup.exe"
    }
}
