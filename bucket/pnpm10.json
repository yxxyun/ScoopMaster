{
	"version": "10.34.3",
	"description": "Fast, disk space efficient package manager",
	"homepage": "https://pnpm.io/",
	"license": "MIT",
	"architecture": {
		"64bit": {
			"url": "https://github.com/pnpm/pnpm/releases/download/v10.34.3/pnpm-win-x64.exe#/pnpm.exe",
			"hash": "d4d658a382b729b84174a65f86e4732ba64a8c831115d536b442a5b608b50e09"
		},
		"arm64": {
			"url": "https://github.com/pnpm/pnpm/releases/download/v10.34.3/pnpm-win-arm64.exe#/pnpm.exe",
			"hash": "69ddf5ecbe0779a3d766c9d444df83f966c1d5163d18c93f0c3b0f98c0c47a9f"
		}
	},
	"bin": ["pnpm.exe", ["pnpm.exe", "pnpx", "dlx"]],
	"post_install": [
		"pnpm config set cacheDir \"$($persist_dir -replace '\\\\', '/')/cache\"",
		"pnpm config set globalBinDir \"$($persist_dir -replace '\\\\', '/')/bin\"",
		"pnpm config set globalDir \"$($persist_dir -replace '\\\\', '/')/global\"",
		"pnpm config set stateDir \"$($persist_dir -replace '\\\\', '/')/state\"",
		"pnpm config set storeDir \"$($persist_dir -replace '\\\\', '/')/store\"",
		"pnpm setup"
	],
	"env_set": {
		"PNPM_HOME": "$persist_dir"
	},
	"persist": ["bin", "cache", "global", "state", "store"],
	"checkver": {
		"url": "https://api.github.com/repos/pnpm/pnpm/releases",
		"regex": "pnpm (10[.][0-9.]+)"
	},
	"autoupdate": {
		"architecture": {
			"64bit": {
				"url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win-x64.exe#/pnpm.exe"
			},
			"arm64": {
				"url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win-arm64.exe#/pnpm.exe"
			}
		}
	}
}
