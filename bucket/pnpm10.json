{
	"version": "10.34.3",
	"description": "Fast, disk space efficient package manager (version 10)",
	"homepage": "https://pnpm.io/",
	"license": "MIT",
	"architecture": {
		"64bit": {
			"url": "https://github.com/pnpm/pnpm/releases/download/v10.34.3/pnpm-win-x64.exe",
			"hash": "d4d658a382b729b84174a65f86e4732ba64a8c831115d536b442a5b608b50e09"
		},
		"arm64": {
			"url": "https://github.com/pnpm/pnpm/releases/download/v10.34.3/pnpm-win-arm64.exe",
			"hash": "69ddf5ecbe0779a3d766c9d444df83f966c1d5163d18c93f0c3b0f98c0c47a9f"
		}
	},
	"bin": ["pnpm.exe", ["pnpm.exe", "pnpx", "dlx"]],
	"pre_install": "mv \"$dir/$fname\" \"$dir/pnpm.exe\"",
	"post_install": [
		"pnpm config set enable-global-virtual-store true",
		"pnpm config set cache-dir \"$($persist_dir -replace '\\\\', '/')/cache\"",
		"pnpm config set state-dir \"$($persist_dir -replace '\\\\', '/')/state\"",
		"pnpm config set store-dir \"$($persist_dir -replace '\\\\', '/')/store\"",
		"pnpm setup"
	],
	"env_set": {
		"PNPM_HOME": "$persist_dir"
	},
	"checkver": {
		"url": "https://api.github.com/repos/pnpm/pnpm/releases",
		"jsonpath": "$[*].tag_name",
		"regex": "v(10[.][0-9.]+)"
	},
	"autoupdate": {
		"architecture": {
			"64bit": {
				"url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win-x64.exe"
			},
			"arm64": {
				"url": "https://github.com/pnpm/pnpm/releases/download/v$version/pnpm-win-arm64.exe"
			}
		}
	}
}
