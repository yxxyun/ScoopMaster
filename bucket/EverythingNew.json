{"version":"1.5.0.1413b","description":"Everything 1.5 Alpha - 极致快速的本地文件与文件夹搜索工具（1.5 重构预览版）","homepage":"https://www.voidtools.com/","license":"MIT","architecture":{"64bit":{"url":"https://www.voidtools.com/Everything-1.5.0.1413b.x64.zip","hash":"638ba3b4e187b07bd73cdee24bf7863a962ec865716e6a7e521cbb04f7edd29f"}},"bin":"Everything.exe","shortcuts":[["Everything.exe","Everything"]],"pre_install":["foreach ($file in @('Everything.ini', 'Filters.csv', 'Bookmarks.csv')) {","    if (!(Test-Path \"$dir\\$file\")) { New-Item -Path \"$dir\\$file\" -ItemType File -Force | Out-Null }","}","$iniPath = \"$dir\\Everything.ini\"","$content = Get-Content $iniPath -Raw -ErrorAction SilentlyContinue","if ($content -notmatch 'appdata=') {","    Add-Content $iniPath \"`r`nappdata=$dir\"","}"],"installer":{"script":"if (is_admin) { Start-Process \"$dir\\Everything.exe\" -ArgumentList \"-install-service\" -Wait } else { warning \"需要管理员权限来安装 Everything 系统服务，否则可能无法搜索 NTFS 盘符。\" }"},"uninstaller":{"script":"if (is_admin) { Start-Process \"$dir\\Everything.exe\" -ArgumentList \"-uninstall-service\" -Wait }"},"persist":["Everything.ini","Filters.csv","Bookmarks.csv"],"from":"https://github.com/jkjkit/scoop"}
