{
    "version": "0.2.26",
    "description": "A modern terminal workspace with AI-powered session management built with Tauri",
    "homepage": "https://github.com/Harukaon/shelf",
    "license": "Apache-2.0",
    "notes": [
        "Shelf stores user config at %USERPROFILE%\\.shelf\\ (ai_settings.json, ai_sessions.json, config.json)",
        "Logs are at %LOCALAPPDATA%\\com.shelf.app\\logs\\",
        "This package persists the .shelf config directory and logs via Junction links"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Harukaon/shelf/releases/download/v0.2.26/Shelf_0.2.26_x64-setup.exe#/dl.7z",
            "hash": "26111a1066b26a2ade47de019ae27dc90a7097b7c5d01c93c0af9ae7b2215864"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninstall.exe\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": "Shelf.exe",
    "shortcuts": [
        [
            "Shelf.exe",
            "Shelf"
        ]
    ],
    "post_install": [
        "$createJunction = {",
        "    param([string]$Source, [string]$Target)",
        "    ensure $Target",
        "    $parent = Split-Path $Source -Parent",
        "    if ($parent) { New-Item -ItemType Directory -Path $parent -Force | Out-Null }",
        "",
        "    if (Test-Path $Source) {",
        "        $item = Get-Item -LiteralPath $Source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"Junction already exists: $source\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) { throw \"Path exists and is not a directory: $Source\" }",
        "        & robocopy $Source $Target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) { Write-Host \"Migration failed: $Source\"; return }",
        "        $backup = \"$Source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try { Move-Item -LiteralPath $Source -Destination $backup -Force } catch { Write-Host \"Cannot rename: $Source\"; return }",
        "    }",
        "    New-Item -Path $Source -ItemType Junction -Value $Target | Out-Null",
        "}",
        "",
        "& $createJunction (Join-Path $env:USERPROFILE '.shelf') (Join-Path $persist_dir 'shelf-config')",
        "& $createJunction (Join-Path $env:LOCALAPPDATA 'com.shelf.app\\logs') (Join-Path $persist_dir 'logs')"
    ],
    "post_uninstall": [
        "$paths = @(",
        "    (Join-Path $env:USERPROFILE '.shelf'),",
        "    (Join-Path $env:LOCALAPPDATA 'com.shelf.app\\logs')",
        ")",
        "foreach ($path in $paths) {",
        "    if (Test-Path $path) {",
        "        $item = Get-Item -LiteralPath $path -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) { Remove-Item -LiteralPath $path -Force }",
        "    }",
        "}"
    ],
    "persist": [
        "shelf-config",
        "logs"
    ],
    "checkver": {
        "github": "https://github.com/Harukaon/shelf"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Harukaon/shelf/releases/download/v$version/Shelf_$version_x64-setup.exe#/dl.7z"
            }
        }
    }
}
