{
    "version": "3751.0",
    "description": "The library that allows to use GTA V script native functions in custom *.asi plugins",
    "homepage": "http://www.dev-c.com/gtav/scripthookv/",
    "license": "Freeware",
    "url": "https://ntscorp.ru/dev-c/ScriptHookV_3751.0_1013.29.zip",
    "hash": "5f6fc5740faf427c6c2904b985ca9c73992110b489ae1a09c1ab39e815c07a29",
    "extract_dir": "bin",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Move-Item \"$dir\\*\" \"$env:GTAV_PATH\" -Exclude 'NativeTrainer.asi', 'args.txt' -Force",
        "Remove-Item \"$dir\\*\""
    ],
    "checkver": {
        "url": "http://www.dev-c.com/gtav/scripthookv/",
        "regex": "v(\\d+\\.\\d+)\\s*/\\s*(\\d+\\.\\d+)",
        "replace": "${1}"
    },
    "autoupdate": {
        "url": "https://ntscorp.ru/dev-c/ScriptHookV_$match1_$match2.zip"
    }
}
