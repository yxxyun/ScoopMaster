{
    "version": "140.13.0esr",
    "description": "A free email application that's easy to set up and customize.",
    "homepage": "https://www.thunderbird.net",
    "license": "MPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/140.13.0esr/win64/pl/Thunderbird%20Setup%20140.13.0esr.exe#/dl.7z",
            "hash": "sha512:15e2c600e44b4698b5ce8cfbf1e686e0e685c6bf60125f4f2b9d1f56c693b7275331f45e5f9a7f83583e5f3031e153e07808cc4a2c736df2e2cc0b0bf1e4fcef"
        },
        "32bit": {
            "url": "https://archive.mozilla.org/pub/thunderbird/releases/140.13.0esr/win32/pl/Thunderbird%20Setup%20140.13.0esr.exe#/dl.7z",
            "hash": "sha512:7de0b603b3fbe5979787d4919aea76e68be504a59463207828ae3c2e8f92831a58edf6832859a5cfc669988cafa7e479b91ed95518d48eff6e2403951be6b93e"
        }
    },
    "notes": [
        "To set profile 'Scoop' as *DEFAULT*, or profiles/settings was lost after update:",
        "  - Run 'Thunderbird Profile Manager', choose 'Scoop' then click 'Start Thunderbird'.",
        "  - Visit 'about:profiles' page in Thunderbird to check *DEFAULT* profile.",
        "For details: https://support.mozilla.org/en-US/kb/profile-manager-create-and-remove-thunderbird-profiles"
    ],
    "extract_dir": "core",
    "post_install": [
        "~\\scoop\\apps\\thunderbird-polish\\current\\thunderbird.exe -CreateProfile \"Scoop $persist_dir\\profile\"",
        "$Addition = \"$persist_dir\\addition\"",
        "if (Test-Path $Addition) {",
        "  info 'Copying additional items...'",
        "  Copy-Item -Path $Addition\\* -Destination $dir -Force -Recurse -ErrorAction SilentlyContinue",
        "}"
    ],
    "shortcuts": [
        [
            "thunderbird.exe",
            "Thunderbird"
        ],
        [
            "thunderbird.exe",
            "Thunderbird Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/thunderbird_versions.json",
        "jsonpath": "$.THUNDERBIRD_ESR"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/win64/pl/Thunderbird%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/pl/$basename"
                }
            },
            "32bit": {
                "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/win32/pl/Thunderbird%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/thunderbird/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win32/pl/$basename"
                }
            }
        }
    }
}
