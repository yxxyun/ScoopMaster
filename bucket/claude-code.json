{
    "version": "2.1.209",
    "description": "Agentic coding assistant by Anthropic — write, edit, debug, and explore your codebase in your terminal",
    "homepage": "https://code.claude.com",
    "license": "Proprietary",
    "architecture": {
        "64bit": {
            "url": "https://downloads.claude.ai/claude-code-releases/2.1.209/win32-x64/claude.exe#/claude.exe",
            "hash": "b9d5e8542338a0918534e55d046a7c960ae4af5ee214c7e4e80a89067b63ea2c"
        }
    },
    "bin": [
        [
            "claude.exe",
            "claude"
        ],
        [
            "claude.exe",
            "cc"
        ]
    ],
    "pre_install": [
        "# 将 ~/.claude 软链接到 persist/data，升级时数据不丢失",
        "$claude_dir = Join-Path $env:USERPROFILE \".claude\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\link.ps1\" $claude_dir $persist_data",
        "# 确保 .local/bin 存在（Claude Code 自检依赖此路径）",
        "$localBin = Join-Path $env:USERPROFILE \".local\\bin\"",
        "if (-not (Test-Path $localBin)) { New-Item -ItemType Directory -Path $localBin -Force | Out-Null }"
    ],
    "post_install": [
        "# 复制 scoop shim + .shim 配置到 ~/.local/bin（Claude Code 自检需要）",
        "$localBin = Join-Path $env:USERPROFILE \".local\\bin\"",
        "# 直接从 E:\\scoop\\shims\\ 复制（已包含正确的 .shim 配置）",
        "Copy-Item \"$env:SCOOP\\shims\\claude.exe\" \"$localBin\\claude.exe\" -Force",
        "Copy-Item \"$env:SCOOP\\shims\\claude.shim\" \"$localBin\\claude.shim\" -Force"
    ],
    "post_uninstall": [
        "## 卸载时清理",
        "$claude_dir = Join-Path $env:USERPROFILE \".claude\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\unlink.ps1\" $claude_dir",
        "# 清理 .local/bin 中的 shim 副本",
        "$localBin = Join-Path $env:USERPROFILE \".local\\bin\"",
        "@(\"$localBin\\claude.exe\", \"$localBin\\claude.shim\") | ForEach-Object { if (Test-Path $_) { Remove-Item -Force $_ -ErrorAction SilentlyContinue } }"
    ],
    "persist": "data",
    "checkver": {
        "url": "https://downloads.claude.ai/claude-code-releases/latest",
        "regex": "^([\\d.]+)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://downloads.claude.ai/claude-code-releases/$version/win32-x64/claude.exe#/claude.exe"
            }
        }
    }
}
