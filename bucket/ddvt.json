{
    "version": "0.74",
    "description": "Dolby Vision Tool (DDVT) - Light version. Requires manual placement of 3rd party tools.",
    "homepage": "https://github.com/DonaldFaQ/DDVT",
    "license": "Freeware",
    "url": "https://github.com/DonaldFaQ/DDVT/releases/download/0.74/DDVT_v0.74.7z",
    "hash": "423a64a42ba536d962ea7b297d6756be3d4b7bd43791a1f2e508504001e0becb",
    "depends": [
        "main/ffmpeg",
        "extras/mkvtoolnix",
        "hdr10plus_tool",
        "extras/dovi-tool"
    ],
    "bin": [
        "DDVT_DEMUXER.cmd",
        "DDVT_FILEINFO.cmd",
        "DDVT_HYBRID.cmd",
        "DDVT_INJECTOR.cmd",
        "DDVT_MEDIAINFO.cmd",
        "DDVT_MKVTOMP4.cmd",
        "DDVT_OPTIONS.cmd",
        "DDVT_REMOVER.cmd"
    ],
    "post_install": [
        "New-Item -ItemType Directory -Force -Path \"$dir\\tools\" | Out-Null",
        "Write-Host 'Copying core binaries (ffmpeg, mkvmerge, hdr10plus, dovi_tool) to /tools...' -ForegroundColor Cyan",
        "Copy-Item \"$(scoop which ffmpeg)\" -Destination \"$dir\\tools\\ffmpeg.exe\" -Force",
        "Copy-Item \"$(scoop which mkvmerge)\" -Destination \"$dir\\tools\\mkvmerge.exe\" -Force",
        "Copy-Item \"$(scoop which hdr10plus_tool)\" -Destination \"$dir\\tools\\hdr10plus_tool.exe\" -Force",
        "Copy-Item \"$(scoop which dovi_tool)\" -Destination \"$dir\\tools\\dovi_tool.exe\" -Force"
    ],
    "notes": [
        "IMPORTANT - MANUAL STEPS REQUIRED:",
        "This version of DDVT does not include all 3rd party tools (like metafier, mp4muxer, etc.).",
        "",
        "1. Go to the official repository: https://github.com/DonaldFaQ/DDVT",
        "2. Download the '3rd party tools' or the 'FULL' package.",
        "3. Copy all missing files from the 'tools' folder of that package into:",
        "   '$dir\\tools'",
        "",
        "The core tools (ffmpeg, mkvmerge, dovi_tool, hdr10plus_tool) have already been placed there by Scoop."
    ],
    "checkver": {
        "github": "https://github.com/DonaldFaQ/DDVT",
        "regex": "DDVT_v([\\d.]+)\\.7z"
    },
    "autoupdate": {
        "url": "https://github.com/DonaldFaQ/DDVT/releases/download/$version/DDVT_v$version.7z"
    }
}
