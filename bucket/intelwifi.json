{
    "version": "24.40.0",
    "description": "intel wifi driver",
    "homepage": "https://www.intel.com/content/www/us/en/download/19351/intel-wireless-wi-fi-drivers-for-windows-10-and-windows-11.html",
    "license": "Proprietary",
    "url": "https://downloadmirror.intel.com/918237/WiFi-24.40.0-Driver64-Win10-Win11.exe#/setup.exe",
    "hash": "38d81a9fcde6de220cdeb712d33b86e8f648aa4c1267a46c6387c709508f7453",
    "depends": "curl",
    "installer": {
        "script": "start-process \"$dir\\setup.exe\" -wait -NoNewWindow -a '-q -s'"
    },
    "uninstaller": {
        "file": "setup.exe",
        "args": [
            "-q",
            "-s",
            "-uninstall"
        ]
    },
    "checkver": {
        "script": [
            "$src = 'https://www.intel.com/content/www/us/en/download/19351/intel-wireless-wi-fi-drivers-for-windows-10-and-windows-11.html'",
            "$html = curl -s $src",
            "$ver = [regex]::Matches($html, 'name=\"DownloadVersion\" content=\"(?<version>[\\d.]+)\"')",
            "$url = [regex]::Matches($html, 'download-button(.*)\"https://downloadmirror.intel.com/(?<url>.*exe)\"')",
            "[string]::Format('{0}|{1}', $ver[0].groups['version'].value, $url[0].groups['url'].value)"
        ],
        "regex": "(?<version>.+)\\|(?<url>.+)"
    },
    "autoupdate": {
        "url": "https://downloadmirror.intel.com/$matchUrl#/setup.exe"
    }
}
