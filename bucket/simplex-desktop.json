{
    "##": "ltguillaume/schep",
    "version": "6.5.4",
    "description": "Private and secure chat and applications platform. Desktop GUI app.",
    "homepage": "https://simplex.chat",
    "license": "AGPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/simplex-chat/simplex-chat/releases/download/v6.5.4/simplex-desktop-windows-x86_64.msi",
            "hash": "06df2bfa9122b641e54c3ba26608178120d35e051ecdb178ac0322c2769a06db"
        }
    },
    "shortcuts": [
        [
            "SimpleX\\SimpleX.exe",
            "SimpleX Desktop"
        ]
    ],
    "post_install": [
        "if (-not (Test-Path \"$Env:AppData\\SimpleX\\*\")) {",
        "    Remove-Item \"$Env:AppData\\SimpleX\" 2>$null",
        "    if (-not (Test-Path \"$persist_dir\")) {",
        "        New-Item -ItemType Directory -Path \"$persist_dir\" >$null",
        "    }",
        "    New-DirectoryJunction \"$Env:AppData\\SimpleX\" \"$persist_dir\" >$null",
        "}"
    ],
    "pre_uninstall": [
        "$SimpleX_data = Get-Item \"$Env:AppData\\SimpleX\"",
        "if (\"$($SimpleX_data.Target)\" -eq \"$persist_dir\") { $SimpleX_data.Delete() }"
    ],
    "checkver": {
        "github": "https://github.com/simplex-chat/simplex-chat"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/simplex-chat/simplex-chat/releases/download/v$version/simplex-desktop-windows-x86_64.msi"
            }
        }
    }
}
