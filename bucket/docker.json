{
    "version": "29.4.3",
    "description": "Docker {cli, engine, compose, buildx} for windows containers",
    "homepage": "https://docs.docker.com/engine",
    "license": "Apache-2.0",
    "architecture": {
        "64bit": {
            "url": "https://download.docker.com/win/static/stable/x86_64/docker-29.4.3.zip",
            "hash": "993b582d09f511a5a260f69a97163472459ecf8ac11a209e87ef6ea0cdb4203b"
        }
    },
    "depends": [
        "docker-compose",
        "docker-buildx"
    ],
    "extract_dir": "docker",
    "bin": [
        "docker.exe",
        "dockerd.exe"
    ],
    "post_install": "& \"$bucketsdir\\chris\\scripts\\$app\\$app.ps1\" -install",
    "pre_uninstall": "& \"$bucketsdir\\chris\\scripts\\$app\\$app.ps1\" -uninstall",
    "checkver": {
        "github": "https://github.com/moby/moby",
        "regex": "docker-v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://download.docker.com/win/static/stable/x86_64/docker-$version.zip"
            }
        }
    }
