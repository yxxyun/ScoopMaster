    "hash": "9ECE8205D12404A7ADD14980D3D718430177B458B6B6FB0ECB257764FF9558FE",
    "pre_install": [
        "# Create initial config files",
        "if (!(Test-Path -Path \"$dir\\ComicsViewer.ini\")) {",
        "    (New-Item -ItemType \"File\" -Path \"$dir\" -Name \"ComicsViewer.ini\") | Out-Null",
        "}",
        "if (!(Test-Path -Path \"$dir\\CVBkmk\")) {",
        "    (New-Item -ItemType \"Directory\" -Path \"$dir\" -Name \"CVBkmk\") | Out-Null",
        "}"
    ],
    "bin": "ComicsViewer.exe",
    "shortcuts": [
        [
            "ComicsViewer.exe",
            "ComicsViewer"
        ]
    ],
    "persist": [
        "ComicsViewer.ini",
        "CVBkmk"
    ],
    "checkver": {
        "url": "https://raw.githubusercontent.com/sqliuchang/strnghrs_packages/main/index.htm",
        "regex": "name=\"?ComicsViewer\"?[\\s\\S]+?([\\d.]+)</TD>"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/sqliuchang/strnghrs_packages/main/ComicsViewer_chn.zip"
    }
