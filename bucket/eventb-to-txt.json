    "depends": "python",
    "url": "https://files.pythonhosted.org/packages/de/46/2e2abdb71d272153eb0a877ef71cfa305cf0711a3c40be9c7fdc5a94b331/eventb_to_txt-1.7-py3-none-any.whl",
