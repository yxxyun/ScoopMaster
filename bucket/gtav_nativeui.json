{
    "version": "1.9.1",
    "description": "A ScriptHookDotNet based library that helps you quickly and easily build Rockstar-like menus",
    "homepage": "https://github.com/Guad/NativeUI",
    "license": "MIT",
    "url": "https://github.com/Guad/NativeUI/releases/download/1.9.1/Release.zip",
    "hash": "690aae3de0e4bc177658425d76f90bea48ff2305e39b174ff4adec2a2a34cf6e",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "New-Item \"$env:GTAV_PATH\\scripts\" -ItemType Directory -Force | Out-Null",
        "Move-Item \"$dir\\NativeUI.dll\" \"$env:GTAV_PATH\\scripts\" -Force",
        "Remove-Item \"$dir\\*\""
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/Guad/NativeUI/releases/download/$version/Release.zip"
    }
}
