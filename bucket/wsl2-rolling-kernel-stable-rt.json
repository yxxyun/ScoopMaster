{
    "version": "6.19.6",
    "description": "Rolling Release Stable Real-Time Kernel for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-6.19.6/bzImage-x86_64-rt",
            "hash": "70fd65ac5e35e27b26aa771b30cf61cb4abce4a7bc6ce9c9d653d7ad1f3eb87a",
            "post_install": [
                "#####################################################",
                "# Set WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "#          Channel: STABLE | Arch: x86_64           #",
                "#####################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelInstall -UsingNamespace System.Text",
                "$kernel_path=\"$original_dir\\bzImage-x86_64-rt\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "########################################################",
                "# Remove WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "########################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-6.19.6/Image-arm64-rt",
            "hash": "49447b138e466f294f9df94104d64cad6bd042baf4ba46acc566dbb0ca7b7b02",
            "post_install": [
                "#####################################################",
                "# Set WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "#           Channel: STABLE | Arch: arm64           #",
                "#####################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelInstall -UsingNamespace System.Text",
                "$kernel_path=\"$original_dir\\Image-arm64-rt\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "########################################################",
                "# Remove WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "########################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64-rt"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64-rt"
            }
        }
    }
