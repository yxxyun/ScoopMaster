{
    "version": "145.0.7632.160",
    "description": "Portable with Chrome++.",
    "homepage": "https://www.google.com/chrome/",
    "license": {
        "identifier": "Freeware",
        "url": "https://www.google.com/chrome/terms/"
    },
    "depends": "chrome-plus",
    "architecture": {
        "64bit": {
            "url": "https://dl.google.com/release2/chrome/nuloamky47wcog6772kpqu2zyu_145.0.7632.160/145.0.7632.160_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "99508495d81d8b221e9cc0ba65121af390efeec937c18717cc9fb53bd575f747",
            "pre_install": [
                "Copy-Item -Path \"$dir\\..\\..\\chrome-plus\\current\\x64\\*\" -Destination \"$dir\" -Recurse",
                "Move-Item -Path \"$dir\\Chrome-bin\\*\" -Destination \"$dir\\App\\\"",
                "Remove-Item \"$dir\\Chrome-bin\""
            ]
        },
        "32bit": {
            "url": "https://dl.google.com/release2/chrome/ad4munnxzifdyrychahurtkhfesq_145.0.7632.160/145.0.7632.160_chrome_installer_uncompressed.exe#/dl.7z",
            "hash": "a53308ddc9cc66d28c3b1b969f366708bb22c00016fdc0a45676c366bc74fdbf",
            "pre_install": [
                "Copy-Item -Path \"$dir\\..\\..\\chrome-plus\\current\\x86\\*\" -Destination \"$dir\" -Recurse",
                "Move-Item -Path \"$dir\\Chrome-bin\\*\" -Destination \"$dir\\App\\\"",
                "Remove-Item \"$dir\\Chrome-bin\""
            ]
        }
    },
    "persist": [
        "App\\chrome++.ini",
        "Cache",
        "Data"
    ],
    "bin": [
        [
            "App\\chrome.exe",
            "chrome",
            "--no-default-browser-check --no-first-run --disable-logging --disable-background-networking --disable-crash-reporter --disable-breakpad"
        ]
    ],
    "shortcuts": [
        [
            "App\\chrome.exe",
            "Google Chrome",
            "--no-default-browser-check --no-first-run --disable-logging --disable-background-networking --disable-crash-reporter --disable-breakpad"
        ]
    ],
    "env_set": {
        "CHROME_EXECUTABLE": "$dir\\App\\chrome.exe"
    },
    "checkver": {
        "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
        "regex": "(?sm)<stable32><version>(?<version>[\\d.]+)</version>.+release2/chrome/(?<32>[\\w-]+)_.+<stable64>.+release2/chrome/(?<64>[\\w-]+)_.+</stable64>"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dl.google.com/release2/chrome/$match64_$version/$version_chrome_installer_uncompressed.exe#/dl.7z",
                "hash": {
                    "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
                    "xpath": "/chromechecker/stable64[version='$version']/sha256"
                }
            },
            "32bit": {
                "url": "https://dl.google.com/release2/chrome/$match32_$version/$version_chrome_installer_uncompressed.exe#/dl.7z",
                "hash": {
                    "url": "https://scoopinstaller.github.io/UpdateTracker/googlechrome/chrome.min.xml",
                    "xpath": "/chromechecker/stable32[version='$version']/sha256"
                }
            }
        }
    }
}
