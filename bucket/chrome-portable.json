            "hash": "8944a164175a5cef6bc5ff631627a88337c9fe35c93ce335b4cfbeadc4dafc1f",
            "pre_install": [
                "Copy-Item -Path \"$dir\\..\\..\\chrome-plus\\current\\x64\\*\" -Destination \"$dir\" -Recurse",
