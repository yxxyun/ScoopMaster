{"version":"1.6.4","homepage":"https://github.com/Aitum/obs-vertical-canvas","description":"Plugin for OBS Studio to add vertical canvas by Aitum","license":"GPL-2.0","notes":"If you don't have any obs-studio version installed in your computer, please install one of the following below. Then uninstall this app and install it again.","suggest":{"OBS":["main/obs-studio","main/obs-studio-small","main/obs-studio-pre"]},"architecture":{"64bit":{"url":"https://github.com/Aitum/obs-vertical-canvas/releases/download/1.6.4/vertical-canvas-windows.zip","hash":"3ba2ecd7d1e6b7bd5920cf40f6dd03c042979e0778ec17169797cb748176718b"}},"pre_install":["'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {","    $obs = \"$(appdir $_ $global)\"","    if (Test-Path $obs) {","       info \"Install for $_\"","       Copy-Item \"$dir\\data\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue","       Copy-Item \"$dir\\obs-plugins\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue","   }","}"],"pre_uninstall":["'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {","    $obs = \"$(appdir $_ $global)\"","    if (Test-Path $obs) {","        info \"Uninstall for $_\"","        Remove-Item \"$obs\\current\\data\\obs-plugins\\vertical-canvas\" -Force -Recurse -ErrorAction SilentlyContinue","        Remove-Item \"$obs\\current\\obs-plugins\\64bit\\vertical-canvas.*\" -Force -ErrorAction SilentlyContinue","    }","}"],"checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/Aitum/obs-vertical-canvas/releases/download/$version/vertical-canvas-windows.zip"}}},"from":"https://github.com/anxshi/various-infills"}
