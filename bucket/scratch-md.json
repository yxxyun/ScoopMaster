{"version":"0.10.0","description":"Minimalist, offline-first markdown note-taking app (Tauri).","homepage":"https://www.ericli.io/scratch","license":"MIT","notes":["Portable install: NSIS setup.exe extracted with 7-Zip (no system installer).","Settings stored under %APPDATA%\\com.scratch.app, junctioned to scoop persist.","On Windows 10, install extras/webview2 if the app fails to start."],"suggest":{"Microsoft Edge WebView2":"main/webview2"},"architecture":{"64bit":{"url":"https://github.com/erictli/scratch/releases/download/v0.10.0/Scratch_0.10.0_x64-setup.exe#/dl.7z","hash":"9c1d7be9e7f7d9091a8e58a56aeee7d57cf8f344166e9cbed593e281e05674ed"}},"pre_install":["$links = @(,@(\"$env:APPDATA\\com.scratch.app\", \"$persist_dir\\appdata\\com.scratch.app\"))","foreach ($pair in $links) {","    $linkPath = $pair[0]","    $storePath = $pair[1]","    New-Item -ItemType Directory -Path $storePath -Force | Out-Null","    if (Test-Path -LiteralPath $linkPath) {","        $item = Get-Item -LiteralPath $linkPath -Force","        if ($item.Attributes -band [System.IO.FileAttributes]::ReparsePoint) {","            $targetPath = @($item.Target)[0]","            if ($targetPath) {","                try {","                    $resolvedTarget = (Resolve-Path -LiteralPath $targetPath -ErrorAction Stop).Path","                    $resolvedStore = (Resolve-Path -LiteralPath $storePath -ErrorAction Stop).Path","                    if ($resolvedTarget -ne $resolvedStore) {","                        throw \"Refusing to overwrite existing link at $linkPath because it points to $resolvedTarget\"","                    }","                } catch {","                    throw \"Refusing to overwrite existing link at $linkPath\"","                }","            }","            continue","        }","        Get-ChildItem -LiteralPath $linkPath -Force -ErrorAction SilentlyContinue | ForEach-Object {","            Move-Item -LiteralPath $_.FullName -Destination $storePath -Force -ErrorAction SilentlyContinue","        }","        Remove-Item -LiteralPath $linkPath -Recurse -Force","    }","    New-Item -ItemType Junction -Path $linkPath -Value $storePath | Out-Null","}","Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\uninstall.exe\", \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue"],"pre_uninstall":["$links = @(,@(\"$env:APPDATA\\com.scratch.app\", \"$persist_dir\\appdata\\com.scratch.app\"))","foreach ($pair in $links) {","    $linkPath = $pair[0]","    $storePath = $pair[1]","    if (!(Test-Path -LiteralPath $linkPath)) { continue }","    $item = Get-Item -LiteralPath $linkPath -Force","    if (!($item.Attributes -band [System.IO.FileAttributes]::ReparsePoint)) { continue }","    $targetPath = @($item.Target)[0]","    if (!$targetPath) { continue }","    try {","        $resolvedTarget = (Resolve-Path -LiteralPath $targetPath -ErrorAction Stop).Path","        $resolvedStore = (Resolve-Path -LiteralPath $storePath -ErrorAction Stop).Path","        if ($resolvedTarget -eq $resolvedStore) {","            Remove-Item -LiteralPath $linkPath -Recurse -Force -ErrorAction SilentlyContinue","        }","    } catch {","        continue","    }","}"],"bin":[["Scratch.exe","scratch-md"]],"shortcuts":[["Scratch.exe","Scratch"]],"checkver":{"github":"https://github.com/erictli/scratch"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/erictli/scratch/releases/download/v$version/Scratch_$version_x64-setup.exe#/dl.7z"}}},"from":"https://github.com/zunaidFarouque/Zunaid-Scoop-Bucket"}
