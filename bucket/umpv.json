{
    "version": "1.5.1",
    "description": "A mpv wrapper which implements single instance mode.",
    "homepage": "https://github.com/zhongfly/umpv-go",
    "architecture": {
        "64bit": {
            "url": "https://github.com/zhongfly/umpv-go/releases/download/v1.5.1/umpv-windows-amd64.zip",
            "hash": "661843fdf9973a3255c064e686e48389d904d5855e6f848d4f5652eb24ad4fa6"
        },
        "arm64": {
            "url": "https://github.com/zhongfly/umpv-go/releases/download/v1.5.1/umpv-windows-arm64.zip",
            "hash": "aa1c9b1b7db8a1c26a8fb98dd90dc8e36bbe9ca2baa5623b50670840f8bf4b17"
        }
    },
    "shortcuts": [
        [
            "umpv.exe",
            "umpv"
        ]
    ],
    "persist": "umpv.conf",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/zhongfly/umpv-go/releases/download/v$version/umpv-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/zhongfly/umpv-go/releases/download/v$version/umpv-windows-arm64.zip"
            }
        }
    },
    "pre_install": [
        "$conf = \"$dir\\umpv.conf\"",
        "if (!(Test-Path $conf)) {",
        "    Set-Content -Path $conf -Value 'loadfile-flag=replace'",
        "}"
    ]
}
