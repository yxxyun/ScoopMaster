{
    "version": "3889.0-1158.13",
    "description": "The library that allows to use GTA V script native functions in custom *.asi plugins",
    "homepage": "http://www.dev-c.com/gtav/scripthookv/",
    "license": "Freeware",
    "url": "http://www.dev-c.com/files/ScriptHookV_3889.0_1158.13.zip",
    "hash": "b64c97c3353906f14621e7e9511e4aec2a7d436ecc21ed124d3816585e2e6188",
    "extract_dir": "bin",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "Copy-Item \"$dir\\ScriptHookV.dll\" \"$env:GTAV_PATH\" -Force",
        "Remove-Item \"$dir\\*\" -Force -Recurse"
    ],
    "checkver": {
        "url": "http://www.dev-c.com/gtav/scripthookv/",
        "regex": "v(\\d+\\.\\d+)\\s*/\\s*(\\d+\\.\\d+)",
        "replace": "${1}-${2}"
    },
    "autoupdate": {
        "url": "http://www.dev-c.com/files/ScriptHookV_$match1_$match2.zip"
    }
}
