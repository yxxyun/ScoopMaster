{"version":"2.1.0","description":"Game Save Manager (GSM) - 游戏存档管理工具，支持自动检测、备份、还原游戏存档，集成 PCGamingWiki 数据库 | A game save manager with auto-detection, backup, restore, and PCGamingWiki database integration","homepage":"https://gamezonelabs.com","license":{"identifier":"GPL-3.0-only","url":"https://github.com/dyang886/Game-Save-Manager/blob/main/LICENSE.txt"},"architecture":{"64bit":{"url":"https://github.com/dyang886/Game-Save-Manager/releases/download/v2.1.0/Game.Save.Manager.Setup.2.1.0.exe","hash":"408b13b79044196d4d377626b5ba557f2642d7954404c1a5c64a659771e1ae06"}},"pre_install":["# 确保 persist 数据目录存在（pre_install 阶段 Scoop 尚未创建 persist 目录）","if (!(Test-Path \"$persist_dir\\data\")) {","    New-Item -ItemType Directory -Force -Path \"$persist_dir\\data\" | Out-Null","}","","$junction = \"$env:APPDATA\\game-save-manager\"","if (Test-Path $junction) {","    if ((Get-Item $junction -Force -ErrorAction SilentlyContinue).Attributes -band [System.IO.FileAttributes]::ReparsePoint) {","        [System.IO.Directory]::Delete($junction)","    } else {","        Write-Host \"迁移 %APPDATA%\\game-save-manager 已有数据到 persist 目录...\"","        Get-ChildItem $junction | Move-Item -Destination \"$persist_dir\\data\" -Force","        Remove-Item $junction -Force -Recurse","    }","}","New-Item -ItemType Junction -Path $junction -Target \"$persist_dir\\data\" | Out-Null","","# 注册 .gsmr 文件关联（每次安装/更新都刷新，指向 current 路径）","$exePath = \"$(Split-Path $dir -Parent)\\current\\Game Save Manager.exe\"","New-Item -Path 'HKCU:\\Software\\Classes\\.gsmr\\OpenWithProgids' -Force | Out-Null","New-ItemProperty -Path 'HKCU:\\Software\\Classes\\.gsmr\\OpenWithProgids' -Name 'GameSaveManagerBackup.gsmr' -PropertyType String -Force | Out-Null","New-Item -Path 'HKCU:\\Software\\Classes\\GameSaveManagerBackup.gsmr\\shell\\open\\command' -Force | Out-Null","Set-ItemProperty -Path 'HKCU:\\Software\\Classes\\GameSaveManagerBackup.gsmr' -Name '(default)' -Value 'Game Save Manager Backup' -Type String","New-Item -Path 'HKCU:\\Software\\Classes\\GameSaveManagerBackup.gsmr\\DefaultIcon' -Force | Out-Null","Set-ItemProperty -Path 'HKCU:\\Software\\Classes\\GameSaveManagerBackup.gsmr\\DefaultIcon' -Name '(default)' -Value \"$exePath,0\" -Type String","Set-ItemProperty -Path 'HKCU:\\Software\\Classes\\GameSaveManagerBackup.gsmr\\shell\\open\\command' -Name '(default)' -Value \"`\"$exePath`\" `\"%1`\"\" -Type String"],"installer":{"script":["Expand-InnoArchive \"$dir\\$fname\" -Removable"]},"post_install":["# 重建 junction（更新后 Scoop 清理旧版本但 persist 数据保留）","if (!(Test-Path \"$persist_dir\\data\")) { New-Item -ItemType Directory -Force -Path \"$persist_dir\\data\" | Out-Null }","$junction = \"$env:APPDATA\\game-save-manager\"","if (Test-Path $junction) {","    $item = Get-Item $junction -Force -ErrorAction SilentlyContinue","    if ($item.Attributes -band [System.IO.FileAttributes]::ReparsePoint) {","        [System.IO.Directory]::Delete($junction)","    }","}","New-Item -ItemType Junction -Path $junction -Target \"$persist_dir\\data\" | Out-Null"],"pre_uninstall":["$junction = \"$env:APPDATA\\game-save-manager\"","if ((Test-Path $junction) -and ((Get-Item $junction -Force -ErrorAction SilentlyContinue).Attributes -band [System.IO.FileAttributes]::ReparsePoint)) {","    [System.IO.Directory]::Delete($junction)","}"],"post_uninstall":["Remove-Item 'HKCU:\\Software\\Classes\\.gsmr' -Recurse -Force -ErrorAction SilentlyContinue","Remove-Item 'HKCU:\\Software\\Classes\\GameSaveManagerBackup.gsmr' -Recurse -Force -ErrorAction SilentlyContinue"],"uninstaller":{"script":["Stop-Process -Name 'Game Save Manager' -Force -ErrorAction SilentlyContinue","Start-Sleep -Milliseconds 1500","# 清理开始菜单快捷方式残留（校验目标路径指向本应用目录，避免误删同名非 Scoop 快捷方式）","$appDir = Split-Path $dir -Parent","$shell = New-Object -ComObject WScript.Shell","@(\"$env:APPDATA\", \"$env:ProgramData\") | ForEach-Object {","    $lnk = \"$_\\Microsoft\\Windows\\Start Menu\\Programs\\Game Save Manager.lnk\"","    if ((Test-Path $lnk) -and ($shell.CreateShortcut($lnk).TargetPath -like \"$appDir\\*\")) {","        Remove-Item $lnk -Force -ErrorAction SilentlyContinue","    }","}"]},"shortcuts":[["Game Save Manager.exe","..\\Game Save Manager"]],"persist":"data","notes":["数据持久化: 应用数据/game-save-manager（含数据库/GSM Database）等数据","已通过目录联接 (junction) 重定向到 Scoop persist 目录。","卸载时不会残留数据，重新安装自动恢复。","",".gsmr 文件关联已在安装/更新时自动注册，双击 .gsmr 文件可直接用 Game Save Manager 打开。"],"checkver":{"github":"https://github.com/dyang886/Game-Save-Manager"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/dyang886/Game-Save-Manager/releases/download/v$version/Game.Save.Manager.Setup.$version.exe"}}},"from":"https://github.com/Arama0517/scoop-bucket"}
