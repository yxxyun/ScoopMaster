{
    "version": "2.1.0",
    "description": "Type `git open` to open the GitHub page or website for a repository in your browser.",
    "homepage": "https://github.com/paulirish/git-open",
    "license": "MIT",
    "suggest": {
        "Git": "main/git"
    },
    "notes": [
        "It must be used inside a Bash/Zsh session,",
        "The easiest Windows option is Git Bash.",
        "(Experimental) To keep the right tools first, add these to the TOP of your System PATH",
        "  $env:SCOOP\\apps\\git\\current\\bin",
        "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "url": "https://github.com/paulirish/git-open/archive/refs/tags/v2.1.0.zip",
    "hash": "8fa1093cfb1f51031a904c70823764dd07ffdca24c42d0c8dd16367bbd9b2a06",
    "extract_dir": "git-open-2.1.0",
    "pre_install": [
        "Remove-Item -Path \"$dir\\*\" -Exclude 'git-open', 'LICENSE.md' -Recurse -Force",
        "New-Item -Path \"$dir\\git-open.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\git-open.cmd\" -Value \"bash  $env:SCOOP\\apps\\git-open\\current\\git-open %*\""
    ],
    "bin": "git-open.cmd",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/paulirish/git-open/archive/refs/tags/v$version.zip",
        "extract_dir": "git-open-$version"
    }
}
