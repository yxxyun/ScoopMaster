    "license": "GPL-3.0",
    "notes": [
        "Codux 是高性能 AI 编程终端，统一 Codex、Claude Code 等 8+ 种 AI CLI 的工作区。",
        "需要 Windows 11。"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/duxweb/codux/releases/download/v2.0.0-rc.6/codux-2.0.0-rc.6-windows-x86_64-setup.exe",
            "hash": "1bebc42dee75411c5ad8c0babc7e7789d9a920896a08347c1595cdb9d47883c0"
        }
    },
    "installer": {
        "script": [
            "$exe = Get-ChildItem \"$dir\\codux-*-windows-x86_64-setup.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
            "if ($exe) { Start-Process -FilePath $exe.FullName -ArgumentList '/S', \"/D=$dir\" -Wait -NoNewWindow }"
        ]
    },
    "post_install": "Remove-Item \"$dir\\codux-*-windows-x86_64-setup.exe\", \"$dir\\Uninstall.exe\" -Force -ErrorAction SilentlyContinue",
    "bin": "Codux.exe",
    "shortcuts": [
        [
            "Codux.exe",
            "Codux"
        ]
    ],
    "checkver": {
        "url": "https://github.com/duxweb/codux/releases",
        "regex": "download/v([0-9]+\\.[0-9]+\\.[0-9]+(?:-(?:beta|rc)\\.[0-9]+)?)/codux-[0-9]+\\.[0-9]+\\.[0-9]+(?:-(?:beta|rc)\\.[0-9]+)?-windows-x86_64-setup\\.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/duxweb/codux/releases/download/v$version/codux-$version-windows-x86_64-setup.exe"
            }
        }
    }
}
