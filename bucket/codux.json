{
    "version": "2.0.0-rc.5",
    "description": "The high-performance AI coding terminal — desktop workspace for Codex, Claude Code, and 8+ AI coding CLIs",
    "homepage": "https://github.com/duxweb/codux",
    "license": "GPL-3.0",
    "notes": [
        "Codux 是高性能 AI 编程终端，统一 Codex、Claude Code 等 8+ 种 AI CLI 的工作区。",
        "需要 Windows 11。"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/duxweb/codux/releases/download/v2.0.0-rc.5/codux-2.0.0-rc.5-windows-x86_64-setup.exe",
            "hash": "a09ccd2bbda2e54fd09fff6505abc4474e15b8c10915f134339774f86416d5aa"
        }
    },
    "installer": {
        "script": [
            "$exe = Get-ChildItem \"$dir\\codux-*-windows-x86_64-setup.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
            "if ($exe) { Start-Process -FilePath $exe.FullName -ArgumentList '/S', \"/D=$dir\" -Wait -NoNewWindow }"
        ]
    },
    "post_install": "Remove-Item \"$dir\\codux-*-windows-x86_64-setup.exe\", \"$dir\\Uninstall.exe\" -Force -ErrorAction SilentlyContinue",
    "bin": "Codux.exe",
    "shortcuts": [
        [
            "Codux.exe",
            "Codux"
        ]
    ],
    "checkver": {
        "github": "https://github.com/duxweb/codux"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/duxweb/codux/releases/download/v$version/codux-$version-windows-x86_64-setup.exe"
            }
        }
    }
}
