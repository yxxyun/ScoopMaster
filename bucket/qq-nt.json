{
    "version": "9.9.32.260716",
    "description": "QQ-NT",
    "homepage": "https://im.qq.com",
    "license": "Freeware",
    "url": "https://qq-web.cdn-go.cn/im.qq.com_new/latest/rainbow/windowsConfig.js#/QQ-NT.json",
    "pre_install": [
        "$release = $version -replace '\\.\\d+$'",
        "$build = $version -replace '^.*\\.'",
        "$config = Get-Content -Raw \"$dir\\QQ-NT.json\"",
        "$pattern = \"https://qqdl\\.gtimg\\.cn/qqfile/QQNTV2/$([regex]::Escape($release))/release/[a-f0-9]+/QQ_$([regex]::Escape($release))_$([regex]::Escape($build))_x64_01\\.exe\"",
        "$sourceUrl = [regex]::Match($config, $pattern).Value",
        "if (!$sourceUrl) { throw \"未找到 QQ $version 的 x64 下载地址。\" }",
        "$response = Invoke-RestMethod -Method Post -Uri 'https://im.qq.com/http2rpc/gotrpc/noauth/trpc.qqntv2.urlsign.UrlSign/GetSign' -ContentType 'application/json' -Headers @{ 'x-oidb' = '{\"uint32_command\":\"0x9b8e\",\"uint32_service_type\":1}'; Origin = 'https://im.qq.com'; Referer = 'https://im.qq.com/index/' } -Body (@{ url = $sourceUrl } | ConvertTo-Json -Compress)",
        "$signedUrl = $response.data.url",
        "if (!$signedUrl) { throw \"QQ 未返回已签名的下载地址：$($response.message)\" }",
        "Invoke-WebRequest -UseBasicParsing -Uri $signedUrl -OutFile \"$dir\\QQ-NT.exe\"",
        "Expand-7zipArchive -Path \"$dir\\QQ-NT.exe\" -DestinationPath $dir -ExtractDir 'Files' -Removal",
        "Remove-Item \"$dir\\QQ-NT.json\" -Force"
    ],
    "shortcuts": [
        [
            "QQ.exe",
            "QQ"
        ]
    ],
    "checkver": {
        "url": "https://qq-web.cdn-go.cn/im.qq.com_new/latest/rainbow/windowsConfig.js",
        "regex": "QQNTV2/[\\d.]+/release/([a-f0-9]+)/QQ_([\\d.]+)_(\\d+)_x64_01\\.exe",
        "replace": "${2}.${3}"
    },
    "autoupdate": {
        "url": "https://qq-web.cdn-go.cn/im.qq.com_new/latest/rainbow/windowsConfig.js#/QQ-NT.json"
    }
}
