{
    "version": "3.7.0",
    "description": "A modern toolbox for Android and OpenHarmony devices",
    "homepage": "https://github.com/Uotan-Dev/UotanToolboxNT",
    "license": "GPL-3.0-only",
    "notes": [
        "本包会托管默认日志、备份、临时解包目录以及 %LOCALAPPDATA%\\UotanToolbox\\ 下的用户设置",
        "软件内“导出 APK 到桌面”是上游固定行为，不纳入 Scoop persist",
        "若你在软件设置中手动修改备份目录，后续备份将保存到你指定的位置"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/Uotan-Dev/UotanToolboxNT/releases/download/3.7.0/UotanToolbox_Windows_x64_3.7.0.zip",
            "hash": "84e5ce74afbae82d4b1b845501ec1a65d90c1b0d6d17ca580fe9b605f6b68284"
        },
        "arm64": {
            "url": "https://github.com/Uotan-Dev/UotanToolboxNT/releases/download/3.7.0/UotanToolbox_Windows_arm64_3.7.0.zip",
            "hash": "15ad8bf3f0e2e3bb6b3a8ca5f02664cb5950cb0782ede9afafa3eca8611a08ac"
        }
    },
    "bin": [
        [
            "UotanToolbox.cmd",
            "uotantoolboxnt"
        ]
    ],
    "shortcuts": [
        [
            "UotanToolbox.cmd",
            "Uotan Toolbox NT"
        ]
    ],
    "post_install": [
        "ensure (Join-Path $persist_dir 'Log')",
        "ensure (Join-Path $persist_dir 'Backup')",
        "ensure (Join-Path $persist_dir 'Temp')",
        "ensure (Join-Path $persist_dir 'data')",
        "",
        "$launcher = @(",
        "    '@echo off',",
        "    \"set \\\"TEMP=$persist_dir\\Temp\\\"\",",
        "    \"set \\\"TMP=$persist_dir\\Temp\\\"\",",
        "    'start \"\" \"%~dp0UotanToolbox.exe\" %*'",
        ") -join \"`r`n\"",
        "[IO.File]::WriteAllText((Join-Path $dir 'UotanToolbox.cmd'), $launcher, [Text.UTF8Encoding]::new($false))",
        "",
        "$source = Join-Path $env:LOCALAPPDATA 'UotanToolbox'",
        "$target = Join-Path $persist_dir 'data'",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "post_uninstall": [
        "$source = Join-Path $env:LOCALAPPDATA 'UotanToolbox'",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Remove-Item -LiteralPath $source -Force",
        "    }",
        "}"
    ],
    "persist": [
        "Backup",
        "Log",
        "Temp",
        "data"
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Uotan-Dev/UotanToolboxNT/releases/download/$version/UotanToolbox_Windows_x64_$version.zip"
            },
            "arm64": {
                "url": "https://github.com/Uotan-Dev/UotanToolboxNT/releases/download/$version/UotanToolbox_Windows_arm64_$version.zip"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
