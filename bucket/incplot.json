{
    "version": "1.0.0",
    "description": "CLI tool drawing great looking plots in the terminal focused on user ergonomics and simplicity",
    "homepage": "https://github.com/InCom-0/incplot/",
    "license": {
        "identifier": "MIT"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/InCom-0/incplot/releases/download/v1.0.0/incplot_windows_msvc_x86_64.zip",
            "hash": "8b4285afb38547e2c68893ee2a27a989614e9016318f15d366d63128b6678792",
            "extract_dir": "incplot_windows_msvc_x86_64"
        },
        "arm64": {
            "url": "https://github.com/InCom-0/incplot/releases/download/v1.0.0/incplot_windows_msvc_arm64.zip",
            "hash": "01973856e4824082b8c98428e7543de87192e3b030f97a8855da4ce5801c779b",
            "extract_dir": "incplot_windows_msvc_arm64"
        }
    },
    "pre_install": [
        "$src = Join-Path $dir 'configDB.seed.sqlite'",
        "$dst = Join-Path $dir 'configDB.sqlite'",
        "if (-not (Test-Path $src)) { throw \"Manifest error: missing seed database '$src'. Package is invalid.\" }",
        "if (-not (Test-Path $dst)) { Copy-Item $src $dst -Force }"
    ],
    "bin": "incplot.exe",
    "checkver": {
        "url": "https://api.github.com/repos/InCom-0/incplot/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v(?<majorVersion>[\\w.-]+)\\.(?<minorVersion>[\\w.-]+)\\.(?<patchVersion>[\\w.-]+)",
        "replace": "${majorVersion}.${minorVersion}.${patchVersion}"
    },
    "persist": "configDB.sqlite",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/InCom-0/incplot/releases/download/v$version/incplot_windows_msvc_x86_64.zip"
            },
            "arm64": {
                "url": "https://github.com/InCom-0/incplot/releases/download/v$version/incplot_windows_msvc_arm64.zip"
            }
        },
        "hash": {
            "url": "$baseurl/shasum.txt"
        }
    }
}
