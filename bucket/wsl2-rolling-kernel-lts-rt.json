{
    "version": "6.18.16",
    "description": "Rolling Release LTS Real-Time Kernel for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS",
    "license": "GPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.16/bzImage-x86_64-rt",
            "hash": "e010e9c71c6edc7708e11b3ff8c5a73cc4d5807a8779dd02f8e2cde7fc090941",
            "post_install": [
                "#####################################################",
                "# Set WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "#            Channel: LTS | Arch: x86_64            #",
                "#####################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelInstall -UsingNamespace System.Text",
                "$kernel_path=\"$original_dir\\bzImage-x86_64-rt\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "########################################################",
                "# Remove WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "########################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelUninstall -UsingNamespace System.Text",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.16/Image-arm64-rt",
            "hash": "12877775d001d3aa348c83ebc9c4fa04d5483a4258d3e2da11405b190c6dae3e",
            "post_install": [
                "#####################################################",
                "# Set WSL2 rolling Real-Time kernel in `.wslconfig` #",
                "#            Channel: LTS | Arch: arm64             #",
                "#####################################################",
                "$ini = Add-Type -memberDefinition @\"",
                "[DllImport(\"Kernel32\")]",
                "public static extern long WritePrivateProfileString (string section, string key, string val, string filePath);",
                "\"@ -passthru -name WSL2RollingKernelInstall -UsingNamespace System.Text",
                "$kernel_path=\"$original_dir\\Image-arm64-rt\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = $ini::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                "########################################################",
