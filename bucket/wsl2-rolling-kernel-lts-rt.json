            "hash": "fe7a14aeb9cb404e25a6a4b8ce8b12fa06b758c5765a3906197ac63fd62a9795",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\bzImage-x86_64-rt\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-6.18.30/Image-arm64-rt",
            "hash": "82be4687226492d3f720550373d391cd7b0607510445f3ade1422a1aadc7813a",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\Image-arm64-rt\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "notes": "To get kernel modules support, please install wsl2-rolling-kernel-lts-rt-addon.",
    "suggest": {
        "modules": "frostbite/wsl2-rolling-kernel-lts-rt-addon"
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/latest",
        "regex": "linux-wsl-lts-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-$version/bzImage-x86_64-rt"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-$version/Image-arm64-rt"
            }
        }
    }
