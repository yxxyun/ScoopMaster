            ]
        }
    },
    "notes": "To get kernel modules support, please install wsl2-rolling-kernel-lts-rt-addon.",
    "suggest": {
        "modules": "frostbite/wsl2-rolling-kernel-lts-rt-addon"
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/latest",
        "regex": "linux-wsl-lts-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-$version/bzImage-x86_64-rt"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling-LTS/releases/download/linux-wsl-lts-$version/Image-arm64-rt"
            }
