    "license": "Freeware",
    "url": "http://example.com",
    "pre_install": [
        "$url = \"https://www.mediafire.com/file/wt37sbsejk7iepm/PowerSettingsExplorer.zip/file\"",
        "if ((Invoke-RestMethod -Uri $url) -match 'aria-label=\"Download file\"\\s+href=\"(?<url>[^\"]+)\"') {",
        "    $dl_url = $Matches.url",
        "}",
        "Invoke-WebRequest -Uri $dl_url -OutFile \"$dir\\dl.zip\"",
        "Expand-7zipArchive -Path \"$dir\\dl.zip\" -Removal"
    ],
    "shortcuts": [
        [
            "PowerSettingsExplorer.exe",
            "PowerSettingsExplorer"
        ]
    ],
    "checkver": {
        "url": "https://www.mediafire.com/api/1.5/file/get_info.php?response_format=json&quick_key=wt37sbsejk7iepm",
        "jsonpath": "$.response.file_info.created",
        "regex": "([\\d-]+)"
    }
}
