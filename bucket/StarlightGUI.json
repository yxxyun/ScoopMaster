{"version":"3.0.0-pre3","description":"Starlight GUI - 一个强大而易用的 Windows 内核级工具箱，使用 C++/WinRT WinUI3 编写 | A powerful and easy-to-use Windows kernel-level toolbox, written with C++/WinRT WinUI3","homepage":"https://github.com/OpenStarlight/StarlightGUI","license":{"identifier":"Apache-2.0","url":"https://github.com/OpenStarlight/StarlightGUI/blob/main/LICENSE"},"architecture":{"64bit":{"url":"https://github.com/OpenStarlight/StarlightGUI/releases/download/v3.0.0-pre3/Starlight.GUI-v3.0.0-pre3-Package.zip","hash":"0f390dc65c30ddde246cdb6fd0da0e22bf806c3c77f0ebc5a4eda4182e3245c9"}},"pre_install":["# 创建空配置文件占位，确保 persist 将其视为文件而非文件夹","if (!(Test-Path \"$dir\\StarlightGUI.json\")) { Set-Content -Path \"$dir\\StarlightGUI.json\" -Value '{}' -Encoding ASCII -Force }"],"uninstaller":{"script":["# 结束进程（终止后等待文件句柄释放，避免文件锁定导致卸载失败）","Stop-Process -Name StarlightGUI -Force -ErrorAction SilentlyContinue","Start-Sleep -Milliseconds 1500","# 清理开始菜单快捷方式残留（校验目标路径指向本应用目录，避免误删同名非 Scoop 快捷方式）","$appDir = Split-Path $dir -Parent","$shell = New-Object -ComObject WScript.Shell","@(\"$env:APPDATA\", \"$env:ProgramData\") | ForEach-Object {","    $lnk = \"$_\\Microsoft\\Windows\\Start Menu\\Programs\\Starlight GUI.lnk\"","    if ((Test-Path $lnk) -and ($shell.CreateShortcut($lnk).TargetPath -like \"$appDir\\*\")) {","        Remove-Item $lnk -Force -ErrorAction SilentlyContinue","    }","}"]},"shortcuts":[["StarlightGUI.exe","..\\Starlight GUI"]],"persist":"StarlightGUI.json","checkver":{"script":["$releases = Invoke-RestMethod 'https://api.github.com/repos/OpenStarlight/StarlightGUI/releases'","$latest = $releases | Select-Object -First 1","$version = $latest.tag_name -replace '^v'","Write-Output $version"],"regex":"([\\d.]+(?:-[\\w.]+)?)"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/OpenStarlight/StarlightGUI/releases/download/v$version/Starlight.GUI-v$version-Package.zip"}}},"from":"https://github.com/ExLei/Scoop-Bucket"}
