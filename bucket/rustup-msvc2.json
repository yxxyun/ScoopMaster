{
    "version": "1.29.0",
    "description": "Manage multiple rust installations with ease",
    "homepage": "https://rustup.rs",
    "license": "MIT|Apache-2.0",
    "notes": [
        "I added a \"pre-install\" script to install msvc components needed by rust.",
        "But it has not been tested whether it is feasible."
    ],
    "architecture": {
        "64bit": {
            "url": "https://static.rust-lang.org/rustup/dist/x86_64-pc-windows-msvc/rustup-init.exe",
            "hash": "86478e53f769379d7f0ebfa7c9aa97cb76ca92233f79aa2cc0dbee2efaac73c7"
        },
        "32bit": {
            "url": "https://static.rust-lang.org/rustup/dist/i686-pc-windows-msvc/rustup-init.exe",
            "hash": "f574ea2bd6d798b6072b3a45e3053f3cabcc2cb48d6b4bd59b661b41d675b31a"
        },
        "arm64": {
            "url": "https://static.rust-lang.org/rustup/dist/aarch64-pc-windows-msvc/rustup-init.exe",
            "hash": "3af309e6c3062aa11df0e932954f69d13b734d8a431e593812f3ecd9ff9e6ef6"
        }
    },
    "installer": {
        "script": [
            "[Environment]::SetEnvironmentVariable('CARGO_HOME', \"$persist_dir\\.cargo\", 'Process')",
            "[Environment]::SetEnvironmentVariable('RUSTUP_HOME', \"$persist_dir\\.rustup\", 'Process')",
            "Invoke-ExternalCommand -Path \"$dir\\rustup-init.exe\" -Args @('-y', '--no-modify-path') | Out-Null"
        ]
    },
    "env_add_path": ".cargo\\bin",
    "env_set": {
        "CARGO_HOME": "$persist_dir\\.cargo",
        "RUSTUP_HOME": "$persist_dir\\.rustup"
    },
    "persist": [
        ".cargo",
        ".rustup"
    ],
    "checkver": {
        "url": "https://sh.rustup.rs",
        "regex": "rustup-init ([\\d.]+) \\("
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://static.rust-lang.org/rustup/dist/x86_64-pc-windows-msvc/rustup-init.exe"
            },
            "32bit": {
                "url": "https://static.rust-lang.org/rustup/dist/i686-pc-windows-msvc/rustup-init.exe"
            },
            "arm64": {
                "url": "https://static.rust-lang.org/rustup/dist/aarch64-pc-windows-msvc/rustup-init.exe"
            }
        },
        "hash": {
            "url": "$url.sha256"
        }
    },
    "pre_install": [
        "# 路径设置",
        "$installerDir = \"$dir\\installer\"",
        "New-Item -ItemType Directory -Force -Path $installerDir | Out-Null",
        "$installerPath = \"$installerDir\\vs_buildtools.exe\"",
        "$customInstallPath = \"$dir\\vs_buildtools\"",
        "",
        "# 使用绝对路径（适配不同环境）",
        "$configPath = \"$env:SCOOP/buckets/zhanyu/config/buildtools.vsconfig\"",
        "",
        "Write-Host \"Use config file: $configPath\" -ForegroundColor Cyan",
        "if (-not (Test-Path $configPath)) {",
        "    Write-Host \"Error: config file not found\" -ForegroundColor Red",
        "    exit 1",
        "}",
        "",
        "Write-Host 'Download the installation program...' -ForegroundColor Cyan",
        "iwr -Uri 'https://aka.ms/vs/stable/vs_BuildTools.exe' -OutFile $installerPath -UseBasicParsing",
        "",
        "Write-Host 'Install components to a custom path using a configuration file...' -ForegroundColor Cyan",
        "$arguments = @('--quiet', '--wait', '--norestart', \"--config=`\"$configPath`\"\", \"--installPath=`\"$customInstallPath`\"\")",
        "Start-Process -FilePath $installerPath -ArgumentList $arguments -Wait"
    ],
    "post_install": [
        "# 安装完成后清理临时文件",
        "if (Test-Path \"$dir\\installer\") {",
        "    Write-Host 'Clean up temporary files...' -ForegroundColor Cyan",
        "    Remove-Item -Recurse -Force \"$dir\\installer\" -ErrorAction SilentlyContinue",
        "}"
    ]
}
