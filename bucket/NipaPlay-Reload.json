{
    "version": "1.9.20",
    "description": "A modern video player based on Flutter, supporting multiple video sources and formats",
    "homepage": "https://github.com/MCDFsteve/NipaPlay-Reload",
    "license": "GPL-3.0-only",
    "notes": [
        "NipaPlay-Reload 是一个基于 Flutter 的现代视频播放器",
        "用户数据存储在：%USERPROFILE%\\Documents\\nipaplay\\",
        "  - 视频缓存、下载文件、播放历史等",
        "本包会将该目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "url": "https://github.com/MCDFsteve/NipaPlay-Reload/releases/download/v1.9.20/NipaPlay_1.9.20_Windows_x64.zip",
    "hash": "f8cdd8bc00d656234f26c6e087291275e07731975d6206de631d22beba35b29e",
    "extract_dir": "NipaPlay_1.9.20_Windows_x64",
    "bin": "NipaPlay.exe",
    "shortcuts": [
        [
            "NipaPlay.exe",
            "NipaPlay"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:USERPROFILE 'Documents\\nipaplay'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/MCDFsteve/NipaPlay-Reload"
    },
    "autoupdate": {
        "url": "https://github.com/MCDFsteve/NipaPlay-Reload/releases/download/v$version/NipaPlay_$version_Windows_x64.zip",
        "extract_dir": "NipaPlay_$version_Windows_x64"
    }
}
