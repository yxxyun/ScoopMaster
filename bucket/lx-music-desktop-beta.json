        [
            "lx-music-desktop.exe",
            "LX Music"
        ]
    ],
    "persist": "portable",
    "checkver": {
        "script": [
            "$version_url = 'https://raw.githubusercontent.com/lyswhut/lx-music-desktop/beta/package.json'",
            "$version_info = Invoke-RestMethod -Uri $version_url",
            "$actions_url = 'https://api.github.com/repos/lyswhut/lx-music-desktop/actions/workflows/beta-pack.yml/runs?branch=beta&status=success'",
            "$actions_info = Invoke-RestMethod -Uri $actions_url",
            "$run_id = $actions_info.workflow_runs[0].id",
            "Write-Output \"$($version_info.version) $run_id\""
        ],
        "regex": "(\\S+)\\s+(?<runid>\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://nightly.link/lyswhut/lx-music-desktop/actions/runs/$matchRunid/lx-music-desktop-win_x64-green.zip"
            },
            "32bit": {
