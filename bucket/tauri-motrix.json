{
    "version": "0.2.4",
    "description": "A full-featured download manager based on Tauri.",
    "homepage": "https://github.com/Taoister39/tauri-motrix",
    "license": "GPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Taoister39/tauri-motrix/releases/download/v0.2.4/Tauri.Motrix_0.2.4_x64-setup.exe#/dl.7z",
            "hash": "0c20c036e31fe01193782a324288d6694580c6f13e5bbb12887cc023965a4bd4"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninst*\" -Force -Recurse",
    "installer": {
        "script": [
            "ensure \"$persist_dir\" | Out-Null",
            "$targetPath = \"$env:APPDATA\\com.tauri-motrix.app\"",
            "$linkType = (Get-Item -Path $targetPath -ErrorAction SilentlyContinue).LinkType",
            "if (Test-Path $targetPath) {",
            "    if ($linkType -eq 'Junction') {",
            "        Remove-Item -Path $targetPath -Force",
            "    } else {",
            "        Get-ChildItem -Path $targetPath -Force | Move-Item -Destination $persist_dir -Force",
            "        Remove-Item -Path $targetPath -Force -Recurse",
            "    }",
            "}",
            "New-Item \"$env:APPDATA\\com.tauri-motrix.app\" -ItemType Junction -Target \"$persist_dir\" | Out-Null"
        ]
    },
    "uninstaller": {
        "script": [
            "Remove-Item \"$env:APPDATA\\com.tauri-motrix.app\" -Recurse -Force -ErrorAction 'SilentlyContinue'",
            "Remove-Item \"$env:LOCALAPPDATA\\com.tauri-motrix.app\" -Recurse -Force -ErrorAction 'SilentlyContinue'"
        ]
    },
    "shortcuts": [
        [
            "tauri-motrix.exe",
            "Tauri Motrix"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Taoister39/tauri-motrix/releases/download/v0.2.4/Tauri.Motrix_0.2.4_x64-setup.exe#/dl.7z"
            }
        }
    }
}
