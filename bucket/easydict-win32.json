{
    "version": "0.8.4",
    "description": "Easy to look up words or translate text. Windows port of tisfeng/Easydict.",
    "homepage": "https://github.com/xiaocang/easydict_win32",
    "license": "GPL-3.0",
    "notes": "MacOS alternative: https://github.com/tisfeng/Easydict",
    "architecture": {
        "64bit": {
            "url": "https://github.com/xiaocang/easydict_win32/releases/download/v0.8.4/easydict_win32-v0.8.4-x64.zip",
            "hash": "sha256:5fbe8f727fa96caf03d7a1281a17579d1771478164182c8cd55b4517ae61f1da"
        },
        "arm64": {
            "url": "https://github.com/xiaocang/easydict_win32/releases/download/v0.8.4/easydict_win32-v0.8.4-arm64.zip",
            "hash": "sha256:af3b0351c37cd0d195a70ecd46212bab55b99edeb6dd4dbdb58a2c1f912aeedd"
        }
    },
    "bin": "Easydict.WinUI.exe",
    "shortcuts": [["Easydict.WinUI.exe", "Easydict.WinUI"]],
    "persist": "data\\Easydict",
    "installer": {
        "script": [
            "$target = \"$env:LOCALAPPDATA\\Easydict\"",
            "$store = \"$persist_dir\\data\\Easydict\"",
            "if (Test-Path $target -PathType Container) {",
            "    $item = Get-Item $target",
            "    if (!$item.LinkType) {",
            "        if (!(Test-Path $store)) { New-Item -ItemType Directory -Force $store | Out-Null }",
            "        Move-Item -Path \"$target\\*\" -Destination $store -Force",
            "        Remove-Item -Force $target",
            "    }",
            "}",
            "if (!(Test-Path $target)) { New-Item -ItemType Junction -Path $target -Target $store | Out-Null }"
        ]
    },
    "uninstaller": {
        "script": [
            "$target = \"$env:LOCALAPPDATA\\Easydict\"",
            "if ((Get-Item $target).LinkType -eq 'Junction') { Remove-Item -Force $target }"
        ]
    },
    "checkver": {
        "github": "https://github.com/xiaocang/easydict_win32"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/xiaocang/easydict_win32/releases/download/v$version/easydict_win32-v$version-x64.zip"
            },
            "arm64": {
                "url": "https://github.com/xiaocang/easydict_win32/releases/download/v$version/easydict_win32-v$version-arm64.zip"
            }
        }
    }
}
