{
    "version": "1.2.40",
    "description": "一个CodexApp的增强工具，努力让Codex变得更好用更舒服",
    "homepage": "https://github.com/BigPizzaV3/CodexPlusPlus",
    "license": "MIT",
    "suggest": {
        "Codex Desktop": "sdoog/codex-app"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/BigPizzaV3/CodexPlusPlus/releases/download/v1.2.40/CodexPlusPlus-1.2.40-windows-x64-setup.exe#/dl.7z",
            "hash": "c66040f6d75572f34e3e0b216f34c0be682a2eca856b804b0a5b16a200ded068"
        }
    },
    "shortcuts": [
        [
            "codex-plus-plus.exe",
            "Codex++"
        ],
        [
            "codex-plus-plus-manager.exe",
            "Codex++ 管理工具"
        ]
    ],
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "New-PersistDirectory \"$env:APPDATA\\Codex++\" \"$persist_dir\\AppData\" -Migrate",
        "New-PersistDirectory \"$env:LOCALAPPDATA\\com.bigpizzav3.codexplusplus.manager\" \"$persist_dir\\LocalAppData\" -Migrate"
    ],
    "post_install": "Remove-Item \"$dir\\uninstall*\", \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue",
    "pre_uninstall": [
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\Codex++\"",
        "Remove-Junction \"$env:LOCALAPPDATA\\com.bigpizzav3.codexplusplus.manager\""
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/BigPizzaV3/CodexPlusPlus/releases/download/v$version/CodexPlusPlus-$version-windows-x64-setup.exe#/dl.7z"
            }
        }
    }
}
