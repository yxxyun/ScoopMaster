{"version":"1.0.2","homepage":"https://github.com/FiniteSingularity/obs-retro-effects","description":"A collection of OBS filters to give your stream that retro feel. ","license":"GPL-2.0","notes":"If you don't have any obs-studio version installed in your computer, please install one of the following below. Then uninstall this app and install it again.","suggest":{"OBS":["main/obs-studio","main/obs-studio-small","main/obs-studio-pre"]},"url":"https://github.com/FiniteSingularity/obs-retro-effects/releases/download/1.0.2/obs-retro-effects-1.0.2-windows.zip","hash":"3b7239d01b2f71193c906041f2dbe94aba94cd5d492633ae00bedbfeafad6b2e","pre_install":["    if ($architecture -eq '64bit') {","        Remove-Item \"$dir\\obs-plugins\\32bit\" -Recurse","    }","    elseif ($architecture -eq '32bit') {","        Remove-Item \"$dir\\obs-plugins\\64bit\" -Recurse","    }","'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {","    $obs = \"$(appdir $_ $global)\"","    if (Test-Path $obs) {","       info \"Install for $_\"","       Copy-Item \"$dir\\data\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue","       Copy-Item \"$dir\\obs-plugins\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue","   }","}"],"pre_uninstall":["'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {","    $obs = \"$(appdir $_ $global)\"","    if (Test-Path $obs) {","        info \"Uninstall for $_\"","        Remove-Item \"$obs\\current\\data\\obs-plugins\\obs-retro-effects\" -Force -Recurse -ErrorAction SilentlyContinue","        Remove-Item \"$obs\\current\\obs-plugins\\32bit\\obs-retro-effects.*\" -Force -ErrorAction SilentlyContinue","        Remove-Item \"$obs\\current\\obs-plugins\\64bit\\obs-retro-effects.*\" -Force -ErrorAction SilentlyContinue","    }","}"],"checkver":"github","autoupdate":{"url":"https://github.com/FiniteSingularity/obs-retro-effects/releases/download/$version/obs-retro-effects-$version-windows.zip"},"from":"https://github.com/Arama0517/scoop-bucket"}
