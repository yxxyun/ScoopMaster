{
    "version": "0.11.7",
    "description": "an uv-completion generator",
    "homepage": "https://github.com/woyxiang/slug",
    "url": "http://www.msftconnecttest.com/connecttest.txt",
    "hash": "5e9a7996fe94d7be10595d7133748760bf8348198b71b7a50fd8affaa980ac61",
    "license": "MIT",
    "installer": {
        "script": [
            "ensure ~/.config/pwsh/completions",
            "Remove-Item $dir\\connecttest.txt",
            "uv generate-shell-completion powershell > ~/.config/pwsh/completions/uv-completion.ps1"
        ]
    },
    "uninstaller": {
        "script": [
            "Remove-Item ~\\.config\\pwsh\\completions\\uv-completion.ps1 -ErrorAction SilentlyContinue"
        ]
    },
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "url": "http://www.msftconnecttest.com/connecttest.txt"
    }
}
