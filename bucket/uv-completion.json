{
    "version": "0.11.29",
    "description": "uv completion as a PowerShell module",
    "homepage": "https://docs.astral.sh/uv",
    "url": "http://www.msftconnecttest.com/connecttest.txt",
    "hash": "5e9a7996fe94d7be10595d7133748760bf8348198b71b7a50fd8affaa980ac61",
    "license": "Apache-2.0|MIT",
    "depends": "uv",
    "notes": [
        "Run following command to import uv-completion automatically in Powershell:",
        "$dir\\add-profile-content.ps1"
    ],
    "pre_install": "if (!(Test-Path \"$bucketsdir\\extras\")) { throw 'Please install extras bucket first: scoop bucket add extras' }",
    "installer": {
        "script": [
            "Remove-Item \"$dir\\connecttest.txt\" -ErrorAction SilentlyContinue",
            "uv generate-shell-completion powershell | Out-File -FilePath \"$dir\\uv-completion.psm1\" -Encoding utf8",
            "New-ModuleManifest -Path \"$dir\\uv-completion.psd1\" -RootModule 'uv-completion.psm1' -ModuleVersion $version -Author 'Astral'"
        ]
    },
    "post_install": [
        "Import-Module uv-completion",
        "$BucketDir = Find-BucketDirectory -Root -Name extras",
        "$UtilsPath = $BucketDir | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (Test-Path $UtilsPath) {",
        "    Unblock-File $UtilsPath",
        "    Import-Module $UtilsPath",
        "    New-ProfileModifier -Type ImportModule -Name uv-completion -BucketDir $BucketDir",
        "    New-ProfileModifier -Type RemoveModule -Name uv-completion -BucketDir $BucketDir",
        "    Remove-Module ModifyPSProfile -ErrorAction SilentlyContinue",
        "} else {",
        "    throw 'Missing files, please update scoop buckets and reinstall this app.'",
        "}"
    ],
    "pre_uninstall": [
        "Remove-Module uv-completion -ErrorAction SilentlyContinue",
        "$UtilsPath = Find-BucketDirectory -Root -Name extras | Join-Path -ChildPath \"scripts\\ModifyPSProfile.psm1\"",
        "if (($cmd -eq 'uninstall') -and (Test-Path \"$dir\\remove-profile-content.ps1\") -and (Test-Path $UtilsPath)) {",
        "    Unblock-File $UtilsPath",
        "    & \"$dir\\remove-profile-content.ps1\"",
        "}"
    ],
    "psmodule": {
        "name": "uv-completion"
    },
    "checkver": {
        "github": "https://github.com/astral-sh/uv"
    },
    "autoupdate": {
        "url": "http://www.msftconnecttest.com/connecttest.txt"
    }
}
