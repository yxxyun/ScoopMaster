{
    "version": "1.2.0",
    "description": "Download and play games you own on the HIKARI FIELD store.",
    "homepage": "https://store.hikarifield.co.jp/client",
    "license": {
        "identifier": "Proprietary",
        "url": "https://store.hikarifield.co.jp/about/terms-and-conditions"
    },
    "architecture": {
        "64bit": {
            "url": "https://client.hikarifield.co.jp/release/HIKARI-FIELD-CLIENT-Setup-1.2.0.zip",
            "hash": "2a11139a35b44e006ece02107358aa675c05e98016665d5b103176be5ffc191d"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\HIKARI-FIELD-CLIENT-Setup-$version.exe\" \"$dir\" -ExtractDir '$PLUGINSDIR' -Removal",
        "Expand-7zipArchive \"$dir\\app-64.7z\" \"$dir\" -Removal"
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\apeiraco\\bin\\persist-utils.ps1\"",
            "Set-PersistLinks -PersistDir $persist_dir -LinkMap @{ 'appdata' = '$env:APPDATA\\hikari-field-client' }"
        ]
    },
    "uninstaller": {
        "script": [
            ". \"$bucketsdir\\apeiraco\\bin\\persist-utils.ps1\"",
            "Remove-PersistLinks -PersistDir $persist_dir -LinkMap @{ 'appdata' = '$env:APPDATA\\hikari-field-client' }"
        ]
    },
    "bin": "HIKARI FIELD CLIENT.exe",
    "shortcuts": [
        [
            "HIKARI FIELD CLIENT.exe",
            "HIKARI FIELD CLIENT"
        ]
    ],
    "checkver": {
        "url": "https://store.hikarifield.co.jp/client",
        "regex": "当前版本: ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://client.hikarifield.co.jp/release/HIKARI-FIELD-CLIENT-Setup-$version.zip"
            }
        }
    }
}

