{
    "version": "3.1.1",
    "description": "An updated version of the original iFruitAddon by CamxxCore",
    "homepage": "https://github.com/Bob74/iFruitAddon2",
    "license": "MIT",
    "url": "https://github.com/Bob74/iFruitAddon2/releases/download/v3.1.1/iFruitAddon2-3.1.1.zip",
    "hash": "1af5be6349e4c8d39973551e5051a72fc354cdfe8b1757df721629532c1b8579",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "New-Item \"$env:GTAV_PATH\\scripts\" -ItemType Directory -Force | Out-Null",
        "Move-Item \"$dir\\iFruitAddon2.dll\" \"$env:GTAV_PATH\\scripts\" -Force",
        "Remove-Item \"$dir\\*\""
    ],
    "checkver": {
        "github": "https://github.com/Bob74/iFruitAddon2",
        "regex": "v(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "url": "https://github.com/Bob74/iFruitAddon2/releases/download/v$version/iFruitAddon2-$version.zip"
    }
}
