{
    "version": "1.5.0",
    "description": "基于 Pixai Tagger ONNX 的本地图像自动打 Danbooru 标签 GUI 工具",
    "homepage": "https://github.com/wai55555/PixaiTaggerOnnxGui",
    "license": {
        "identifier": "Apache-2.0, LGPL-3.0",
