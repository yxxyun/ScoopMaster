    },
    "url": "https://github.com/wai55555/PixaiTaggerOnnxGui/releases/download/v1.5.0/PixaiTaggerOnnxGui_v1.5.0.zip",
    "hash": "e0f43d2a5e7714e2da4de89b3f70f9aad6d8bef55b4ef649a9f432cbb7ccf4e2",
    "bin": "pixai_tagger_gui.exe",
    "shortcuts": [
        [
            "pixai_tagger_gui.exe",
            "PixAI Tagger ONNX GUI"
        ]
    ],
    "persist": [
        "config.ini",
        "inputs",
        "pixai-tagger-v0.9-onnx\\model.onnx"
    ],
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.ini\")) { Set-Content \"$dir\\config.ini\" -Value '' -Encoding UTF8 }",
        "if (!(Test-Path \"$persist_dir\\pixai-tagger-v0.9-onnx\\model.onnx\")) {",
        "    New-Item -ItemType Directory -Path \"$dir\\pixai-tagger-v0.9-onnx\" -Force | Out-Null",
        "    New-Item \"$dir\\pixai-tagger-v0.9-onnx\\model.onnx\" -Force | Out-Null",
        "}"
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/wai55555/PixaiTaggerOnnxGui/releases/download/v$version/PixaiTaggerOnnxGui_v$version.zip"
    }
}
