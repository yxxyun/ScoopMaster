{
    "version": "1.12.6",
    "description": "一个简单的看直播软件，支持 Bilibili、抖音、斗鱼、虎牙等平台",
    "homepage": "https://github.com/June6699/dart_simple_live",
    "license": "GPL-3.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/June6699/dart_simple_live/releases/download/v1.12.6/SimpleLive-Windows-v1.12.6.zip",
            "hash": "fcb7a64d49d4fd50f8cda771b72d6f83384aee7648f7d61b0b29d4a7c053591f"
        }
    },
    "post_install": [
        "$targetPath = \"$persist_dir\\simple-live\"",
        "$configPath = \"$env:APPDATA\\simple_live_app\"",
        "ensure $targetPath | Out-Null",
        "$linkType = (Get-Item -Path $configPath -ErrorAction SilentlyContinue).LinkType",
        "if (Test-Path $configPath) {",
        "    if ($linkType -eq 'Junction') {",
        "        Remove-Item -Path $configPath -Force",
        "    } else {",
        "        Get-ChildItem -Path $configPath -Force | Move-Item -Destination $targetPath -Force",
        "        Remove-Item -Path $configPath -Force -Recurse",
        "    }",
        "}",
        "New-Item $configPath -ItemType Junction -Target $targetPath | Out-Null"
    ],
    "shortcuts": [
        [
            "simple_live_app.exe",
            "Simple Live"
        ]
    ],
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/June6699/dart_simple_live/releases/download/v$version/SimpleLive-Windows-v$version.zip"
            }
        }
    }
}
