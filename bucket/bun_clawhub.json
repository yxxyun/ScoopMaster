{
    "version": "0.9.0",
    "description": "ClawHub 是 OpenClaw 的公共 Skills 注册中心。它是一项免费服务：所有 Skills 都是公开的、开放的，所有人都可以查看、共享和复用。Skills 就是一个包含 SKILL.md 文件（以及辅助文本文件）的文件夹。你可以在网页应用中浏览 Skills，也可以使用 CLI 来搜索、安装、更新和发布 Skills。",
    "homepage": "https://clawhub.ai/",
    "license": "MIT",
    "depends": "bun",
    "url": "https://raw.githubusercontent.com/morning-start/code-bucket/refs/heads/master/scripts/placeholder.txt",
    "env_set": {
        "CLAWHUB_REGISTRY": "https://cn.clawhub-mirror.com"
    },
    "pre_install": [
        "$appdata_dir = Join-Path $env:APPDATA \"clawhub\"",
        "$persist_data_dir = Join-Path $persist_dir data",
        "& \"$bucketsdir\\code\\scripts\\link.ps1\" $appdata_dir $persist_data_dir"
    ],
    "post_uninstall": [
        "$appdata_dir = Join-Path $env:APPDATA \"clawhub\"",
        "& \"$bucketsdir\\code\\scripts\\unlink.ps1\" $appdata_dir"
    ],
    "persist": [
        "data"
    ],
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/morning-start/code-bucket/refs/heads/master/scripts/placeholder.txt"
    }
}
