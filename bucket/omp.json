{
    "version": "16.3.12",
    "description": "AI coding agent for the terminal - sessions, subagents, slash commands, extensions",
    "homepage": "https://omp.sh/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/can1357/oh-my-pi/releases/download/v16.3.12/omp-windows-x64.exe#/omp.exe",
            "hash": "803871b9ef3ecd6466e2319a5f4f69aab1bbcdd5c9bbc58292bb6d4001db6ac9"
        }
    },
    "bin": "omp.exe",
    "pre_install": [
        "# 链接 ~/.omp 到 persist/data，升级时数据不丢失",
        "$omp_dir = Join-Path $env:USERPROFILE \".omp\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\link.ps1\" $omp_dir $persist_data"
    ],
    "post_uninstall": [
        "$omp_dir = Join-Path $env:USERPROFILE \".omp\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\unlink.ps1\" $omp_dir"
    ],
    "persist": "data",
    "checkver": {
        "github": "https://github.com/can1357/oh-my-pi"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/can1357/oh-my-pi/releases/download/v$version/omp-windows-x64.exe#/omp.exe",
                "hash": {
                    "url": "https://api.github.com/repos/can1357/oh-my-pi/releases/tags/v$version",
                    "jp": "$.assets[?(@.name=='omp-windows-x64.exe')].digest"
                }
            }
        }
    }
}
