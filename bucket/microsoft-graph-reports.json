{
    "version": "2.36.1",
    "description": "Microsoft Graph PowerShell Cmdlets",
    "homepage": "https://github.com/microsoftgraph/msgraph-sdk-powershell",
    "license": "https://aka.ms/devservicesagreement",
    "depends": "microsoft-graph-authentication",
    "pre_install": "Remove-Item \"$dir\\_rels\", \"$dir\\package\", \"$dir\\*Content_Types*.xml\" -Recurse",
    "pre_uninstall": [
        "$InstalledDeps = $manifest.depends | Where-Object { Test-Path \"$(appdir $_)\\current\" }",
        "if (-not $InstalledDeps) { return }",
        "if ($global) { scoop uninstall --global $InstalledDeps }",
        "else { scoop uninstall $InstalledDeps }"
    ],
    "checkver": {
        "regex": "<h2>([\\d\\.]+)</h2>",
        "url": "https://www.powershellgallery.com/packages/microsoft.graph.reports"
    },
    "autoupdate": {
        "url": "https://www.powershellgallery.com/api/v2/package/microsoft.graph.reports/$version#/microsoft.graph.reports.nupkg"
    },
    "hash": "66a1ae687dd49fea68d99f13c419103f805a725b235f7419d1d19176831d4e69",
    "url": "https://www.powershellgallery.com/api/v2/package/microsoft.graph.reports/2.36.1#/microsoft.graph.reports.nupkg",
    "psmodule": {
