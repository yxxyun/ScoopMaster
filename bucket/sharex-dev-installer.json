{"version":"20.2.0.1138","description":"Screen capture, file sharing and productivity tool. Development build using the native installer.","homepage":"https://getsharex.com/","license":"GPL-3.0-only","notes":["Tracks installer builds published to ShareX/DevBuilds.","This uses ShareX's native Inno Setup package and therefore shares its application identity with other installed ShareX builds."],"architecture":{"64bit":{"url":"https://github.com/ShareX/DevBuilds/releases/download/v20.2.0.1138/ShareX-20.2.0.1138-setup-x64.exe","hash":"5e86cfe19a7b7b3b9d9d9d361377e0acd8066821b991a208c37327298a7a40e1"}},"installer":{"script":["Get-Process ShareX -ErrorAction SilentlyContinue | Stop-Process -Force","$setup = Get-ChildItem \"$dir\\ShareX-*-setup-x64.exe\" | Select-Object -First 1","if (-not $setup) { throw 'ShareX setup executable was not found' }","$arguments = @('/VERYSILENT', '/SUPPRESSMSGBOXES', '/NORESTART', '/SP-', '/NORUN', '/TASKS=', \"/DIR=`\"$dir`\"\")","$process = Start-Process -FilePath $setup.FullName -ArgumentList $arguments -Wait -PassThru","if ($process.ExitCode -ne 0) { throw \"ShareX setup exited with code $($process.ExitCode)\" }","Remove-Item $setup.FullName -Force"]},"uninstaller":{"script":["Get-Process ShareX -ErrorAction SilentlyContinue | Stop-Process -Force","$uninstaller = Get-ChildItem \"$dir\\unins*.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1","if ($uninstaller) {","    $process = Start-Process -FilePath $uninstaller.FullName -ArgumentList @('/VERYSILENT', '/SUPPRESSMSGBOXES', '/NORESTART') -Wait -PassThru","    if ($process.ExitCode -ne 0) { throw \"ShareX uninstaller exited with code $($process.ExitCode)\" }","}"]},"bin":[["ShareX.exe","sharex-dev-installer"]],"checkver":{"url":"https://api.github.com/repos/ShareX/DevBuilds/releases?per_page=100","script":["$release = @($page | ConvertFrom-Json) | Where-Object {","    if ($_.draft -or $_.tag_name -notmatch '^v\\d+(?:\\.\\d+){3}$') { return $false }","    $version = $_.tag_name.TrimStart('v')","    $_.assets.name -contains \"ShareX-$version-setup-x64.exe\"","} | Sort-Object { [version]($_.tag_name.TrimStart('v')) } -Descending | Select-Object -First 1","if (-not $release) { throw 'No complete ShareX dev installer release found' }","$release.tag_name.TrimStart('v')"],"regex":"^(?<version>\\d+(?:\\.\\d+){3})$"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/ShareX/DevBuilds/releases/download/v$version/ShareX-$version-setup-x64.exe"}}},"from":"https://github.com/marcmy/scoop-bucket"}
