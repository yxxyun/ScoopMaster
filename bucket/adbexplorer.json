    "license": "MIT",
    "suggest": {
        ".NET Desktop Runtime": "versions/windowsdesktop-runtime-10.0",
         "adb": "main/adb"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/Alex4SSB/ADB-Explorer/releases/download/v1.0.26061/ADB_Explorer_1.0.26061_x64.7z",
            "hash": "93202ad410ed523f29f53d9e9339e7e79c48ab3a217a2ccd2d8f2f632156df26"
        },
        "arm64": {
            "url": "https://github.com/Alex4SSB/ADB-Explorer/releases/download/v1.0.26061/ADB_Explorer_1.0.26061_ARM64.7z",
            "hash": "6f8579bb3a604424849b123cdb3ce82e875fe1cf97b7d7a16ada22c7e76ef6d2"
        },
    },
    "pre_install": [
        "$subdir = Get-ChildItem \"$dir\\net*\" -Directory | Select-Object -First 1",
        "Move-Item \"$($subdir.FullName)\\*\" $dir -Force",
        "Remove-Item $subdir.FullName -Recurse -Force",
        "if (!(Test-Path \"$dir\\settings.json\") -and !(Test-Path \"$persist_dir\\settings.json\")) { '{\"CheckForUpdates\":false}' | Set-Content \"$dir\\settings.json\" }"
    ],
    "bin": [
        [
            "ADB Explorer.exe",
            "adbexplorer",
            "$dir/settings.json"
        ]
    ],
    "shortcuts": [
        [
            "ADB Explorer.exe",
            "ADB Explorer",
            "$dir/settings.json"
        ]
    ],
    "persist": "settings.json",
    "pre_uninstall": "Get-Process adb -ErrorAction SilentlyContinue | Stop-Process -Force",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Alex4SSB/ADB-Explorer/releases/download/v$version/ADB_Explorer_$version_x64.7z"
            },
            "arm64": {
                "url": "https://github.com/Alex4SSB/ADB-Explorer/releases/download/v$version/ADB_Explorer_$version_ARM64.7z",
            }
        }
    }
}
