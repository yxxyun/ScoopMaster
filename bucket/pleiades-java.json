        "    Invoke-Expression \"7z x `\"$exe`\" -o`\"$dir`\" -y | Out-Null\"",
        "    Remove-Item \"$exe\"",
        "}",
        "Get-ChildItem \"$dir\" -Filter \"pleiades-*\" -Directory | Remove-Item -Recurse -Force"
    ],
    "shortcuts": [
        [
            "eclipse.exe",
            "Eclipse (Pleiades) for Java Developers"
        ]
    ],
    "checkver": {
        "url": "https://willbrains.jp/pleiades.html?v=4",
        "regex": "pleiades-([\\d]{4})-([\\d]{2})-java-win-64bit-jre_([\\d]{8})\\.exe",
        "replace": "${3}",
        "reverse": true
    }
