{
    "version": "0.29.50",
    "description": "Tabbit AI Browser for Windows",
    "homepage": "https://www.tabbit-ai.com/",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://releases.tabbit-ai.com/upgrade/windows/stable_x64_cn/Tabbit%20Browser_stable_x64_cn_0.29.50.exe"
        }
    },
    "installer": {
        "script": [
            "$exe = Get-ChildItem \"$dir\\Tabbit*.exe\" -ErrorAction SilentlyContinue | Select-Object -First 1",
            "if ($exe) { Start-Process -FilePath $exe.FullName -ArgumentList '/VERYSILENT', '/SUPPRESSMSGBOXES', '/NORESTART', '/SP-', \"/DIR=$dir\" -Wait -NoNewWindow }"
        ]
    },
    "post_install": "Remove-Item \"$dir\\Tabbit*.exe\" -Force -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "Tabbit Browser.exe",
            "Tabbit Browser"
        ]
    ],
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://releases.tabbit-ai.com/upgrade/windows/stable_x64_cn/Tabbit%20Browser_stable_x64_cn_$version.exe"
            }
        }
    }
}
