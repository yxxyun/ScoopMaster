{
    "version": "0.29.50",
    "description": "Tabbit AI Browser for Windows",
    "homepage": "https://www.tabbit-ai.com/",
    "license": "Freeware",
    "architecture": {
        "64bit": {
            "url": "https://releases.tabbit-ai.com/upgrade/windows/stable_x64_cn/Tabbit%20Browser_stable_x64_cn_0.29.50.exe",
            "hash": "1be81ff154373a3b45278233b847ab0265a492d08c7c0dfbe6ea334847eee505"
        }
    },
    "installer": {
        "script": [
            "$file = (Get-ChildItem \"$dir\" 'Tabbit*.exe' | Select-Object -First 1).FullName",
            "Expand-7ZipArchive \"$file\" \"$dir\\\" -Removal",
            "if (Test-Path \"$dir\\`$PLUGINSDIR\\app-64.7z\") { Expand-7ZipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal }",
            "if (Test-Path \"$dir\\chrome.7z\") { Expand-7ZipArchive \"$dir\\chrome.7z\" \"$dir\\\" -Removal }",
            "if (Test-Path \"$dir\\Chrome-bin\") { Get-ChildItem \"$dir\\Chrome-bin\" -Force | Move-Item -Destination \"$dir\" -Force }",
            "$retry = 0; while ((Test-Path \"$dir\\Chrome-bin\") -and $retry -lt 12) { try { Remove-Item \"$dir\\Chrome-bin\" -Force -Recurse -ErrorAction Stop } catch { Start-Sleep -Milliseconds 500 }; $retry++ }",
            "Remove-Item \"$dir\\`$PLUGINSDIR\",\"$dir\\`$R0\" -Force -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "post_install": "Remove-Item \"$dir\\Tabbit Browser_stable_x64_cn_*.exe\" -Force -ErrorAction SilentlyContinue",
    "shortcuts": [
        [
            "Tabbit Browser.exe",
            "Tabbit Browser"
        ]
    ],
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://releases.tabbit-ai.com/upgrade/windows/stable_x64_cn/Tabbit%20Browser_stable_x64_cn_$version.exe"
            }
        }
    }
}
