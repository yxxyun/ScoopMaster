{"version":"1.7.0","description":"Context Menu Manager Plus - Windows 右键菜单管理工具，支持新菜单监控、传统菜单管理、Win11 新菜单管理、Shell Extension 探测等功能 | A Windows context menu management tool with new menu monitoring","homepage":"https://github.com/PLFJY/ContextMenuMgr","license":{"identifier":"GPL-3.0-only","url":"https://github.com/PLFJY/ContextMenuMgr/blob/main/LICENSE"},"architecture":{"64bit":{"url":"https://github.com/PLFJY/ContextMenuMgr/releases/download/v1.7.0/ContextMenuMgrPlus-1.7.0-framework-dependent-portable.zip","hash":"675d4c8bb0cb5bd702d84891fb763bf449d1eb1d76a0060eb28f60492006ae9c"}},"uninstaller":{"script":["# 结束进程（终止后等待文件句柄释放，避免文件锁定导致卸载失败）","Stop-Process -Name ContextMenuManagerPlus -Force -ErrorAction SilentlyContinue","Start-Sleep -Milliseconds 1500","# 清理开始菜单快捷方式残留（校验目标路径指向本应用目录，避免误删同名非 Scoop 快捷方式）","$appDir = Split-Path $dir -Parent","$shell = New-Object -ComObject WScript.Shell","@(\"$env:APPDATA\", \"$env:ProgramData\") | ForEach-Object {","    $lnk = \"$_\\Microsoft\\Windows\\Start Menu\\Programs\\Context Menu Manager Plus.lnk\"","    if ((Test-Path $lnk) -and ($shell.CreateShortcut($lnk).TargetPath -like \"$appDir\\*\")) {","        Remove-Item $lnk -Force -ErrorAction SilentlyContinue","    }","}"]},"shortcuts":[["ContextMenuManagerPlus.exe","..\\Context Menu Manager Plus"]],"checkver":{"github":"https://github.com/PLFJY/ContextMenuMgr"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/PLFJY/ContextMenuMgr/releases/download/v$version/ContextMenuMgrPlus-$version-framework-dependent-portable.zip"}}},"notes":["此版本为 framework-dependent 便携版，需要 .NET Runtime 10.0 或更高版本：","  https://dotnet.microsoft.com/download/dotnet/10.0","","数据存储在应用目录外，Scoop 更新/卸载不会删除：","  %ProgramData%\\ContextMenuMgr\\（当前版本，含设置/状态/日志）","  %LocalAppData%\\ContextMenuMgr\\（旧版遗留，新版自动迁移）"],"from":"https://github.com/Arama0517/scoop-bucket"}
