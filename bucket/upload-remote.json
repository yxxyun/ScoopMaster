{
    "version": "2.0.1",
    "description": "Cross-platform file upload tool for Windows, Mac, iOS, and Android",
    "homepage": "https://www.ntwind.com/software/uploadremote.html",
    "license": "Proprietary",
    "url": "https://www.ntwind.com/download/UploadRemote_2.0.1-win-x64.exe",
    "installer": {
        "script": [
            "Start-Process \"$dir\\$fname\" -ArgumentList '/S' -Wait",
            "Remove-Item \"$dir\\$fname\""
        ]
    },
    "uninstaller": {
        "script": [
            "$uninstall = Get-ItemProperty HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Uninstall\\* | Where-Object {$_.DisplayName -like '*Upload Remote*'}",
            "if ($uninstall) {",
            "    Start-Process $uninstall.UninstallString -ArgumentList '/S' -Wait",
            "}"
        ]
    },
    "checkver": {
        "url": "https://www.ntwind.com/download-all.html",
        "regex": "UploadRemote_([\\d.]+)-win-x64\\.exe"
    },
    "autoupdate": {
        "url": "https://www.ntwind.com/download/UploadRemote_$version-win-x64.exe"
    },
