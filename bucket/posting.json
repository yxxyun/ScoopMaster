{
    "version": "2.10.0",
    "description": "Modern TUI HTTP/API client",
    "homepage": "https://posting.sh",
    "license": "Apache-2.0",
    "depends": "python311",
    "architecture": {
        "64bit": {
            "url": "https://github.com/darrenburns/posting/archive/refs/tags/2.10.0.zip",
            "hash": "12aa711692349aa216abf2b7c55d605a6bc396aeeac1a8facb84e4bcbf817e7a"
        }
    },
    "installer": {
        "script": [
            "$ErrorActionPreference = 'Stop'",
            "$venv = Join-Path $dir 'venv'",
            "python -m venv $venv",
            "$pip = Join-Path $venv 'Scripts\\pip.exe'",
            "& $pip install --no-cache-dir --upgrade pip",
            "$source = Join-Path $dir \"posting-$version\"",
            "& $pip install --no-cache-dir $source",
            "if (Test-Path $source) { Remove-Item $source -Recurse -Force }"
        ]
    },
    "bin": [
        [
            "venv\\Scripts\\posting.exe",
            "posting"
        ]
    ],
    "checkver": {
        "github": "https://github.com/darrenburns/posting",
        "regex": "releases/tag/([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/darrenburns/posting/archive/refs/tags/$version.zip"
            }
        }
    }
}
