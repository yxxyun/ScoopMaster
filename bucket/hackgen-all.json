{"homepage":"https://github.com/yuru7/HackGen","license":"OFL-1.1","version":"2.10.0","url":["https://github.com/yuru7/HackGen/releases/download/v2.10.0/HackGen_v2.10.0.zip","https://github.com/yuru7/HackGen/releases/download/v2.10.0/HackGen_NF_v2.10.0.zip"],"hash":["sha256:ED182E2A4B95792D94DEA7932F6B45280B5AE353651BE249D5F6B7867B788DB7","sha256:F8ABD483D5EDFAD88A78ED511978F43C83B43C48E364AA29EBE4A68217474428"],"installer":{"script":["Write-Host \"Installing HackGen + HackGen Nerd fonts...\"","$fontdir = \"$env:LocalAppData\\Microsoft\\Windows\\Fonts\"","# Ensure Fonts folder exists in $dir","if (!(Test-Path \"$dir\\Fonts\")) { New-Item -ItemType Directory -Path \"$dir\\Fonts\" | Out-Null }","Get-ChildItem $dir -Recurse -Filter '*.ttf' | ForEach-Object {","   $fontName = $_.Name","   $regName = $fontName.Replace($_.Extension, ' (TrueType)')","   Copy-Item $_.FullName -Destination $fontdir -Force","   New-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $regName -Value \"$fontdir\\$fontName\" -Force | Out-Null","}"]},"uninstaller":{"script":["Write-Host \"Removing HackGen + HackGen Nerd fonts...\"","$fontdir = \"$env:LocalAppData\\Microsoft\\Windows\\Fonts\"","Get-ChildItem $dir -Recurse -Filter '*.ttf' | ForEach-Object {","   $fontName = $_.Name","   $regName = $fontName.Replace($_.Extension, ' (TrueType)')","   Remove-ItemProperty -Path 'HKCU:\\Software\\Microsoft\\Windows NT\\CurrentVersion\\Fonts' -Name $regName -Force -ErrorAction SilentlyContinue","   Remove-Item \"$fontdir\\$fontName\" -Force -ErrorAction SilentlyContinue","}"]},"from":"https://github.com/watanabe1115/scoop-watanabe1115"}
