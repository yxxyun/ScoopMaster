{
    "version": "2.37.0",
    "description": "Microsoft Graph PowerShell Cmdlets",
    "homepage": "https://github.com/microsoftgraph/msgraph-sdk-powershell",
    "license": "https://aka.ms/devservicesagreement",
    "depends": "microsoft-graph-authentication",
    "pre_install": "Remove-Item \"$dir\\_rels\", \"$dir\\package\", \"$dir\\*Content_Types*.xml\" -Recurse",
    "pre_uninstall": [
        "$InstalledDeps = $manifest.depends | Where-Object { Test-Path \"$(appdir $_)\\current\" }",
        "if (-not $InstalledDeps) { return }",
        "if ($global) { scoop uninstall --global $InstalledDeps }",
        "else { scoop uninstall $InstalledDeps }"
    ],
    "checkver": {
        "regex": "<h2>([\\d\\.]+)</h2>",
        "url": "https://www.powershellgallery.com/packages/microsoft.graph.devices.serviceannouncement"
    },
    "autoupdate": {
        "url": "https://www.powershellgallery.com/api/v2/package/microsoft.graph.devices.serviceannouncement/$version#/microsoft.graph.devices.serviceannouncement.nupkg"
    },
    "hash": "b4f1457d0cef0493c66e5d66d5f1d995a6fc2fb104eab11faee0be4f3945bcd7",
    "url": "https://www.powershellgallery.com/api/v2/package/microsoft.graph.devices.serviceannouncement/2.37.0#/microsoft.graph.devices.serviceannouncement.nupkg",
