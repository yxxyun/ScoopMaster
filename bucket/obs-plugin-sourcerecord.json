{"version":"0.4.8","homepage":"https://github.com/exeldro/obs-source-record","description":"Plugin for OBS Studio to make sources available to record via a filter","license":"GPL-2.0","notes":"If you don't have any obs-studio version installed in your computer, please install one of the following below. Then uninstall this app and install it again.","suggest":{"OBS":["main/obs-studio","main/obs-studio-small","main/obs-studio-pre"]},"url":"https://github.com/exeldro/obs-source-record/releases/download/0.4.8/source-record-0.4.8-windows.zip","hash":"c2e461afc42746bb8f1861f0aaef63c42f5cc436b55da1a21b3b07bc6d014074","pre_install":["    if ($architecture -eq '64bit') {","        Remove-Item \"$dir\\obs-plugins\\32bit\" -Recurse","    }","    elseif ($architecture -eq '32bit') {","        Remove-Item \"$dir\\obs-plugins\\64bit\" -Recurse","    }","'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {","    $obs = \"$(appdir $_ $global)\"","    if (Test-Path $obs) {","       info \"Install for $_\"","       Copy-Item \"$dir\\data\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue","       Copy-Item \"$dir\\obs-plugins\" \"$obs\\current\" -Recurse -ErrorAction SilentlyContinue","   }","}"],"pre_uninstall":["'obs-studio', 'obs-studio-small', 'obs-studio-pre' | ForEach-Object {","    $obs = \"$(appdir $_ $global)\"","    if (Test-Path $obs) {","        info \"Uninstall for $_\"","        Remove-Item \"$obs\\current\\data\\obs-plugins\\source-record\" -Force -Recurse -ErrorAction SilentlyContinue","        Remove-Item \"$obs\\current\\obs-plugins\\32bit\\source-record.*\" -Force -ErrorAction SilentlyContinue","        Remove-Item \"$obs\\current\\obs-plugins\\64bit\\source-record.*\" -Force -ErrorAction SilentlyContinue","    }","}"],"checkver":"github","autoupdate":{"url":"https://github.com/exeldro/obs-source-record/releases/download/$version/source-record-$version-windows.zip"},"from":"https://github.com/anxshi/various-infills"}
