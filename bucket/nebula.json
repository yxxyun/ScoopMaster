    "bin": [
        "nebula.exe",
        "nebula-cert.exe"
    ],
    "pre_install": [
        "if (!(Test-Path \"$dir\\config.yml\")) {",
        "    warn 'Downloading default config.yml ...'",
        "    ",
        "    Invoke-WebRequest -Uri 'https://raw.githubusercontent.com/slackhq/nebula/master/examples/config.yml' -OutFile \"$dir\\config.yml\"",
        "    warn 'config.yml has been downloaded'",
        "}"
    ],
    "persist": "config.yml",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/slackhq/nebula/releases/download/v$version/nebula-windows-amd64.zip"
    }
}
