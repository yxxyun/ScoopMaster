{
    "version": "7.1.2",
    "description": "Rolling Release Stable Kernel for Windows Subsystem for Linux2 (WSL2)",
    "homepage": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling",
    "license": "GPL-2.0",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.1.2/bzImage-x86_64",
            "hash": "21134e985df828592fe20f3e8886320058b6767094bb17aceec457525aa4d52c",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\bzImage-x86_64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        },
        "arm64": {
            "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-7.1.2/Image-arm64",
            "hash": "9df9dd847a8e57b05909470123364edfb27fe675d8ced4b52314f264cffccbee",
            "post_install": [
                ". $bucketsdir\\$bucket\\scripts\\IniFile.ps1",
                "$kernel_path=\"$original_dir\\Image-arm64\" -replace \"\\\\\", \"\\\\\" # double all back-slashess",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $kernel_path, \"$env:USERPROFILE\\.wslconfig\")"
            ],
            "post_uninstall": [
                ". $bucketsdir\\$($install.bucket)\\scripts\\IniFile.ps1",
                "$null = [IniFile]::WritePrivateProfileString(\"wsl2\", \"kernel\", $null, \"$env:USERPROFILE\\.wslconfig\")"
            ]
        }
    },
    "notes": "To get kernel modules support, please install wsl2-rolling-kernel-stable-addon.",
    "suggest": {
        "modules": "frostbite/wsl2-rolling-kernel-stable-addon"
    },
    "checkver": {
        "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/latest",
        "regex": "linux-wsl-stable-([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/bzImage-x86_64"
            },
            "arm64": {
                "url": "https://github.com/Nevuly/WSL2-Linux-Kernel-Rolling/releases/download/linux-wsl-stable-$version/Image-arm64"
            }
        }
    }
}
