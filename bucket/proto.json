{
    "version": "0.55.3",
    "description": "A pluggable multi-language version manager.",
    "homepage": "https://github.com/moonrepo/proto",
    "license": "MIT",
    "url": "https://github.com/moonrepo/proto/releases/download/v0.55.3/proto_cli-x86_64-pc-windows-msvc.zip",
    "bin": "proto.exe",
    "hash": "998078edbfc84d67c1132fcaa4ae23c7c4e6fc826f29223d6aae26bd75ef4f6b",
    "checkver": "github",
    "persist": ".proto",
    "env_add_path": [
        ".proto\\shims",
        ".proto\\bin"
    ],
    "env_set": {
        "PROTO_HOME": "$dir\\.proto"
    },
    "pre_install": [
        "if (!(Test-Path \"$dir\\.proto\\config.toml\")) { New-Item -ItemType File -Path \"$dir\\.proto\\config.toml\" -Force | Out-Null }",
        "if (!(Select-String -Path \"$dir\\.proto\\config.toml\" -Pattern '\\[settings\\]' -Quiet)) { Add-Content -Path \"$dir\\.proto\\config.toml\" -Value \"`[settings]`ntelemetry = false`nauto-install = true\" }"
    ],
    "autoupdate": {
        "url": "https://github.com/moonrepo/proto/releases/download/v$version/proto_cli-x86_64-pc-windows-msvc.zip",
        "hash": {
            "url": "https://github.com/moonrepo/proto/releases/download/v$version/proto_cli-x86_64-pc-windows-msvc.zip.sha256"
        }
    }
}
