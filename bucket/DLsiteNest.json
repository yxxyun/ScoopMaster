{
    "version": "2.0.20",
    "description": "Store (DLsite), viewer (DLsite Play), and community (DL Channel). Access them all without having to jump between services.",
    "homepage": "https://www.dlsite.com/modpub/guide/dlsitenest/en/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.dlsite.com/home/dlnest/regulations#entext"
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\dlsitenest-v$version-win32-x64.exe\" \"$dir\"",
        "Remove-Item \"$dir\\`$PLUGINSDIR\", \"$dir\\dlsitenest-v$version-win32-x64.exe\" -Recurse"
    ],
    "architecture": {
        "64bit": {
            "url": "https://www.dlsite.com/modpub/nest/releases/dlsitenest-v2.0.20-win32-x64.exe",
            "hash": "914e698b985927b0a9e37a5655acf8883e708a7bb94914d4f38cb06f17069969"
        }
    },
    "shortcuts": [
        [
            "DLsiteNest.exe",
            "DLsiteNest"
        ]
    ],
    "persist": [
        "Library",
        "DownloadCache"
    ],
    "checkver": {
        "script": [
            ". bin\\url-utils.ps1",
            "Get-RedirectedUrl -url \"https://dlsite.jp/NEST\""
        ],
        "regex": "dlsitenest-v([\\d.]+)-win32-x64.exe"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://www.dlsite.com/modpub/nest/releases/dlsitenest-v$version-win32-x64.exe"
            }
        }
    }
}
