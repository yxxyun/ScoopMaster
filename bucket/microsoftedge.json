        "    Copy-Item \"$env:LocalAppData\\Microsoft\\Edge\\User Data\\*\" \"$dir\\User Data\" -Recurse",
        "}"
    ],
    "env_set": {
        "CHROME_EXECUTABLE": "$dir\\msedge.exe"
    },
    "persist": "User Data",
    "shortcuts": [
        [
            "msedge.exe",
