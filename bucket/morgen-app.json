            "hash": "sha512:cce412964e8cbf10ccc1ac805513ee6e551143592295f732db3391c0f93c4e28364cfdaed6024e13ecf6c3a5abf482058e11f86d420f0beab9fbce8277650a54",
            "pre_install": [
                "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\"",
                "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Recurse"
