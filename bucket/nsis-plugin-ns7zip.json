{
    "version": "2.3.1",
    "description": "NSIS plugin for 7z, ZIP, NSIS archive extraction",
    "homepage": "https://github.com/systempal/nsis-plugin-ns7zip",
    "license": "MIT",
    "depends": "7zip",
    "url": "https://github.com/systempal/nsis-plugin-ns7zip/releases/download/v2.3.1/nsis-plugin-ns7zip-2.3.1-bundle.zip",
    "hash": "eb66570a3bacd50982eef5bb41819811c5bab156ba3a1049db83b1a1bfda2121",
    "architecture": {
        "64bit": {
            "extract_dir": "amd64-unicode"
        },
        "32bit": {
            "extract_dir": "x86-unicode"
        }
    },
    "post_install": [
        "New-Item -ItemType SymbolicLink -Path \"$(appdir 7zip $global)\\current\\Formats\\nsis7z.dll\" -Target $dir\\nsis7z.dll | Out-Null"
    ],
    "pre_uninstall": [
        "Remove-Item -Path \"$(appdir 7zip $global)\\current\\Formats\\nsis7z.dll\" -Force | Out-Null"
    ],
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/systempal/nsis-plugin-ns7zip/releases/download/v$version/nsis-plugin-ns7zip-$version-bundle.zip"
    }
}
