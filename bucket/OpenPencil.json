{
    "version": "0.4.3",
    "description": "The world's first open-source AI-native vector design tool with concurrent Agent Teams. Design-as-Code alternative to Pencil",
    "homepage": "https://github.com/ZSeven-W/openpencil",
    "license": "MIT",
    "notes": [
        "OpenPencil 是一个开源 AI 原生矢量设计工具",
        "用户数据存储在：%APPDATA%\\OpenPencil\\",
        "  - settings.json : 应用设置",
        "  - preferences.json : 用户偏好",
        "本包会将该目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/ZSeven-W/openpencil/releases/download/v0.4.3/OpenPencil-0.4.3-x64-win.exe#/dl.7z",
            "hash": "79ac681d501dda0931d298f2fd817b8c5bbfb02044ab6795ae9fc9fab058e396"
        }
    },
    "pre_install": [
        "Expand-7zipArchive \"$dir\\`$PLUGINSDIR\\app-64.7z\" \"$dir\" -Removal",
        "Remove-Item \"$dir\\`$*\", \"$dir\\uninstall.exe\" -Force -Recurse -ErrorAction SilentlyContinue"
    ],
    "bin": "OpenPencil.exe",
    "shortcuts": [
        [
            "OpenPencil.exe",
            "OpenPencil"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'OpenPencil'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": "data",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/ZSeven-W/openpencil/releases/download/v$version/OpenPencil-$matchHead-x64-win.exe#/dl.7z"
            }
        }
    }
}
