{
    "version": "2.61",
    "description": "A translations for KeePass 2.x",
    "homepage": "https://keepass.info/translations.html",
    "license": "Unknown",
    "depends": "extras/keepass",
    "url": "https://sourceforge.net/projects/keepass/files/Translations%202.x/2.61/KeePass-2.61-Japanese.zip",
    "hash": "sha1:6595c35fdf1a3b670b550dda94186a4506bfe006",
    "installer": {
        "script": "Copy-Item \"$dir\\Japanese.lngx\" \"$(appdir keepass $global)\\current\\Languages\" -Recurse"
    },
    "uninstaller": {
        "script": "Remove-Item \"$(appdir keepass $global)\\current\\Languages\\Japanese.lngx\" -Recurse"
    },
    "checkver": {
        "url": "https://sourceforge.net/projects/keepass/rss",
        "regex": "/Translations 2\\.x/([\\d.]+)/KeePass-[\\d.]+-Japanese\\.zip"
    },
    "autoupdate": {
