{
  "version": "1.0.5.0",
  "description": "InterSystems Windows Tray",
  "homepage": "https://www.intersystems.com/",
  "license": "Proprietary",
  "architecture": {
    "64bit": {
      "url": "https://iris-windows-tray-bucket.s3.us-east-2.amazonaws.com/v1.0.5.0/IrisNotificationArea_1.0.5.0_x64.msix",
      "hash": "sha256:F2A2E42453986EAC279C521BCA408427B97A8A56FFD2744349D498853AB5A394"
    }
  },
  "pre_install": [
    "Stop-Process -Name 'IrisNotificationArea' -Force -ErrorAction SilentlyContinue"
  ],
  "installer": {
    "script": [
      "Write-Host 'Registering MSIX Package with Windows...' -ForegroundColor Cyan",
      "Add-AppxPackage -Path (Get-ChildItem \"$dir\\*.msix\").FullName"
    ]
  },
  "post_install": [
    "Write-Host 'Launching IRIS Windows Tray...' -ForegroundColor Cyan",
    "Start-Process \"shell:AppsFolder\\com.intersystems.tray_736885xzhtrt2!App\""
  ],
  "pre_uninstall": [
    "Stop-Process -Name 'IrisNotificationArea' -Force -ErrorAction SilentlyContinue"
  ],
  "uninstaller": {
    "script": [
      "Write-Host 'Removing MSIX Package...' -ForegroundColor Cyan",
      "$app = Get-AppxPackage -Name '*intersystems.tray*'",
      "if ($app) { Remove-AppxPackage -Package $app.PackageFullName }"
    ]
  }
}
