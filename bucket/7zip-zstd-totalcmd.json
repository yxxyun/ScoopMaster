{
    "version": "26.02-v1.5.7-R2",
    "description": "Replace Total Commander's tc7z.dll, supporting 7-Zip's Zstandard (Zstd, Brotli, Lz4, Lz5, Lizard) formats.",
    "homepage": "https://github.com/mcmilk/7-Zip-zstd",
    "license": "LGPL-2.1-or-later",
    "depends": "extras/totalcommander",
    "pre_install": [
        "$tc_procs = Get-Process -Name \"totalcmd\", \"totalcmd64\" -ErrorAction SilentlyContinue",
        "if ($tc_procs) {",
        "    Write-Host \"[Error] Total Commander is currently running!\" -ForegroundColor Red",
        "    Write-Host \"Installation aborted to protect directory structure. Please close Total Commander and try again.\" -ForegroundColor Yellow",
        "    exit 1",
        "}"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/mcmilk/7-Zip-zstd/releases/download/v26.02-v1.5.7-R2/TotalCmd.7z",
            "hash": "a44a9fd63972beee9760e3036ef52ee1ead2ac09b1f5fb170b35a52ec2a5b9dc",
            "installer": {
                "script": [
                    "$TCDir = $(appdir totalcommander $global)",
                    "if (Test-Path \"$TCDir\\current\") {",
                    "    Start-Sleep -Milliseconds 500",
                    "    try {",
                    "        Copy-Item \"$dir\\tc7z64.dll\" \"$TCDir\\current\" -Force -ErrorAction Stop",
                    "    } catch {",
                    "        Write-Warning \"First copy attempt failed: $_. Retrying in 2 seconds...\"",
                    "        Start-Sleep -Seconds 2",
                    "        Copy-Item \"$dir\\tc7z64.dll\" \"$TCDir\\current\" -Force",
                    "    }",
                    "} else {",
                    "    Write-Warning \"Total Commander (scoop) not found. Skipped injection.\"",
                    "}"
                ]
            }
        },
        "32bit": {
            "url": "https://github.com/mcmilk/7-Zip-zstd/releases/download/v26.02-v1.5.7-R2/TotalCmd.7z",
            "hash": "a44a9fd63972beee9760e3036ef52ee1ead2ac09b1f5fb170b35a52ec2a5b9dc",
            "installer": {
                "script": [
                    "$TCDir = $(appdir totalcommander $global)",
                    "if (Test-Path \"$TCDir\\current\") {",
                    "    Start-Sleep -Milliseconds 500",
                    "    try {",
                    "        Copy-Item \"$dir\\tc7z.dll\" \"$TCDir\\current\" -Force -ErrorAction Stop",
                    "    } catch {",
                    "        Write-Warning \"First copy attempt failed: $_. Retrying in 2 seconds...\"",
                    "        Start-Sleep -Seconds 2",
                    "        Copy-Item \"$dir\\tc7z.dll\" \"$TCDir\\current\" -Force",
                    "    }",
                    "} else {",
                    "    Write-Warning \"Total Commander (scoop) not found. Skipped injection.\"",
                    "}"
                ]
            }
        },
        "arm64": {
            "url": "https://github.com/mcmilk/7-Zip-zstd/releases/download/v26.02-v1.5.7-R2/TotalCmd.7z",
            "hash": "a44a9fd63972beee9760e3036ef52ee1ead2ac09b1f5fb170b35a52ec2a5b9dc",
            "installer": {
                "script": [
                    "$TCDir = $(appdir totalcommander $global)",
                    "if (Test-Path \"$TCDir\\current\") {",
                    "    Start-Sleep -Milliseconds 500",
                    "    try {",
                    "        Copy-Item \"$dir\\tc7zarm64.dll\" \"$TCDir\\current\" -Force -ErrorAction Stop",
                    "    } catch {",
                    "        Write-Warning \"First copy attempt failed: $_. Retrying in 2 seconds...\"",
                    "        Start-Sleep -Seconds 2",
                    "        Copy-Item \"$dir\\tc7zarm64.dll\" \"$TCDir\\current\" -Force",
                    "    }",
                    "} else {",
                    "    Write-Warning \"Total Commander (scoop) not found. Skipped injection.\"",
                    "}"
                ]
            }
        }
    },
    "checkver": {
        "url": "https://api.github.com/repositories/61958135/releases",
        "jsonpath": "$[0].tag_name",
        "regex": "^v(?<version>.*)$"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/mcmilk/7-Zip-zstd/releases/download/v$version/TotalCmd.7z"
            },
            "32bit": {
                "url": "https://github.com/mcmilk/7-Zip-zstd/releases/download/v$version/TotalCmd.7z"
            },
            "arm64": {
                "url": "https://github.com/mcmilk/7-Zip-zstd/releases/download/v$version/TotalCmd.7z"
            }
        }
    }
