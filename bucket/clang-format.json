    "installer": {
        "script": [
            "Push-Location \"$dir\"",
            "python -m venv cf",
            ".\\cf\\Scripts\\activate",
            "try {",
            "    python -m pip install \"$fname\"",
            "}",
            "finally {",
            "    Remove-Item \"$fname\"",
            "    deactivate",
            "    Pop-Location",
            "}"
        ]
    },
