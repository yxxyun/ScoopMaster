{
    "version": "0.1.4",
    "description": "Search clipboard text across dictionary groups using GoldenDict.",
    "homepage": "https://github.com/scillidan/AHK-GoldenDictSearchInGroup",
    "license": "MIT",
    "notes": [
        "You can start \"GoldenDict Search In Group\" with Windows by running:",
        "reg import \"$dir\\add-startup.reg\"",
        "Or enable it from the tray menu.",
        "PS: If app crashes, please check the configuration file (.ini)."
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/scillidan/AHK-GoldenDictSearchInGroup/releases/download/v0.1.4/GoldenDictSearchInGroup.zip",
            "hash": "828fe452dd5b14783b74bac09c58d3edbb4ed531b5df74642c9be0909f0e0597"
        }
    },
    "post_install": [
        "$dirpath = $dir.Replace('\\', '\\\\')",
        "'add-startup.reg', 'remove-startup.reg' | ForEach-Object {",
        "    if (Test-Path \"$bucketsdir\\pile\\scripts\\$app\\$_\") {",
        "        $content = Get-Content \"$bucketsdir\\pile\\scripts\\$app\\$_\"",
        "        $content = $content.Replace('$dir', $dirpath)",
        "        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }",
        "        $content | Set-Content -Path \"$dir\\$_\"",
        "    }",
        "}"
    ],
    "post_uninstall": "if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }",
    "shortcuts": [
        [
            "GoldenDictSearchInGroup.exe",
            "GoldenDict Search In Group"
        ]
    ],
    "persist": "GoldenDictSearchInGroup.ini",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/scillidan/AHK-GoldenDictSearchInGroup/releases/download/v$version/GoldenDictSearchInGroup.zip"
            }
        }
    }
}
