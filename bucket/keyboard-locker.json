{"version":"1.0","description":"AutoHotkey script to temporarily lock your keyboard.","homepage":"https://github.com/sophice/ahk-keyboard-locker","license":"GPL-3.0-only","notes":["Configuration file (settings.ini) and icons (unlocked.ico, locked.ico) is auto-generated on first run.","You can customize the shortcut, for example:","shortcut=^!+Insert","shortcut-hint=Ctrl+Alt+Shift+Insert","You can start Keyboard Locker with Windows by running:","reg import \"$dir\\add-startup.reg\""],"architecture":{"64bit":{"url":"https://github.com/sophice/ahk-keyboard-locker/releases/download/v1.0/keyboard-locker.exe","hash":"038d09b82e63a52608a342a697c50254c71ab8dbeef3bdb5a4e1e15db5673d94"}},"post_install":["$dirpath = $dir.Replace('\\', '\\\\')","'add-startup.reg', 'remove-startup.reg' | ForEach-Object {","    if (Test-Path \"$bucketsdir\\$bucket\\scripts\\$app\\$_\") {","        $content = Get-Content \"$bucketsdir\\$bucket\\scripts\\$app\\$_\"","        $content = $content.Replace('$dir', $dirpath)","        if ($global) { $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE') }","        $content | Set-Content -Path \"$dir\\$_\"","    }","}"],"post_uninstall":"if (Test-Path \"$dir\\remove-startup.reg\") { reg import \"$dir\\remove-startup.reg\" }","shortcuts":[["keyboard-locker.exe","Keyboard Locker"]],"persist":"settings.ini","checkver":"github","autoupdate":{"architecture":{"64bit":{"url":"https://github.com/sophice/ahk-keyboard-locker/releases/download/v$version/keyboard-locker.exe"}}},"from":"https://github.com/scillidan/scoop-pile"}
