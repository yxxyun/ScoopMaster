    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "Write-Host 'Installing to ' -NoNewline; Write-Host $env:GTAV_PATH -NoNewline; Write-Host '...'",
        "Move-Item \"$dir\\menyooStuff\" \"$env:GTAV_PATH\" -Force",
        "Move-Item \"$dir\\Menyoo.asi\" \"$env:GTAV_PATH\" -Force",
        "Remove-Item \"$dir\\*\""
    ],
    "checkver": {
        "github": "https://github.com/itsjustcurtis/MenyooSP",
        "regex": "v(\\d+\\.\\d+\\.\\d+)"
    },
    "autoupdate": {
        "url": "https://github.com/itsjustcurtis/MenyooSP/releases/download/v$version/MenyooSP.zip"
    }
}
