{
    "version": "0.2020.05.24",
    "description": "A Scoop tab completion module for PowerShell",
    "homepage": "https://github.com/woyxiang/scoop-completion   ",
    "url": "https://github.com/woyxiang/scoop-completion/raw/refs/heads/master/src/scoop-completion.ps1",
    "hash": "61F9ECFD50582A3E835130AED823DBE266A4B50643C5ACE866B7F6AFAC717643",
    "license": "MIT",
    "post_install":
        [
            "ensure ~/.config/pwsh/completions",
            "cp $dir\\scoop-completion.ps1 ~/.config/pwsh/completions/scoop-completion.ps1"
        ]
    ,
    "uninstaller": {
        "script": "Remove-Item ~\\.config\\pwsh\\completions\\scoop-completion.ps1 -ErrorAction SilentlyContinue"
    },
    "checkver": {
        "url":"https://github.com/woyxiang/scoop-completion/commits/master/scoop-completion.ps1.atom",
        "regex": "(?s)>(\\d+)-(\\d+)-(\\d+)T.*?/(?<sha>[0-9a-f]{40})",
        "replace": "0.${1}.${2}.${3}"
    },
    "autoupdate": {
        "url": "https://raw.githubusercontent.com/woyxiang/scoop-completion/$matchSha/scoop-completion.ps1"
    }
}
