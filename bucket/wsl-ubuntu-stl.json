{
    "version": "24.04",
    "description": "Ubuntu 24.04 LTS (Noble Numbat) for WSL",
    "homepage": "https://learn.microsoft.com/zh-cn/windows/wsl/install-on-server",
    "license": "Freeware",
    "depends": "ChuckieChen945_Tangyuan/wsl-customized",
    "architecture": {
        "64bit": {
            "url": "https://wslstorestorage.blob.core.windows.net/wslblob/Ubuntu2404-240425.AppxBundle#/ubuntu.7z",
            "hash": "510639de5934e003ffb5b5c4f91cfae6823fb75388c2464f7bc909baf4dc5dd6"
        }
    },
    "pre_install": [
        "ensure \"$persist_dir\\data\"",
        "Expand-7zipArchive \"$dir\\Ubuntu_2404.0.5.0_x64.appx\" -DestinationPath \"$dir\\x64\""
    ],
    "installer": {
        "script": [
            "info \"Importing WSL distribution...\"",
            "wsl --import Ubuntu-24.04 \"$persist_dir\\data\" \"$dir\\x64\\install.tar.gz\""
        ]
    },
    "post_install": [
        "Get-ChildItem -Path $dir -Recurse | Remove-Item -Force -ErrorAction SilentlyContinue -Recurse"
    ],
    "uninstaller": {
        "script": ["wsl --unregister Ubuntu-24.04"]
    },
    "persist": "data",
    "notes": "Ubuntu 24.04 has been installed and registered as 'Ubuntu-24.04'."
}
