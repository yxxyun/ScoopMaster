{
    "version": "0.9.16",
    "description": "A tiling window manager for Windows 10/11, built with Janet and ❤️.",
    "homepage": "https://agent-kilo.github.io/jwno/",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": [
                "https://github.com/agent-kilo/jwno/archive/refs/tags/v0.9.16.zip",
                "https://github.com/agent-kilo/jwno/releases/download/v0.9.16/jwno.exe"
            ],
            "hash": [
                "7ca3b5accff24e1fd9609decad13b09f198b25e6b7f4fcb7019beeb2fd6fa157",
                "b4ba82b9a78413b61beae20d61fa63a43b53cb10245aaccb5dcdf4707466857e"
            ],
            "extract_dir": "jwno-0.9.16"
        }
    },
    "pre_install": [
        "Remove-Item \"$dir\\*\" -Exclude *.exe,*.md,doc,example -Recurse",
        "if (-not (Test-Path \"$persist_dir\\jwno-config.janet\")) {",
        "    Copy-Item \"$dir\\example\\tutorial.janet\" \"$dir\\jwno-config.janet\" -ErrorAction SilentlyContinue | Out-Null",
        "}"
    ],
    "bin": "jwno.exe",
    "shortcuts": [
        [
            "jwno.exe",
            "Jwno"
        ]
    ],
    "persist": "jwno-config.janet",
    "checkver": "github",
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": [
                    "https://github.com/agent-kilo/jwno/archive/refs/tags/v$version.zip",
                    "https://github.com/agent-kilo/jwno/releases/download/v$version/jwno.exe"
                ],
                "extract_dir": "jwno-$version"
            }
        }
    }
}
