{
    "version": "0.264",
    "description": "Lightweight control tool for Asus laptops. (Manual fan control)",
    "homepage": "https://github.com/seerge/g-helper-experimental-release",
    "license": "unknown",
    "notes": "Asus System Control Interface v3+ and .NET Desktop Runtime 7 are required.",
    "suggest": {
        ".NET Desktop Runtime 8.0": "versions/windowsdesktop-runtime-8.0"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/seerge/g-helper-experimental-release/releases/download/v0.264/GHelper.zip",
            "hash": "5217c91e81af2eebc3d2f8e57ff5e7780394f57a2280d42977d163ad73063670"
        }
    },
    "pre_install": [
        "if ((installed 'g-helper') -or (installed 'g-helper-experimental-pawnio')) { throw 'Only 1 g-helper can be install.' }",
        "if (!(is_admin)) { throw 'Admin privileges are required.' }"
    ],
    "post_install": [
        "if (Test-Path $env:APPDATA\\GHelper) {",
        "    Copy-Item -Path $env:APPDATA\\GHelper\\* -Destination \"$persist_dir\\data\" -Force -Recurse",
        "    Remove-Item $env:APPDATA\\GHelper -Force -Recurse",
        "}",
        "if (Test-Path $env:ProgramData\\GHelper) {",
        "    Copy-Item -Path $env:ProgramData\\GHelper\\* -Destination \"$persist_dir\\backup\" -Force -Recurse",
        "    Remove-Item $env:ProgramData\\GHelper -Force -Recurse",
        "}",
        "New-Item -ItemType Junction -Path $env:APPDATA\\GHelper -Target $persist_dir\\data | Out-Null",
        "New-Item -ItemType Junction -Path $env:ProgramData\\GHelper -Target $persist_dir\\backup | Out-Null"
    ],
    "pre_uninstall": "if (!(is_admin)) { throw 'Admin privileges are required.' }",
    "uninstaller": {
        "script": [
            "Remove-Item $env:APPDATA\\GHelper -Force -Recurse",
            "Remove-Item $env:ProgramData\\GHelper -Force -Recurse"
        ]
    },
    "bin": "GHelper.exe",
    "shortcuts": [["GHelper.exe", "G-Helper"]],
    "persist": ["data", "backup"],
    "checkver": {
        "github": "https://github.com/seerge/g-helper-experimental-release/"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/seerge/g-helper-experimental-release/releases/download/v$version/GHelper.zip"
            }
        }
    }
}
