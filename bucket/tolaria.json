    "hash": "9a6b86716a743450654b83d55d02123a8e8e7e8cdb23854d217a053232e25c73",
    "installer": {
        "script": [
            "Expand-7zipArchive -Path \"$dir\\$fname\" -Removal",
            "Remove-Item \"$dir\\uninstall.exe\" -Force -ErrorAction SilentlyContinue",
            "Remove-Item \"$dir\\`$PLUGINSDIR\" -Force -Recurse -ErrorAction SilentlyContinue"
        ]
    },
    "shortcuts": [
        [
            "tolaria.exe",
            "Tolaria"
        ]
    ],
    "checkver": {
        "github": "https://github.com/refactoringhq/tolaria",
        "regex": "Tolaria v(\\d{4})-(0?)(\\d{1,2})-(0?)(\\d{1,2})",
        "replace": "${1}.${3}.${5}"
    },
    "autoupdate": {
        "url": "https://github.com/refactoringhq/tolaria/releases/download/v$match1-$match2$match3-$match4$match5/Tolaria_$version_x64-setup.exe"
    }
}
