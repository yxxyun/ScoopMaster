{
    "version": "2.0.11",
    "description": "A paint.net effect plugin that enables the use of 3rd party 8bf filters",
    "homepage": "https://github.com/0xC0000054/PSFilterPdn",
    "license": "MIT",
    "depends": "extras/paint.net",
    "url": "https://github.com/0xC0000054/PSFilterPdn/releases/download/v2.0.11/PSFilterPdn.zip",
    "hash": "f3b2046bdf38b4b32147567b1db5748bdb594b91ca9877e9533ef97de10d6861",
    "post_install": [
        "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\"",
        "Move-Item -Path \"$dir\\PSFilterPdn\" -Destination \"$paintdotnet\" -Force"
    ],
    "uninstaller": {
        "script": [
            "$paintdotnet = \"$(appdir paint.net)\\current\\Effects\"",
            "Remove-Item \"$paintdotnet\\PSFilterPdn\" -Force -Recurse"
        ]
    },
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/0xC0000054/PSFilterPdn/releases/download/v$version/PSFilterPdn.zip"
    }
}
