{
    "version": "1.3.1",
    "description": "JavaFX-based animator, constraint solver and model checker built on ProB (B, Event-B, CSP-M, TLA+, Z)",
    "homepage": "https://prob.hhu.de/",
    "license": "EPL-2.0",
    "depends": "java/temurin21-jdk",
    "url": "https://stups.hhu-hosting.de/downloads/prob2/1.3.1/prob2-ui-1.3.1-multi.jar#/prob2-ui.jar",
    "hash": "c2a82dbac83794db66d8afbc3fbb186fc6cf2b818c6cec17ed6242aecf6684fa",
    "pre_install": [
        "'@\"%~dp0..\\..\\temurin21-jdk\\current\\bin\\java.exe\" --enable-native-access=ALL-UNNAMED -jar \"%~dp0prob2-ui.jar\" %*' | Out-File -Encoding ascii \"$dir\\prob2-ui.cmd\"",
        "Add-Type -AssemblyName System.IO.Compression.FileSystem,System.Drawing; $z=[IO.Compression.ZipFile]::OpenRead(\"$dir\\prob2-ui.jar\"); $e=$z.GetEntry('de/prob2/ui/ProB_Icon.png'); $ms=New-Object IO.MemoryStream; $s=$e.Open(); $s.CopyTo($ms); $s.Dispose(); $z.Dispose(); $png=$ms.ToArray(); $img=[Drawing.Image]::FromStream((New-Object IO.MemoryStream(,$png))); $wd=$img.Width; $ht=$img.Height; $img.Dispose(); $fs=[IO.File]::Create(\"$dir\\prob2-ui.ico\"); $bw=New-Object IO.BinaryWriter($fs); $bw.Write([uint16]0); $bw.Write([uint16]1); $bw.Write([uint16]1); $bw.Write([byte]$(if($wd -ge 256){0}else{$wd})); $bw.Write([byte]$(if($ht -ge 256){0}else{$ht})); $bw.Write([byte]0); $bw.Write([byte]0); $bw.Write([uint16]1); $bw.Write([uint16]32); $bw.Write([uint32]$png.Length); $bw.Write([uint32]22); $bw.Write($png); $bw.Dispose()"
    ],
    "bin": "prob2-ui.cmd",
    "shortcuts": [
        [
            "..\\..\\temurin21-jdk\\current\\bin\\javaw.exe",
            "ProB2-UI",
            "--enable-native-access=ALL-UNNAMED -jar \"..\\..\\..\\prob2-ui\\current\\prob2-ui.jar\"",
            "prob2-ui.ico"
        ]
    ],
    "checkver": {
        "url": "https://stups.hhu-hosting.de/downloads/prob2/?C=M;O=D",
        "regex": "href=\"?(\\d+(?:\\.\\d+)+)/"
    },
    "autoupdate": {
        "url": "https://stups.hhu-hosting.de/downloads/prob2/$version/prob2-ui-$version-multi.jar#/prob2-ui.jar"
    },
    "notes": "Start Menu shortcut launches the GUI via javaw (no console window); the 'prob2-ui' shim runs the CLI. On first use ProB2-UI downloads the matching ProB kernel into ~/.prob. The multi-platform jar bundles JavaFX, so the plain Temurin JRE is enough."
}
