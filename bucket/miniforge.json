{
    "version": "26.1.1-2",
    "homepage": "https://github.com/conda-forge/miniforge",
    "description": "A minimal conda distribution specific to conda-forge.",
    "license": "BSD-3-Clause",
    "architecture": {
        "64bit": {
            "url": "https://github.com/conda-forge/miniforge/releases/download/26.1.1-2/Miniforge3-26.1.1-2-Windows-x86_64.exe",
            "hash": "eac38a51bcd68eb7a211c7a5673b6aee9439db657e54749a02fbf919bd9c6708"
        }
    },
    "installer": {
        "args": [
            "/S",
            "/InstallationType=JustMe",
            "/RegisterPython=0",
            "/AddToPath=0",
            "/NoRegistry=1",
            "/D=$dir"
        ]
    },
    "uninstaller": {
        "file": "Uninstall-Miniforge3.exe",
        "args": "/S"
    },
    "bin": "scripts\\conda.exe",
    "post_install": "conda config --system --set auto_activate_base false",
    "checkver": {
        "github": "https://github.com/conda-forge/miniforge",
        "regex": "tag/([\\d.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/conda-forge/miniforge/releases/download/$version/Miniforge3-$version-Windows-x86_64.exe",
                "hash": {
                    "url": "$url.sha256"
                }
            }
        }
    }
}
