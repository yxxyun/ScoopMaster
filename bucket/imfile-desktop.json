{
    "version": "1.2.2",
    "description": "A full-featured download manager",
    "homepage": "https://github.com/imfile-io/imfile-desktop",
    "license": "MIT",
    "notes": [
        "imFile 是一个全功能下载管理器桌面应用",
        "源码将配置、任务会话、DHT 数据和 goed2kd 配置写入 Electron 的 userData 目录",
        "结合上游 productName=imFile，可确认用户数据目录为 %APPDATA%\\imFile\\",
        "本包会将该目录持久化到 Scoop 的 persist，并在原路径创建 Junction 指向 persist"
    ],
    "architecture": {
        "64bit": {
            "url": "https://github.com/imfile-io/imfile-desktop/releases/download/imFile-1.2.2/imFile-Setup-1.2.2.exe#/dl.7z",
            "hash": "66716169283d5df61ceec5905dda5f3d5f092e85408185094f5744edc0ba6818"
        }
    },
    "pre_install": "Remove-Item \"$dir\\`$*\", \"$dir\\uninstall.exe\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": "imFile.exe",
    "shortcuts": [
        [
            "imFile.exe",
            "imFile"
        ]
    ],
    "post_install": [
        "$source = Join-Path $env:APPDATA 'imFile'",
        "$target = Join-Path $persist_dir 'data'",
        "ensure $target",
        "",
        "if (Test-Path $source) {",
        "    $item = Get-Item -LiteralPath $source -Force",
        "    if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "        Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "        return",
        "    }",
        "    if (-not $item.PSIsContainer) {",
        "        throw \"配置路径已存在且不是目录：$source\"",
        "    }",
        "",
        "    & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "    if ($LASTEXITCODE -gt 7) {",
        "        Write-Host \"迁移失败，保留原目录：$source\"",
        "        return",
        "    }",
        "",
        "    $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "    try {",
        "        Move-Item -LiteralPath $source -Destination $backup -Force",
        "        Write-Host \"已备份原配置目录：$backup\"",
        "    } catch {",
        "        Write-Host \"无法重命名原目录：$source\"",
        "        return",
        "    }",
        "}",
        "",
        "New-Item -Path $source -ItemType Junction -Value $target | Out-Null"
    ],
    "persist": "data",
    "checkver": {
        "url": "https://api.github.com/repos/imfile-io/imfile-desktop/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "imFile-(?<version>[\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/imfile-io/imfile-desktop/releases/download/imFile-$version/imFile-Setup-$version.exe#/dl.7z"
            }
        },
        "hash": {
            "mode": "download"
        }
    }
}
