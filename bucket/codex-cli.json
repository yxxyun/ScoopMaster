{
    "version": "0.142.3",
    "description": "OpenAI Codex CLI - AI coding assistant for your terminal",
    "homepage": "https://github.com/openai/codex",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.142.3/codex-package-x86_64-pc-windows-msvc.tar.gz",
            "hash": "sha256:9c293befc715eae55a4f06577b55339a317c5f01270425de1941484fe96611c4"
        },
        "arm64": {
            "url": "https://github.com/openai/codex/releases/download/rust-v0.142.3/codex-package-aarch64-pc-windows-msvc.tar.gz",
            "hash": "sha256:a98edbd893ffbec81b5ba63398d32c30bc8b520fb0f66cd8931ca7ba2f7ef96c"
        }
    },
    "bin": "bin/codex.exe",
    "pre_install": [
        "# 将 ~/.codex 软链接到 persist/data，升级时数据不丢失",
        "$codex_dir = Join-Path $env:USERPROFILE \".codex\"",
        "$persist_data = Join-Path $persist_dir \"data\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\link.ps1\" $codex_dir $persist_data"
    ],
    "post_uninstall": [
        "$codex_dir = Join-Path $env:USERPROFILE \".codex\"",
        "& \"$bucketsdir\\\\code\\\\scripts\\\\unlink.ps1\" $codex_dir"
    ],
    "persist": ["data"],
    "checkver": {
        "url": "https://github.com/openai/codex/releases",
        "regex": "/releases/tag/rust-v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-package-x86_64-pc-windows-msvc.tar.gz"
            },
            "arm64": {
                "url": "https://github.com/openai/codex/releases/download/rust-v$version/codex-package-aarch64-pc-windows-msvc.tar.gz"
            }
        }
    }
}
