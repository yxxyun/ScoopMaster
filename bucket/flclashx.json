{
    "version": "0.4.1",
    "description": "A Flutter-based cross-platform Clash GUI client",
    "homepage": "https://github.com/pluralplay/FlClashX",
    "license": "GPL-3.0-or-later",
    "architecture": {
        "64bit": {
            "url": "https://github.com/pluralplay/FlClashX/releases/download/v0.4.1/FlClashX-windows-amd64.zip",
            "hash": "064ffa8bc52bae45ebeb711229b2be09232aa293da519097a4e22b38d1ea318c"
        },
        "arm64": {
            "url": "https://github.com/pluralplay/FlClashX/releases/download/v0.4.1/FlClashX-windows-arm64.zip",
            "hash": "da6d11e56b3c35c94f6f20baf23e5b31b1e7737f29dc1737df25c9ce4b274da9"
        }
    },
    "shortcuts": [
        [
            "FlClashX.exe",
            "FlClashX"
        ]
    ],
    "installer": {
        "script": [
            ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
            "New-PersistDirectory \"$env:APPDATA\\com.follow\\clashx\" \"$persist_dir\\AppData\" -Migrate"
        ]
    },
    "pre_uninstall": [
        "while (Get-Service -Name 'FlClashHelperService' -ErrorAction SilentlyContinue) {",
        "    Invoke-ExternalCommand 'sc.exe' -ArgumentList @('stop', 'FlClashHelperService') -RunAs -Quiet",
        "    Invoke-ExternalCommand 'sc.exe' -ArgumentList @('delete', 'FlClashHelperService') -RunAs -Quiet",
        "}",
        "$bucket = $install.bucket",
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Stop-App",
        "Remove-Junction \"$env:APPDATA\\com.follow\\clashx\"",
        "Remove-EmptyDirectory \"$env:APPDATA\\com.follow\""
    ],
    "checkver": {
        "github": "https://github.com/pluralplay/FlClashX"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/pluralplay/FlClashX/releases/download/v$version/FlClashX-windows-amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/pluralplay/FlClashX/releases/download/v$version/FlClashX-windows-arm64.zip"
            }
        }
    }
}
