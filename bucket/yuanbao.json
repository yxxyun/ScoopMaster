    "installer": {
        "script": [
            "7z e \"$dir\\$fname\" -o\"$dir\\_nsis_temp\" -tnsis -y | Out-Null",
            "Copy-Item \"$dir\\_nsis_temp\\yuanbao.exe\" \"$dir\\yuanbao.exe\" -Force",
            "$inner7z = Get-ChildItem \"$dir\\_nsis_temp\" -Filter 'install*.7z' | Select-Object -First 1",
            "if ($inner7z) { 7z x $inner7z.FullName -o\"$dir\" -y | Out-Null }",
            "$verDir = Get-ChildItem \"$dir\" -Directory | Where-Object { $_.Name -match '^\\d+\\.\\d+\\.\\d+\\.\\d+$' } | Select-Object -First 1",
            "if ($verDir -and (Test-Path \"$($verDir.FullName)\\content.pkg.nsisbin\")) {",
            "    Push-Location \"$($verDir.FullName)\\content.pkg.nsisbin\"",
            "    7z a -tzip \"$($verDir.FullName)\\content.pkg\" \"*\" -r | Out-Null",
            "    Pop-Location",
            "    Remove-Item \"$($verDir.FullName)\\content.pkg.nsisbin\" -Recurse -Force",
            "}",
            "Remove-Item \"$dir\\_nsis_temp\" -Recurse -Force",
            "Remove-Item \"$dir\\$fname\" -Force"
        ]
    },
    "bin": "yuanbao.exe",
    "shortcuts": [
        [
            "yuanbao.exe",
            "元宝"
        ]
    ],
