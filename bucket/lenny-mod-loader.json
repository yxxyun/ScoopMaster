{
    "version": "0.4-b8825",
    "description": "A unique way of installing and maintaining mods in Grand Theft Auto V",
    "homepage": "https://www.lcpdfr.com/lml/index/",
    "license": "Freeware",
    "url": "https://github.com/fruini/scoop-bin/raw/refs/heads/main/lenny-mod-loader/lml_beta_0413.zip",
    "hash": "0b99c21d032cfc2369fcf977d6cc171a31102f3787ccf2d23b35fc62e9ed779b",
    "pre_install": [
        "if (!(Test-Path \"$env:GTAV_PATH\\PlayGTAV.exe\")) {error 'Please create the environment variable GTAV_PATH pointing to your GTAV directory before installing this package.'; break}",
        "",
        "Remove-Item \"$dir\\license.txt\"",
        "Remove-Item \"$dir\\readme.txt\"",
        "Move-Item \"$dir\\ModManager\\*\" \"$dir\"",
        "Remove-Item -Path \"$dir\\ModManager\"",
        "",
        "Remove-Item \"$dir\\ModLoader\\_PLACE ALL THIS IN THE GAME ROOT\"",
        "Remove-Item \"$dir\\ModLoader\\lml\\_MODS GO HERE\"",
        "Move-Item \"$dir\\ModLoader\\*\" \"$env:GTAV_PATH\" -Force -ErrorAction SilentlyContinue",
        "Remove-Item -Path \"$dir\\ModLoader\" -Recurse"
    ],
    "shortcuts": [
        [
            "ModManager.UI.exe",
            "Lenny's Mod Loader"
        ]
    ]
}
