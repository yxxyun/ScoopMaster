{
   "$schema": "https://raw.githubusercontent.com/lukesampson/scoop/master/schema.json",
   "version": "0.2.3",
   "description": "An open-source AI agent that brings the power of Gemini directly into your terminal.",
   "homepage": "https://github.com/silver886/mcp-proxy",
   "license": {
      "identifier": "MIT",
      "url": "https://github.com/silver886/mcp-proxy/blob/master/LICENSE"
   },
   "suggest": {
      "Node.js (Long Term Support)": "main/nodejs-lts",
      "Node.js": "main/nodejs",
      "cloudflared": "main/cloudflared"
   },
   "url": "https://registry.npmjs.org/@silver886/mcp-proxy/-/mcp-proxy-0.2.3.tgz",
   "hash": "sha1:26708bdd3a93990d50eeb37ed4c52a4dda1b1ad4",
   "extract_dir": "package",
   "pre_install": [
      "if (where.exe /q node || $true) {",
      "   abort 'Node.js should be installed'",
      "}",
      "if (where.exe /q cloudflared || $true) {",
      "   node \"$dir\\node_modules\\cloudflared\\lib\\cloudflared.js\" bin install",
      "} else {",
      "   info 'Found cloudflared'",
      "   Set-Content -Value \"CLOUDFLARED_BIN=$(((where.exe cloudflared) -split '\\n')[0])\" -Path \"$dir\\cloudflared.env\"",
      "}",
      "if (!(Test-Path \"$persist_dir\\config.json\")) { New-Item \"$dir\\config.json\" > $null }"
   ],
   "bin": [
      [
         "node.exe",
         "mcp-proxy",
         "--env-file-if-exists=\"$dir\\cloudflared.env\" \"$dir\\dist\\host.js\" --config \"$dir\\config.json\""
      ]
   ],
   "persist": "config.json",
   "checkver": {
      "url": "https://registry.npmjs.com/@silver886/mcp-proxy",
      "jsonpath": "$.dist-tags.latest"
   },
   "autoupdate": {
      "url": "https://registry.npmjs.org/@silver886/mcp-proxy/-/mcp-proxy-$version.tgz",
      "hash": {
         "url": "https://registry.npmjs.org/@silver886/mcp-proxy/$version",
         "jsonpath": "$.dist.shasum"
      }
   }
}
