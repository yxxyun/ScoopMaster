{
    "version": "20260408",
    "description": "GitHub CLI extension to display GitHub notifications.",
    "homepage": "https://github.com/meiji163/gh-notify",
    "license": "Unlicense",
    "suggest": {
        "Git": "main/git"
    },
    "notes": [
        "It must be used inside a Bash/Zsh session,",
        "The easiest Windows option is Git Bash.",
        "(Experimental) To keep the right tools first, add these to the TOP of your System PATH",
        "  $env:SCOOP\\apps\\git\\current\\bin",
        "  $env:SCOOP\\apps\\git\\current\\usr\\bin"
    ],
    "url": "https://github.com/meiji163/gh-notify/archive/main.zip",
    "hash": "1da10993fdfd513d06ee08ef2f026ad074fbc54d531dd731abe8fc1f694ae644",
    "extract_dir": "gh-notify-main",
    "pre_install": [
        "Remove-Item -Path \"$dir\\*\" -Exclude 'gh-notify', 'LICENSE' -Recurse -Force",
        "New-Item -Path \"$dir\\gh-notify.cmd\" -ItemType File -Force",
        "Add-Content -Path \"$dir\\gh-notify.cmd\" -Value \"bash $env:SCOOP\\apps\\gh-notify\\current\\gh-notify %*\""
    ],
    "bin": "gh-notify.cmd",
    "checkver": {
        "url": "https://api.github.com/repos/meiji163/gh-notify/commits?per_page=1",
        "jsonpath": "$[0].commit.author.date",
        "regex": "(\\d{4})-(\\d{2})-(\\d{2}).*",
        "replace": "$1$2$3"
    },
    "autoupdate": {
        "url": "https://github.com/meiji163/gh-notify/archive/main.zip"
    }
}
