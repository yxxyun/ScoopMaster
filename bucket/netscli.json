{
  "version": "0.2.0",
  "description": "Network scanner with CLI, TUI, desktop app, and MCP server. Written in Rust.",
  "homepage": "https://netscli.com",
  "license": "MIT",
  "architecture": {
    "64bit": {
      "url": "https://github.com/fstubner/netscli/releases/download/v0.2.0/netscli-windows-x86_64.exe#/netscli.exe",
      "hash": "790c0867ba035ad85704c7ebaba65ade23ff9c9f4327fbe5b3f5f2515cfe3002"
    }
  },
  "bin": "netscli.exe",
  "post_install": [
    "# Shell completions. PowerShell profile path varies; wire the snippet in on first install.",
    "$script = \"$dir\\netscli-completions.ps1\"",
    "& \"$dir\\netscli.exe\" completions powershell | Set-Content -Encoding UTF8 $script",
    "Write-Host \"Shell completions written to $script. Add '. $script' to your PowerShell profile to enable tab completion.\""
  ],
  "checkver": {
    "github": "https://github.com/fstubner/netscli"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/fstubner/netscli/releases/download/v$version/netscli-windows-x86_64.exe#/netscli.exe"
      }
    },
    "hash": {
      "url": "$url.sha256"
    }
  }
}
