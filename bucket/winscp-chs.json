    "depends": "extras/winscp",
    "post_install": "if(Test-Path \"$(appdir winscp)\\$version\\WinSCP.exe\"){Copy-Item \"$original_dir\\WinSCP.chs\" \"$(appdir winscp)\\$version\\\"}else{Write-Error \"Please install winscp first\"}",
    "post_uninstall": "Remove-Item \"$(appdir winscp)\\$version\\WinSCP.chs\" -Force -ErrorAction SilentlyContinue",
    "checkver": {
        "url": "https://winscp.net/eng/downloads.php",
        "regex": "WinSCP-([\\d.]+)-Portable\\.zip"
    },
    "autoupdate": {
        "url": "https://winscp.net/translations/dll/$version/chs.zip"
    }
}
