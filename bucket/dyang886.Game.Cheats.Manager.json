{"version":"2.4.6","description":"Game Cheats Manager (GCM) - 游戏修改器管理工具，集成多来源修改器搜索、下载、自动更新等功能 | A single-player game trainer manager with multi-source search, download, and auto-update","homepage":"https://gamezonelabs.com","license":{"identifier":"GPL-3.0-only","url":"https://github.com/dyang886/Game-Cheats-Manager/blob/main/LICENSE.txt"},"architecture":{"64bit":{"url":"https://github.com/dyang886/Game-Cheats-Manager/releases/download/v2.4.6/Game.Cheats.Manager.Setup.2.4.6.exe","hash":"d6229ec299b001c277327e78256cb7bcc471a5bb90a86fbd6aeebcb76bc6a129"}},"pre_install":["# 确保 persist 数据目录存在（pre_install 阶段 Scoop 尚未创建 persist 目录）","if (!(Test-Path \"$persist_dir\\data\")) {","    New-Item -ItemType Directory -Force -Path \"$persist_dir\\data\" | Out-Null","}","","$junction = \"$env:APPDATA\\GCM Settings\"","if (Test-Path $junction) {","    if ((Get-Item $junction -Force -ErrorAction SilentlyContinue).Attributes -band [System.IO.FileAttributes]::ReparsePoint) {","        [System.IO.Directory]::Delete($junction)","    } else {","        Write-Host \"迁移 %APPDATA%\\GCM Settings 已有数据到 persist 目录...\"","        Get-ChildItem $junction | Move-Item -Destination \"$persist_dir\\data\" -Force","        Remove-Item $junction -Force -Recurse","    }","}","New-Item -ItemType Junction -Path $junction -Target \"$persist_dir\\data\" | Out-Null"],"installer":{"script":["Expand-InnoArchive \"$dir\\$fname\" -Removable"]},"post_install":["# 重建 junction（更新后 Scoop 清理旧版本但 persist 数据保留）","if (!(Test-Path \"$persist_dir\\data\")) { New-Item -ItemType Directory -Force -Path \"$persist_dir\\data\" | Out-Null }","$junction = \"$env:APPDATA\\GCM Settings\"","if (Test-Path $junction) {","    $item = Get-Item $junction -Force -ErrorAction SilentlyContinue","    if ($item.Attributes -band [System.IO.FileAttributes]::ReparsePoint) {","        [System.IO.Directory]::Delete($junction)","    }","}","New-Item -ItemType Junction -Path $junction -Target \"$persist_dir\\data\" | Out-Null"],"pre_uninstall":["$junction = \"$env:APPDATA\\GCM Settings\"","if ((Test-Path $junction) -and ((Get-Item $junction -Force -ErrorAction SilentlyContinue).Attributes -band [System.IO.FileAttributes]::ReparsePoint)) {","    [System.IO.Directory]::Delete($junction)","}"],"uninstaller":{"script":["Stop-Process -Name 'Game Cheats Manager' -Force -ErrorAction SilentlyContinue","Start-Sleep -Milliseconds 1500","# 清理开始菜单快捷方式残留（校验目标路径指向本应用目录，避免误删同名非 Scoop 快捷方式）","$appDir = Split-Path $dir -Parent","$shell = New-Object -ComObject WScript.Shell","@(\"$env:APPDATA\", \"$env:ProgramData\") | ForEach-Object {","    $lnk = \"$_\\Microsoft\\Windows\\Start Menu\\Programs\\Game Cheats Manager.lnk\"","    if ((Test-Path $lnk) -and ($shell.CreateShortcut($lnk).TargetPath -like \"$appDir\\*\")) {","        Remove-Item $lnk -Force -ErrorAction SilentlyContinue","    }","}"]},"shortcuts":[["Game Cheats Manager.exe","..\\Game Cheats Manager"]],"persist":"data","notes":["数据持久化: 应用配置/settings.json、数据库/db 等数据","已通过目录联接 (junction) 重定向到 Scoop persist 目录。","卸载时不会残留数据，重新安装自动恢复。"],"checkver":{"github":"https://github.com/dyang886/Game-Cheats-Manager"},"autoupdate":{"architecture":{"64bit":{"url":"https://github.com/dyang886/Game-Cheats-Manager/releases/download/v$version/Game.Cheats.Manager.Setup.$version.exe"}}},"from":"https://github.com/Arama0517/scoop-bucket"}
