{
    "version": "3.3.0",
    "description": "一个基于 Wails + C# + Next.js 开发的桌面应用，用于控制飞智 BS系列 散热器设备，提供风扇控制、温度监控等功能。",
    "homepage": "https://github.com/TIANLI0/THRM",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/TIANLI0/THRM/releases/download/v3.3.0/THRM-windows-portable.zip",
            "hash": "92acddf4980e2be996c6e8deaf4c563a01eeb4ae3430c5450f50bfec19194ca4"
        }
    },
    "pre_install": "if (!(is_admin)) { throw 'Admin privileges are required.' }",
    "post_install": [
        "if (Test-Path $env:USERPROFILE\\.thrm) {",
        "    Copy-Item -Path $env:USERPROFILE\\.thrm\\* -Destination \"$persist_dir\\config\" -Force -Recurse",
        "    Remove-Item $env:USERPROFILE\\.thrm -Force -Recurse",
        "}",
        "New-Item -ItemType Junction -Path $env:USERPROFILE\\.thrm -Target $persist_dir\\config | Out-Null",
        "& \"$dir\\PawnIO_setup.exe\" -uninstall -silent",
        "& \"$dir\\PawnIO_setup.exe\" -install -silent",
        "cmd /c 'schtasks /delete /tn \"THRM\" /f 2>nul'",
        "cmd /c 'schtasks /delete /tn \"BS2PRO-Controller\" /f 2>nul'",
        "cmd /c 'schtasks /delete /tn \"BS2PRO-Core\" /f 2>nul'",
        "schtasks.exe /create /tn \"THRM\" /tr \"`\"$dir\\THRM Core.exe`\" --autostart\" /sc onlogon /delay 0000:15 /rl highest /f"
    ],
    "pre_uninstall": "if (!(is_admin)) { throw 'Admin privileges are required.' }",
    "uninstaller": {
        "script": "& \"$dir\\PawnIO_setup.exe\" -uninstall -silent && Remove-Item $env:USERPROFILE\\.thrm -Force -Recurse && cmd /c 'schtasks /delete /tn \"THRM\" /f 2>nul'"
    },
    "bin": "THRM.exe",
    "shortcuts": [
        [
            "THRM.exe",
            "THRM"
        ]
    ],
    "persist": [
        "config",
        "themes",
        "telemetry"
    ],
    "checkver": {
        "github": "https://github.com/TIANLI0/THRM"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TIANLI0/THRM/releases/download/v$version/THRM-windows-portable.zip"
            }
        }
    }
}
