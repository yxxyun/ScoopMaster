{
    "version": "3.5.1",
    "description": "一个基于 Wails + C# + Next.js 开发的桌面应用，用于控制飞智 BS系列 散热器设备，提供风扇控制、温度监控等功能。",
    "homepage": "https://github.com/TIANLI0/THRM",
    "license": "MIT",
    "depends": "pawnio",
    "architecture": {
        "64bit": {
            "url": "https://github.com/TIANLI0/THRM/releases/download/v3.5.1/THRM-windows-portable.zip",
            "hash": "9d92287fd7b43325b6f1c50248e865c62d6fc66d91eb065d2155ec7797549efb"
        }
    },
    "notes": [
        "If Windows Developer Mode is not enabled, the built-in pawnio installer will be kept as-is.",
        "For the best experience, please avoid using the 'Reinstall PawnIO' option in the app settings,",
        "as the built-in installer may not be the latest version.",
        "To have the pawnio installer always up-to-date with pawnio, enable Windows Developer Mode and reinstall this app."
    ],
    "post_install": [
        "if (Test-Path $env:USERPROFILE\\.thrm) {",
        "    Copy-Item -Path $env:USERPROFILE\\.thrm\\* -Destination \"$persist_dir\\config\" -Force -Recurse",
        "    Remove-Item $env:USERPROFILE\\.thrm -Force -Recurse",
        "}",
        "New-Item -ItemType Junction -Path $env:USERPROFILE\\.thrm -Target $persist_dir\\config | Out-Null",
        "$DevModRegistryPath = 'HKLM:\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\AppModelUnlock'",
        "if ((Test-Path $DevModRegistryPath) -and (Get-ItemProperty -Path $DevModRegistryPath -Name AllowDevelopmentWithoutDevLicense -ErrorAction SilentlyContinue).AllowDevelopmentWithoutDevLicense -eq 1) {",
        "    Remove-Item \"$dir\\PawnIO_setup.exe\" -Force -ErrorAction SilentlyContinue",
        "    New-Item -ItemType SymbolicLink -Path \"$dir\\PawnIO_setup.exe\" -Target \"$(appdir 'pawnio')\\current\\PawnIO_setup.exe\" | Out-Null",
        "}"
    ],
    "uninstaller": {
        "script": "Remove-Item $env:USERPROFILE\\.thrm -Force -Recurse"
    },
    "bin": "THRM.exe",
    "shortcuts": [
        [
            "THRM.exe",
            "THRM"
        ]
    ],
    "persist": [
        "config",
        "themes",
        "telemetry"
    ],
    "checkver": {
        "github": "https://github.com/TIANLI0/THRM"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/TIANLI0/THRM/releases/download/v$version/THRM-windows-portable.zip"
            }
        }
    }
}
