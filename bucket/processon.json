{
  "version": "5.14.14",
  "description": "ProcessOn is a free online flowchart, mind map, and collaborative diagram tool",
  "homepage": "https://www.processon.com",
  "license": "Freeware",
  "url": "https://pocdn.processon.com/pc_client/po/ProcessOn_5.14.14.exe",
  "hash": "sha256:c0598124cd2849d9971676e4a570b50bbbf7612d3ebb0398b2314c448671626b",
  "pre_install": [
    "if (!(Test-Path \"$persist_dir\\user_data\")) { New-Item -Path \"$persist_dir\\user_data\" -ItemType Directory | Out-Null }"
  ],
  "installer": {
    "script": [
      "$archive = Get-ChildItem \"$dir\" -Filter '*.exe' | Select-Object -First 1",
      "if ($archive) {",
      "  Invoke-ExternalCommand 7z -ArgumentList 'x \"-o$dir\" \"$($archive.FullName)\" -y' | Out-Null",
      "  Remove-Item \"$($archive.FullName)\" -Force",
      "}"
    ]
  },
  "shortcuts": [
    [
      "ProcessOn.exe",
      "ProcessOn"
    ]
  ],
  "persist": [
    "user_data"
  ],
  "notes": [
    "ProcessOn is a free online flowchart, mind map, and diagram tool.",
    "Visit https://www.processon.com for more information."
  ]
}


